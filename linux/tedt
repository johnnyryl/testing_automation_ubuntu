Add this helper right after those regex definitions, around line 1959–1961, before BOOT_ARTIFACT_CHECK_PREFIXES:

def content_without_kickstart_script_blocks(content: str) -> str:
    kept_lines = []
    inside_script = False
    script_section_prefixes = (
        "%pre",
        "%post",
        "%onerror",
        "%traceback",
    )
    for line in content.splitlines():
        stripped = line.strip()
        if stripped.startswith(script_section_prefixes):
            inside_script = True
            kept_lines.append("")
            continue
        if inside_script and stripped == "%end":
            inside_script = False
            kept_lines.append("")
            continue
        if inside_script:
            kept_lines.append("")
            continue
        kept_lines.append(line)
    return "\n".join(kept_lines)

