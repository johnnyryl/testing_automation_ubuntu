3. Replace copy_managed_path.yml with this cleaner final version

This version uses one clear skip variable: repo_environment_init_should_skip_existing_path.

# UNCLASSIFIED
- name: "Normalize managed path key {{ repo_environment_init_path_item.dest_rel }}"
  ansible.builtin.set_fact:
    repo_environment_init_path_item_dest_rel_normalized: >-
      {{
        repo_environment_init_path_item.dest_rel
        | regex_replace('^\\./', '')
        | regex_replace('/+$', '')
      }}
- name: "Set preserve match state for {{ repo_environment_init_path_item.dest_rel }}"
  ansible.builtin.set_fact:
    repo_environment_init_path_is_preserved: >-
      {{
        repo_environment_init_respect_preserve_file | bool
        and not repo_environment_init_overwrite_existing | bool
        and repo_environment_init_path_item_dest_rel_normalized in
          (repo_environment_init_active_preserve_entries | default([]))
      }}
- name: "Check destination {{ repo_environment_init_path_item.dest_rel }}"
  ansible.builtin.stat:
    path: "{{ repo_environment_init_path_item.dest }}"
  register: repo_environment_init_dest_stat
- name: "Set skip state for existing preserved path {{ repo_environment_init_path_item.dest_rel }}"
  ansible.builtin.set_fact:
    repo_environment_init_should_skip_existing_path: >-
      {{
        repo_environment_init_path_is_preserved | bool
        and repo_environment_init_dest_stat.stat.exists | default(false)
      }}
- name: "Skip preserved existing path {{ repo_environment_init_path_item.dest_rel }}"
  ansible.builtin.debug:
    msg: "Preserving existing managed path because it is listed in .sync-preserve: {{ repo_environment_init_path_item.dest_rel }}"
  when:
    - repo_environment_init_should_skip_existing_path | bool
- name: "Back up existing managed path {{ repo_environment_init_path_item.dest_rel }}"
  ansible.builtin.include_tasks: backup_item.yml
  vars:
    repo_environment_init_backup_src: "{{ repo_environment_init_path_item.dest }}"
    repo_environment_init_backup_rel: "{{ repo_environment_init_path_item.dest_rel }}"
  when:
    - repo_environment_init_backup | bool
    - repo_environment_init_dest_stat.stat.exists
    - not (repo_environment_init_should_skip_existing_path | bool)
- name: "Ensure parent directory exists for {{ repo_environment_init_path_item.dest_rel }}"
  ansible.builtin.file:
    path: "{{ repo_environment_init_path_item.dest | dirname }}"
    state: directory
    owner: root
    group: root
    mode: "0755"
  when:
    - not (repo_environment_init_should_skip_existing_path | bool)
- name: "Copy managed directory {{ repo_environment_init_path_item.dest_rel }}"
  ansible.builtin.copy:
    src: "{{ repo_environment_init_path_item.src }}/"
    dest: "{{ repo_environment_init_path_item.dest }}/"
    owner: root
    group: root
    mode: preserve
  when:
    - repo_environment_init_path_item.expected_type == "directory"
    - not (repo_environment_init_should_skip_existing_path | bool)
- name: "Copy managed file {{ repo_environment_init_path_item.dest_rel }}"
  ansible.builtin.copy:
    src: "{{ repo_environment_init_path_item.src }}"
    dest: "{{ repo_environment_init_path_item.dest }}"
    owner: root
    group: root
    mode: "0644"
  when:
    - repo_environment_init_path_item.expected_type == "file"
    - not (repo_environment_init_should_skip_existing_path | bool)
# UNCLASSIFIED

