###############################################################################
# 09. Repository helpers
###############################################################################
ensure_trailing_slashless() {
  local value="$1"
  printf '%s' "${value%/}"
}

resolve_repo_sources() {
  local os_major="$1"
  local candidate=""
  local version_root=""
  local -a repo_pair=()
  local -a version_candidates=()

  if [[ -n "${BASEOS_SOURCE}" || -n "${APPSTREAM_SOURCE}" ]]; then
    [[ -n "${BASEOS_SOURCE}" && -n "${APPSTREAM_SOURCE}" ]] || fail "Use both --baseos-source and --appstream-source together"
    return 0
  fi

  if [[ -n "${REPO_SOURCE}" ]]; then
    if is_url "${REPO_SOURCE}"; then
      REPO_SOURCE="$(ensure_trailing_slashless "${REPO_SOURCE}")"
      BASEOS_SOURCE="${REPO_SOURCE}/BaseOS"
      APPSTREAM_SOURCE="${REPO_SOURCE}/AppStream"
      return 0
    fi

    mapfile -t repo_pair < <(resolve_local_repo_pair "${REPO_SOURCE}" || true)
    if [[ ${#repo_pair[@]} -eq 2 ]]; then
      BASEOS_SOURCE="${repo_pair[0]}"
      APPSTREAM_SOURCE="${repo_pair[1]}"
      return 0
    fi

    mapfile -t version_candidates < <(find "${REPO_SOURCE}" -maxdepth 4 -type d $begin:math:text$ \-iname \"rhel\$\{os\_major\}iso\" \-o \-iname \"\*rhel\$\{os\_major\}\*\" $end:math:text$ 2>/dev/null | sort -u || true)
    for version_root in "${version_candidates[@]}"; do
      mapfile -t repo_pair < <(resolve_local_repo_pair "${version_root}" || true)
      if [[ ${#repo_pair[@]} -eq 2 ]]; then
        BASEOS_SOURCE="${repo_pair[0]}"
        APPSTREAM_SOURCE="${repo_pair[1]}"
        return 0
      fi
    done

    fail "Unable to find valid BaseOS/AppStream repos with repodata under --repo-source ${REPO_SOURCE}"
  fi

  for candidate in \
    "${BUNDLE_ROOT}/extracted_isos/rhel${os_major}iso" \
    "${BUNDLE_ROOT}/extracted_isos/rhel${os_major}" \
    "${BUNDLE_ROOT}/rhel${os_major}iso" \
    "${BUNDLE_ROOT}/rhel${os_major}"; do
    verbose "Searching repo sources under: ${candidate}"
    mapfile -t repo_pair < <(resolve_local_repo_pair "${candidate}" || true)
    if [[ ${#repo_pair[@]} -eq 2 ]]; then
      BASEOS_SOURCE="${repo_pair[0]}"
      APPSTREAM_SOURCE="${repo_pair[1]}"
      info "Detected local repo sources:"
      info "  BaseOS    : ${BASEOS_SOURCE}"
      info "  AppStream : ${APPSTREAM_SOURCE}"
      return 0
    fi
  done

  for candidate in \
    "${BUNDLE_ROOT}/extracted_isos" \
    "${BUNDLE_ROOT}" \
    "${BUNDLE_PARENT}"; do
    verbose "Searching version-specific repo roots under: ${candidate}"
    [[ -d "${candidate}" ]] || continue
    mapfile -t version_candidates < <(find "${candidate}" -maxdepth 4 -type d $begin:math:text$ \-iname \"rhel\$\{os\_major\}iso\" \-o \-iname \"\*rhel\$\{os\_major\}\*\" $end:math:text$ 2>/dev/null | sort -u || true)
    for version_root in "${version_candidates[@]}"; do
      mapfile -t repo_pair < <(resolve_local_repo_pair "${version_root}" || true)
      if [[ ${#repo_pair[@]} -eq 2 ]]; then
        BASEOS_SOURCE="${repo_pair[0]}"
        APPSTREAM_SOURCE="${repo_pair[1]}"
        info "Detected local repo sources:"
        info "  BaseOS    : ${BASEOS_SOURCE}"
        info "  AppStream : ${APPSTREAM_SOURCE}"
        return 0
      fi
    done
  done

  return 1
}

to_baseurl() {
  local source="$1"

  if is_url "${source}"; then
    printf '%s' "$(ensure_trailing_slashless "${source}")"
  else
    repo_dir_is_valid "${source}" || fail "Local repo path is not valid or missing repodata/repomd.xml: ${source}"
    printf 'file://%s' "$(cd "${source}" && pwd)"
  fi
}

configure_bootstrap_repo_file() {
  local baseos_baseurl="$1"
  local appstream_baseurl="$2"

  TEMP_REPO_FILE="$(mktemp /tmp/aerolit-bootstrap-XXXXXX.repo)"
  TEMP_FILES+=("${TEMP_REPO_FILE}")

  cat > "${TEMP_REPO_FILE}" <<EOF
[aerolit-bootstrap-baseos]
name=AeroLIT Bootstrap BaseOS
baseurl=${baseos_baseurl}
enabled=1
gpgcheck=0

[aerolit-bootstrap-appstream]
name=AeroLIT Bootstrap AppStream
baseurl=${appstream_baseurl}
enabled=1
gpgcheck=0
EOF

  if [[ "${DRY_RUN}" == true ]]; then
    info "DRY RUN: would install temporary repo file from ${TEMP_REPO_FILE} to /etc/yum.repos.d/zz-aerolit-bootstrap.repo"
    cat "${TEMP_REPO_FILE}"
    return 0
  fi

  as_root install -m 0644 -- "${TEMP_REPO_FILE}" /etc/yum.repos.d/zz-aerolit-bootstrap.repo
  TEMP_REPO_FILE="/etc/yum.repos.d/zz-aerolit-bootstrap.repo"
}

install_ansible_if_needed() {
  local baseos_baseurl=""
  local appstream_baseurl=""

  if command -v ansible-playbook >/dev/null 2>&1; then
    info "ansible-playbook is already available. Skipping ansible-core installation."
    return 0
  fi

  if [[ "${SKIP_ANSIBLE_INSTALL}" == true ]]; then
    fail "ansible-playbook is missing and --skip-ansible-install was used"
  fi

  need_cmd dnf

  if [[ "${PREFER_BUNDLE_REPOS}" == true ]]; then
    info "Using bundle BaseOS/AppStream repos first because --prefer-bundle-repos was used."
    resolve_repo_sources "${OS_MAJOR}" || fail "Unable to locate valid BaseOS/AppStream sources automatically. Use --repo-source or --baseos-source/--appstream-source."

    baseos_baseurl="$(to_baseurl "${BASEOS_SOURCE}")"
    appstream_baseurl="$(to_baseurl "${APPSTREAM_SOURCE}")"

    configure_bootstrap_repo_file "${baseos_baseurl}" "${appstream_baseurl}"

    if [[ "${DRY_RUN}" == true ]]; then
      info "DRY RUN: would install ansible-core from bundle bootstrap repos."
      return 0
    fi

    as_root dnf --disablerepo='*' \
      --enablerepo='aerolit-bootstrap-baseos' \
      --enablerepo='aerolit-bootstrap-appstream' \
      install -y ansible-core

    command -v ansible-playbook >/dev/null 2>&1 || fail "ansible-playbook is still not available after ansible-core installation"
    return 0
  fi

  info "ansible-playbook is not currently installed."
  info "Trying existing configured repositories first."

  if [[ "${DRY_RUN}" == true ]]; then
    info "DRY RUN: would try 'dnf install -y ansible-core' using current repos"
    if resolve_repo_sources "${OS_MAJOR}"; then
      info "DRY RUN: if current repos were insufficient, would create temporary repo definitions for:"
      info "  BaseOS    : ${BASEOS_SOURCE}"
      info "  AppStream : ${APPSTREAM_SOURCE}"
      info "DRY RUN: would then install ansible-core from those sources"
    else
      warn "DRY RUN: no bundle repo sources were auto-detected"
    fi
    info "DRY RUN: ansible is not installed, so playbook execution will be skipped"
    return 0
  fi

  if as_root dnf install -y ansible-core; then
    info "Installed ansible-core using existing configured repositories."
    return 0
  fi

  warn "Existing configured repositories were not enough to install ansible-core."

  resolve_repo_sources "${OS_MAJOR}" || fail "Unable to locate valid BaseOS/AppStream sources automatically. Use --repo-source or --baseos-source/--appstream-source."

  baseos_baseurl="$(to_baseurl "${BASEOS_SOURCE}")"
  appstream_baseurl="$(to_baseurl "${APPSTREAM_SOURCE}")"

  configure_bootstrap_repo_file "${baseos_baseurl}" "${appstream_baseurl}"

  info "Installing ansible-core using temporary AeroLIT bootstrap repos."
  as_root dnf --disablerepo='*' \
    --enablerepo='aerolit-bootstrap-baseos' \
    --enablerepo='aerolit-bootstrap-appstream' \
    install -y ansible-core

  command -v ansible-playbook >/dev/null 2>&1 || fail "ansible-playbook is still not available after ansible-core installation"
}

###############################################################################
# 10. Provisioning repo var detection
###############################################################################
repo_id_sanitize() {
  local value="$1"
  value="${value,,}"
  value="${value//[^a-z0-9._-]/-}"
  value="${value#-}"
  value="${value%-}"
  printf '%s' "${value}"
}

infer_rhel_key_from_path() {
  local path="$1"

  if [[ "${path}" =~ [Rr][Hh][Ee][Ll][-_/]*([0-9]+) ]]; then
    printf 'rhel%s' "${BASH_REMATCH[1]}"
    return 0
  fi

  return 1
}

path_under_nfs_export() {
  local path="$1"
  [[ "${path}" == "${NFS_EXPORT_PATH}" || "${path}" == "${NFS_EXPORT_PATH}/"* ]]
}

local_path_to_client_baseurl() {
  local path="$1"
  local rel=""

  require_absolute_path_value "local repo path" "${path}"
  path_under_nfs_export "${path}" || fail "Local provisioning repo path is not under --nfs-export-path, so clients will not see it: ${path}"

  rel="${path#${NFS_EXPORT_PATH}}"
  rel="${rel#/}"

  if [[ -n "${rel}" ]]; then
    printf 'file://%s/%s' "${PATH_FOR_ANSIBLE%/}" "${rel}"
  else
    printf 'file://%s' "${PATH_FOR_ANSIBLE%/}"
  fi
}

repo_source_to_client_baseurl() {
  local source="$1"

  if is_url "${source}"; then
    printf '%s' "$(ensure_trailing_slashless "${source}")"
  else
    source="$(normalize_local_path "provision repo source" "${source}" "${BUNDLE_ROOT}")"
    repo_dir_is_valid "${source}" || fail "Provision repo path is missing repodata/repomd.xml: ${source}"
    local_path_to_client_baseurl "${source}"
  fi
}

PROVISION_REPO_RHEL7_FILE=""
PROVISION_REPO_RHEL8_FILE=""
PROVISION_REPO_RHEL9_FILE=""
PROVISION_REPO_RHEL10_FILE=""

init_provision_repo_files() {
  PROVISION_REPO_RHEL7_FILE="$(make_temp_file)"
  PROVISION_REPO_RHEL8_FILE="$(make_temp_file)"
  PROVISION_REPO_RHEL9_FILE="$(make_temp_file)"
  PROVISION_REPO_RHEL10_FILE="$(make_temp_file)"
  : > "${PROVISION_REPO_RHEL7_FILE}"
  : > "${PROVISION_REPO_RHEL8_FILE}"
  : > "${PROVISION_REPO_RHEL9_FILE}"
  : > "${PROVISION_REPO_RHEL10_FILE}"
}

provision_repo_file_for_os() {
  local os_key="$1"

  case "${os_key}" in
    rhel7) printf '%s' "${PROVISION_REPO_RHEL7_FILE}" ;;
    rhel8) printf '%s' "${PROVISION_REPO_RHEL8_FILE}" ;;
    rhel9) printf '%s' "${PROVISION_REPO_RHEL9_FILE}" ;;
    rhel10) printf '%s' "${PROVISION_REPO_RHEL10_FILE}" ;;
    *) fail "Unsupported provisioning repo OS key: ${os_key}" ;;
  esac
}

append_provision_repo() {
  local os_key="$1"
  local repo_id="$2"
  local repo_name="$3"
  local baseurl="$4"
  local os_file=""

  os_file="$(provision_repo_file_for_os "${os_key}")"

  if [[ -s "${os_file}" ]]; then
    awk -v id="${repo_id}" '
      $0 ~ /^    - id: / {
        if ($0 == "    - id: " id) { skip=1; next }
        skip=0
      }
      skip { next }
      { print }
    ' "${os_file}" > "${os_file}.tmp"
    mv -- "${os_file}.tmp" "${os_file}"
  fi

  {
    echo "    - id: ${repo_id}"
    echo "      name: ${repo_name}"
    echo "      baseurl: $(yaml_quote "${baseurl}")"
    echo "      enabled: true"
    echo "      gpgcheck: false"
  } >> "${os_file}"
}

write_grouped_provision_repo_file() {
  local output_file="$1"
  local major=""
  local os_file=""

  echo "aerolit_yum_repositories:" > "${output_file}"

  for major in 7 8 9 10; do
    os_file="$(provision_repo_file_for_os "rhel${major}")"
    if [[ -s "${os_file}" ]]; then
      echo "  rhel${major}:" >> "${output_file}"
      cat "${os_file}" >> "${output_file}"
    fi
  done
}

add_extra_provision_repos() {
  local entry=""
  local left=""
  local source=""
  local os_key=""
  local repo_short=""
  local repo_id=""
  local repo_name=""
  local baseurl=""

  if [[ ${#PROVISION_EXTRA_REPOS[@]} -eq 0 ]]; then
    return 0
  fi

  for entry in "${PROVISION_EXTRA_REPOS[@]}"; do
    [[ "${entry}" == *=* ]] || fail "--provision-extra-repo must be OS:ID=PATH_OR_URL: ${entry}"
    left="${entry%%=*}"
    source="${entry#*=}"
    [[ "${left}" == *:* ]] || fail "--provision-extra-repo must be OS:ID=PATH_OR_URL: ${entry}"

    os_key="${left%%:*}"
    repo_short="${left#*:}"
    os_key="${os_key,,}"

    [[ "${os_key}" =~ ^rhel(7|8|9|10)$ ]] || fail "--provision-extra-repo OS must be rhel7, rhel8, rhel9, or rhel10: ${entry}"
    [[ "${repo_short}" =~ ^[A-Za-z0-9._-]+$ ]] || fail "--provision-extra-repo ID must be simple text: ${entry}"

    baseurl="$(repo_source_to_client_baseurl "${source}")"
    repo_id="aerolit-${os_key}-$(repo_id_sanitize "${repo_short}")"
    repo_name="AeroLIT ${os_key} ${repo_short}"

    append_provision_repo "${os_key}" "${repo_id}" "${repo_name}" "${baseurl}"
  done
}

detect_bundle_provision_repos() {
  local major=""
  local root=""
  local base=""
  local app=""
  local repo_path=""
  local rhel_key=""
  local repo_name=""
  local repo_id=""
  local -a pair=()
  local output_file=""

  init_provision_repo_files
  output_file="$(make_temp_file)"

  if [[ "${AUTO_DETECT_PROVISION_REPOS}" == true ]]; then
    for major in 7 8 9 10; do
      pair=()

      if [[ "${major}" == "${OS_MAJOR}" && -n "${BASEOS_SOURCE}" && -n "${APPSTREAM_SOURCE}" ]]; then
        continue
      fi

      for root in \
        "${BUNDLE_ROOT}/extracted_isos/rhel${major}iso" \
        "${BUNDLE_ROOT}/extracted_isos/rhel${major}" \
        "${BUNDLE_ROOT}/rhel${major}iso" \
        "${BUNDLE_ROOT}/rhel${major}"; do
        mapfile -t pair < <(resolve_local_repo_pair "${root}" || true)
        [[ ${#pair[@]} -eq 2 ]] && break
      done

      if [[ ${#pair[@]} -eq 2 ]]; then
        base="${pair[0]}"
        app="${pair[1]}"

        append_provision_repo \
          "rhel${major}" \
          "aerolit-rhel${major}-baseos" \
          "AeroLIT RHEL${major} BaseOS" \
          "$(local_path_to_client_baseurl "${base}")"

        append_provision_repo \
          "rhel${major}" \
          "aerolit-rhel${major}-appstream" \
          "AeroLIT RHEL${major} AppStream" \
          "$(local_path_to_client_baseurl "${app}")"
      fi
    done

    if [[ -d "${BUNDLE_ROOT}/repos" ]]; then
      while IFS= read -r repo_path; do
        rhel_key="$(infer_rhel_key_from_path "${repo_path}" || true)"
        [[ -n "${rhel_key}" ]] || continue
        [[ "${rhel_key}" =~ ^rhel(7|8|9|10)$ ]] || continue

        repo_name="$(basename "${repo_path}")"
        repo_id="aerolit-${rhel_key}-$(repo_id_sanitize "${repo_name}")"

        append_provision_repo \
          "${rhel_key}" \
          "${repo_id}" \
          "AeroLIT ${rhel_key} ${repo_name}" \
          "$(local_path_to_client_baseurl "${repo_path}")"
      done < <(find "${BUNDLE_ROOT}/repos" -type f -path '*/repodata/repomd.xml' 2>/dev/null | while read -r f; do dirname "$(dirname "${f}")"; done | sort -u)
    fi
  fi

  if [[ -n "${BASEOS_SOURCE}" && -n "${APPSTREAM_SOURCE}" ]]; then
    append_provision_repo \
      "rhel${OS_MAJOR}" \
      "aerolit-rhel${OS_MAJOR}-baseos" \
      "AeroLIT RHEL${OS_MAJOR} BaseOS" \
      "$(repo_source_to_client_baseurl "${BASEOS_SOURCE}")"

    append_provision_repo \
      "rhel${OS_MAJOR}" \
      "aerolit-rhel${OS_MAJOR}-appstream" \
      "AeroLIT RHEL${OS_MAJOR} AppStream" \
      "$(repo_source_to_client_baseurl "${APPSTREAM_SOURCE}")"
  fi

  add_extra_provision_repos
  write_grouped_provision_repo_file "${output_file}"

  echo "${output_file}"
}

indent_file() {
  local spaces="$1"
  local file="$2"
  sed "s/^/${spaces}/" "${file}"
}

write_bootstrap_generated_group_vars_file() {
  local output_file="$1"
  local repo_vars_file="${2:-}"

  {
    echo "# UNCLASSIFIED"
    echo "#"
    echo "# Generated by AeroLIT bootstrap.sh / bootstrap_controller.sh."
    echo "# Do not hand-edit this file for local defaults."
    echo "# Put local/manual defaults in workstation_defaults.yml instead."
    echo

    if [[ -n "${PATH_FOR_ANSIBLE}" ]]; then
      echo "path_for_ansible: $(yaml_quote "${PATH_FOR_ANSIBLE}")"
      echo

      if [[ -n "${NFS_SERVER_IP}" && -n "${NFS_EXPORT_PATH}" ]]; then
        echo "mount_point_setup_single_site_mounts:"
        echo "  - path: $(yaml_quote "${PATH_FOR_ANSIBLE}")"
        echo "    mode: '0755'"
        echo "    owner: root"
        echo "    group: root"
        echo "    src: $(yaml_quote "${NFS_SERVER_IP}:${NFS_EXPORT_PATH}")"
        echo
      fi
    fi

    if [[ -n "${EPEL_APPROVED}" ]]; then
      echo "enable_epel: ${EPEL_APPROVED}"
      echo
    fi

    if [[ -n "${repo_vars_file}" && -s "${repo_vars_file}" ]] && grep -q '^  rhel[0-9]' "${repo_vars_file}"; then
      cat "${repo_vars_file}"
      echo
    fi

    echo "# UNCLASSIFIED"
  } > "${output_file}"
}

install_bootstrap_generated_group_vars_file() {
  local source_file="$1"
  local dest_file="${GENERATED_GROUP_VARS_FILE}"
  local dest_dir=""

  [[ -n "${source_file}" && -f "${source_file}" ]] || return 0

  if [[ "${DRY_RUN}" == true ]]; then
    info "DRY RUN: would write generated bootstrap group vars to ${dest_file}"
    if [[ "${VERBOSE}" == true ]]; then
      cat "${source_file}"
    fi
    return 0
  fi

  dest_dir="$(dirname "${dest_file}")"

  as_root mkdir -p -- "${dest_dir}"

  if [[ -f "${dest_file}" ]] && cmp -s "${source_file}" "${dest_file}"; then
    verbose "Generated bootstrap group vars already up to date: ${dest_file}"
    return 0
  fi

  as_root install -m 0644 -- "${source_file}" "${dest_file}"
  info "Wrote generated bootstrap group vars: ${dest_file}"
}

###############################################################################
# 11. Extra vars generation
