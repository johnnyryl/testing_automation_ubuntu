write_bootstrap_vars_file() {
  local file
  file="$(make_temp_file)"
  {
    echo "repo_environment_init_repo_root: $(yaml_quote "${COLLECTIONS_HUB_ROOT}")"
    echo "repo_environment_init_respect_preserve_file: true"
    echo "repo_environment_init_overwrite_existing: ${OVERWRITE_INITIALIZED_FILES}"
  } > "${file}"
  echo "${file}"
}

write_pxe_vars_file() {
  local file
  local dns=""

  file="$(make_temp_file)"
  : > "${file}"

  if [[ -n "${PXE_SERVER_IP}" ]]; then
    echo "pxe_content_server_ip: $(yaml_quote "${PXE_SERVER_IP}")" >> "${file}"
    echo "pxe_dnsmasq_pxe_server_ip: $(yaml_quote "${PXE_SERVER_IP}")" >> "${file}"
    echo "pxe_dnsmasq_tftp_server_ip: $(yaml_quote "${PXE_SERVER_IP}")" >> "${file}"
  fi

  if [[ -n "${PXE_HTTP_PORT}" ]]; then
    echo "pxe_content_host_port: ${PXE_HTTP_PORT}" >> "${file}"
    echo "pxe_dnsmasq_http_port: ${PXE_HTTP_PORT}" >> "${file}"
  fi

  [[ -n "${PXE_INTERFACE}" ]] && echo "pxe_dnsmasq_interface: $(yaml_quote "${PXE_INTERFACE}")" >> "${file}"
  [[ -n "${PXE_DHCP_START}" ]] && echo "pxe_dnsmasq_dhcp_range_start: $(yaml_quote "${PXE_DHCP_START}")" >> "${file}"
  [[ -n "${PXE_DHCP_END}" ]] && echo "pxe_dnsmasq_dhcp_range_end: $(yaml_quote "${PXE_DHCP_END}")" >> "${file}"
  [[ -n "${PXE_DHCP_NETMASK}" ]] && echo "pxe_dnsmasq_dhcp_netmask: $(yaml_quote "${PXE_DHCP_NETMASK}")" >> "${file}"

  if [[ -n "${PXE_GATEWAY}" ]]; then
    if [[ "${PXE_GATEWAY,,}" == "none" ]]; then
      echo "pxe_dnsmasq_gateway: ''" >> "${file}"
    else
      echo "pxe_dnsmasq_gateway: $(yaml_quote "${PXE_GATEWAY}")" >> "${file}"
    fi
  fi

  [[ -n "${PXE_ISO_ROOT}" ]] && echo "pxe_content_iso_root: $(yaml_quote "${PXE_ISO_ROOT}")" >> "${file}"

  if [[ -n "${PXE_CONTENT_IMAGE_SOURCE}" ]]; then
    echo "pxe_content_image_source: $(yaml_quote "${PXE_CONTENT_IMAGE_SOURCE}")" >> "${file}"
  fi
  [[ -n "${PXE_CONTENT_IMAGE}" ]] && echo "pxe_content_image: $(yaml_quote "${PXE_CONTENT_IMAGE}")" >> "${file}"
  [[ -n "${PXE_CONTENT_RUNTIME_IMAGE}" ]] && echo "pxe_content_runtime_image: $(yaml_quote "${PXE_CONTENT_RUNTIME_IMAGE}")" >> "${file}"
  [[ -n "${PXE_CONTENT_IMAGE_TAR_SRC}" ]] && echo "pxe_content_image_tar_src: $(yaml_quote "${PXE_CONTENT_IMAGE_TAR_SRC}")" >> "${file}"
  [[ -n "${PXE_CONTENT_IMAGE_TAR_PATH}" ]] && echo "pxe_content_image_tar_path: $(yaml_quote "${PXE_CONTENT_IMAGE_TAR_PATH}")" >> "${file}"

  if [[ ${#PXE_DNS_SERVERS[@]} -gt 0 ]]; then
    echo "pxe_dnsmasq_dns_servers:" >> "${file}"
    for dns in "${PXE_DNS_SERVERS[@]}"; do
      echo "  - $(yaml_quote "${dns}")" >> "${file}"
    done
  fi

  echo "${file}"
}

write_controller_vars_file() {
  local file
  local repo_vars_file=""
  local generated_group_vars_tmp=""

  file="$(make_temp_file)"
  generated_group_vars_tmp="$(make_temp_file)"
  GENERATED_GROUP_VARS_SOURCE_FILE="${generated_group_vars_tmp}"

  : > "${file}"

  echo "group_vars_defaults_manage_nfs_mount_defaults: false" >> "${file}"
  echo "group_vars_defaults_manage_scalar_values: false" >> "${file}"
  echo "group_vars_defaults_manage_extra_blocks: false" >> "${file}"
  echo >> "${file}"

  if [[ -n "${NFS_EXPORT_PATH}" ]]; then
    echo "nfs_server_exports:" >> "${file}"
    echo "  - path: $(yaml_quote "${NFS_EXPORT_PATH}")" >> "${file}"

    if [[ "${NFS_ALLOW_ALL_CLIENTS}" == true ]]; then
      echo "    clients: ''" >> "${file}"
      echo "    allow_all_clients: true" >> "${file}"
    else
      echo "    clients: $(yaml_quote "${NFS_ALLOW_CLIENTS}")" >> "${file}"
      echo "    allow_all_clients: false" >> "${file}"
    fi

    echo "    create_path: ${NFS_CREATE_EXPORT_PATH}" >> "${file}"
    echo "    options:" >> "${file}"
    echo "      - rw" >> "${file}"
    echo "      - sync" >> "${file}"
    echo "      - no_subtree_check" >> "${file}"
    echo >> "${file}"
  fi

  if [[ -n "${PATH_FOR_ANSIBLE}" ]]; then
    echo "path_for_ansible: $(yaml_quote "${PATH_FOR_ANSIBLE}")" >> "${file}"
    echo >> "${file}"

    if [[ -n "${NFS_SERVER_IP}" && -n "${NFS_EXPORT_PATH}" ]]; then
      echo "mount_point_setup_single_site_mounts:" >> "${file}"
      echo "  - path: $(yaml_quote "${PATH_FOR_ANSIBLE}")" >> "${file}"
      echo "    mode: '0755'" >> "${file}"
      echo "    owner: root" >> "${file}"
      echo "    group: root" >> "${file}"
      echo "    src: $(yaml_quote "${NFS_SERVER_IP}:${NFS_EXPORT_PATH}")" >> "${file}"
      echo >> "${file}"
    fi
  fi

  if [[ -n "${EPEL_APPROVED}" ]]; then
    echo "enable_epel: ${EPEL_APPROVED}" >> "${file}"
    echo >> "${file}"
  fi

  if [[ "${MANAGE_PROVISION_REPO_VARS}" == true ]]; then
    if [[ "${AUTO_DETECT_PROVISION_REPOS}" == true || ${#PROVISION_EXTRA_REPOS[@]} -gt 0 || -n "${BASEOS_SOURCE}" || -n "${APPSTREAM_SOURCE}" ]]; then
      repo_vars_file="$(detect_bundle_provision_repos)"

      if grep -q '^  rhel[0-9]' "${repo_vars_file}"; then
        cat "${repo_vars_file}" >> "${file}"
        echo >> "${file}"
      else
        warn "No provisioning repos were detected for generated group_vars."
      fi
    fi
  fi

  write_bootstrap_generated_group_vars_file "${generated_group_vars_tmp}" "${repo_vars_file}"

  echo "${file}"
}

###############################################################################
# 12. Ansible runners
###############################################################################
run_playbook() {
  local name="$1"
  local cfg="$2"
  local playbook="$3"
  local vars_file="$4"
  local use_become="$5"
  shift 5

  local -a extra_vars=("$@")
  local -a args=()
  local item=""

  [[ -f "${cfg}" ]] || fail "Ansible config not found: ${cfg}"
  [[ -f "${playbook}" ]] || fail "Playbook not found: ${playbook}"

  args+=(ansible-playbook)
  args+=(-i "${LOCALHOST_INVENTORY}")
  args+=(-c local)

  if [[ "${use_become}" == true ]]; then
    args+=(-b)
  fi

  [[ "${DRY_RUN}" == true ]] && args+=(--check)
  [[ "${VERBOSE}" == true ]] && args+=(-v)

  [[ -s "${vars_file}" ]] && args+=(-e "@${vars_file}")

  for item in "${extra_vars[@]}"; do
    args+=(-e "${item}")
  done

  args+=("${playbook}")

  info
  info "Running ${name}: $(basename "${playbook}")"

  if [[ "${VERBOSE}" == true || "${DRY_RUN}" == true ]]; then
    printf 'ANSIBLE CMD: ANSIBLE_CONFIG=%q ' "${cfg}"
    printf '%q ' "${args[@]}"
    printf '\n'
  fi

  (
    cd "${PLAYBOOKS_DIR}"
    ANSIBLE_CONFIG="${cfg}" "${args[@]}"
  )
}

append_vars_files_as_extra_vars() {
  local -n target_array="$1"
  shift
  local file=""

  for file in "$@"; do
    target_array+=("@${file}")
  done
}

