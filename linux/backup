      ;;
    --allow-root-bundle)
      ALLOW_ROOT_BUNDLE=true
      shift
      ;;

    --bootstrap-only)
      RUN_PXE=false
      RUN_CONTROLLER=false
      shift
      ;;
    --overwrite-initialized-files)
      OVERWRITE_INITIALIZED_FILES=true
      shift
      ;;
    --skip-pxe)
      RUN_PXE=false
      shift
      ;;
    --skip-controller)
      RUN_CONTROLLER=false
      shift
      ;;

    --repo-source)
      [[ $# -ge 2 ]] || fail "--repo-source requires a value"
