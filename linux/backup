#!/usr/bin/env bash
# UNCLASSIFIED

set -Eeuo pipefail

###############################################################################
# 01. Defaults
###############################################################################
DRY_RUN=false
VERBOSE=false
DEBUG=false
ASSUME_YES=false
ALLOW_ROOT_BUNDLE=false

RUN_BOOTSTRAP=true
RUN_PXE=true
RUN_CONTROLLER=true
OVERWRITE_INITIALIZED_FILES=false

SKIP_ANSIBLE_INSTALL=false
KEEP_BOOTSTRAP_REPO_FILE=false
PREFER_BUNDLE_REPOS=false

REPO_SOURCE=""
BASEOS_SOURCE=""
APPSTREAM_SOURCE=""

PXE_SERVER_IP=""
PXE_HTTP_PORT="18080"
PXE_INTERFACE=""
PXE_DHCP_START=""
PXE_DHCP_END=""
PXE_DHCP_NETMASK=""
PXE_GATEWAY=""
PXE_ISO_ROOT=""
declare -a PXE_DNS_SERVERS=()

PXE_CONTENT_IMAGE_SOURCE="auto"
PXE_CONTENT_IMAGE=""
PXE_CONTENT_RUNTIME_IMAGE=""
PXE_CONTENT_IMAGE_TAR_SRC=""
PXE_CONTENT_IMAGE_TAR_PATH="/srv/pxe-content/pxe-content.tar"

NFS_SERVER_IP=""
NFS_EXPORT_PATH=""
NFS_ALLOW_CLIENTS=""
NFS_ALLOW_ALL_CLIENTS=false
NFS_CREATE_EXPORT_PATH=false
PATH_FOR_ANSIBLE="/home/unix/sysadmin"
EPEL_APPROVED=""

MANAGE_PROVISION_REPO_VARS=true
AUTO_DETECT_PROVISION_REPOS=true
declare -a PROVISION_EXTRA_REPOS=()

declare -a BOOTSTRAP_EXTRA_VARS=()
declare -a PXE_EXTRA_VARS=()
declare -a CONTROLLER_EXTRA_VARS=()

declare -a BOOTSTRAP_EXTRA_VARS_FILES=()
declare -a PXE_EXTRA_VARS_FILES=()
declare -a CONTROLLER_EXTRA_VARS_FILES=()

declare -a TEMP_FILES=()
TEMP_REPO_FILE=""

###############################################################################
# 02. Logging helpers
###############################################################################
fail() {
  echo "ERROR: $*" >&2
  exit 1
}

warn() {
  echo "WARNING: $*" >&2
}

info() {
  echo "$*"
}

verbose() {
  if [[ "${VERBOSE}" == true ]]; then
    echo "VERBOSE: $*"
  fi
}

trap 'echo "ERROR: bootstrap_controller.sh failed at line ${BASH_LINENO[0]:-${LINENO}} while running: ${BASH_COMMAND}" >&2' ERR

cleanup() {
  local path=""

  if [[ -n "${TEMP_REPO_FILE}" && -f "${TEMP_REPO_FILE}" && "${KEEP_BOOTSTRAP_REPO_FILE}" != true && "${DRY_RUN}" != true ]]; then
    rm -f -- "${TEMP_REPO_FILE}" || true
  fi

  for path in "${TEMP_FILES[@]:-}"; do
    [[ -n "${path}" && -e "${path}" ]] && rm -f -- "${path}" || true
  done
}
trap cleanup EXIT

###############################################################################
# 03. Usage
###############################################################################
usage() {
  cat <<'EOF'
bootstrap.sh / collections-hub/scripts/bootstrap_controller.sh

Bootstrap an AeroLIT bundle host in this order:
  1. bootstrap_repo_environment.yml
  2. pxe_server.yml           optional
  3. ansible_controller.yml   optional

The bundle entry point is bootstrap.sh at the bundle root.
That wrapper forwards to collections-hub/scripts/bootstrap_controller.sh.

Typical bundle layout:
  <bundle>/
  |-- bootstrap.sh
  |-- collections-hub/
  |-- extracted_isos/
  |   `-- rhel8iso|rhel9iso|rhel10iso/
  |       |-- BaseOS/
  |       `-- AppStream/
  |-- files/
  |   `-- pxe/pxe-content.tar
  `-- repos/
      `-- third-party-rhel8-rpms/

Usage:
  ./bootstrap.sh [OPTIONS]
  ./collections-hub/scripts/bootstrap_controller.sh [OPTIONS]

Execution flow:
  --bootstrap-only
      Run only bootstrap_repo_environment.yml.

  --overwrite-initialized-files
      Allow bootstrap_repo_environment.yml to overwrite initialized files that
      are normally protected by .sync-preserve.

  --skip-pxe
      Skip pxe_server.yml.

  --skip-controller
      Skip ansible_controller.yml.

Repository and Ansible install options:
  --repo-source PATH_OR_URL
      Parent source containing BaseOS and AppStream.
      Local examples:
        extracted_isos/rhel8iso
        /mnt/repos/rhel9
      HTTP example:
        http://repo-server/repos/rhel9

  --baseos-source PATH_OR_URL
  --appstream-source PATH_OR_URL
      Explicit BaseOS/AppStream sources. Use both together.
      These override auto-detected bundle repos for the controller OS.

  --prefer-bundle-repos
      Use detected/provided bundle BaseOS/AppStream repos first when installing
      ansible-core instead of trying currently configured repos first.

  --skip-ansible-install
      Do not install ansible-core. Fail if ansible-playbook is missing.

  --keep-bootstrap-repo-file
      Leave /etc/yum.repos.d/zz-aerolit-bootstrap.repo in place after exit.

PXE-friendly options:
  --pxe-server-ip IP
      IP address PXE clients use to reach this server.
      Find candidates with:
        ip -br addr
        ip route get 1.1.1.1

  --pxe-http-port PORT
      HTTP port exposed by the pxe-content container.
      Default: 18080

  --pxe-interface IFACE
      Network interface dnsmasq listens on for PXE/DHCP.
      Find interfaces with:
        ip -br link
        ip -br addr

  --pxe-dhcp-start IP
  --pxe-dhcp-end IP
      DHCP range handed out to PXE clients.
      Example for PXE server 192.168.109.139/24:
        --pxe-dhcp-start 192.168.109.100
        --pxe-dhcp-end   192.168.109.200

  --pxe-dhcp-netmask MASK
      DHCP netmask, usually matching the PXE interface network.
      Example:
        --pxe-dhcp-netmask 255.255.255.0

  --pxe-gateway IP|none
      Gateway offered to PXE clients.
      Use "none" for isolated direct-cable/lab PXE networks.

  --pxe-dns IP
      Adds a DNS server to pxe_dnsmasq_dns_servers.
      May be specified more than once.

  --pxe-iso-root PATH
      Host path bind-mounted into the pxe-content container.
      Default auto-detects:
        <bundle>/extracted_isos/rhel<controller_major>iso
      Relative paths are normalized under the bundle root.

PXE content image options:
  --pxe-content-image-source auto|registry|tar
      How pxe_content gets its container image.
      Default: auto
      auto uses tar when <bundle>/files/pxe/pxe-content.tar exists,
      otherwise the pxe_content role default is used.

  --pxe-content-image IMAGE
      Registry image when image source is registry.
      Maps to pxe_content_image.

  --pxe-content-runtime-image IMAGE
      Image name Quadlet/Podman should run after the image is available.
      Maps to pxe_content_runtime_image.

  --pxe-content-image-tar-src PATH
      Controller-side tar file to copy/load when image source is tar.
      Default if present:
        <bundle>/files/pxe/pxe-content.tar

  --pxe-content-image-tar-path PATH
      Target-side tar path used by podman load.
      Default:
        /srv/pxe-content/pxe-content.tar

Controller/NFS/group-vars options:
  --nfs-server-ip IP
      IP address provisioned machines use to mount the NFS export from this host.
      Often the controller IP on the provisioning network.
      Find candidates with:
        ip -br addr

  --nfs-export-path PATH
      Local path exported by nfs_server.
      Default:
        <bundle root>
      This must be an absolute local path.

  --nfs-allow-clients SPEC
      Client spec for /etc/exports.
      Examples:
        192.168.98.0/24
        192.168.109.0/24
        192.168.98.25

  --nfs-allow-all-clients
      Use allow_all_clients: true for nfs_server_exports.
      Useful for first lab tests, but narrow it later.

  --nfs-create-export-path
      Set create_path: true in nfs_server_exports.

  --path-for-ansible PATH
      Path where provisioned machines will mount/use the exported bundle.
      This becomes the client-visible base path for files and repos.
      Default:
        /home/unix/sysadmin
      This must be an absolute path.

  --epel-approved BOOL
      Sets enable_epel in generated group vars.
      Accepted:
        true false yes no 1 0 on off

Provisioning repo variables:
  --skip-provision-repo-vars
      Do not write detected repo variables into generated group_vars.

  --no-auto-provision-repos
      Do not auto-detect bundle repos for future provisioned machines.

  --provision-extra-repo OS:ID=PATH_OR_URL
      Add or override a repo for future provisioned machines.
      May be specified more than once.
      OS examples: rhel8, rhel9, rhel10
      Local paths must be inside --nfs-export-path so clients can see them.
      Examples:
        --provision-extra-repo rhel8:third-party=repos/third-party-rhel8-rpms
        --provision-extra-repo rhel9:epel=http://repo-server/rhel9/epel

Safety options:
  --assume-yes
      Answer yes to safety prompts.

  --allow-root-bundle
      Allow running from a bundle located under /root without prompting.

Extra vars:
  The following options may be specified more than once:
    --bootstrap-extra-var KEY=VALUE
    --pxe-extra-var KEY=VALUE
    --controller-extra-var KEY=VALUE

Extra vars files may also be specified more than once:
    --bootstrap-extra-vars-file FILE
    --pxe-extra-vars-file FILE
    --controller-extra-vars-file FILE

General options:
  --dry-run
      Do not change the system. If Ansible is available, playbooks run in
      --check mode.

  --verbose
      Show more output.

  --debug
      Enable shell tracing. Implies --verbose.

  -h, --help
      Show this help text.

Examples:
  # Full combined setup: bootstrap repo environment, PXE server, then controller
  ./bootstrap.sh \
    --pxe-server-ip 192.168.109.139 \
    --pxe-interface ens160 \
    --pxe-dhcp-start 192.168.109.100 \
    --pxe-dhcp-end 192.168.109.200 \
    --pxe-dhcp-netmask 255.255.255.0 \
    --nfs-server-ip 192.168.98.141 \
    --nfs-allow-clients 192.168.98.0/24 \
    --epel-approved true

  # Controller only: skip PXE setup
  ./bootstrap.sh \
    --skip-pxe \
    --nfs-server-ip 192.168.98.141 \
    --nfs-allow-clients 192.168.98.0/24 \
    --epel-approved true

  # PXE only: skip controller setup
  ./bootstrap.sh \
    --skip-controller \
    --pxe-server-ip 192.168.109.139 \
    --pxe-interface ens160 \
    --pxe-dhcp-start 192.168.109.100 \
    --pxe-dhcp-end 192.168.109.200 \
    --pxe-dhcp-netmask 255.255.255.0

  # Bootstrap repo environment only
  ./bootstrap.sh --bootstrap-only

  # Force bootstrap templates to overwrite initialized files
  ./bootstrap.sh --bootstrap-only --overwrite-initialized-files

  # Use a specific local BaseOS/AppStream parent source
  ./bootstrap.sh --repo-source extracted_isos/rhel8iso

  # Use separate BaseOS and AppStream HTTP sources
  ./bootstrap.sh \
    --baseos-source http://server/repos/rhel9/BaseOS \
    --appstream-source http://server/repos/rhel9/AppStream

  # Use the bundled pxe-content tar explicitly
  ./bootstrap.sh \
    --pxe-server-ip 192.168.109.139 \
    --pxe-interface ens160 \
    --pxe-content-image-source tar \
    --pxe-content-image-tar-src files/pxe/pxe-content.tar

  # Add future provisioning repos into generated group_vars
  ./bootstrap.sh \
    --skip-pxe \
    --nfs-server-ip 192.168.98.141 \
    --nfs-allow-clients 192.168.98.0/24 \
    --provision-extra-repo rhel8:third-party=repos/third-party-rhel8-rpms \
    --provision-extra-repo rhel9:epel=http://repo-server/rhel9/epel

  # Pass repeated extra vars through to the PXE playbook
  ./bootstrap.sh \
    --pxe-server-ip 192.168.109.139 \
    --pxe-interface ens160 \
    --pxe-extra-var pxe_dnsmasq_log_queries=true \
    --pxe-extra-var pxe_dnsmasq_extra_firewall_ports='["8081/tcp"]'

  # Use vars files for larger custom setups
  ./bootstrap.sh \
    --pxe-extra-vars-file /path/to/pxe-vars.yml \
    --controller-extra-vars-file /path/to/controller-vars.yml

  # Dry-run the controller path
  ./bootstrap.sh \
    --dry-run \
    --skip-pxe \
    --nfs-server-ip 192.168.98.141 \
    --nfs-allow-clients 192.168.98.0/24
EOF
}

###############################################################################
# 04. Basic helpers
###############################################################################
need_cmd() {
  command -v "$1" >/dev/null 2>&1 || fail "Missing required command: $1"
}

as_root() {
  if [[ "${EUID}" -eq 0 ]]; then
    "$@"
  else
    need_cmd sudo
    sudo "$@"
  fi
}

is_url() {
  [[ "$1" =~ ^https?:// ]]
}

normalize_bool() {
  case "${1,,}" in
    true|yes|1|on) echo "true" ;;
    false|no|0|off) echo "false" ;;
    *) fail "Invalid boolean value: $1" ;;
  esac
}

yaml_quote() {
  local value="$1"
  value=${value//\'/\'\'}
  printf "'%s'" "${value}"
}

make_temp_file() {
  local path
  path="$(mktemp)"
  TEMP_FILES+=("${path}")
  echo "${path}"
}

require_file_arg() {
  local label="$1"
  local path="$2"
  [[ -f "${path}" ]] || fail "${label} file not found: ${path}"
}

validate_extra_var() {
  local label="$1"
  local value="$2"
  [[ "${value}" == *=* ]] || fail "${label} must be in KEY=VALUE form: ${value}"
  [[ "${value%%=*}" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]] || fail "${label} key must be a valid variable name: ${value%%=*}"
}

validate_no_whitespace_path() {
  local label="$1"
  local value="$2"
  [[ "${value}" != *[[:space:]]* ]] || fail "${label} must not contain whitespace: ${value}"
}

path_is_absolute() {
  [[ "$1" == /* ]]
}

normalize_local_path() {
  local label="$1"
  local value="$2"
  local base_dir="${3:-$(pwd)}"

  [[ -n "${value}" ]] || return 0
  validate_no_whitespace_path "${label}" "${value}"

  if is_url "${value}"; then
    printf '%s' "${value%/}"
    return 0
  fi

  if path_is_absolute "${value}"; then
    printf '%s' "${value%/}"
    return 0
  fi

  warn "${label} was provided as a relative path: ${value}"
  warn "Normalizing it relative to: ${base_dir}"
  printf '%s/%s' "${base_dir%/}" "${value}"
}

require_absolute_path_value() {
  local label="$1"
  local value="$2"

  validate_no_whitespace_path "${label}" "${value}"
  path_is_absolute "${value}" || fail "${label} must be an absolute path: ${value}"
}

confirm_continue() {
  local prompt="$1"
  local reply=""

  if [[ "${ASSUME_YES}" == true ]]; then
    info "${prompt}"
    info "Continuing because --assume-yes was used."
    return 0
  fi

  if [[ ! -t 0 ]]; then
    fail "${prompt} Re-run with --assume-yes to continue in non-interactive mode."
  fi

  printf '%s [y/N]: ' "${prompt}" >&2
  read -r reply
  case "${reply,,}" in
    y|yes) return 0 ;;
    *) fail "User declined to continue." ;;
  esac
}

###############################################################################
# 05. Path discovery
###############################################################################
SOURCE="${BASH_SOURCE[0]}"
while [[ -L "${SOURCE}" ]]; do
  SCRIPT_DIR="$(cd -P "$(dirname "${SOURCE}")" && pwd)"
  SOURCE="$(readlink "${SOURCE}")"
  [[ "${SOURCE}" != /* ]] && SOURCE="${SCRIPT_DIR}/${SOURCE}"
done

SCRIPT_DIR="$(cd -P "$(dirname "${SOURCE}")" && pwd)"
COLLECTIONS_HUB_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
BUNDLE_ROOT="$(cd "${COLLECTIONS_HUB_ROOT}/.." && pwd)"
BUNDLE_PARENT="$(cd "${BUNDLE_ROOT}/.." && pwd)"
PLAYBOOKS_DIR="${COLLECTIONS_HUB_ROOT}/ansible"

BOOTSTRAP_PLAYBOOK="${PLAYBOOKS_DIR}/bootstrap_repo_environment.yml"
PXE_PLAYBOOK="${PLAYBOOKS_DIR}/pxe_server.yml"
CONTROLLER_PLAYBOOK="${PLAYBOOKS_DIR}/ansible_controller.yml"

BOOTSTRAP_CFG="${PLAYBOOKS_DIR}/ansible_template.cfg"
MAIN_CFG="${PLAYBOOKS_DIR}/ansible.cfg"
EFFECTIVE_MAIN_CFG="${MAIN_CFG}"

GENERATED_GROUP_VARS_FILE="${PLAYBOOKS_DIR}/group_vars/all/aerolit_bootstrap_generated.yml"
GENERATED_GROUP_VARS_SOURCE_FILE=""

LOCALHOST_INVENTORY="localhost,"

NFS_EXPORT_PATH="${BUNDLE_ROOT}"

###############################################################################
# 06. OS and repo helper functions used by defaults and main flow
###############################################################################
get_os_major() {
  local version_id=""
  if [[ -r /etc/os-release ]]; then
    version_id="$(awk -F= '/^VERSION_ID=/{gsub(/"/,"",$2); print $2}' /etc/os-release)"
  fi
  [[ -n "${version_id}" ]] || fail "Unable to determine OS version from /etc/os-release"
  echo "${version_id%%.*}"
}

repo_dir_is_valid() {
  local path="$1"
  [[ -d "${path}" ]] || return 1
  [[ -f "${path}/repodata/repomd.xml" ]] || return 1
}

resolve_local_repo_pair() {
  local root="$1"
  local base=""
  local app=""

  [[ -d "${root}" ]] || return 1

  if repo_dir_is_valid "${root}/BaseOS"; then
    base="${root}/BaseOS"
  elif repo_dir_is_valid "${root}/baseos"; then
    base="${root}/baseos"
  fi

  if repo_dir_is_valid "${root}/AppStream"; then
    app="${root}/AppStream"
  elif repo_dir_is_valid "${root}/appstream"; then
    app="${root}/appstream"
  fi

  if [[ -n "${base}" && -n "${app}" ]]; then
    printf '%s\n%s\n' "${base}" "${app}"
    return 0
  fi

  base="$(find "${root}" -maxdepth 6 $begin:math:text$ \-path \'\*\/BaseOS\/repodata\/repomd\.xml\' \-o \-path \'\*\/baseos\/repodata\/repomd\.xml\' $end:math:text$ -type f 2>/dev/null | head -n 1 || true)"
  app="$(find "${root}" -maxdepth 6 $begin:math:text$ \-path \'\*\/AppStream\/repodata\/repomd\.xml\' \-o \-path \'\*\/appstream\/repodata\/repomd\.xml\' $end:math:text$ -type f 2>/dev/null | head -n 1 || true)"

  [[ -n "${base}" ]] && base="$(dirname "$(dirname "${base}")")"
  [[ -n "${app}" ]] && app="$(dirname "$(dirname "${app}")")"

  if [[ -n "${base}" && -n "${app}" ]] && repo_dir_is_valid "${base}" && repo_dir_is_valid "${app}"; then
    printf '%s\n%s\n' "${base}" "${app}"
    return 0
  fi

  return 1
}

detect_default_pxe_iso_root() {
  local os_major="$1"
  local candidate=""

  for candidate in \
    "${BUNDLE_ROOT}/extracted_isos/rhel${os_major}iso" \
    "${BUNDLE_ROOT}/extracted_isos/rhel${os_major}" \
    "${BUNDLE_ROOT}/rhel${os_major}iso" \
    "${BUNDLE_ROOT}/rhel${os_major}"; do
    if [[ -d "${candidate}" ]]; then
      printf '%s' "${candidate}"
      return 0
    fi
  done

  printf '%s' "${BUNDLE_ROOT}/extracted_isos/rhel${os_major}iso"
}

###############################################################################
# 07. Argument parsing
###############################################################################
while [[ $# -gt 0 ]]; do
  case "$1" in
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    --verbose)
      VERBOSE=true
      shift
      ;;
    --debug)
      DEBUG=true
      VERBOSE=true
      shift
      ;;
    --assume-yes|-y)
