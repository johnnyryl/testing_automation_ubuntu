Directly under it, add:

write_bootstrap_generated_group_vars_file() {
  local output_file="$1"
  local repo_vars_file="${2:-}"
  {
    echo "# UNCLASSIFIED"
    echo "#"
    echo "# Generated by AeroLIT bootstrap.sh / bootstrap_controller.sh."
    echo "# Do not hand-edit this file for local defaults."
    echo "# Put local/manual defaults in workstation_defaults.yml instead."
    echo
    if [[ -n "${PATH_FOR_ANSIBLE}" ]]; then
      echo "path_for_ansible: $(yaml_quote "${PATH_FOR_ANSIBLE}")"
      echo
      if [[ -n "${NFS_SERVER_IP}" && -n "${NFS_EXPORT_PATH}" ]]; then
        echo "mount_point_setup_single_site_mounts:"
        echo "  - path: $(yaml_quote "${PATH_FOR_ANSIBLE}")"
        echo "    mode: '0755'"
        echo "    owner: root"
        echo "    group: root"
        echo "    src: $(yaml_quote "${NFS_SERVER_IP}:${NFS_EXPORT_PATH}")"
        echo
      fi
    fi
    if [[ -n "${EPEL_APPROVED}" ]]; then
      echo "epel_is_approved: ${EPEL_APPROVED}"
      echo
    fi
    if [[ -n "${repo_vars_file}" && -s "${repo_vars_file}" ]] && grep -q '^  rhel[0-9]' "${repo_vars_file}"; then
      cat "${repo_vars_file}"
      echo
    fi
    echo "# UNCLASSIFIED"
  } > "${output_file}"
}
install_bootstrap_generated_group_vars_file() {
  local source_file="$1"
  local dest_file="${GENERATED_GROUP_VARS_FILE}"
  local dest_dir=""
  [[ -n "${source_file}" && -f "${source_file}" ]] || return 0
  if [[ "${DRY_RUN}" == true ]]; then
    info "DRY RUN: would write generated bootstrap group vars to ${dest_file}"
    if [[ "${VERBOSE}" == true ]]; then
      cat "${source_file}"
    fi
    return 0
  fi
  dest_dir="$(dirname "${dest_file}")"
  as_root mkdir -p -- "${dest_dir}"
  if [[ -f "${dest_file}" ]] && cmp -s "${source_file}" "${dest_file}"; then
    verbose "Generated bootstrap group vars already up to date: ${dest_file}"
    return 0
  fi
  as_root install -m 0644 -- "${source_file}" "${dest_file}"
  info "Wrote generated bootstrap group vars: ${dest_file}"
}

3. Replace the entire write_controller_vars_file() function

Replace your current write_controller_vars_file() with this whole block:

write_controller_vars_file() {
  local file
  local repo_vars_file=""
  local generated_group_vars_tmp=""
  file="$(make_temp_file)"
  generated_group_vars_tmp="$(make_temp_file)"
  GENERATED_GROUP_VARS_SOURCE_FILE="${generated_group_vars_tmp}"
  : > "${file}"
  # Bootstrap now writes generated group vars to:
  #   group_vars/all/zz_aerolit_bootstrap_generated.yml
  #
  # Do not let group_vars_defaults inject generated bootstrap data into
  # workstation_defaults.yml.
  echo "group_vars_defaults_manage_nfs_mount_defaults: false" >> "${file}"
  echo "group_vars_defaults_manage_scalar_values: false" >> "${file}"
  echo "group_vars_defaults_manage_extra_blocks: false" >> "${file}"
  echo >> "${file}"
  if [[ -n "${NFS_EXPORT_PATH}" ]]; then
    echo "nfs_server_exports:" >> "${file}"
    echo "  - path: $(yaml_quote "${NFS_EXPORT_PATH}")" >> "${file}"
    if [[ "${NFS_ALLOW_ALL_CLIENTS}" == true ]]; then
      echo "    clients: ''" >> "${file}"
      echo "    allow_all_clients: true" >> "${file}"
    else
      echo "    clients: $(yaml_quote "${NFS_ALLOW_CLIENTS}")" >> "${file}"
      echo "    allow_all_clients: false" >> "${file}"
    fi
    echo "    create_path: ${NFS_CREATE_EXPORT_PATH}" >> "${file}"
    echo "    options:" >> "${file}"
    echo "      - rw" >> "${file}"
    echo "      - sync" >> "${file}"
    echo "      - no_subtree_check" >> "${file}"
    echo >> "${file}"
  fi
  if [[ -n "${PATH_FOR_ANSIBLE}" ]]; then
    echo "path_for_ansible: $(yaml_quote "${PATH_FOR_ANSIBLE}")" >> "${file}"
    echo >> "${file}"
    if [[ -n "${NFS_SERVER_IP}" && -n "${NFS_EXPORT_PATH}" ]]; then
      echo "mount_point_setup_single_site_mounts:" >> "${file}"
      echo "  - path: $(yaml_quote "${PATH_FOR_ANSIBLE}")" >> "${file}"
      echo "    mode: '0755'" >> "${file}"
      echo "    owner: root" >> "${file}"
      echo "    group: root" >> "${file}"
      echo "    src: $(yaml_quote "${NFS_SERVER_IP}:${NFS_EXPORT_PATH}")" >> "${file}"
      echo >> "${file}"
    fi
  fi
  if [[ -n "${EPEL_APPROVED}" ]]; then
    echo "epel_is_approved: ${EPEL_APPROVED}" >> "${file}"
    echo >> "${file}"
  fi
  if [[ "${MANAGE_PROVISION_REPO_VARS}" == true ]]; then
    if [[ "${AUTO_DETECT_PROVISION_REPOS}" == true || ${#PROVISION_EXTRA_REPOS[@]} -gt 0 || -n "${BASEOS_SOURCE}" || -n "${APPSTREAM_SOURCE}" ]]; then
      repo_vars_file="$(detect_bundle_provision_repos)"
      if grep -q '^  rhel[0-9]' "${repo_vars_file}"; then
        cat "${repo_vars_file}" >> "${file}"
        echo >> "${file}"
      else
        warn "No provisioning repos were detected for generated group_vars."
      fi
    fi
  fi
  write_bootstrap_generated_group_vars_file "${generated_group_vars_tmp}" "${repo_vars_file}"
  echo "${file}"
}

