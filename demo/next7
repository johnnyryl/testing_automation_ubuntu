    printf '%s\n' "${DISK_LINES[@]}" \
    | awk -F'|' '$2 == "0" { print }' \
    | sort -t'|' -k3,3nr \
    | head -n 1 \
    | cut -d'|' -f1
)"
if [ -z "${PRIMARY_DISK}" ]; then
    PRIMARY_DISK="$(
        printf '%s\n' "${DISK_LINES[@]}" \
        | sort -t'|' -k3,3nr \
        | head -n 1 \
        | cut -d'|' -f1
    )"
fi
PRIMARY_SIZE_BYTES="$(
    printf '%s\n' "${DISK_LINES[@]}" \
    | awk -F'|' -v disk="${PRIMARY_DISK}" '$1 == disk { print $3 }'
)"
MIN_PRIMARY_BYTES=$(( MIN_PRIMARY_GIB * 1024 * 1024 * 1024 ))
if [ "${PRIMARY_SIZE_BYTES:-0}" -lt "${MIN_PRIMARY_BYTES}" ]; then
    echo "WARNING: Primary disk ${PRIMARY_DISK} is smaller than ${MIN_PRIMARY_GIB} GiB."
    echo "Continuing because this may be an intentional lab or small VM install."
fi
SECONDARY_DISK="$(
    printf '%s\n' "${DISK_LINES[@]}" \
    | awk -F'|' -v primary="${PRIMARY_DISK}" '$1 != primary { print }' \
    | sort -t'|' -k3,3nr \
    | head -n 1 \
    | cut -d'|' -f1
)"
if [ "${PRIMARY_ONLY}" = "true" ]; then
    SECONDARY_DISK=""
fi
if [ "${ADD_DATA_VOLUME}" != "true" ]; then
    SECONDARY_DISK=""
fi
DLIST="${PRIMARY_DISK}"
if [ -n "${SECONDARY_DISK}" ]; then
    DLIST="${PRIMARY_DISK},${SECONDARY_DISK}"
fi
echo "Primary disk: ${PRIMARY_DISK}"
if [ -n "${SECONDARY_DISK}" ]; then
    echo "Secondary encrypted data disk: ${SECONDARY_DISK}"
else
    echo "Secondary encrypted data disk: none"
fi
cat > "${PART_CONFIG}" <<EOF
# Generated by AeroLIT luks-workstation-dynamic-lvm.ks.j2
ignoredisk --only-use=${DLIST}
zerombr
bootloader --append="crashkernel=auto" --boot-drive=${PRIMARY_DISK}
clearpart --all --initlabel --drives=${DLIST}
# Boot partitions remain unencrypted because the installer and firmware need them.
part /boot --fstype=xfs --ondisk=${PRIMARY_DISK} --size=1024
part /boot/efi --fstype=efi --ondisk=${PRIMARY_DISK} --size=600 --fsoptions="umask=0077,shortname=winnt"
# Encrypted primary LVM physical volume
part pv.01 --fstype=lvmpv --ondisk=${PRIMARY_DISK} --size=1 --grow --encrypted --passphrase=${LUKS_PASSPHRASE}
# Primary volume group
volgroup rootvg --pesize=4096 pv.01
# Logical volumes
logvol / --fstype=xfs --size=20480 --grow --name=root --vgname=rootvg
logvol /home --fstype=xfs --size=20480 --name=home --vgname=rootvg
logvol /tmp --fstype=xfs --size=10240 --name=tmp --vgname=rootvg
logvol /var --fstype=xfs --size=15360 --name=var --vgname=rootvg
logvol /var/log --fstype=xfs --size=20480 --name=log --vgname=rootvg
logvol /var/log/audit --fstype=xfs --size=20480 --name=audit --vgname=rootvg
logvol /var/tmp --fstype=xfs --size=5120 --name=vartmp --vgname=rootvg
logvol /opt --fstype=xfs --size=10240 --name=opt --vgname=rootvg
logvol swap --fstype=swap --size=4096 --name=swap --vgname=rootvg
EOF
if [ -n "${SECONDARY_DISK}" ]; then
    cat >> "${PART_CONFIG}" <<EOF
# Encrypted secondary data disk
part pv.02 --fstype=lvmpv --ondisk=${SECONDARY_DISK} --size=1 --grow --encrypted --passphrase=${LUKS_PASSPHRASE}
volgroup datavg --pesize=4096 pv.02
logvol /data --fstype=xfs --size=1 --grow --name=data --vgname=datavg
EOF
fi
echo
echo "Generated encrypted storage configuration:"
echo "------------------------------------------"
sed 's/--passphrase=[^ ]*/--passphrase=__hidden__/g' "${PART_CONFIG}"
echo
%end

