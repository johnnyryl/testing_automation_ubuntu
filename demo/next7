# Storage layout: workstation dynamic LVM
#
# This creates /tmp/part.conf during %pre and includes it into the Kickstart.
# It chooses a primary install disk, optionally detects a secondary data disk,
# and creates separate logical volumes for common security/compliance boundaries.
#
# Jinja variables you can override later:
#   storage_primary_only: true/false
#   storage_min_primary_gib: minimum primary disk size warning threshold
#   storage_add_data_volume: true/false
%include /tmp/part.conf
%pre --interpreter=/bin/bash
set -o pipefail
PART_CONFIG="/tmp/part.conf"
INSTALL_TTY="/dev/tty1"
PRIMARY_ONLY="{{ storage_primary_only | default('false') }}"
ADD_DATA_VOLUME="{{ storage_add_data_volume | default('true') }}"
MIN_PRIMARY_GIB="{{ storage_min_primary_gib | default('40') }}"
if [ -e "${INSTALL_TTY}" ]; then
    exec < "${INSTALL_TTY}" > "${INSTALL_TTY}" 2> "${INSTALL_TTY}"
fi
echo
echo "=========================================="
echo "AeroLIT workstation storage detection"
echo "=========================================="
echo
# Build a disk list in the format:
# name|rota|size_bytes
#
# rota=0 usually means SSD/NVMe.
# rota=1 usually means spinning disk.
mapfile -t DISK_LINES < <(
    lsblk -dn -b -o NAME,TYPE,ROTA,SIZE \
    | awk '$2 == "disk" { print $1 "|" $3 "|" $4 }'
)
if [ "${#DISK_LINES[@]}" -lt 1 ]; then
    echo "ERROR: No installable disks were detected."
    echo "reboot" > "${PART_CONFIG}"
    exit 0
fi
# Prefer the largest non-rotational disk. If none exists, use the largest disk.
PRIMARY_DISK="$(
    printf '%s\n' "${DISK_LINES[@]}" \
    | awk -F'|' '$2 == "0" { print }' \
    | sort -t'|' -k3,3nr \
    | head -n 1 \
    | cut -d'|' -f1
)"
if [ -z "${PRIMARY_DISK}" ]; then
    PRIMARY_DISK="$(
        printf '%s\n' "${DISK_LINES[@]}" \
        | sort -t'|' -k3,3nr \
        | head -n 1 \
        | cut -d'|' -f1
    )"
fi
PRIMARY_SIZE_BYTES="$(
    printf '%s\n' "${DISK_LINES[@]}" \
    | awk -F'|' -v disk="${PRIMARY_DISK}" '$1 == disk { print $3 }'
)"
MIN_PRIMARY_BYTES=$(( MIN_PRIMARY_GIB * 1024 * 1024 * 1024 ))
if [ "${PRIMARY_SIZE_BYTES:-0}" -lt "${MIN_PRIMARY_BYTES}" ]; then
    echo "WARNING: Primary disk ${PRIMARY_DISK} is smaller than ${MIN_PRIMARY_GIB} GiB."
    echo "Continuing because this may be an intentional lab or small VM install."
fi
SECONDARY_DISK="$(
    printf '%s\n' "${DISK_LINES[@]}" \
    | awk -F'|' -v primary="${PRIMARY_DISK}" '$1 != primary { print }' \
    | sort -t'|' -k3,3nr \
    | head -n 1 \
    | cut -d'|' -f1
)"
if [ "${PRIMARY_ONLY}" = "true" ]; then
    SECONDARY_DISK=""
fi
if [ "${ADD_DATA_VOLUME}" != "true" ]; then
    SECONDARY_DISK=""
fi
DLIST="${PRIMARY_DISK}"
if [ -n "${SECONDARY_DISK}" ]; then
    DLIST="${PRIMARY_DISK},${SECONDARY_DISK}"
fi
echo "Primary disk: ${PRIMARY_DISK}"
if [ -n "${SECONDARY_DISK}" ]; then
    echo "Secondary data disk: ${SECONDARY_DISK}"
else
    echo "Secondary data disk: none"
fi
cat > "${PART_CONFIG}" <<EOF
# Generated by AeroLIT workstation-dynamic-lvm.ks.j2
ignoredisk --only-use=${DLIST}
zerombr
bootloader --append="crashkernel=auto" --boot-drive=${PRIMARY_DISK}
clearpart --all --initlabel --drives=${DLIST}
# Boot partitions
part /boot --fstype=xfs --ondisk=${PRIMARY_DISK} --size=1024
part /boot/efi --fstype=efi --ondisk=${PRIMARY_DISK} --size=600 --fsoptions="umask=0077,shortname=winnt"
# Primary LVM physical volume
part pv.01 --fstype=lvmpv --ondisk=${PRIMARY_DISK} --size=1 --grow
# Primary volume group
volgroup rootvg --pesize=4096 pv.01
# Logical volumes
logvol / --fstype=xfs --size=20480 --grow --name=root --vgname=rootvg
logvol /home --fstype=xfs --size=20480 --name=home --vgname=rootvg
logvol /tmp --fstype=xfs --size=10240 --name=tmp --vgname=rootvg
logvol /var --fstype=xfs --size=15360 --name=var --vgname=rootvg
logvol /var/log --fstype=xfs --size=20480 --name=log --vgname=rootvg
logvol /var/log/audit --fstype=xfs --size=20480 --name=audit --vgname=rootvg
logvol /var/tmp --fstype=xfs --size=5120 --name=vartmp --vgname=rootvg
logvol /opt --fstype=xfs --size=10240 --name=opt --vgname=rootvg
logvol swap --fstype=swap --size=4096 --name=swap --vgname=rootvg
EOF
if [ -n "${SECONDARY_DISK}" ]; then
    cat >> "${PART_CONFIG}" <<EOF
# Secondary data disk
part pv.02 --fstype=lvmpv --ondisk=${SECONDARY_DISK} --size=1 --grow
volgroup datavg --pesize=4096 pv.02
logvol /data --fstype=xfs --size=1 --grow --name=data --vgname=datavg
EOF
fi
echo
echo "Generated storage configuration:"
echo "--------------------------------"
cat "${PART_CONFIG}"
echo
%end

