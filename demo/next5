templates/partials/070-network/_meta.yml

title: Network configuration
order: 70
required: true
selection: one
default: dhcp_link
description: Configures the primary network connection used during and after installation.
applies_to:
  os:
    - rhel7
    - rhel8
    - rhel9
    - rhel10
  profiles:
    - minimal
    - small_disk
    - developer_workstation
options:
  - id: dhcp_link
    file: dhcp-link.ks.j2
    title: DHCP on active link
    description: Uses DHCP on the first active network link. This is the safest default for PXE labs and most VM installs.
    recommended: true
    risk: low
    warning: ""
    requires: []
    conflicts:
      - dhcp_link_with_hostname_prompt
      - dhcp_specific_device
      - static_ip_placeholder
  - id: dhcp_link_with_hostname_prompt
    file: dhcp-link-with-hostname-prompt.ks.j2
    title: DHCP with hostname prompt
    description: Uses DHCP and asks the installer user to type a hostname during installation.
    recommended: false
    risk: medium
    warning: This requires console interaction and is not fully unattended.
    requires: []
    conflicts:
      - dhcp_link
      - dhcp_specific_device
      - static_ip_placeholder
  - id: dhcp_specific_device
    file: dhcp-specific-device.ks.j2
    title: DHCP on a specific network device
    description: Uses DHCP on a specific interface name, such as ens192.
    recommended: false
    risk: medium
    warning: Interface names can change between hardware, VMs, and OS versions.
    requires: []
    conflicts:
      - dhcp_link
      - dhcp_link_with_hostname_prompt
      - static_ip_placeholder
  - id: static_ip_placeholder
    file: static-ip-placeholder.ks.j2
    title: Static IP placeholder
    description: Shows the format for a static IP Kickstart network line.
    recommended: false
    risk: high
    warning: Do not use this as-is. Replace the placeholder IP, gateway, DNS, hostname, and device values first.
    requires: []
    conflicts:
      - dhcp_link
      - dhcp_link_with_hostname_prompt
      - dhcp_specific_device
notes: DHCP on the active link is the best default because the PXE boot already proved that at least one network path works.
tags:
  - required
  - network
  - default

templates/partials/070-network/dhcp-link.ks.j2

# Network configuration
network --bootproto=dhcp --device=link --activate --onboot=on

templates/partials/070-network/dhcp-link-with-hostname-prompt.ks.j2

# Network configuration generated during %pre
%include /tmp/networkhost.txt
%pre --interpreter=/bin/bash
set -o pipefail
NETWORK_HOST_FILE="/tmp/networkhost.txt"
INSTALL_TTY="/dev/tty1"
if [ -e "${INSTALL_TTY}" ]; then
    exec < "${INSTALL_TTY}" > "${INSTALL_TTY}" 2> "${INSTALL_TTY}"
fi
echo
echo "=========================================="
echo "AeroLIT hostname prompt"
echo "=========================================="
echo
echo "Enter the short hostname for this machine."
echo "Do not include the domain name."
echo
read -r HOSTNAME_INPUT || HOSTNAME_INPUT=""
HOSTNAME_INPUT="$(echo "${HOSTNAME_INPUT}" | tr -cd 'A-Za-z0-9-')"
if [ -z "${HOSTNAME_INPUT}" ]; then
    HOSTNAME_INPUT="localhost"
fi
echo "network --bootproto=dhcp --device=link --activate --onboot=on --hostname=${HOSTNAME_INPUT}" > "${NETWORK_HOST_FILE}"
%end

templates/partials/070-network/dhcp-specific-device.ks.j2

# Network configuration for a specific device
network --bootproto=dhcp --device={{ network_device | default('ens192') }} --activate --onboot=on

templates/partials/070-network/static-ip-placeholder.ks.j2

# Static IP placeholder
# Replace these values before using this option in a real install.
network --bootproto=static \
  --device={{ network_device | default('link') }} \
  --activate \
  --onboot=on \
  --ip={{ static_ip | default('192.0.2.50') }} \
  --netmask={{ static_netmask | default('255.255.255.0') }} \
  --gateway={{ static_gateway | default('192.0.2.1') }} \
  --nameserver={{ static_nameserver | default('192.0.2.53') }} \
  --hostname={{ static_hostname | default('aerolit-placeholder.localdomain') }}

