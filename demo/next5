title: Firewall
order: 100
required: true
selection: one
default: enable_ssh
description: Configures the local firewall on the installed system.
applies_to:
  os:
    - rhel7
    - rhel8
    - rhel9
    - rhel10
  profiles:
    - minimal
    - small_disk
    - developer_workstation
options:
  - id: enable_ssh
    file: enable-ssh.ks.j2
    title: Enable firewall and allow SSH
    description: Enables the firewall and allows inbound SSH so the system can be managed after installation.
    recommended: true
    risk: low
    warning: Only SSH is opened by default.
    requires:
      - sshd_enabled
    conflicts:
      - disabled
  - id: disabled
    file: disabled.ks.j2
    title: Disable firewall
    description: Disables the local firewall.
    recommended: false
    risk: high
    warning: Avoid this unless a separate network security control or exception exists.
    requires: []
    conflicts:
      - enable_ssh
notes: For PXE-installed systems, allowing SSH is useful because Ansible or other post-install automation usually connects over SSH.
tags:
  - required
  - security
  - firewall
  - default

templates/partials/100-firewall/enable-ssh.ks.j2

# Firewall configuration
firewall --enabled --service=ssh

templates/partials/100-firewall/disabled.ks.j2

# Firewall configuration
firewall --disabled

