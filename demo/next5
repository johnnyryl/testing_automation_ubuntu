templates/partials/090-selinux/_meta.yml

title: SELinux mode
order: 90
required: true
selection: one
default: enforcing
description: Controls the SELinux security mode on the installed system.
applies_to:
  os:
    - rhel7
    - rhel8
    - rhel9
    - rhel10
  profiles:
    - minimal
    - small_disk
    - developer_workstation
options:
  - id: enforcing
    file: enforcing.ks.j2
    title: Enforcing
    description: SELinux policy is enforced. This is the recommended secure default.
    recommended: true
    risk: low
    warning: Some custom software may need proper SELinux labels or policy fixes.
    requires: []
    conflicts:
      - permissive
      - disabled
  - id: permissive
    file: permissive.ks.j2
    title: Permissive
    description: SELinux logs policy violations but does not block them.
    recommended: false
    risk: medium
    warning: Useful for troubleshooting, but weaker than enforcing mode.
    requires: []
    conflicts:
      - enforcing
      - disabled
  - id: disabled
    file: disabled.ks.j2
    title: Disabled
    description: Disables SELinux.
    recommended: false
    risk: high
    warning: Avoid this unless there is a documented exception.
    requires: []
    conflicts:
      - enforcing
      - permissive
notes: Enforcing should be the AeroLIT default because the project is security and compliance minded.
tags:
  - required
  - security
  - stig
  - default

templates/partials/090-selinux/enforcing.ks.j2

# SELinux configuration
selinux --enforcing

templates/partials/090-selinux/permissive.ks.j2

# SELinux configuration
selinux --permissive

templates/partials/090-selinux/disabled.ks.j2

# SELinux configuration
selinux --disabled

