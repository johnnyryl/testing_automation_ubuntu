templates/partials/080-auth/_meta.yml

title: Root account
order: 80
required: true
selection: one
default: root_password
description: Configures the root account for the installed system.
applies_to:
  os:
    - rhel7
    - rhel8
    - rhel9
    - rhel10
  profiles:
    - minimal
    - small_disk
    - developer_workstation
options:
  - id: root_password
    file: root-password.ks.j2
    title: Set encrypted root password
    description: Sets the root password using the encrypted hash passed into the PXE content generator.
    recommended: true
    risk: medium
    warning: Replace the default password hash before using this in a real environment.
    requires: []
    conflicts:
      - root_password_locked
  - id: root_password_locked
    file: root-password-locked.ks.j2
    title: Lock root account
    description: Locks the root account so root cannot be used for direct login.
    recommended: false
    risk: high
    warning: Only use this when another admin user, SSH key, or post-install access method is configured.
    requires: []
    conflicts:
      - root_password
notes: The generated status and index files should never expose the real root password hash.
tags:
  - required
  - auth
  - security

templates/partials/080-auth/root-password.ks.j2

# Root password
rootpw --iscrypted {{ rootpw_hash }}

templates/partials/080-auth/root-password-locked.ks.j2

# Lock root account
rootpw --lock

