templates/partials/160-anaconda-policy/password-policies-default.ks.j2

# Anaconda password policy defaults
#
# These settings control password checks inside the installer.
# They do not replace post-install OS password policy hardening.
pwpolicy root --minlen=6 --minquality=1 --notstrict --nochanges --notempty
pwpolicy user --minlen=6 --minquality=1 --notstrict --nochanges --emptyok
pwpolicy luks --minlen=6 --minquality=1 --notstrict --nochanges --notempty

