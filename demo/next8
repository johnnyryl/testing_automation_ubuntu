# Package selection: minimal install
#
# Best for:
#   - PXE validation
#   - lab VMs
#   - small servers
#   - Ansible-managed base systems
#
# Keep this intentionally small. Add tools in minimal-plus-tools.ks.j2 instead.
%packages
@^minimal-environment
%end

⸻

templates/partials/130-packages/minimal-plus-tools.ks.j2

# Package selection: minimal install plus common tools
#
# Best for:
#   - small systems that still need troubleshooting tools
#   - Ansible controller targets
#   - PXE lab machines
#   - systems that need basic compliance/scanning readiness
#
# Keep this useful, but not workstation-sized.
%packages
@^minimal-environment
# Core troubleshooting and administration
bash-completion
bind-utils
curl
lsof
net-tools
nfs-utils
rsync
tar
tmux
unzip
vim-enhanced
wget
zip
# Security, audit, and compliance helpers
aide
audit
kexec-tools
openscap-scanner
scap-security-guide
# Identity and domain-readiness packages
adcli
oddjob
oddjob-mkhomedir
realmd
sssd
# Automation and container basics
git
podman
{% if os_major | int == 7 %}
# RHEL 7 uses a different policycoreutils helper package name.
policycoreutils-python
{% else %}
policycoreutils-python-utils
{% endif %}
%end

