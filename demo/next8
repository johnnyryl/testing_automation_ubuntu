templates/partials/130-packages/workstation.ks.j2

# Package selection: workstation desktop
#
# Best for:
#   - graphical RHEL workstation installs
#   - engineering desktop baselines
#   - developer workstation profiles that do not need the broader developer package set
#
# Keep this focused on the OS workstation experience. Put site-specific software
# such as Chrome, VS Code, NVIDIA scripts, internal agents, or domain joins in
# post-install/extra sections or Ansible.
%packages
@^workstation-product-environment
@development
@graphical-admin-tools
@system-tools
@security-tools
# Common workstation/admin tools
aide
curl
git
kexec-tools
nfs-utils
podman
rsync
tmux
vim-enhanced
wget
# Identity and directory integration readiness
adcli
oddjob
oddjob-mkhomedir
realmd
sssd
{% if os_major | int == 8 %}
# RHEL 8 workstation builds commonly used gnome-apps in the older reference files.
@gnome-apps
scap-workbench
{% elif os_major | int >= 9 %}
# RHEL 9/10 reference files moved toward gnome-desktop and left gnome-apps out.
@gnome-desktop
{% endif %}
{% if os_major | int == 7 %}
# RHEL 7 uses a different policycoreutils helper package name.
policycoreutils-python
{% else %}
policycoreutils-python-utils
{% endif %}
%end

