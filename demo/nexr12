templates/partials/200-extras/proxy-enterprise.ks.j2

# Optional extra: enterprise proxy configuration
#
# This writes shell proxy variables and optional DNF/YUM proxy settings.
# Leave proxy_url empty to skip.
%post --interpreter=/bin/bash --log=/root/aerolit-proxy-enterprise.log
set -euo pipefail
PROXY_URL="{{ proxy_url | default('', true) }}"
NO_PROXY="{{ no_proxy | default('127.0.0.1,localhost', true) }}"
if [ -z "${PROXY_URL}" ]; then
  echo "No proxy_url provided. Skipping proxy configuration."
  exit 0
fi
cat > /etc/profile.d/aerolit-proxy.sh <<EOF
# Managed by AeroLIT Kickstart
export http_proxy="${PROXY_URL}"
export https_proxy="${PROXY_URL}"
export HTTP_PROXY="${PROXY_URL}"
export HTTPS_PROXY="${PROXY_URL}"
export no_proxy="${NO_PROXY}"
export NO_PROXY="${NO_PROXY}"
EOF
chmod 0644 /etc/profile.d/aerolit-proxy.sh
if [ -f /etc/dnf/dnf.conf ]; then
  if ! grep -q '^proxy=' /etc/dnf/dnf.conf; then
    echo "proxy=${PROXY_URL}" >> /etc/dnf/dnf.conf
  fi
fi
if [ -f /etc/yum.conf ]; then
  if ! grep -q '^proxy=' /etc/yum.conf; then
    echo "proxy=${PROXY_URL}" >> /etc/yum.conf
  fi
fi
echo "Configured enterprise proxy: ${PROXY_URL}"
echo "Configured no_proxy: ${NO_PROXY}"
%end

