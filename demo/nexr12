templates/partials/200-extras/banner-lockdown.ks.j2

# Optional extra: login banners and basic desktop banner configuration
#
# This adds SSH/local login banners and attempts to configure the GNOME login
# banner when dconf is available.
%post --interpreter=/bin/bash --log=/root/aerolit-banner-lockdown.log
set -euo pipefail
BANNER_TEXT="{{ banner_text | default('This system is for authorized use only. Activity may be monitored.', true) }}"
cat > /etc/issue <<EOF
${BANNER_TEXT}
EOF
cat > /etc/issue.net <<EOF
${BANNER_TEXT}
EOF
mkdir -p /etc/ssh/sshd_config.d
cat > /etc/ssh/sshd_config.d/10-aerolit-banner.conf <<EOF
# Managed by AeroLIT Kickstart
Banner /etc/issue.net
EOF
# GNOME login banner support.
# This is best-effort because minimal installs may not include dconf/GDM.
if command -v dconf >/dev/null 2>&1 || [ -d /etc/dconf/db ]; then
  mkdir -p /etc/dconf/db/gdm.d
  mkdir -p /etc/dconf/db/gdm.d/locks
  cat > /etc/dconf/db/gdm.d/01-aerolit-login-banner <<EOF
[org/gnome/login-screen]
banner-message-enable=true
banner-message-text='${BANNER_TEXT}'
disable-user-list=true
EOF
  cat > /etc/dconf/db/gdm.d/locks/01-aerolit-login-banner <<EOF
/org/gnome/login-screen/banner-message-enable
/org/gnome/login-screen/banner-message-text
/org/gnome/login-screen/disable-user-list
EOF
  dconf update || true
fi
echo "Configured local, SSH, and best-effort GNOME login banners."
%end

