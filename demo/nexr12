templates/partials/200-extras/chrony-enterprise-server.ks.j2

# Optional extra: configure enterprise Chrony/NTP servers
#
# Provide a space-separated list through chrony_servers.
# Example:
# chrony_servers: "10.10.10.10 time.example.local"
%post --interpreter=/bin/bash --log=/root/aerolit-chrony-enterprise-server.log
set -euo pipefail
CHRONY_SERVERS="{{ chrony_servers | default('', true) }}"
if [ -z "${CHRONY_SERVERS}" ]; then
  echo "No chrony_servers provided. Skipping Chrony enterprise server configuration."
  exit 0
fi
if [ ! -f /etc/chrony.conf ]; then
  echo "WARNING: /etc/chrony.conf was not found. Skipping Chrony configuration."
  exit 0
fi
cp -a /etc/chrony.conf /etc/chrony.conf.aerolit.bak
# Remove common default pool/server lines so the enterprise list is authoritative.
sed -i \
  -e '/^[[:space:]]*pool[[:space:]]/d' \
  -e '/^[[:space:]]*server[[:space:]]/d' \
  /etc/chrony.conf
{
  echo ""
  echo "# Managed by AeroLIT Kickstart"
  for server in ${CHRONY_SERVERS}; do
    echo "server ${server} iburst"
  done
} >> /etc/chrony.conf
if command -v systemctl >/dev/null 2>&1; then
  systemctl enable chronyd || true
fi
echo "Configured Chrony servers: ${CHRONY_SERVERS}"
%end

