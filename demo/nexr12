templates/partials/200-extras/domain-join.ks.j2

# Optional extra: domain join placeholder
#
# Recommended approach:
#   Use Ansible after install for real domain join logic.
#
# This Kickstart partial creates a helper script at:
#   /root/aerolit-domain-join.sh
#
# It does not automatically join the domain unless explicitly enabled.
%post --interpreter=/bin/bash --log=/root/aerolit-domain-join-placeholder.log
set -euo pipefail
DOMAIN="{{ domain_name | default('', true) }}"
JOIN_USER="{{ domain_join_user | default('', true) }}"
AUTO_JOIN="{{ domain_join_enabled | default('false', true) }}"
cat > /root/aerolit-domain-join.sh <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
DOMAIN="${1:-}"
JOIN_USER="${2:-}"
if [ -z "${DOMAIN}" ] || [ -z "${JOIN_USER}" ]; then
  echo "Usage: $0 <domain> <join-user>"
  echo "Example: $0 example.com admin_user"
  exit 1
fi
if ! command -v realm >/dev/null 2>&1; then
  echo "ERROR: realm command not found. Install realmd and required packages first."
  exit 1
fi
echo "Discovering domain: ${DOMAIN}"
realm discover "${DOMAIN}"
echo "Joining domain: ${DOMAIN}"
echo "You will be prompted for the domain join password."
realm join --user="${JOIN_USER}" "${DOMAIN}"
echo "Domain join complete."
realm list
EOF
chmod 0700 /root/aerolit-domain-join.sh
echo "Created /root/aerolit-domain-join.sh"
if [ "${AUTO_JOIN}" = "true" ]; then
  echo "domain_join_enabled=true was set, but automatic domain join is intentionally not performed by this placeholder."
  echo "Run /root/aerolit-domain-join.sh after install or move domain join into Ansible."
fi
%end

