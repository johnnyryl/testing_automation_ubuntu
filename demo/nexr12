templates/partials/200-extras/ad-sudo-group.ks.j2

# Optional extra: AD / enterprise sudo group
#
# This creates a sudoers drop-in for an enterprise/admin group.
# It does not create the group or join the system to a domain.
%post --interpreter=/bin/bash --log=/root/aerolit-ad-sudo-group.log
set -euo pipefail
SUDO_GROUP="{{ ad_sudo_group | default('', true) }}"
if [ -z "${SUDO_GROUP}" ]; then
  echo "No ad_sudo_group was provided. Skipping sudo group configuration."
  exit 0
fi
mkdir -p /etc/sudoers.d
cat > /etc/sudoers.d/aerolit-ad-sudo-group <<EOF
# Managed by AeroLIT Kickstart
%${SUDO_GROUP} ALL=(ALL) ALL
EOF
chmod 0440 /etc/sudoers.d/aerolit-ad-sudo-group
if command -v visudo >/dev/null 2>&1; then
  visudo -cf /etc/sudoers.d/aerolit-ad-sudo-group
fi
echo "Configured sudo access for group: ${SUDO_GROUP}"
%end

