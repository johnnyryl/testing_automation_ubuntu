templates/partials/200-extras/chrome-vscode-install.ks.j2

# Optional extra: install Chrome and VS Code
#
# This assumes the packages are already available from configured repositories.
# It intentionally does not add public internet repositories.
%post --interpreter=/bin/bash --log=/root/aerolit-chrome-vscode-install.log
set -euo pipefail
PKG_MGR="dnf"
if ! command -v dnf >/dev/null 2>&1 && command -v yum >/dev/null 2>&1; then
  PKG_MGR="yum"
fi
INSTALL_PACKAGES="{{ gui_tool_packages | default('google-chrome-stable code', true) }}"
if [ -z "${INSTALL_PACKAGES}" ]; then
  echo "No gui_tool_packages provided. Skipping Chrome/VS Code install."
  exit 0
fi
echo "Attempting to install GUI tool packages: ${INSTALL_PACKAGES}"
if ${PKG_MGR} -y install ${INSTALL_PACKAGES}; then
  echo "GUI tool package install completed."
else
  echo "WARNING: One or more GUI tool packages could not be installed."
  echo "Make sure the needed RPMs/repos are available in the offline environment."
fi
%end

