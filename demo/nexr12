templates/partials/200-extras/disable-bluetooth.ks.j2

# Optional extra: disable Bluetooth
#
# Useful for hardened or workstation-controlled environments where Bluetooth
# is not allowed.
%post --interpreter=/bin/bash --log=/root/aerolit-disable-bluetooth.log
set -euo pipefail
mkdir -p /etc/modprobe.d
cat > /etc/modprobe.d/aerolit-disable-bluetooth.conf <<EOF
# Managed by AeroLIT Kickstart
install bluetooth /bin/true
blacklist bluetooth
blacklist btusb
EOF
if command -v systemctl >/dev/null 2>&1; then
  systemctl disable bluetooth.service >/dev/null 2>&1 || true
  systemctl mask bluetooth.service >/dev/null 2>&1 || true
fi
echo "Bluetooth kernel modules and service disabled where applicable."
%end

