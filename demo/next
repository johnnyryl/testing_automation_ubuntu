Here’s the next part: the developer workstation Kickstart template set.

Create this new folder first:

mkdir -p templates/partials/workstation

Then add these files.

templates/partials/workstation/eula.ks.j2

# License agreement
eula --agreed

templates/partials/workstation/install-mode-graphical.ks.j2

# Use graphical install for workstation builds.
graphical

templates/partials/workstation/repos-rhel-media.ks.j2

# Use the PXE-served extracted ISO tree as install media.
{% if os_major|int >= 8 %}
url --url="{{ repo_url }}/BaseOS/"
repo --name="appstream" --baseurl="{{ repo_url }}/AppStream/"
{% else %}
url --url="{{ repo_url }}/"
{% endif %}

templates/partials/workstation/language-keyboard-timezone.ks.j2

# Locale, keyboard, and timezone.
lang en_US.UTF-8
keyboard --vckeymap=us --xlayouts='us'
timezone America/Chicago --utc

templates/partials/workstation/network-dhcp.ks.j2

# Use DHCP on the first connected network device.
network --bootproto=dhcp --device=link --activate

templates/partials/workstation/root-password.ks.j2

# Root password.
rootpw --iscrypted {{ rootpw_hash }}

templates/partials/workstation/security-basics.ks.j2

# Basic security posture.
firstboot --disable
selinux --enforcing
firewall --enabled --service=ssh
services --enabled=sshd,chronyd

templates/partials/workstation/firstboot-reboot.ks.j2

# Reboot automatically after installation.
reboot

templates/partials/workstation/storage-workstation-lvm.ks.j2

# Dynamic workstation storage layout.
#
# This writes /tmp/part.conf during %pre and then includes it.
# It supports:
# - /dev/sdX
# - /dev/vdX
# - /dev/nvmeXnY
# - UEFI and legacy BIOS
# - one-disk systems
# - two-disk systems, with /data placed on the second disk
%pre --interpreter=/bin/bash --log=/tmp/aerolit-storage-pre.log
set -o pipefail
PART_CONFIG=/tmp/part.conf
: > "$PART_CONFIG"
DISK_LIST=$(
  lsblk -dn -b -o NAME,TYPE,SIZE,RM \
    | awk '$2 == "disk" && $4 == 0 { print $1, $3 }' \
    | sort -k2,2nr \
    | awk '{ print $1 }'
)
PRIMARY_DISK=$(printf '%s\n' "$DISK_LIST" | sed -n '1p')
SECONDARY_DISK=$(printf '%s\n' "$DISK_LIST" | sed -n '2p')
NUM_DISKS=$(printf '%s\n' "$DISK_LIST" | grep -c . || true)
if [ -z "$PRIMARY_DISK" ]; then
  echo "ERROR: No suitable install disk found." > /dev/tty1
  sleep 10
  reboot
fi
PR_D=$(basename "$PRIMARY_DISK")
if [ -n "$SECONDARY_DISK" ]; then
  SE_D=$(basename "$SECONDARY_DISK")
  DLIST="$PR_D,$SE_D"
else
  SE_D=""
  DLIST="$PR_D"
fi
echo "ignoredisk --only-use=$DLIST" >> "$PART_CONFIG"
echo "zerombr" >> "$PART_CONFIG"
echo "clearpart --all --initlabel --drives=$DLIST" >> "$PART_CONFIG"
echo "bootloader --append=\"crashkernel=auto\" --boot-drive=$PR_D" >> "$PART_CONFIG"
if [ -d /sys/firmware/efi ]; then
  echo "part /boot/efi --fstype=\"efi\" --ondisk=$PR_D --size=500 --fsoptions=\"umask=0077,shortname=winnt\"" >> "$PART_CONFIG"
else
  echo "part biosboot --fstype=\"biosboot\" --ondisk=$PR_D --size=1" >> "$PART_CONFIG"
fi
echo "part /boot --fstype=\"ext4\" --ondisk=$PR_D --size=1024" >> "$PART_CONFIG"
echo "part pv.01 --fstype=\"lvmpv\" --ondisk=$PR_D --size=1 --grow" >> "$PART_CONFIG"
if [ "$NUM_DISKS" -gt 1 ] && [ -n "$SE_D" ]; then
  echo "part pv.02 --fstype=\"lvmpv\" --ondisk=$SE_D --size=1 --grow" >> "$PART_CONFIG"
fi
echo "volgroup rootvg --pesize=4096 pv.01" >> "$PART_CONFIG"
if [ "$NUM_DISKS" -gt 1 ] && [ -n "$SE_D" ]; then
  echo "volgroup localvg --pesize=4096 pv.02" >> "$PART_CONFIG"
fi
echo "logvol / --fstype=\"ext4\" --size=1 --grow --name=root --vgname=rootvg" >> "$PART_CONFIG"
echo "logvol /home --fstype=\"ext4\" --size=20480 --name=home --vgname=rootvg" >> "$PART_CONFIG"
echo "logvol /tmp --fstype=\"ext4\" --size=15360 --name=tmp --vgname=rootvg" >> "$PART_CONFIG"
echo "logvol /var --fstype=\"ext4\" --size=15360 --name=var --vgname=rootvg" >> "$PART_CONFIG"
echo "logvol /var/log --fstype=\"ext4\" --size=20480 --name=log --vgname=rootvg" >> "$PART_CONFIG"
echo "logvol /var/log/audit --fstype=\"ext4\" --size=20480 --name=audit --vgname=rootvg" >> "$PART_CONFIG"
echo "logvol /var/tmp --fstype=\"ext4\" --size=5120 --name=vtmp --vgname=rootvg" >> "$PART_CONFIG"
if [ "$NUM_DISKS" -gt 1 ] && [ -n "$SE_D" ]; then
  echo "logvol /data --fstype=\"ext4\" --size=1 --grow --name=data --vgname=localvg" >> "$PART_CONFIG"
fi
%end
%include /tmp/part.conf

templates/partials/workstation/packages-workstation.ks.j2

%packages
@^workstation-product-environment
@development
@graphical-admin-tools
@system-tools
@security-tools
kexec-tools
aide
podman
oddjob
oddjob-mkhomedir
adcli
realmd
sssd
wget
nfs-utils
%end

templates/partials/workstation/kdump-enabled.ks.j2

%addon com_redhat_kdump --enable --reserve-mb='auto'
%end

templates/partials/workstation/post-workstation-light.ks.j2

%post --interpreter=/bin/bash --log=/root/aerolit-workstation-post.log
set -o pipefail
echo "AeroLIT Developer Workstation post-install started."
if command -v systemctl >/dev/null 2>&1; then
  systemctl enable sshd || true
  systemctl enable chronyd || true
  systemctl set-default graphical.target || true
fi
mkdir -p /root/aerolit
cat > /root/aerolit/workstation-install-info.txt <<EOF
AeroLIT Developer Workstation
Generated from PXE profile: {{ profile_id }}
OS: {{ os_id }}
Install repo: {{ repo_url }}
Installed at: $(date -u)
EOF
echo "AeroLIT Developer Workstation post-install complete."
%end

Now add the shared developer workstation Kickstart.

templates/ks/developer-workstation.ks.j2

#version=RHEL{{ os_major }}
# ---------------------------------------------------------------------------
# AeroLIT Developer Workstation Kickstart
#
# This template intentionally avoids site-specific configuration.
# Environment-specific actions such as domain join, proxy setup, NVIDIA driver
# installation, internal certificates, and application installs should be
# handled later by Ansible unless they are truly required during installation.
# ---------------------------------------------------------------------------
{% include "partials/workstation/eula.ks.j2" %}
{% include "partials/workstation/install-mode-graphical.ks.j2" %}
{% include "partials/workstation/repos-rhel-media.ks.j2" %}
{% include "partials/workstation/language-keyboard-timezone.ks.j2" %}
{% include "partials/workstation/network-dhcp.ks.j2" %}
{% include "partials/workstation/root-password.ks.j2" %}
{% include "partials/workstation/security-basics.ks.j2" %}
{% include "partials/workstation/firstboot-reboot.ks.j2" %}
{% include "partials/workstation/storage-workstation-lvm.ks.j2" %}
{% include "partials/workstation/packages-workstation.ks.j2" %}
{% include "partials/workstation/kdump-enabled.ks.j2" %}
{% include "partials/workstation/post-workstation-light.ks.j2" %}

Now replace your developer workstation profile with this.

content/profiles/10-developer-workstation.yml

profile_id: developer_workstation
title: Developer Workstation Installs
install_label: Developer Workstation
menu_target: developer_workstation
implemented: true
show_in_main_menu: true
uefi: true
bios: true
supported_os:
  - rhel10
  - rhel9
  - rhel8
kickstart_template: ks/developer-workstation.ks.j2
kernel_args:
  - nomodeset

One required test update: anywhere your tests still treat developer workstation as a placeholder, remove it from the placeholder regex.

Change this:

developer-workstation|security-baseline|security-luks|embedded-edge

to this:

security-baseline|security-luks|embedded-edge

Then rebuild the test image and run:

podman run --rm --entrypoint /usr/local/bin/pxe-content-test registry.gitlab.us.lmco.com/lit/containers/pxe-content:test all

This gives you a clean first version of the developer workstation profile without dragging in the old hardcoded repo URLs, proxy setup, domain join, NVIDIA script, or other site-specific pieces.