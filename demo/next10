templates/partials/150-post/firstboot-marker.ks.j2

# Write AeroLIT install marker
%post --interpreter=/bin/bash --log=/root/aerolit-firstboot-marker-post.log
set -o pipefail
mkdir -p /root/aerolit
cat > /root/aerolit/install-info.txt <<EOF
AeroLIT PXE Install
Profile ID: {{ profile_id }}
Profile title: {{ profile_title }}
OS ID: {{ os_id }}
OS title: {{ os_title }}
Install repo: {{ repo_url }}
Kickstart URL: {{ kickstart_url }}
Installed at UTC: $(date -u)
EOF
chmod 0600 /root/aerolit/install-info.txt
%end

templates/partials/150-post/workstation-light.ks.j2

# Light workstation post-install setup
%post --interpreter=/bin/bash --log=/root/aerolit-workstation-light-post.log
set -o pipefail
mkdir -p /root/aerolit
if command -v systemctl >/dev/null 2>&1; then
    systemctl enable sshd || true
    systemctl set-default graphical.target || true
fi
cat > /root/aerolit/workstation-install-info.txt <<EOF
AeroLIT Developer Workstation
Profile ID: {{ profile_id }}
OS ID: {{ os_id }}
Install repo: {{ repo_url }}
Installed at UTC: $(date -u)
EOF
chmod 0600 /root/aerolit/workstation-install-info.txt
%end

templates/partials/150-post/ansible-handoff-placeholder.ks.j2

# Future Ansible handoff placeholder
#
# This does not run Ansible yet. It only writes a small handoff file so future
# AeroLIT automation has a predictable place to look.
%post --interpreter=/bin/bash --log=/root/aerolit-ansible-handoff-placeholder-post.log
set -o pipefail
mkdir -p /root/aerolit/handoff
cat > /root/aerolit/handoff/ansible-handoff.env <<EOF
AEROLIT_PROFILE_ID={{ profile_id }}
AEROLIT_OS_ID={{ os_id }}
AEROLIT_REPO_URL={{ repo_url }}
AEROLIT_KICKSTART_URL={{ kickstart_url }}
AEROLIT_HANDOFF_READY=false
EOF
chmod 0600 /root/aerolit/handoff/ansible-handoff.env
%end

