templates/partials/020-install-mode/_meta.yml

title: Installer mode
order: 20
required: true
selection: one
default: text
description: Chooses how the Red Hat installer interface runs during installation.
applies_to:
  os:
    - rhel7
    - rhel8
    - rhel9
    - rhel10
  profiles:
    - minimal
    - small_disk
    - developer_workstation
options:
  - id: text
    file: text.ks.j2
    title: Text installer
    description: Runs the installer in text mode. This is usually best for PXE, VMs, labs, and remote installs.
    recommended: true
    risk: low
    warning: Text mode has fewer interactive screens than graphical mode.
    requires: []
    conflicts:
      - graphical
      - cmdline
  - id: graphical
    file: graphical.ks.j2
    title: Graphical installer
    description: Runs the installer in graphical mode. This is more visual but less ideal for headless PXE workflows.
    recommended: false
    risk: low
    warning: Graphical mode may require working graphics, console access, or VNC-style access.
    requires: []
    conflicts:
      - text
      - cmdline
  - id: cmdline
    file: cmdline.ks.j2
    title: Command line installer
    description: Runs the installer in the most minimal command-line mode.
    recommended: false
    risk: medium
    warning: Use only for highly automated installs. Missing required Kickstart values can make troubleshooting harder.
    requires: []
    conflicts:
      - text
      - graphical
notes: For most AeroLIT PXE profiles, text mode is the safest default.
tags:
  - required
  - installer
  - default

