templates/partials/050-install-source/_meta.yml

title: Installation source
order: 50
required: true
selection: one
default: pxe_extracted_media
description: Tells the installer where to get the RHEL installation content.
applies_to:
  os:
    - rhel7
    - rhel8
    - rhel9
    - rhel10
  profiles:
    - minimal
    - small_disk
    - developer_workstation
options:
  - id: pxe_extracted_media
    file: pxe-extracted-media.ks.j2
    title: PXE extracted ISO tree
    description: Uses the detected AeroLIT PXE HTTP path as the installation source.
    recommended: true
    risk: low
    warning: The matching extracted ISO tree must be served over HTTP and must include the expected boot and repo content.
    requires: []
    conflicts:
      - pxe_baseos_appstream
  - id: pxe_baseos_appstream
    file: pxe-baseos-appstream.ks.j2
    title: PXE BaseOS plus AppStream
    description: Uses BaseOS as the main install source and AppStream as an additional repository for RHEL 8, 9, and 10 style media.
    recommended: false
    risk: medium
    warning: Use this only when the extracted media has BaseOS and AppStream directories. Do not use for RHEL 7.
    applies_to:
      os:
        - rhel8
        - rhel9
        - rhel10
      profiles:
        - minimal
        - small_disk
        - developer_workstation
    requires: []
    conflicts:
      - pxe_extracted_media
notes: The default pxe_extracted_media option matches the current AeroLIT generator model because repo_url points to the detected OS HTTP path.
tags:
  - required
  - repository
  - default

templates/partials/050-install-source/pxe-extracted-media.ks.j2

# Use PXE-served extracted installation media
url --url="{{ repo_url }}"

templates/partials/050-install-source/pxe-baseos-appstream.ks.j2

# Use PXE-served BaseOS and AppStream repositories
url --url="{{ repo_url }}/BaseOS"
repo --name="AppStream" --baseurl="{{ repo_url }}/AppStream"

