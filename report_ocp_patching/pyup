# ---------------------------------------------------------------------------
# Compatibility helpers
# ---------------------------------------------------------------------------
def network_is_subnet_of(network, parent):
    """Python 3.6 compatible replacement for IPv4Network.subnet_of()."""
    return network.version == parent.version and network.network_address in parent and network.broadcast_address in parent


def is_rfc1918(network):
    return any(network_is_subnet_of(network, private_network) for private_network in RFC1918_NETWORKS)


# ---------------------------------------------------------------------------
# Command helpers
# ---------------------------------------------------------------------------
def run_json(cmd):
    try:
        result = subprocess.run(
            cmd,
            check=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            universal_newlines=True,
        )
        return json.loads(result.stdout)
    except Exception:
        return []


def get_default_route():
    routes = run_json(["ip", "-j", "-4", "route", "show", "default"])
    if not routes:
        return {}
    route = routes[0]
    return {
        "dev": str(route.get("dev", "")),
        "gateway": str(route.get("gateway", "")),
    }


def get_interfaces():
    links = run_json(["ip", "-j", "link", "show"])
    addrs = run_json(["ip", "-j", "-4", "addr", "show", "scope", "global"])

    addr_map = {}
    for item in addrs:
        ifname = str(item.get("ifname", ""))
        for addr in item.get("addr_info", []):
            local = addr.get("local")
            prefixlen = addr.get("prefixlen")
            if local and prefixlen is not None:
                try:
                    parsed = ipaddress.ip_interface("{}/{}".format(local, prefixlen))
                    if isinstance(parsed, ipaddress.IPv4Interface):
                        addr_map.setdefault(ifname, []).append(parsed)
                except ValueError:
                    pass

    interfaces = []
    for link in links:
        ifname = str(link.get("ifname", ""))
        if ifname == "lo" or not ifname:
            continue
        interfaces.append(
            InterfaceInfo(
                name=ifname,
                state=str(link.get("operstate", "UNKNOWN")),
                addresses=addr_map.get(ifname, []),
            )
        )

    return interfaces


# ---------------------------------------------------------------------------
# Prompt helpers
# ---------------------------------------------------------------------------
def read_user_input(rendered_prompt):
    try:
        return input(rendered_prompt)
    except EOFError:
        raise SystemExit("ERROR: interactive input ended before the helper completed.")


def prompt(text, default=None, allow_blank=False, blank_label="blank"):
    if default not in (None, ""):
        suffix = " [default: {}; Enter=default]".format(default)
    elif allow_blank:
        suffix = " [Enter={}]".format(blank_label)
    else:
        suffix = ""

    while True:
        value = read_user_input("{}{}: ".format(text, suffix)).strip()
        if value == "" and default is not None:
            return default
        if value == "" and allow_blank:
            return ""
        if value != "":
            return value
        print("This value is required. Enter a value or press Ctrl+C to cancel.")


def yes_no(text, default=True):
    default_text = "Y/n; Enter=Y" if default else "y/N; Enter=N"
    while True:
        value = read_user_input("{} [{}]: ".format(text, default_text)).strip().lower()
        if value == "":
            return default
        if value in {"y", "yes"}:
            return True
        if value in {"n", "no"}:
            return False
        print("Please answer yes or no. Valid responses are: y, yes, n, no. Press Enter for the default.")


def choose(text, options, default_index=0):
    if not options:
        raise ValueError("choose() requires at least one option")

    default_index = max(0, min(default_index, len(options) - 1))
    print()
    print(text)
    for idx, option in enumerate(options, start=1):
        marker = "* " if idx - 1 == default_index else "  "
        print("{}{}) {}".format(marker, idx, option))

    while True:
        value = read_user_input(
            "Choose 1-{} [default: {}; Enter=default]: ".format(len(options), default_index + 1)
        ).strip()
        if value == "":
            return default_index
        if value.isdigit():
            parsed = int(value)
            if 1 <= parsed <= len(options):
                return parsed - 1
        print("Invalid selection: {}. Choose a number from 1 through {}, or press Enter for the default.".format(value or "<blank>", len(options)))


def prompt_int(text, default, minimum=1, maximum=None):
    while True:
        value = prompt(text, str(default))
        try:
            parsed = int(value)
        except ValueError:
            parsed = minimum - 1

        if parsed < minimum:
            if maximum is None:
                print("Invalid value: {}. Enter a whole number greater than or equal to {}.".format(value, minimum))
            else:
                print("Invalid value: {}. Enter a whole number between {} and {}.".format(value, minimum, maximum))
            continue

        if maximum is not None and parsed > maximum:
            print("Invalid value: {}. Enter a whole number between {} and {}.".format(value, minimum, maximum))
            continue

        return parsed


