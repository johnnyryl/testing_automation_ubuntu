# ---------------------------------------------------------------------------
# IP math helpers
# ---------------------------------------------------------------------------
def dotted_netmask(network):
    return str(network.netmask)


def usable_host_bounds(network):
    """Return normal first/last usable host integer values without expanding hosts()."""
    if network.prefixlen >= 31:
        first = int(network.network_address)
        last = int(network.broadcast_address)
    else:
        first = int(network.network_address) + 1
        last = int(network.broadcast_address) - 1
    return first, last


def usable_host_count(network):
    first, last = usable_host_bounds(network)
    return max(last - first + 1, 0)


def default_server_ip(network):
    first, last = usable_host_bounds(network)
    if first > last:
        raise SystemExit("Network {} has no usable host addresses.".format(network))

    preferred_host_numbers = [10, 5, 2, 1]
    for host_number in preferred_host_numbers:
        candidate = int(network.network_address) + host_number
        if first <= candidate <= last:
            return ipaddress.ip_address(candidate)

    return ipaddress.ip_address(first)


def subtract_reserved_from_ranges(ranges, reserved_values):
    result = ranges[:]
    for reserved in sorted(reserved_values):
        next_result = []
        for start, end in result:
            if reserved < start or reserved > end:
                next_result.append((start, end))
                continue
            if start <= reserved - 1:
                next_result.append((start, reserved - 1))
            if reserved + 1 <= end:
                next_result.append((reserved + 1, end))
        result = next_result
    return result


def available_dhcp_ranges(network, server_ip, gateway_ip=None):
    first, last = usable_host_bounds(network)
    if first > last:
        return []

    reserved = {int(server_ip)}
    if gateway_ip is not None:
        reserved.add(int(gateway_ip))

    return subtract_reserved_from_ranges([(first, last)], reserved)


def max_dhcp_clients(network, server_ip, gateway_ip=None):
    """Return the largest single DHCP pool this helper can generate.

    dnsmasq is being configured with one start/end range, so the usable maximum
    is the largest contiguous range after reserving the server/gateway IPs, not
    the sum of separate ranges split around a reserved address.
    """
    ranges = available_dhcp_ranges(network, server_ip, gateway_ip)
    if not ranges:
        return 0
    return max(end - start + 1 for start, end in ranges)


def suggest_dhcp_range(network, server_ip, requested_clients, gateway_ip=None):
    ranges = available_dhcp_ranges(network, server_ip, gateway_ip)
    if not ranges:
        raise SystemExit("Network {} is too small for a PXE/DHCP range.".format(network))

    def range_len(item):
        return item[1] - item[0] + 1

    max_contiguous = max(range_len(item) for item in ranges)
    if max_contiguous < 1:
        raise SystemExit("Network {} is too small for a PXE/DHCP range.".format(network))

    target_size = min(requested_clients, max_contiguous)
    preferred_starts = [100, 50, 20, 2, 1]

    # Prefer easy-to-read starts like .100 when there is enough contiguous space
    # for exactly the requested number of DHCP client addresses.
    for host_number in preferred_starts:
        candidate_start = int(network.network_address) + host_number
        candidate_end = candidate_start + target_size - 1
        for range_start, range_end in ranges:
            if range_start <= candidate_start <= range_end and candidate_end <= range_end:
                return ipaddress.ip_address(candidate_start), ipaddress.ip_address(candidate_end)

    # Otherwise use the largest contiguous range. This should rarely be needed,
    # but keeps the helper usable with unusual reserved addresses.
    best_start, best_end = max(ranges, key=range_len)
    end = min(best_end, best_start + target_size - 1)
    return ipaddress.ip_address(best_start), ipaddress.ip_address(end)


def parse_gateway_ip(value, network):
    if not value or value.lower() == "none":
        return None
    parsed = parse_ipv4(value)
    if parsed and parsed in network:
        return parsed
    return None


def prompt_dhcp_range(network, server_ip, gateway_ip):
    max_clients = max_dhcp_clients(network, server_ip, gateway_ip)
    if max_clients < 1:
        raise SystemExit("Network {} is too small for a DHCP range after reserving the server/gateway IPs.".format(network))

    print()
    print("The DHCP range is the pool of IPs PXE/provisioned clients will receive.")
    print("The number you enter here becomes the actual DHCP pool size.")
    print("Example: entering 75 means the helper suggests 75 DHCP client addresses.")
    print("Maximum available client addresses in this subnet after reservations: {}".format(max_clients))

    client_count = prompt_int(
        "How many machines should the DHCP range support?",
        min(50, max_clients),
        1,
        max_clients,
    )
    suggested_start, suggested_end = suggest_dhcp_range(network, server_ip, client_count, gateway_ip)

    reserved = {server_ip}
    if gateway_ip is not None:
        reserved.add(gateway_ip)

    print()
    print("Suggested DHCP pool for {} client address(es): {} - {}".format(client_count, suggested_start, suggested_end))
    print("Press Enter to accept each suggested value, or type a different IP inside {}.".format(network))

    while True:
        dhcp_start = prompt_ip(
            "DHCP range start",
            str(suggested_start),
            network,
            reserved=reserved,
            reserved_label="the server or gateway",
        )
        dhcp_end = prompt_ip(
            "DHCP range end",
            str(suggested_end),
            network,
            reserved=reserved,
            reserved_label="the server or gateway",
        )

        if int(dhcp_end) < int(dhcp_start):
            print("Invalid DHCP range: the end address must be greater than or equal to the start address.")
            print("Re-enter the DHCP range.")
            continue

        actual_size = int(dhcp_end) - int(dhcp_start) + 1
        if actual_size != client_count:
            print("WARNING: this DHCP range contains {} address(es), but you requested {}.".format(actual_size, client_count))
            if not yes_no("Keep this DHCP range anyway?", False):
                continue

        if dhcp_start <= server_ip <= dhcp_end:
            print("Invalid DHCP range: it includes the PXE/NFS server IP {}.".format(server_ip))
            print("The DHCP pool should only contain client addresses. Re-enter the DHCP range.")
            continue

        if gateway_ip is not None and dhcp_start <= gateway_ip <= dhcp_end:
            print("Invalid DHCP range: it includes the gateway IP {}.".format(gateway_ip))
            print("The DHCP pool should only contain client addresses. Re-enter the DHCP range.")
            continue

        return dhcp_start, dhcp_end


# ---------------------------------------------------------------------------
# Formatting and file helpers
# ---------------------------------------------------------------------------
def sh_quote(value):
    if value == "":
        return "''"
    safe = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789._/:=-"
    if all(char in safe for char in value):
        return value
    return "'" + value.replace("'", "'\"'\"'") + "'"


def format_command(command_path, args):
    pieces = [sh_quote(command_path)]
    for flag, value in args:
        if value is None:
            pieces.append(flag)
        else:
            pieces.append("{} {}".format(flag, sh_quote(value)))

    if len(pieces) == 1:
        return pieces[0]

    lines = [pieces[0] + " \\"]
    for idx, piece in enumerate(pieces[1:], start=1):
        continuation = " \\" if idx < len(pieces) - 1 else ""
        lines.append("  {}{}".format(piece, continuation))
    return "\n".join(lines)


def next_available_path(directory, filename):
    base, ext = os.path.splitext(filename)
    candidate = os.path.join(directory, filename)
    if not os.path.exists(candidate):
        return candidate

    counter = 2
    while True:
        candidate = os.path.join(directory, "{}-{}{}".format(base, counter, ext))
        if not os.path.exists(candidate):
            return candidate
        counter += 1


def write_executable_script(path, body):
    with open(path, "w", encoding="utf-8") as handle:
        handle.write(body)
    os.chmod(path, 0o755)


def default_bootstrap_path(script_dir):
    return os.path.abspath(os.path.join(script_dir, "..", "..", "bootstrap.sh"))


def is_likely_virtual_interface(name):
    lowered = name.lower()
    if lowered in {"virbr0", "docker0"}:
        return True
    return lowered.startswith(LIKELY_NON_PXE_PREFIXES)


def find_default_interface_index(interfaces, default_dev):
    for idx, interface in enumerate(interfaces):
        if interface.name == default_dev and not is_likely_virtual_interface(interface.name):
            return idx
    for idx, interface in enumerate(interfaces):
        if interface.addresses and not is_likely_virtual_interface(interface.name):
            return idx
    for idx, interface in enumerate(interfaces):
        if interface.name == default_dev:
            return idx
    for idx, interface in enumerate(interfaces):
        if interface.addresses:
            return idx
    return 0


def print_interface_summary(interfaces):
    labels = []
    for interface in interfaces:
        if interface.addresses:
            addr_text = ", ".join(str(addr) for addr in interface.addresses)
        else:
            addr_text = "no IPv4 address detected"

        extra = ""
        if is_likely_virtual_interface(interface.name):
            extra = "  (likely virtual/container interface; usually not for physical PXE)"

        labels.append("{}  state={}  {}{}".format(interface.name, interface.state, addr_text, extra))
    return labels


def format_nmcli_setup(interface_name, server_interface):
    address = str(server_interface)
    con_name = "aerolit-provisioning-{}".format(interface_name)
    return """#!/usr/bin/env bash
# UNCLASSIFIED

set -Eeuo pipefail

# Configure the selected interface with the planned AeroLIT PXE/NFS IP.
# Review this script before running it.
#
# Interface : {interface_name}
# Address   : {address}
#
# If an active NetworkManager connection exists for the interface, this script
# adds the planned address to that connection. If no connection is detected, it
# creates a simple manual connection.
#
# Running nmcli con up can briefly bounce the connection. If this is a remote
# SSH session on the same interface, review carefully or run from console access.

run_as_root() {{
  if [[ "${{EUID}}" -eq 0 ]]; then
    "$@"
  else
    sudo "$@"
  fi
}}

CONNECTION_NAME="$(nmcli -g GENERAL.CONNECTION device show {interface_name} 2>/dev/null | head -n 1 || true)"

if [[ -z "${{CONNECTION_NAME}}" || "${{CONNECTION_NAME}}" == "--" ]]; then
  run_as_root nmcli con add type ethernet ifname {interface_name} con-name {con_name} \\
    ipv4.method manual ipv4.addresses {address} autoconnect yes
  run_as_root nmcli con up {con_name}
else
  run_as_root nmcli con mod "${{CONNECTION_NAME}}" +ipv4.addresses {address}
  run_as_root nmcli con up "${{CONNECTION_NAME}}"
fi

ip -br addr show {interface_name}

# UNCLASSIFIED
""".format(
        interface_name=sh_quote(interface_name),
        con_name=sh_quote(con_name),
        address=sh_quote(address),
    )


def append_passthrough_args(command):
    """Append "$@" to a generated shell command safely.

    This lets the generated aerolit_network_bootstrap.sh script accept any
    additional bootstrap.sh options at runtime, such as --verbose or
    --skip-ansible-install, without editing the generated script.
    """
    lines = command.splitlines()
    if not lines:
        return '"$@"'

    # Ensure the current final command line continues, then add "$@" as the
    # actual final argument. If no arguments are passed to the wrapper script,
    # "$@" expands to nothing.
    lines[-1] = lines[-1] + " \\"
    lines.append('  "$@"')
    return "\n".join(lines)


def format_bootstrap_script(command):
    command_with_passthrough = append_passthrough_args(command)
    return """#!/usr/bin/env bash
# UNCLASSIFIED

set -Eeuo pipefail

# Generated AeroLIT bootstrap command.
#
# Any options passed to this wrapper are forwarded to bootstrap.sh after the
# generated network options. This lets you add normal bootstrap options without
# editing this file, for example:
#   {script_name} --epel-approved true --verbose --skip-ansible-install
#
# Avoid passing duplicate PXE/NFS network options unless you intentionally want
# to override the generated network plan.
{command}

# UNCLASSIFIED
""".format(script_name="$0", command=command_with_passthrough)


