def choose_run_mode():
    print()
    print("First choose what this generated bootstrap command should set up.")
    print("The full setup is the normal all-in-one lab path: PXE server plus Ansible controller/NFS.")
    options = [
        "Full setup: PXE server + Ansible controller/NFS",
        "PXE server only",
        "Ansible controller/NFS only",
    ]
    choice = choose("What do you want this bootstrap command to set up?", options, 0)
    if choice == 0:
        return RunMode(run_pxe=True, run_controller=True)
    if choice == 1:
        return RunMode(run_pxe=True, run_controller=False)
    return RunMode(run_pxe=False, run_controller=True)


def choose_interface(interfaces, default_route):
    print()
    print("Now choose the network interface that provisioning clients will use to reach this host.")
    print("For physical PXE, this is usually a real Ethernet interface connected to the lab/provisioning network.")

    default_idx = find_default_interface_index(interfaces, default_route.get("dev", ""))
    while True:
        selected_idx = choose(
            "Select the interface that PXE/NFS/provisioning clients will connect to:",
            print_interface_summary(interfaces),
            default_idx,
        )
        selected = interfaces[selected_idx]
        if is_likely_virtual_interface(selected.name):
            print()
            print("WARNING: {} looks like a virtual/container interface.".format(selected.name))
            print("That is usually not the right interface for physical PXE clients.")
            if not yes_no("Use this interface anyway?", False):
                continue
        if selected.state.upper() not in {"UP", "UNKNOWN"}:
            print()
            print("WARNING: interface {} is currently state={}.".format(selected.name, selected.state))
            print("That may be fine if you plan to plug it in or let NetworkManager bring it up, but PXE/NFS will not work while it is down.")
            if not yes_no("Use this interface anyway?", False):
                continue
        return selected


def prompt_server_ip(default_ip, network, run_mode):
    print()
    if run_mode.run_pxe and run_mode.run_controller:
        label = "AeroLIT/PXE/NFS host"
    elif run_mode.run_pxe:
        label = "AeroLIT/PXE host"
    else:
        label = "AeroLIT/NFS host"

    print("Choose the IP address this {} will use on the client/provisioning network.".format(label))
    print("Press Enter to accept the default shown in brackets, or type another IP inside {}.".format(network))
    return prompt_ip("Server IP for this host", str(default_ip), network)


def choose_network(selected, default_route, run_mode):
    current_addr = selected.addresses[0] if selected.addresses else None

    print()
    print("Now choose the network/subnet that provisioning clients will use.")
    print("For a simple isolated lab, choosing a dedicated lab subnet is usually safer than using a shared network.")

    mode_options = [
        "Use this interface's current IPv4 subnet",
        "Plan an isolated lab/provisioning subnet",
        "Custom subnet",
    ]
    default_mode = 0 if current_addr else 1

    while True:
        mode = choose("What kind of network should clients use?", mode_options, default_mode)
        isolated_or_custom = mode in {1, 2}

        if mode == 0:
            if current_addr is None:
                print("The selected interface does not have an IPv4 address, so its current subnet cannot be used.")
                print("Choose an isolated lab/provisioning subnet or a custom subnet instead.")
                default_mode = 1
                continue

            network = current_addr.network
            if run_mode.run_pxe and not require_pxe_sized_network(network):
                print("The current subnet is too small for PXE/DHCP: {}.".format(network_size_reason(network)))
                print("Choose an isolated lab/provisioning subnet or a larger custom subnet instead.")
                default_mode = 1
                continue

            if run_mode.run_pxe:
                print()
                print("WARNING: using PXE/DHCP on an existing shared network can accidentally hand out addresses to machines that should not use AeroLIT.")
                print("Only do this on a lab VLAN, isolated switch, direct-cable connection, or an approved provisioning network.")
                if not yes_no("Continue with this existing subnet?", False):
                    default_mode = 1
                    continue

            use_current = yes_no("Use current interface IP {} as the server IP for this host?".format(current_addr.ip), True)
            if use_current:
                server_ip = current_addr.ip
            else:
                server_ip = prompt_server_ip(current_addr.ip, network, run_mode)
            return network, server_ip, current_addr, False

        if mode == 1:
            print()
            print("Pick a private lab/provisioning subnet. Avoid choosing a subnet already used elsewhere on your network.")
            options = ["{:<18} {}".format(cidr, description) for cidr, description in PRIVATE_LAB_NETWORKS]
            options.append("Custom private subnet")
            choice = choose("Pick a lab/provisioning subnet:", options, 0)
            if choice < len(PRIVATE_LAB_NETWORKS):
                network = ipaddress.ip_network(PRIVATE_LAB_NETWORKS[choice][0])
            else:
                network = prompt_network(
                    "Custom private network CIDR",
                    "192.168.109.0/24",
                    require_private=True,
                    require_pxe_size=run_mode.run_pxe,
                )
            server_ip = prompt_server_ip(default_server_ip(network), network, run_mode)
            return network, server_ip, current_addr, True

        network = prompt_network(
            "Custom network CIDR",
            "192.168.109.0/24",
            require_private=False,
            require_pxe_size=run_mode.run_pxe,
        )
        if not is_rfc1918(network):
            print("WARNING: {} is not private RFC1918 address space.".format(network))
            print("That is unusual for a lab/provisioning network. Make sure this is intentional and approved.")
            if not yes_no("Use this non-private network anyway?", False):
                continue
        server_ip = prompt_server_ip(default_server_ip(network), network, run_mode)
        return network, server_ip, current_addr, True


def choose_gateway(network, default_route, isolated_or_custom, server_ip):
    default_gateway = "none"
    route_gateway = default_route.get("gateway", "")
    parsed_route_gateway = parse_ipv4(route_gateway)
    if not isolated_or_custom and parsed_route_gateway and parsed_route_gateway in network and parsed_route_gateway != server_ip:
        default_gateway = str(parsed_route_gateway)

    print()
    if isolated_or_custom:
        print("For isolated PXE labs, 'none' is usually correct because clients only need to reach this AeroLIT host during provisioning.")
    else:
        print("The PXE gateway is what DHCP advertises to clients as their router/default gateway.")

    if yes_no("Use PXE gateway '{}'?".format(default_gateway), True):
        return default_gateway
    return prompt_gateway(default_gateway, network, server_ip)


def choose_dns_servers(default_gateway, server_ip):
    dns_values = []

    print()
    print("DNS is optional for most isolated PXE lab tests.")
    print("This helper does NOT set up a DNS service; it only advertises existing DNS server IPs through DHCP.")
    print("Choose 'no' if clients will use direct IP addresses for PXE, Kickstart, repos, and NFS.")
    print("Choose 'yes' only if clients need to resolve hostnames like repo-server.example.com.")

    if not yes_no("Advertise existing DNS servers to PXE clients?", False):
        return dns_values

    if default_gateway != "none":
        print()
        print("On some normal networks, the gateway/router is also the DNS server.")
        if yes_no("Advertise gateway {} as a DNS server?".format(default_gateway), False):
            dns_values.append(default_gateway)
    else:
        print()
        print("No PXE gateway was selected, so the helper will not suggest a gateway/router as DNS.")

    print()
    print("Only advertise the AeroLIT/PXE/NFS host as DNS if this host is already running a DNS service.")
    if yes_no("Advertise {} as a DNS server?".format(server_ip), False):
        dns_values.append(str(server_ip))

    print()
    print("Add any other existing DNS server IPs one at a time. Press Enter when done.")
    while True:
        value = prompt_dns_server(dns_values)
        if value == "":
            break
        dns_values.append(value)

    return dns_values


def choose_nfs_options(network, server_ip):
    print()
    print("NFS is used so provisioned machines can mount/use the AeroLIT bundle content.")
    print("For the normal all-in-one setup, the same host provides PXE, NFS, and the Ansible/controller content.")
    print("The server IP selected for this host is: {}".format(server_ip))

    same_nfs = yes_no("Use this same AeroLIT/PXE host IP as the NFS server too?", True)
    if same_nfs:
        nfs_server_ip = server_ip
    else:
        print()
        print("Only choose a different NFS server IP if the NFS export will live on another machine or another reachable interface/IP.")
        nfs_server_ip = prompt_ip("NFS server IP clients should mount from", str(server_ip), None)
        if nfs_server_ip not in network:
            print()
            print("WARNING: NFS server IP {} is not inside the selected client network {}.".format(nfs_server_ip, network))
            print("That can work only if PXE/provisioned clients have routing to the NFS server.")
            if not yes_no("Keep this different NFS server IP anyway?", False):
                nfs_server_ip = prompt_ip("NFS server IP clients should mount from", str(server_ip), network)

    print()
    print("Now choose which clients are allowed to mount the NFS export.")
    print("For a normal isolated provisioning network, allowing this subnet is usually correct: {}".format(network))

    nfs_choice = choose(
        "Who should be allowed to mount the NFS export?",
        [
            "Only clients on this provisioning subnet: {}".format(network),
            "Custom CIDR or single client IP",
            "Allow all clients (easy lab test, least restrictive)",
        ],
        0,
    )

    if nfs_choice == 0:
        return nfs_server_ip, str(network), False
    if nfs_choice == 1:
        custom = prompt_nfs_client_spec(str(network))
        return nfs_server_ip, custom, False

    print()
    print("WARNING: --nfs-allow-all-clients is convenient for a quick lab, but it is too broad for long-term use.")
    if not yes_no("Use --nfs-allow-all-clients anyway?", False):
        custom = prompt_nfs_client_spec(str(network))
        return nfs_server_ip, custom, False
    return nfs_server_ip, None, True


def choose_http_port():
    print()
    print("PXE content is served over HTTP by the pxe-content container.")
    print("Port {} is the AeroLIT default and is usually fine unless it conflicts with another service.".format(DEFAULT_HTTP_PORT))
    if yes_no("Use default PXE HTTP port {}?".format(DEFAULT_HTTP_PORT), True):
        return DEFAULT_HTTP_PORT
    return prompt_int("PXE HTTP port", DEFAULT_HTTP_PORT, 1, 65535)


def choose_interface_script_generation(selected, server_interface):
    print()
    print("The selected interface does not currently have the planned server IP:")
    print("  interface : {}".format(selected.name))
    print("  planned IP: {}".format(server_interface))
    if selected.addresses:
        print("  current IPs: " + ", ".join(str(addr) for addr in selected.addresses))
    else:
        print("  current IPs: none detected")
    print()
    print("Before PXE/NFS will work, this host needs the planned IP on the selected interface.")
    print("The helper can generate a separate reviewable nmcli script that adds this IP.")
    print("That interface script will be written and made executable, but it will not run automatically.")
    return yes_no("Generate a separate nmcli interface setup script?", True)


def build_plan(run_mode, selected, default_route):
    network, server_ip, current_addr, isolated_or_custom = choose_network(selected, default_route, run_mode)

    dhcp_start = None
    dhcp_end = None
    gateway = None
    dns_servers = []
    pxe_http_port = DEFAULT_HTTP_PORT

    if run_mode.run_pxe:
        pxe_http_port = choose_http_port()
        gateway = choose_gateway(network, default_route, isolated_or_custom, server_ip)
        gateway_ip = parse_gateway_ip(gateway, network)
        dhcp_start, dhcp_end = prompt_dhcp_range(network, server_ip, gateway_ip)
        dns_servers = choose_dns_servers(gateway, server_ip)

    nfs_server_ip = None
    nfs_allow_clients = None
    nfs_allow_all_clients = False
    if run_mode.run_controller:
        nfs_server_ip, nfs_allow_clients, nfs_allow_all_clients = choose_nfs_options(network, server_ip)

    generate_interface_script = False
    server_interface = ipaddress.ip_interface("{}/{}".format(server_ip, network.prefixlen))
    existing_ips = {addr.ip for addr in selected.addresses}
    interface_needs_ip = server_ip not in existing_ips
    if interface_needs_ip:
        generate_interface_script = choose_interface_script_generation(selected, server_interface)

    return NetworkPlan(
        interface_name=selected.name,
        interface_current_addr=current_addr,
        network=network,
        server_ip=server_ip,
        dhcp_start=dhcp_start,
        dhcp_end=dhcp_end,
        gateway=gateway,
        dns_servers=dns_servers,
        nfs_server_ip=nfs_server_ip,
        nfs_allow_clients=nfs_allow_clients,
        nfs_allow_all_clients=nfs_allow_all_clients,
        pxe_http_port=pxe_http_port,
        interface_needs_ip=interface_needs_ip,
        generate_interface_script=generate_interface_script,
    )


def command_args_from_plan(run_mode, plan):
    cmd_args = []

    if not run_mode.run_pxe:
        cmd_args.append(("--skip-pxe", None))
    if not run_mode.run_controller:
        cmd_args.append(("--skip-controller", None))

    if run_mode.run_pxe:
        if not plan.interface_name:
            raise SystemExit("ERROR: PXE mode requires an interface.")
        if plan.dhcp_start is None or plan.dhcp_end is None:
            raise SystemExit("ERROR: PXE mode requires a DHCP range.")
        cmd_args.extend(
            [
                ("--pxe-server-ip", str(plan.server_ip)),
                ("--pxe-http-port", str(plan.pxe_http_port)),
                ("--pxe-interface", plan.interface_name),
                ("--pxe-dhcp-start", str(plan.dhcp_start)),
                ("--pxe-dhcp-end", str(plan.dhcp_end)),
                ("--pxe-dhcp-netmask", dotted_netmask(plan.network)),
            ]
        )
        if plan.gateway is not None:
            cmd_args.append(("--pxe-gateway", plan.gateway))
        for dns in plan.dns_servers:
            cmd_args.append(("--pxe-dns", dns))

    if run_mode.run_controller:
        if plan.nfs_server_ip is None:
            raise SystemExit("ERROR: controller mode requires an NFS server IP.")
        cmd_args.append(("--nfs-server-ip", str(plan.nfs_server_ip)))
        if plan.nfs_allow_all_clients:
            cmd_args.append(("--nfs-allow-all-clients", None))
        elif plan.nfs_allow_clients:
            cmd_args.append(("--nfs-allow-clients", plan.nfs_allow_clients))
        else:
            raise SystemExit("ERROR: controller mode requires NFS clients or allow-all.")

    return cmd_args


def print_plan(run_mode, plan, command):
    print()
    print("Suggested network plan")
    mode_text = "PXE + controller" if run_mode.run_pxe and run_mode.run_controller else "PXE only" if run_mode.run_pxe else "controller only"
    print("  Bootstrap mode    : {}".format(mode_text))
    print("  Interface         : {}".format(plan.interface_name or "<not used>"))
    print("  Network           : {}".format(plan.network))
    print("  Netmask           : {}".format(dotted_netmask(plan.network)))
    print("  Server IP         : {}".format(plan.server_ip))
    if plan.interface_needs_ip:
        print("  Interface IP      : planned IP is not currently configured")
    else:
        print("  Interface IP      : planned IP already exists on the selected interface")

    if run_mode.run_pxe:
        print("  PXE HTTP port     : {}".format(plan.pxe_http_port))
        print("  DHCP range        : {} - {}".format(plan.dhcp_start, plan.dhcp_end))
        print("  PXE gateway       : {}".format(plan.gateway))
        print("  PXE DNS servers   : {}".format(", ".join(plan.dns_servers) if plan.dns_servers else "<none>"))

    if run_mode.run_controller:
        print("  NFS server IP     : {}".format(plan.nfs_server_ip))
        if plan.nfs_allow_all_clients:
            print("  NFS clients       : all clients")
        else:
            print("  NFS clients       : {}".format(plan.nfs_allow_clients))

    print()
    print("Generated bootstrap command")
    print(command)


def write_generated_scripts(output_dir, plan, bootstrap_command, explicit_bootstrap_output=None):
    interface_script_path = None
    server_interface = ipaddress.ip_interface("{}/{}".format(plan.server_ip, plan.network.prefixlen))

    if plan.generate_interface_script and plan.interface_name:
        interface_script_path = next_available_path(output_dir, DEFAULT_INTERFACE_SCRIPT_NAME)
        write_executable_script(interface_script_path, format_nmcli_setup(plan.interface_name, server_interface))

    if explicit_bootstrap_output:
        bootstrap_script_path = os.path.abspath(explicit_bootstrap_output)
    else:
        bootstrap_script_path = next_available_path(output_dir, DEFAULT_BOOTSTRAP_SCRIPT_NAME)

    write_executable_script(bootstrap_script_path, format_bootstrap_script(bootstrap_command))
    return interface_script_path, bootstrap_script_path


def print_final_instructions(interface_script_path, bootstrap_script_path, interface_name, interface_needs_ip):
    print()
    print("Generated executable script(s)")
    if interface_script_path:
        print("  Interface setup script:")
        print("    {}".format(interface_script_path))
    else:
        print("  Interface setup script: <not generated>")
    print("  Bootstrap script:")
    print("    {}".format(bootstrap_script_path))

    if interface_needs_ip and not interface_script_path:
        print()
        print("WARNING: the planned server IP is not currently on the selected interface.")
        print("No interface setup script was generated, so configure that IP manually before running bootstrap.")

    print()
    print("Recommended next steps")
    step = 1
    if interface_script_path:
        print("  {}. Review the interface setup script:".format(step))
        print("       cat {}".format(interface_script_path))
        step += 1
        print("  {}. Run the interface setup script when ready:".format(step))
        print("       {}".format(interface_script_path))
        step += 1
        if interface_name:
            print("  {}. Confirm the planned IP appears on the interface:".format(step))
            print("       ip -br addr show {}".format(interface_name))
            step += 1
        print("  {}. Review the bootstrap script:".format(step))
        print("       cat {}".format(bootstrap_script_path))
        step += 1
    else:
        print("  {}. Review the bootstrap script:".format(step))
        print("       cat {}".format(bootstrap_script_path))
        step += 1

    print("  {}. Run the bootstrap script when ready:".format(step))
    print("       {}".format(bootstrap_script_path))
    print()
    print("Optional: add extra bootstrap options at run time without editing the script:")
    print("       {} --epel-approved true --verbose --skip-ansible-install".format(bootstrap_script_path))
    print("Extra options are forwarded to bootstrap.sh after the generated network options.")


# ---------------------------------------------------------------------------
# Main
# ---------------------------------------------------------------------------
def main():
    parser = argparse.ArgumentParser(description="Generate AeroLIT bootstrap network options.")
    parser.add_argument("--bootstrap-path", default=None)
    parser.add_argument(
        "--output",
        help="Advanced/testing only: optional bootstrap script output path. Normal use writes next to bootstrap.sh automatically.",
    )
    args = parser.parse_args()

    if not shutil.which("ip"):
        print("ERROR: the 'ip' command is required.", file=sys.stderr)
        return 1

    script_dir = os.path.dirname(os.path.abspath(__file__))
    bootstrap_path = args.bootstrap_path or default_bootstrap_path(script_dir)
    if not os.path.isabs(bootstrap_path):
        bootstrap_path = os.path.abspath(bootstrap_path)

    default_route = get_default_route()
    interfaces = get_interfaces()
    if not interfaces:
        print("ERROR: no non-loopback interfaces were found.", file=sys.stderr)
        return 1

    print()
    print("AeroLIT bootstrap network helper")
    print("This helper asks simple network questions and writes reviewable scripts next to bootstrap.sh.")
    print("It does not change your system and it does not run bootstrap automatically.")
    print()
    print("Safety note: PXE/DHCP should normally run on an isolated provisioning network,")
    print("a lab VLAN, or a direct-cable network. Be careful enabling DHCP on a shared network.")

    run_mode = choose_run_mode()
    selected = choose_interface(interfaces, default_route)
    plan = build_plan(run_mode, selected, default_route)
    command = format_command(bootstrap_path, command_args_from_plan(run_mode, plan))

    output_dir = os.path.dirname(bootstrap_path)

    print_plan(run_mode, plan, command)
    interface_script_path, bootstrap_script_path = write_generated_scripts(
        output_dir,
        plan,
        command,
        explicit_bootstrap_output=args.output,
    )
    print_final_instructions(
        interface_script_path,
        bootstrap_script_path,
        plan.interface_name,
        plan.interface_needs_ip,
    )

    return 0


if __name__ == "__main__":
    raise SystemExit(main())