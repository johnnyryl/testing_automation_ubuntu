: "${CID:=pxe-content}"
: "${SCRIPT:=/usr/local/bin/generate-pxe-content.py}"
pxe_test_inside_container() {
  [[ "${PXE_TEST_INSIDE_CONTAINER:-0}" == "1" ]]
}
require_host_cmd() {
  if pxe_test_inside_container; then
    return 0
  fi
  command -v "$1" >/dev/null 2>&1 || {
    echo "ERROR: Required host command not found: $1" >&2
    exit 1
  }
}
container_exec() {
  if pxe_test_inside_container; then
    "$@"
  else
    podman exec -i "$CID" "$@"
  fi
}
container_sh() {
  if pxe_test_inside_container; then
