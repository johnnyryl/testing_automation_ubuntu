def explain_preserve_path(bundle_path, section, path):
    """Explain whether a path is protected by preserve rules."""
    preserve_file = sync_preserve_file(bundle_path)
    entries = read_preserve_file_entries(preserve_file)
    defaults = preserve_defaults_for_section(section)
    normalized_path = normalize_preserve_path_for_section(path, section)

    user_matches = []
    default_matches = []

    for pattern in entries["patterns"]:
        normalized_pattern = normalize_preserve_pattern_for_section(
            pattern,
            section,
        )
        if path_matches_pattern(normalized_path, normalized_pattern):
            user_matches.append(pattern)

    for pattern in defaults:
        if path_matches_pattern(normalized_path, pattern):
            default_matches.append(pattern)

    print("AeroLIT sync preserve explanation")
    print("")
    print("Section:")
    print("  {}".format(section))
    print("")
    print("Path:")
    print("  {}".format(path))
    print("")
    print("Normalized path:")
    print("  {}".format(normalized_path))
    print("")
    print("Preserve file:")
    print("  {}".format(preserve_file))
    print("")

    if user_matches or default_matches:
        print("Result:")
        print("  preserved")
    else:
        print("Result:")
        print("  not preserved")

    if user_matches:
        print("")
        print("Matching user/project patterns:")
        for pattern in user_matches:
            print("  - {}".format(pattern))

    if default_matches:
        print("")
        print("Matching built-in default patterns:")
        for pattern in default_matches:
            print("  - {}".format(pattern))

    if not user_matches and not default_matches:
        print("")
        print("No preserve patterns matched this path.")

    return 0


def edit_preserve_file(preserve_file):
    """Open preserve file in the user's editor."""
    ensure_preserve_file_exists(preserve_file)

    editor = os.environ.get("VISUAL") or os.environ.get("EDITOR")

    if not editor:
        print("ERROR: VISUAL or EDITOR is not set.", file=sys.stderr)
        print("", file=sys.stderr)
        print("Preserve file:")
        print("  {}".format(preserve_file))
        return 2

    command = shlex.split(editor)
    command.append(str(preserve_file))

    try:
        return subprocess.call(command)
    except OSError as exc:
        print("ERROR: Could not launch editor: {}".format(exc), file=sys.stderr)
        return 1


def add_preserve_pattern(preserve_file, pattern, section=SECTION_COLLECTIONS_HUB):
    """Add one preserve pattern if missing."""
    pattern = normalize_preserve_pattern_for_section(pattern, section)

    if not pattern:
        raise ValueError("Preserve pattern cannot be empty.")

    entries = read_preserve_file_entries(preserve_file)
    patterns = list(entries["patterns"])

    if pattern in patterns:
        return False, pattern

    patterns.append(pattern)

    if entries["exists"]:
        preserve_file = Path(preserve_file)
        existing_text = preserve_file.read_text()

        with preserve_file.open("a") as handle:
            if existing_text and not existing_text.endswith("\n"):
                handle.write("\n")
            handle.write("{}\n".format(pattern))
    else:
        write_preserve_file_patterns(preserve_file, patterns)

    return True, pattern


def remove_preserve_pattern(preserve_file, pattern, section=SECTION_COLLECTIONS_HUB):
    """Remove one preserve pattern if present."""
    pattern = normalize_preserve_pattern_for_section(pattern, section)
    entries = read_preserve_file_entries(preserve_file)
    patterns = list(entries["patterns"])

    if pattern not in patterns:
        return False, pattern

    patterns = [item for item in patterns if item != pattern]
    write_preserve_file_patterns(preserve_file, patterns)

    return True, pattern


