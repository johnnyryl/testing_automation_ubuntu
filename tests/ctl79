def read_text_lines_for_diff(path):
    """Read text lines for a diff, replacing undecodable bytes."""
    path = Path(path)

    if is_probably_binary_file(path):
        return None

    try:
        with path.open("r", encoding="utf-8", errors="replace") as handle:
            return handle.readlines()
    except OSError:
        return None


def show_conflict_diff(plan, relative_path, max_lines=None):
    """Show a unified diff for a conflicted file."""
    if max_lines is None:
        max_lines = plan.get("_diff_lines", DEFAULT_DIFF_LINE_LIMIT)

    source_path = Path(plan["source_path"]) / relative_path
    target_path = Path(plan["target_path"]) / relative_path

    if not source_path.exists():
        print("")
        print("No incoming file exists for this path.")
        print("The incoming bundle removed it.")
        return

    if not target_path.exists():
        print("")
        print("No local target file exists for this path.")
        return

    if is_probably_binary_file(source_path) or is_probably_binary_file(target_path):
        print("")
        print("Binary file diff skipped:")
        print("  local:    {}".format(target_path))
        print("  incoming: {}".format(source_path))
        print("")
        print("Use checksums or external tools to compare binary files.")
        return

    source_lines = read_text_lines_for_diff(source_path)
    target_lines = read_text_lines_for_diff(target_path)

    if source_lines is None or target_lines is None:
        print("")
        print("Could not read one of the files for text diff:")
        print("  local:    {}".format(target_path))
        print("  incoming: {}".format(source_path))
        return

    print("")
    print("Diff:")
    print("  local:    {}".format(target_path))
    print("  incoming: {}".format(source_path))
    print("  max lines: {}".format(max_lines))
    print("")

    diff = difflib.unified_diff(
        target_lines,
        source_lines,
        fromfile="local/{}".format(relative_path),
        tofile="incoming/{}".format(relative_path),
    )

    count = 0
    printed = False

    for line in diff:
        count += 1

        if count > max_lines:
            print("... diff truncated after {} lines".format(max_lines))
            break

        print(line, end="")
        printed = True

    if not printed:
        print("No text diff was produced.")


