def report_safe_value(value):
    """Return a YAML-safe value for reports."""
    if isinstance(value, Path):
        return str(value)

    if isinstance(value, dict):
        cleaned = {}
        for key, item in value.items():
            cleaned[str(key)] = report_safe_value(item)
        return cleaned

    if isinstance(value, (list, tuple)):
        return [report_safe_value(item) for item in value]

    return value


