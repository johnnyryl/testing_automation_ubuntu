def sync_report_files():
    """Return sync report files newest first."""
    report_dir = sync_log_dir()

    if not report_dir.exists():
        return []

    reports = [
        path
        for path in report_dir.glob("*-sync-report.yml")
        if path.is_file()
    ]

    return sorted(reports, reverse=True)


def load_sync_report(path):
    """Load one sync report."""
    data = read_yaml_file(path, default=None)

    if not isinstance(data, dict):
        raise ValueError("Sync report is not a YAML mapping: {}".format(path))

    return data


def report_is_rollback_candidate(report):
    """Return True if a report has data useful for rollback."""
    if report.get("dry_run"):
        return False

    plan = report.get("plan", {})
    if plan.get("section") != SECTION_COLLECTIONS_HUB:
        return False

    for item in report.get("changed", []):
        if item.get("action") in (
            "add",
            "update",
            "bundle-managed-update",
            "remove",
        ):
            return True

    return False


def find_rollback_report(identifier=None):
    """Find a rollback report by timestamp/path, or return latest candidate."""
    reports = sync_report_files()

    if identifier:
        identifier_path = Path(identifier).expanduser()

        if identifier_path.exists():
            report = load_sync_report(identifier_path)
            return identifier_path, report

        matches = []
        for path in reports:
            if path.name.startswith(identifier):
                matches.append(path)
                continue

            if identifier in path.name:
                matches.append(path)

        if not matches:
            raise ValueError(
                "No sync report matched rollback target: {}".format(identifier)
            )

        report_path = matches[0]
        return report_path, load_sync_report(report_path)

    for report_path in reports:
        report = load_sync_report(report_path)

        if report_is_rollback_candidate(report):
            return report_path, report

    raise ValueError("No rollback-capable sync reports were found.")


