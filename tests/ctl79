def confirm_continue():
    """Prompt user for confirmation."""
    try:
        answer = input("Continue? [y/N] ").strip().lower()
    except EOFError:
        return False

    return answer in ("y", "yes")


def prompt_choice(prompt, valid_choices, default=None):
    """Prompt for one choice."""
    valid_choices = tuple(valid_choices)

    while True:
        try:
            answer = input(prompt).strip().lower()
        except EOFError:
            return default

        if not answer and default:
            return default

        if answer in valid_choices:
            return answer

        print("Please choose one of: {}".format(", ".join(valid_choices)))


def append_unique_plan_item(plan, key, item):
    """Append a plan item if its path is not already present."""
    path = item.get("path")

    for existing in plan.get(key, []):
        if existing.get("path") == path:
            return False

    plan.setdefault(key, []).append(item)
    return True


def read_text_lines_for_diff(path):
    """Read text lines for a diff, replacing undecodable bytes."""
    try:
        with Path(path).open("r", encoding="utf-8", errors="replace") as handle:
            return handle.readlines()
    except OSError:
        return None


def show_conflict_diff(plan, relative_path, max_lines=300):
    """Show a unified diff for a conflicted file."""
    source_path = Path(plan["source_path"]) / relative_path
    target_path = Path(plan["target_path"]) / relative_path

    if not source_path.exists():
        print("")
        print("No incoming file exists for this path.")
        print("The incoming bundle removed it.")
        return

    if not target_path.exists():
        print("")
        print("No local target file exists for this path.")
        return

    source_lines = read_text_lines_for_diff(source_path)
    target_lines = read_text_lines_for_diff(target_path)

    if source_lines is None or target_lines is None:
        print("")
        print("Could not read one of the files for diff:")
        print("  local:    {}".format(target_path))
        print("  incoming: {}".format(source_path))
        return

    print("")
    print("Diff:")
    print("  local:    {}".format(target_path))
    print("  incoming: {}".format(source_path))
    print("")

    diff = difflib.unified_diff(
        target_lines,
        source_lines,
        fromfile="local/{}".format(relative_path),
        tofile="incoming/{}".format(relative_path),
    )

    count = 0
    printed = False

    for line in diff:
        count += 1

        if count > max_lines:
            print("... diff truncated after {} lines".format(max_lines))
            break

        print(line, end="")
        printed = True

    if not printed:
        print("No text diff was produced.")


def resolve_conflicts_interactively(plan, preserve_file):
    """Interactively resolve sync conflicts.

    Mutates the plan by moving conflicts into update/remove/preserve actions.
    """
    conflicts = list(plan.get("conflicts", []))
    remaining = []

    if not conflicts:
        return True

    print("")
    print("Interactive conflict review")
    print("")

    for index, conflict in enumerate(conflicts, 1):
        relative = conflict.get("path")
        reason = conflict.get("reason", "conflict")
        action = conflict.get("action", "")

        if not relative:
            remaining.append(conflict)
            continue

        source_path = Path(plan["source_path"]) / relative
        incoming_exists = source_path.exists()

        while True:
            print("")
            print("Conflict {}/{}:".format(index, len(conflicts)))
            print("  {}".format(relative))
            print("")
            print("Reason:")
            print("  {}".format(reason))

            if action:
                print("")
                print("Planned action:")
                print("  {}".format(action))

            print("")

            if incoming_exists:
                print("Choices:")
                print("  [u] use incoming version")
                print("  [k] keep local version for this run")
                print("  [p] preserve this path permanently")
                print("  [d] show diff")
                print("  [q] quit review")
                choice = prompt_choice("Choice [k]: ", ("u", "k", "p", "d", "q"), "k")

                if choice == "d":
                    show_conflict_diff(plan, relative)
                    continue

                if choice == "u":
                    append_unique_plan_item(
                        plan,
                        "update",
                        {
                            "path": relative,
                            "reason": "resolved conflict: use incoming",
                        },
                    )
                    break

                if choice == "k":
                    append_unique_plan_item(
                        plan,
                        "preserve",
                        {
                            "path": relative,
                            "reason": "manual conflict review",
                            "action": "keep local for this run",
                        },
                    )
                    break

                if choice == "p":
                    add_preserve_pattern(preserve_file, relative)
                    append_unique_plan_item(
                        plan,
                        "preserve",
                        {
                            "path": relative,
                            "reason": "added to preserve file",
                            "action": "keep local",
                        },
                    )
                    break

                if choice == "q":
                    remaining.append(conflict)
                    plan["conflicts"] = remaining
                    return False

            else:
                print("Choices:")
                print("  [r] remove local file")
                print("  [k] keep local file for this run")
                print("  [p] preserve this path permanently")
                print("  [q] quit review")
                choice = prompt_choice("Choice [k]: ", ("r", "k", "p", "q"), "k")

                if choice == "r":
                    append_unique_plan_item(
                        plan,
                        "remove",
                        {
                            "path": relative,
                            "reason": "resolved conflict: remove local file",
                        },
                    )
                    break

                if choice == "k":
                    append_unique_plan_item(
                        plan,
                        "preserve",
                        {
                            "path": relative,
                            "reason": "manual conflict review",
                            "action": "skip removal for this run",
                        },
                    )
                    break

                if choice == "p":
                    add_preserve_pattern(preserve_file, relative)
                    append_unique_plan_item(
                        plan,
                        "preserve",
                        {
                            "path": relative,
                            "reason": "added to preserve file",
                            "action": "skip removal",
                        },
                    )
                    break

                if choice == "q":
                    remaining.append(conflict)
                    plan["conflicts"] = remaining
                    return False

    plan["conflicts"] = remaining
    return True


def parse_number_selection(answer, maximum):
    """Parse a comma-separated number selection."""
    selected = []

    for part in answer.split(","):
        part = part.strip()

        if not part:
            continue

        if "-" in part:
            start_text, end_text = part.split("-", 1)

            try:
                start = int(start_text)
                end = int(end_text)
            except ValueError:
                continue

            for value in range(start, end + 1):
                if 1 <= value <= maximum and value not in selected:
                    selected.append(value)

            continue

        try:
            value = int(part)
        except ValueError:
            continue

        if 1 <= value <= maximum and value not in selected:
            selected.append(value)

    return selected


def review_removals_interactively(plan, preserve_file):
    """Interactively review safe removals."""
    removals = list(plan.get("remove", []))

    if not removals:
        return True

    print("")
    print("Removal review")
    print("")
    print("These files are safe removal candidates because they were previously")
    print("tracked by AeroLIT, are missing from the incoming source, and do not")
    print("appear to have local changes.")
    print("")

    for index, item in enumerate(removals, 1):
        print("  [{}] {}".format(index, item.get("path")))

    print("")
    print("Choices:")
    print("  [r] remove all listed files")
    print("  [s] skip all removals for this run")
    print("  [p] preserve selected files permanently")
    print("  [q] cancel sync")
    choice = prompt_choice("Choice [s]: ", ("r", "s", "p", "q"), "s")

    if choice == "r":
        return True

    if choice == "q":
        return False

    if choice == "s":
        plan["remove"] = []

        for item in removals:
            append_unique_plan_item(
                plan,
                "preserve",
                {
                    "path": item.get("path"),
                    "reason": "manual removal review",
                    "action": "skip removal for this run",
                },
            )

        return True

    if choice == "p":
        print("")
        print("Enter numbers to preserve, for example: 1,3,5-7")
        try:
            answer = input("Preserve numbers: ").strip()
        except EOFError:
            return False

        selected = parse_number_selection(answer, len(removals))
        selected_indexes = set(selected)
        kept_removals = []

        for index, item in enumerate(removals, 1):
            path = item.get("path")

            if index in selected_indexes:
                add_preserve_pattern(preserve_file, path)
                append_unique_plan_item(
                    plan,
                    "preserve",
                    {
                        "path": path,
                        "reason": "added to preserve file",
                        "action": "skip removal",
                    },
                )
            else:
                kept_removals.append(item)

        plan["remove"] = kept_removals
        return True

    return True


def backup_target_file(target_root, relative_path, backup_root):
    """Back up one target file before changing it."""
    source = Path(target_root) / relative_path

    if not source.exists():
        return None

    destination = Path(backup_root) / SECTION_COLLECTIONS_HUB / relative_path
    destination.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(str(source), str(destination))
    return destination


def copy_incoming_file(source_root, target_root, relative_path):
    """Copy one incoming file into target."""
    source = Path(source_root) / relative_path
    target = Path(target_root) / relative_path
    target.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(str(source), str(target))


def remove_target_file(target_root, relative_path):
    """Remove one target file."""
    target = Path(target_root) / relative_path

    if target.exists() and target.is_file():
        target.unlink()


def remove_empty_parents(path, stop_root):
    """Remove empty parent directories up to stop_root."""
    path = Path(path).parent
    stop_root = Path(stop_root)

    while path != stop_root and str(path).startswith(str(stop_root)):
        try:
            path.rmdir()
        except OSError:
            return

        path = path.parent


def apply_collections_hub_plan(plan, no_backup=False):
    """Apply collections-hub sync plan."""
    source_root = Path(plan["source_path"])
    target_root = Path(plan["target_path"])
    changed = []

    backup_root = None
    if not no_backup and (
        plan.get("update")
        or plan.get("bundle_managed_update")
        or plan.get("remove")
    ):
        backup_root = sync_backup_dir() / utc_stamp()
        backup_root.mkdir(parents=True, exist_ok=True)

    for item in plan.get("add", []):
        relative = item["path"]
        copy_incoming_file(source_root, target_root, relative)
        changed.append({"action": "add", "path": relative})

    update_items = []
    update_items.extend(plan.get("update", []))
    update_items.extend(plan.get("bundle_managed_update", []))

    for item in update_items:
        relative = item["path"]

        if backup_root:
            backup_target_file(target_root, relative, backup_root)

        copy_incoming_file(source_root, target_root, relative)

        if item in plan.get("bundle_managed_update", []):
            action = "bundle-managed-update"
        else:
            action = "update"

        changed.append({"action": action, "path": relative})

    for item in plan.get("remove", []):
        relative = item["path"]

        if backup_root:
            backup_target_file(target_root, relative, backup_root)

        remove_target_file(target_root, relative)
        remove_empty_parents(target_root / relative, target_root)
        changed.append({"action": "remove", "path": relative})

    return changed, backup_root


