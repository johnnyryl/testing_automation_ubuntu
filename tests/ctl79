    target_root = Path(target_root)
    trees = {}

    for name, tree_path in sorted(extracted_iso_tree_dirs(target_root).items()):
        trees[name] = extracted_iso_tree_info(tree_path)

    return {
        "updated_utc": utc_iso(),
        "root": str(target_root),
        "trees": trees,
