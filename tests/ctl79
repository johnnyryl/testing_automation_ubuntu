        "plan": {
            "counts": cleanup_plan_counts(plan),
            "estimated_reclaim_bytes": cleanup_plan_size(plan),
            "estimated_reclaim": format_bytes(cleanup_plan_size(plan)),
            "items": list(plan.get("items", [])),
            "warnings": list(plan.get("warnings", [])),
        },
        "changed": changed,
    }


