def run_sync_preserve(args, raw_args):
    """Run aerolitctl sync preserve commands."""
    bundle_path = resolve_bundle_path(args)
    preserve_file = sync_preserve_file(bundle_path)

    if not raw_args:
        print("ERROR: Missing preserve command.", file=sys.stderr)
        print("", file=sys.stderr)
        print("Examples:", file=sys.stderr)
        print("  aerolitctl sync preserve list", file=sys.stderr)
        print("  aerolitctl sync preserve add ansible/group_vars/all/site.yml", file=sys.stderr)
        print("  aerolitctl sync preserve remove ansible/group_vars/all/site.yml", file=sys.stderr)
        print("  aerolitctl sync preserve defaults", file=sys.stderr)
        print("  aerolitctl sync preserve validate", file=sys.stderr)
        print("  aerolitctl sync preserve explain ansible/inventory/hosts.ini", file=sys.stderr)
        print("  aerolitctl sync preserve edit", file=sys.stderr)
        return 2

    command = raw_args[0]

    if command == "list":
        include_defaults = (
            getattr(args, "defaults", False)
            or getattr(args, "all", False)
            or "--defaults" in raw_args
            or "--all" in raw_args
        )
        try:
            sections = preserve_sections_for_display(args)
        except ValueError as exc:
            print("ERROR: {}".format(exc), file=sys.stderr)
            return 2

        return print_preserve_patterns(
            bundle_path,
            include_defaults=include_defaults,
            sections=sections,
        )

    if command == "defaults":
        try:
            sections = preserve_sections_for_display(args)
        except ValueError as exc:
            print("ERROR: {}".format(exc), file=sys.stderr)
            return 2

        added_by_section = []

        for section in sections:
            added = ensure_preserve_file_defaults(
                preserve_file,
                preserve_defaults_for_section(section),
            )
            for pattern in added:
                added_by_section.append((section, pattern))

        print("AeroLIT sync preserve defaults")
        print("")
        print("Preserve file:")
        print("  {}".format(preserve_file))
        print("")

        if not added_by_section:
            print("No changes made. Default preserve rules are already present.")
            return 0

        print("Added default preserve patterns:")
        for section, pattern in added_by_section:
            print("  - {}: {}".format(section, pattern))

        return 0

    if command == "add":
        if len(raw_args) < 2:
            print("ERROR: Missing preserve pattern to add.", file=sys.stderr)
            return 2

        changed_any = False

        for pattern in raw_args[1:]:
            try:
                section = infer_preserve_section(args, pattern)
            except ValueError as exc:
                print("ERROR: {}".format(exc), file=sys.stderr)
                return 2

            changed, normalized = add_preserve_pattern(
                preserve_file,
                pattern,
                section=section,
            )
            changed_any = changed_any or changed

            if changed:
                print("Added preserve pattern:")
            else:
                print("Preserve pattern already exists:")

            print("  {}".format(normalized))
            print("  section: {}".format(section))

        print("")
        print("Preserve file:")
        print("  {}".format(preserve_file))

        return 0 if changed_any else 0

    if command == "remove":
        if len(raw_args) < 2:
            print("ERROR: Missing preserve pattern to remove.", file=sys.stderr)
            return 2

        changed_any = False

        for pattern in raw_args[1:]:
            try:
                section = infer_preserve_section(args, pattern)
            except ValueError as exc:
                print("ERROR: {}".format(exc), file=sys.stderr)
                return 2

            changed, normalized = remove_preserve_pattern(
                preserve_file,
                pattern,
                section=section,
            )
            changed_any = changed_any or changed

            if changed:
                print("Removed preserve pattern:")
            else:
                print("Preserve pattern not found:")

            print("  {}".format(normalized))
            print("  section: {}".format(section))

        print("")
        print("Preserve file:")
        print("  {}".format(preserve_file))

        return 0 if changed_any else 1

    if command == "validate":
        return print_preserve_validation(bundle_path)

    if command == "explain":
        if len(raw_args) < 2:
            print("ERROR: Missing path to explain.", file=sys.stderr)
            print("Example:", file=sys.stderr)
            print("  aerolitctl sync preserve explain ansible/inventory/hosts.ini", file=sys.stderr)
            return 2

        target_path = raw_args[1]

        try:
            section = infer_preserve_section(args, target_path)
        except ValueError as exc:
            print("ERROR: {}".format(exc), file=sys.stderr)
            return 2

        return explain_preserve_path(bundle_path, section, target_path)

    if command == "edit":
        return edit_preserve_file(preserve_file)

    print("ERROR: Unknown preserve command: {}".format(command), file=sys.stderr)
    print("", file=sys.stderr)
    print("Valid commands:", file=sys.stderr)
    print("  list", file=sys.stderr)
    print("  add", file=sys.stderr)
    print("  remove", file=sys.stderr)
    print("  defaults", file=sys.stderr)
    print("  validate", file=sys.stderr)
    print("  explain", file=sys.stderr)
    print("  edit", file=sys.stderr)
    return 2


def pattern_variants(pattern):
    """Return useful variants for one preserve pattern."""
    pattern = normalize_relative_path(pattern.strip())

    if pattern.startswith("./"):
        pattern = pattern[2:]

    variants = [pattern]

    if pattern.startswith("collections-hub/"):
        variants.append(pattern[len("collections-hub/"):])

    return variants


def path_matches_pattern(relative_path, pattern):
    """Return True when a relative path matches one preserve pattern."""
    relative_path = normalize_relative_path(relative_path)

    for variant in pattern_variants(pattern):
        if fnmatch.fnmatchcase(relative_path, variant):
            return True

        if variant.endswith("/**"):
            prefix = variant[:-3]
            if relative_path == prefix or relative_path.startswith(prefix + "/"):
                return True

        if variant.endswith("/"):
            prefix = variant.rstrip("/")
            if relative_path == prefix or relative_path.startswith(prefix + "/"):
                return True

    return False


def is_preserved(relative_path, patterns):
    """Return True when a relative path is protected by preserve rules."""
    for pattern in patterns:
        if path_matches_pattern(relative_path, pattern):
            return True

    return False


def is_bundle_managed_collections_path(relative_path):
    """Return True when a collections-hub path is normal bundle-managed content."""
    for pattern in BUNDLE_MANAGED_COLLECTIONS_PATTERNS:
        if path_matches_pattern(relative_path, pattern):
            return True

    return False


def scan_files(root, preserve_patterns=None):
    """Scan regular files under root and return metadata by relative path."""
    root = Path(root)
    preserve_patterns = list(preserve_patterns or [])
    files = {}
    skipped = []

    if not root.exists():
        return files, skipped

    for current_root, dirnames, filenames in os.walk(
        str(root),
        topdown=True,
        followlinks=False,
    ):
        current_root_path = Path(current_root)

        kept_dirnames = []
        for dirname in sorted(dirnames):
            child_dir = current_root_path / dirname
            relative = relpath(child_dir, root)

            if child_dir.is_symlink():
                skipped.append(
                    {
                        "path": relative,
                        "reason": "symlink directory",
                    }
                )
                continue

            if is_preserved(relative, preserve_patterns):
                skipped.append(
                    {
                        "path": relative,
                        "reason": "preserved directory",
                    }
                )
                continue

            kept_dirnames.append(dirname)

        dirnames[:] = kept_dirnames

        for filename in sorted(filenames):
            path = current_root_path / filename
            relative = relpath(path, root)

            try:
                if path.is_symlink():
                    skipped.append(
                        {
                            "path": relative,
                            "reason": "symlink",
                        }
                    )
                    continue

                if not path.is_file():
                    skipped.append(
                        {
                            "path": relative,
                            "reason": "not a regular file",
                        }
                    )
                    continue

                stat_result = path.stat()
                preserved = is_preserved(relative, preserve_patterns)

                if preserved:
                    files[relative] = {
                        "path": path,
                        "checksum": None,
                        "size_bytes": stat_result.st_size,
                        "mode": stat_result.st_mode & 0o777,
                        "preserved": True,
                    }
                    continue

                files[relative] = {
                    "path": path,
                    "checksum": sha256_file(path),
                    "size_bytes": stat_result.st_size,
                    "mode": stat_result.st_mode & 0o777,
                    "preserved": False,
                }
            except OSError as exc:
                skipped.append(
                    {
                        "path": relative,
                        "reason": "could not inspect file: {}".format(exc),
                    }
                )

    return files, skipped


def empty_plan(section, source_path, target_path):
    """Return an empty sync plan."""
    return {
        "section": section,
        "source_path": str(source_path),
        "target_path": str(target_path),
        "add": [],
        "update": [],
        "bundle_managed_update": [],
        "remove": [],
        "preserve": [],
        "conflicts": [],
        "unchanged": [],
        "local_untracked": [],
        "skipped": [],
        "warnings": [],
        "notes": [],
    }


def manifest_section_files(manifest, section):
    """Return manifest file mapping for a section."""
    return (
        manifest
        .get("sections", {})
        .get(section, {})
        .get("files", {})
    )


def build_collections_hub_plan(source_path, target_path, manifest, force=False):
    """Build collections-hub smart sync plan."""
    preserve_patterns = load_preserve_patterns(
        sync_preserve_file(target_path.parent),
        default_patterns=DEFAULT_COLLECTIONS_HUB_PRESERVE_PATTERNS,
    )

    source_files, source_skipped = scan_files(source_path, preserve_patterns=preserve_patterns)
    target_files, target_skipped = scan_files(target_path, preserve_patterns=preserve_patterns)

    plan = empty_plan(SECTION_COLLECTIONS_HUB, source_path, target_path)
    plan["skipped"].extend(source_skipped)
    plan["skipped"].extend(target_skipped)

    previous_files = manifest_section_files(manifest, SECTION_COLLECTIONS_HUB)
    previous_exists = bool(previous_files)

    if not previous_exists:
        plan["warnings"].append(
            "No installed collections-hub sync manifest exists yet. "
            "Existing changed files will be treated carefully. "
            "If the current collections-hub is trusted, run: "
            "aerolitctl sync baseline --section collections-hub"
        )

    for relative in sorted(source_files):
        source_meta = source_files[relative]
        target_meta = target_files.get(relative)

        if source_meta.get("preserved"):
            plan["preserve"].append(
                {
                    "path": relative,
                    "reason": "preserve rule",
                    "action": "skip incoming file",
                }
            )
            continue

        if target_meta is None:
            plan["add"].append({"path": relative})
            continue

        if target_meta["checksum"] == source_meta["checksum"]:
            plan["unchanged"].append({"path": relative})
            continue

        previous_meta = previous_files.get(relative)
        previous_checksum = None
        if previous_meta:
            previous_checksum = previous_meta.get("checksum")

        if previous_checksum and target_meta["checksum"] != previous_checksum and not force:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "local file changed since last sync",
                    "action": "would update from incoming source",
                }
            )
            continue

        if not previous_checksum and not force:
            if is_bundle_managed_collections_path(relative):
                plan["bundle_managed_update"].append(
                    {
                        "path": relative,
                        "reason": (
                            "bundle-managed collection content; no previous "
                            "sync baseline exists yet"
                        ),
                        "action": "would update from incoming source",
                    }
                )
                continue

            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": (
                        "existing file differs and no previous sync checksum "
                        "is available"
                    ),
                    "action": "would update from incoming source",
                }
            )
            continue

        if is_bundle_managed_collections_path(relative):
            plan["bundle_managed_update"].append(
                {
                    "path": relative,
                    "reason": "bundle-managed collection content",
                    "action": "would update from incoming source",
                }
            )
            continue

        plan["update"].append({"path": relative})

    for relative in sorted(previous_files):
        if relative in source_files:
            continue

        target_meta = target_files.get(relative)
        if target_meta is None:
            continue

        if is_preserved(relative, preserve_patterns):
            plan["preserve"].append(
                {
                    "path": relative,
                    "reason": "preserve rule",
                    "action": "skip removal",
                }
            )
            continue

        previous_checksum = previous_files[relative].get("checksum")

        if previous_checksum and target_meta["checksum"] == previous_checksum:
            plan["remove"].append(
                {
                    "path": relative,
                    "reason": (
                        "previously tracked by AeroLIT, missing from incoming "
                        "source, and unchanged locally since last sync"
                    ),
                    "action": "would remove old bundle-owned file",
                }
            )
        else:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "file removed from incoming source but changed locally",
                    "action": "would remove old bundle-owned file",
                }
            )

    for relative in sorted(target_files):
        if relative in source_files:
            continue

        if relative in previous_files:
            continue

        if target_files[relative].get("preserved"):
            continue

        plan["local_untracked"].append({"path": relative})

    return plan, source_files


def build_files_plan(source_path, target_path, manifest, force=False, mode="additive"):
    """Build files/ sync plan."""
    preserve_patterns = load_preserve_patterns(
        sync_preserve_file(target_path.parent),
        default_patterns=DEFAULT_FILES_PRESERVE_PATTERNS,
    )

    source_files, source_skipped = scan_files(
        source_path,
        preserve_patterns=preserve_patterns,
    )
    target_files, target_skipped = scan_files(
        target_path,
        preserve_patterns=preserve_patterns,
    )

    plan = empty_plan(SECTION_FILES, source_path, target_path)
    plan["skipped"].extend(source_skipped)
    plan["skipped"].extend(target_skipped)

    previous_files = manifest_section_files(manifest, SECTION_FILES)
    previous_exists = bool(previous_files)

    if not previous_exists:
        plan["warnings"].append(
            "No installed files/ sync manifest exists yet. "
            "Existing differing files will be treated carefully. "
            "If the current files/ directory is trusted, run: "
            "aerolitctl sync baseline --section files"
        )

    if mode == "mirror":
        plan["warnings"].append(
            "files/ mirror mode can remove old tracked files missing from the "
            "incoming source. Review removals before applying."
        )

    for relative in sorted(source_files):
        source_meta = source_files[relative]
        target_meta = target_files.get(relative)

        if source_meta.get("preserved"):
            plan["preserve"].append(
                {
                    "path": relative,
                    "reason": "preserve rule",
                    "action": "skip incoming file",
                }
            )
            continue

        if target_meta is None:
            plan["add"].append({"path": relative})
            continue

        if target_meta.get("preserved"):
            plan["preserve"].append(
                {
                    "path": relative,
                    "reason": "preserve rule",
                    "action": "keep local file",
                }
            )
            continue

        if target_meta["checksum"] == source_meta["checksum"]:
            plan["unchanged"].append({"path": relative})
            continue

        previous_meta = previous_files.get(relative)
        previous_checksum = None
        if previous_meta:
            previous_checksum = previous_meta.get("checksum")

        if previous_checksum and target_meta["checksum"] != previous_checksum and not force:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "local files/ item changed since last sync",
                    "action": "would update from incoming source",
                }
            )
            continue

        if not previous_checksum and not force:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "existing files/ item differs and no previous sync checksum is available",
                    "action": "would update from incoming source",
                }
            )
            continue

        plan["update"].append({"path": relative})

    for relative in sorted(target_files):
        if relative in source_files:
            continue

        target_meta = target_files[relative]

        if target_meta.get("preserved"):
            continue

        previous_meta = previous_files.get(relative)

        if mode != "mirror":
            plan["local_untracked"].append(
                {
                    "path": relative,
                    "reason": "kept by files additive mode",
                }
            )
            continue

        if not previous_meta:
            plan["local_untracked"].append(
                {
                    "path": relative,
                    "reason": "local file not tracked by previous files sync",
                }
            )
            continue

        previous_checksum = previous_meta.get("checksum")

        if previous_checksum and target_meta["checksum"] == previous_checksum:
            plan["remove"].append(
                {
                    "path": relative,
                    "reason": "files mirror mode",
                }
            )
        else:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "file missing from incoming source but changed locally",
                    "action": "would remove old tracked files/ item",
                }
            )

    return plan, source_files


def top_level_name(relative_path):
    """Return the first path component for a relative path."""
    parts = normalize_relative_path(relative_path).split("/")

    if not parts:
        return ""

    return parts[0]


def top_level_names(file_map):
    """Return top-level names from scanned file paths."""
    names = set()

    for relative in file_map:
        name = top_level_name(relative)

        if name:
            names.add(name)

    return names


def normalized_repo_tree_name(name):
    """Return normalized repo tree name for reporting."""
    normalized = normalized_rhel_tree_name(name)

    if normalized:
        return normalized

    return str(name).strip()


def normalized_repo_major_name(name):
    """Return normalized repo major name like rhel8, or None."""
    cleaned = str(name or "").strip().lower()
    cleaned = cleaned.replace("-", "").replace("_", "").replace(".", "")

    prefixes = ("rhel", "el")

    for prefix in prefixes:
        if not cleaned.startswith(prefix):
            continue

        suffix = cleaned[len(prefix):]
        digits = []

        for char in suffix:
            if not char.isdigit():
                break
            digits.append(char)

        if digits:
            return "rhel{}".format("".join(digits))

    return None


def repo_major_from_relative_path(relative_path):
    """Return normalized repo major from any component in a repo path."""
    parts = normalize_relative_path(relative_path).split("/")

    for part in parts:
        normalized = normalized_repo_major_name(part)

        if normalized:
            return normalized

    return None


def repo_major_names_from_file_map(file_map):
    """Return normalized repo majors detected from scanned repo files."""
    majors = set()

    for relative in file_map:
        major = repo_major_from_relative_path(relative)

        if major:
            majors.add(major)

    return sorted(majors)


def repo_top_levels_by_major(file_map):
    """Return mapping of normalized repo major to top-level repo trees."""
    result = {}

    for relative in file_map:
        major = repo_major_from_relative_path(relative)

        if not major:
            continue

        top_level = top_level_name(relative)

        if not top_level:
            continue

        result.setdefault(major, [])

        if top_level not in result[major]:
            result[major].append(top_level)

    for major in result:
        result[major] = sorted(result[major])

    return result


def repo_metadata_file(repo_root):
    """Return repo metadata file path for one repo root."""
    return Path(repo_root) / "repodata" / "repomd.xml"


def repo_metadata_exists(repo_root):
    """Return True when repo root has repodata/repomd.xml."""
    return repo_metadata_file(repo_root).is_file()


def find_repo_metadata_dirs(root):
    """Return directories under root that contain repodata/repomd.xml."""
    root = Path(root)
    found = []

    if not root.exists() or not root.is_dir():
        return found

    for current_root, dirnames, filenames in os.walk(str(root), followlinks=False):
        current_root_path = Path(current_root)

        kept_dirnames = []
        for dirname in dirnames:
            child = current_root_path / dirname
            if child.is_symlink():
                continue
            kept_dirnames.append(dirname)

        dirnames[:] = kept_dirnames

        if "repodata" in dirnames:
            candidate = current_root_path
            if repo_metadata_exists(candidate):
                found.append(candidate)

    return sorted(found)


def repo_tree_metadata_summary(root):
    """Return repo metadata summary for top-level repo trees."""
    root = Path(root)
    summary = {}

    if not root.exists() or not root.is_dir():
        return summary

    for child in sorted(root.iterdir()):
        if not child.is_dir():
            continue

        metadata_dirs = find_repo_metadata_dirs(child)

        normalized_major = normalized_repo_major_name(child.name)

        summary[child.name] = {
            "tree": child.name,
            "normalized_tree": normalized_repo_tree_name(child.name),
            "normalized_major": normalized_major,
            "path": str(child),
            "metadata_count": len(metadata_dirs),
            "metadata_dirs": [str(path) for path in metadata_dirs],
            "has_metadata": bool(metadata_dirs),
        }

    return summary


def build_repos_plan(source_path, target_path, manifest, force=False, mode="additive"):
    """Build repos/ sync plan.

    Additive mode keeps older local packages and metadata.

    Mirror mode only removes tracked files under repo top-level trees that are
    present in the incoming source. That prevents a RHEL 8-only repo update from
    deleting existing RHEL 9 or RHEL 10 repo trees.
    """
    source_files, source_skipped = scan_files(source_path, preserve_patterns=[])
    target_files, target_skipped = scan_files(target_path, preserve_patterns=[])

    plan = empty_plan(SECTION_REPOS, source_path, target_path)
    plan["skipped"].extend(source_skipped)
    plan["skipped"].extend(target_skipped)

    previous_files = manifest_section_files(manifest, SECTION_REPOS)
    previous_exists = bool(previous_files)
    incoming_top_levels = top_level_names(source_files)
    incoming_repo_majors = repo_major_names_from_file_map(source_files)
    incoming_top_levels_by_major = repo_top_levels_by_major(source_files)
    repo_metadata = repo_tree_metadata_summary(source_path)

    plan["repo_metadata"] = repo_metadata
    plan["repo_majors"] = {
        "incoming": incoming_repo_majors,
        "incoming_top_levels_by_major": incoming_top_levels_by_major,
    }

    if not previous_exists:
        plan["warnings"].append(
            "No installed repos/ sync manifest exists yet. "
            "Existing differing repo files will be treated carefully. "
            "If the current repos/ directory is trusted, run: "
            "aerolitctl sync baseline --section repos"
        )

    if repo_metadata:
        missing_metadata = []

        for tree_name, tree_info in sorted(repo_metadata.items()):
            if not tree_info.get("has_metadata"):
                missing_metadata.append(tree_name)

        if missing_metadata:
            plan["warnings"].append(
                "Incoming repos/ source has repo trees without repodata/repomd.xml: {}".format(
                    ", ".join(sorted(missing_metadata))
                )
            )
            add_createrepo_c_repo_note(plan, missing_metadata=True)

        metadata_count = 0
        for tree_info in repo_metadata.values():
            metadata_count += tree_info.get("metadata_count", 0)

        if metadata_count:
            plan["notes"].append(
                "Incoming repos/ source contains {} repo metadata location(s).".format(
                    metadata_count
                )
            )
        else:
            plan["warnings"].append(
                "Incoming repos/ source does not contain any repodata/repomd.xml files."
            )
            add_createrepo_c_repo_note(plan, missing_metadata=True)
    else:
        plan["warnings"].append(
            "Incoming repos/ source has no top-level repo trees to inspect."
        )

    if repo_metadata:
        add_createrepo_c_repo_note(plan, missing_metadata=False)

    if incoming_repo_majors:
        plan["notes"].append(
            "Incoming repos/ source includes normalized RHEL repo major(s): {}.".format(
                ", ".join(incoming_repo_majors)
            )
        )
    else:
        plan["warnings"].append(
            "Incoming repos/ source did not contain recognizable RHEL repo major names like rhel8, rhel9, or rhel10."
        )

    if mode == "additive":
        plan["notes"].append(
            "repos/ additive mode keeps local repo files that are missing from "
            "the incoming source. Older RPMs are not removed."
        )

    if mode == "mirror":
        plan["warnings"].append(
            "repos/ mirror mode can remove old tracked repo files, but only "
            "inside repo trees present in the incoming source."
        )

    for relative in sorted(source_files):
        source_meta = source_files[relative]
        target_meta = target_files.get(relative)

        if target_meta is None:
            plan["add"].append({"path": relative})
            continue

        if target_meta["checksum"] == source_meta["checksum"]:
            plan["unchanged"].append({"path": relative})
            continue

        previous_meta = previous_files.get(relative)
        previous_checksum = None

        if previous_meta:
            previous_checksum = previous_meta.get("checksum")

        if previous_checksum and target_meta["checksum"] != previous_checksum and not force:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "local repo file changed since last sync",
                    "action": "would update from incoming source",
                }
            )
            continue

        if not previous_checksum and not force:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "existing repo file differs and no previous sync checksum is available",
                    "action": "would update from incoming source",
                }
            )
            continue

        plan["update"].append({"path": relative})

    for relative in sorted(target_files):
        if relative in source_files:
            continue

        relative_top_level = top_level_name(relative)
        previous_meta = previous_files.get(relative)

        if mode != "mirror":
            plan["local_untracked"].append(
                {
                    "path": relative,
                    "reason": "kept by repos additive mode",
                }
            )
            continue

        if relative_top_level not in incoming_top_levels:
            plan["local_untracked"].append(
                {
                    "path": relative,
                    "reason": (
                        "repo tree not present in incoming source; "
                        "unrelated repo content left alone"
                    ),
                }
            )
            continue

        if not previous_meta:
            plan["local_untracked"].append(
                {
                    "path": relative,
                    "reason": "local repo file not tracked by previous repos sync",
                }
            )
            continue

        previous_checksum = previous_meta.get("checksum")
        target_meta = target_files[relative]

        if previous_checksum and target_meta["checksum"] == previous_checksum:
            plan["remove"].append(
                {
                    "path": relative,
                    "reason": "repos mirror mode",
                }
            )
        else:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "repo file missing from incoming source but changed locally",
                    "action": "would remove old tracked repo file",
                }
            )

    return plan, source_files


def normalized_rhel_tree_name(name):
    """Return normalized rhelN tree name, or None when not recognized."""
    cleaned = str(name).strip().lower()
    cleaned = cleaned.replace("-", "").replace("_", "")

    if cleaned.startswith("rhel"):
        suffix = cleaned[len("rhel"):]
    elif cleaned.startswith("el"):
        suffix = cleaned[len("el"):]
    else:
        return None

    if suffix.endswith("isos"):
        suffix = suffix[:-4]
    elif suffix.endswith("iso"):
        suffix = suffix[:-3]

    if not suffix.isdigit():
        return None

    return "rhel{}".format(suffix)


def rhel_major_from_tree_name(name):
    """Return RHEL major from a tree name like rhel9."""
    normalized = normalized_rhel_tree_name(name)

    if not normalized:
        return None

    return normalized[len("rhel"):]


def extracted_iso_tree_dirs(root):
    """Return recognized extracted ISO tree directories by normalized name."""
    root = Path(root)
    result = {}

    if not root.exists() or not root.is_dir():
        return result

    for child in sorted(root.iterdir()):
        if not child.is_dir():
            continue

        normalized = normalized_rhel_tree_name(child.name)

        if not normalized:
            continue

        result[normalized] = child

    return result


def read_discinfo_version(tree_path):
    """Return best-effort version details from .discinfo."""
    discinfo = Path(tree_path) / ".discinfo"

    if not discinfo.exists():
        return None

    try:
        lines = discinfo.read_text(errors="replace").splitlines()
    except TypeError:
        try:
            with discinfo.open("r") as handle:
                lines = handle.read().splitlines()
        except OSError:
            return None
    except OSError:
        return None

    cleaned = [line.strip() for line in lines if line.strip()]

    if not cleaned:
        return None

    for line in cleaned:
        lowered = line.lower()
        if "red hat" in lowered or "rhel" in lowered:
            return line

    if len(cleaned) > 1:
        return cleaned[1]

    return cleaned[0]


def extracted_iso_tree_info(tree_path):
    """Return basic extracted ISO tree metadata."""
    tree_path = Path(tree_path)

    return {
        "path": str(tree_path),
        "exists": tree_path.exists(),
        "version": read_discinfo_version(tree_path),
        "has_discinfo": (tree_path / ".discinfo").exists(),
        "has_baseos": (tree_path / "BaseOS").is_dir(),
        "has_appstream": (tree_path / "AppStream").is_dir(),
    }


def extracted_iso_version_label(info):
    """Return display label for extracted ISO version metadata."""
    if not info:
        return "none"

    return info.get("version") or "unknown version"


def directory_size_bytes(path):
    """Return total size for a directory tree."""
    path = Path(path)

    if not path.exists():
        return 0

    if path.is_file():
        try:
            return path.stat().st_size
        except OSError:
            return 0

    total = 0

    for current_root, dirnames, filenames in os.walk(str(path), followlinks=False):
        current_root_path = Path(current_root)

        kept_dirnames = []
        for dirname in dirnames:
            child = current_root_path / dirname
            if child.is_symlink():
                continue
            kept_dirnames.append(dirname)

        dirnames[:] = kept_dirnames

        for filename in filenames:
            item = current_root_path / filename

            try:
                if item.is_symlink() or not item.is_file():
                    continue
                total += item.stat().st_size
            except OSError:
                continue

    return total


def count_regular_files(root):
    """Return number of regular files under root."""
    root = Path(root)

    if not root.exists():
        return 0

    if root.is_file():
        return 1

    count = 0

    for current_root, dirnames, filenames in os.walk(str(root), followlinks=False):
        current_root_path = Path(current_root)

        kept_dirnames = []
        for dirname in dirnames:
            child = current_root_path / dirname
            if child.is_symlink():
                continue
            kept_dirnames.append(dirname)

        dirnames[:] = kept_dirnames

        for filename in filenames:
            item = current_root_path / filename

            try:
                if item.is_symlink() or not item.is_file():
                    continue
                count += 1
            except OSError:
                continue

    return count


def backup_metadata_file(backup_root):
    """Return backup metadata file path."""
    return Path(backup_root) / "aerolit-sync-backup.yml"


def pre_sync_manifest_backup_file(backup_root):
    """Return pre-sync manifest backup path."""
    return Path(backup_root) / "installed-manifest.before.yml"


def write_pre_sync_manifest_backup(backup_root, manifest):
    """Write the pre-sync manifest into the backup root."""
    if not backup_root:
        return None

    path = pre_sync_manifest_backup_file(backup_root)
    write_yaml_file(path, manifest)
    return path


def backup_summary(backup_root):
    """Return backup size/count summary."""
    if not backup_root:
        return {}

    backup_root = Path(backup_root)
    size_bytes = directory_size_bytes(backup_root)

    return {
        "path": str(backup_root),
        "exists": backup_root.exists(),
        "size_bytes": size_bytes,
        "size": format_bytes(size_bytes),
        "file_count": count_regular_files(backup_root),
        "metadata_file": str(backup_metadata_file(backup_root)),
        "pre_sync_manifest": (
            str(pre_sync_manifest_backup_file(backup_root))
            if pre_sync_manifest_backup_file(backup_root).exists()
            else None
        ),
    }


def write_backup_metadata(
    backup_root,
    report_path,
    report,
    pre_sync_manifest_path=None,
):
    """Write metadata describing a sync backup."""
    if not backup_root:
        return None

    metadata_path = backup_metadata_file(backup_root)
    plan = report.get("plan", {})

    metadata = {
        "kind": "AeroLITSyncBackup",
        "created_utc": utc_iso(),
        "backup_root": str(backup_root),
        "report": str(report_path),
        "source": report.get("source"),
        "section": plan.get("section"),
        "pre_sync_manifest": (
            str(pre_sync_manifest_path) if pre_sync_manifest_path else None
        ),
        "summary": backup_summary(backup_root),
    }

    write_yaml_file(metadata_path, metadata)
    return metadata_path


def read_backup_metadata_for_report(report):
    """Return backup metadata for a sync report, if available."""
    backup_root = report.get("backup_root")

    if not backup_root:
        return None

    metadata_path = backup_metadata_file(backup_root)

    if not metadata_path.exists():
        return None

    data = read_yaml_file(metadata_path, default=None)

    if not isinstance(data, dict):
        return None

    return data


def restore_pre_sync_manifest_from_backup(report):
    """Restore the pre-sync manifest recorded with a backup."""
    metadata = read_backup_metadata_for_report(report)

    if not metadata:
        return None

    manifest_path = metadata.get("pre_sync_manifest")

    if not manifest_path:
        return None

    manifest_path = Path(manifest_path)

    if not manifest_path.exists():
        return None

    sync_manifest_file().parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(str(manifest_path), str(sync_manifest_file()))

    return manifest_path


def filesystem_free_bytes(path):
    """Return free bytes on the filesystem containing path."""
    path = Path(path)

    probe = path
    while not probe.exists() and probe != probe.parent:
        probe = probe.parent

    if not probe.exists():
        probe = Path("/")

    try:
        return shutil.disk_usage(str(probe)).free
    except OSError:
        return None


def disk_space_check_for_keep_old(source_tree, target_tree, target_root):
    """Return disk-space check for --keep-old-isos behavior."""
    incoming_size = directory_size_bytes(source_tree)
    current_size = directory_size_bytes(target_tree) if target_tree else 0
    free_bytes = filesystem_free_bytes(target_root)

    required_bytes = int(incoming_size * 1.10)

    return {
        "incoming_size_bytes": incoming_size,
        "incoming_size": format_bytes(incoming_size),
        "current_size_bytes": current_size,
        "current_size": format_bytes(current_size),
        "free_bytes": free_bytes,
        "free": format_bytes(free_bytes) if free_bytes is not None else "unknown",
        "required_bytes": required_bytes,
        "required": format_bytes(required_bytes),
        "ok": free_bytes is not None and free_bytes >= required_bytes,
    }


def keep_old_iso_tree_requested(args):
    """Return True when old extracted ISO trees should be archived before replacement."""
    return bool(
        getattr(args, "keep_old_isos", False)
        or getattr(args, "large_backup", False)
    )


def add_requested_option_notes(plan, args):
    """Add notes for optional sync flags."""
    if getattr(args, "restart_affected", False):
        plan["notes"].append(
            "--restart-affected was requested. This sync command does not "
            "restart services automatically yet; restart or redeploy affected "
            "services after reviewing the sync result if needed."
        )

    if getattr(args, "large_backup", False):
        if plan.get("section") == SECTION_EXTRACTED_ISOS:
            plan["notes"].append(
                "--large-backup is enabled for extracted_isos. Existing selected "
                "RHEL major trees will be moved to extracted_isos/archive before replacement."
            )
        else:
            plan["notes"].append(
                "--large-backup was requested. Small-file sections already back up "
                "changed files when backups are enabled; large backup behavior is "
                "currently only meaningful for extracted_isos."
            )


def createrepo_c_available():
    """Return createrepo_c path if available."""
    return shutil.which("createrepo_c")


def add_createrepo_c_repo_note(plan, missing_metadata=False):
    """Add an optional createrepo_c note for repo metadata situations."""
    createrepo_path = createrepo_c_available()

    if missing_metadata:
        if createrepo_path:
            plan["notes"].append(
                "createrepo_c is available at {}. If this repo content is intended "
                "to be served as a yum/dnf repo, repo metadata can be regenerated "
                "outside sync after review.".format(createrepo_path)
            )
        else:
            plan["notes"].append(
                "createrepo_c is not installed. If repo metadata must be regenerated "
                "later, install createrepo_c and run it manually after review."
            )
        return

    if createrepo_path:
        plan["notes"].append(
            "createrepo_c is available at {} if repo metadata regeneration is "
            "needed later.".format(createrepo_path)
        )


def selected_rhel_tree_names(args, incoming_trees):
    """Return incoming RHEL tree names selected by args."""
    requested_major = getattr(args, "rhel_major", None)

    if requested_major:
        requested_name = "rhel{}".format(requested_major)

        if requested_name in incoming_trees:
            return [requested_name]

        return []

    return sorted(incoming_trees.keys())


def build_extracted_isos_plan(source_path, target_path, args):
    """Build extracted_isos replace-by-RHEL-major plan."""
    source_path = Path(source_path)
    target_path = Path(target_path)

    incoming_trees = extracted_iso_tree_dirs(source_path)
    current_trees = extracted_iso_tree_dirs(target_path)
    selected_names = selected_rhel_tree_names(args, incoming_trees)

    plan = empty_plan(SECTION_EXTRACTED_ISOS, source_path, target_path)
    plan["tree_add"] = []
    plan["tree_replace"] = []
    plan["tree_keep"] = []
    plan["tree_skipped"] = []

    if getattr(args, "rhel_major", None) and not selected_names:
        plan["warnings"].append(
            "Incoming extracted_isos source does not contain rhel{}.".format(
                getattr(args, "rhel_major", None)
            )
        )

    if not incoming_trees:
        plan["warnings"].append(
            "No recognized extracted ISO trees were found. Expected directories like rhel8, rhel9, or rhel10."
        )

    plan["notes"].append(
        "extracted_isos sync replaces entire RHEL major trees. It does not perform file-by-file backup."
    )

    if keep_old_iso_tree_requested(args):
        plan["notes"].append(
            "Large extracted ISO backup behavior is enabled. Existing selected "
            "trees will be moved to extracted_isos/archive before replacement."
        )

    for name in selected_names:
        source_tree = incoming_trees[name]
        target_tree = current_trees.get(name)

        if target_tree:
            planned_target = target_tree
        else:
            planned_target = target_path / source_tree.name

        incoming_info = extracted_iso_tree_info(source_tree)
        current_info = extracted_iso_tree_info(target_tree) if target_tree else None

        item = {
            "path": name,
            "source": str(source_tree),
            "target": str(planned_target),
            "incoming": incoming_info,
            "current": current_info,
        }

        if not incoming_info.get("version"):
            plan["warnings"].append(
                "Incoming extracted ISO tree {} version could not be determined from .discinfo.".format(
                    name
                )
            )

        if target_tree and current_info and not current_info.get("version"):
            plan["warnings"].append(
                "Current extracted ISO tree {} version could not be determined from .discinfo.".format(
                    name
                )
            )

        if target_tree and keep_old_iso_tree_requested(args):
            disk_check = disk_space_check_for_keep_old(
                source_tree,
                target_tree,
                target_path,
            )
            item["disk_check"] = disk_check

            if disk_check.get("ok"):
                plan["notes"].append(
                    "--keep-old-isos disk check for {}: incoming {}, current {}, free {}, required {}.".format(
                        name,
                        disk_check.get("incoming_size"),
                        disk_check.get("current_size"),
                        disk_check.get("free"),
                        disk_check.get("required"),
                    )
                )
            else:
                plan["warnings"].append(
                    "--keep-old-isos may not have enough free space for {}: incoming {}, current {}, free {}, required {}.".format(
                        name,
                        disk_check.get("incoming_size"),
                        disk_check.get("current_size"),
                        disk_check.get("free"),
                        disk_check.get("required"),
                    )
                )

        if target_tree:
            item["reason"] = "replace existing extracted ISO tree"
            item["action"] = "archive then replace" if keep_old_iso_tree_requested(args) else "delete then replace"
            plan["tree_replace"].append(item)
        else:
            item["reason"] = "add new extracted ISO tree"
            item["action"] = "copy incoming tree"
            plan["tree_add"].append(item)

    selected_set = set(selected_names)

    for name in sorted(current_trees):
        if name not in selected_set:
            plan["tree_keep"].append(
                {
                    "path": name,
                    "reason": "RHEL major not present/selected in incoming source",
                    "action": "leave unchanged",
                    "current": extracted_iso_tree_info(current_trees[name]),
                }
            )

    return plan


def plan_counts(plan):
    """Return plan count summary."""
    return {
        "add": len(plan.get("add", [])),
        "update": len(plan.get("update", [])),
        "bundle_managed_update": len(plan.get("bundle_managed_update", [])),
        "remove": len(plan.get("remove", [])),
        "preserve": len(plan.get("preserve", [])),
        "conflicts": len(plan.get("conflicts", [])),
        "unchanged": len(plan.get("unchanged", [])),
        "local_untracked": len(plan.get("local_untracked", [])),
        "skipped": len(plan.get("skipped", [])),
        "warnings": len(plan.get("warnings", [])),
        "notes": len(plan.get("notes", [])),
        "tree_add": len(plan.get("tree_add", [])),
        "tree_replace": len(plan.get("tree_replace", [])),
        "tree_keep": len(plan.get("tree_keep", [])),
        "tree_skipped": len(plan.get("tree_skipped", [])),
    }


def plan_display_limit(show_all_files=False):
    """Return file-list display limit for terminal output."""
    if show_all_files:
        return None

    return DEFAULT_FILE_LIST_LIMIT


def important_skipped_count(plan):
    """Return count of skipped entries, mostly for terminal summary."""
    return len(plan.get("skipped", []))


def print_skipped_summary(plan):
    """Print a short skipped summary without flooding the terminal."""
    skipped = important_skipped_count(plan)

    if not skipped:
        return

    print("")
    print("Skipped entries:")
    print("  {}".format(skipped))
    print("  Mostly symlinks, link members, preserved directories, or non-regular files.")
    print("  Use --show-files --show-skipped to list them.")
    print("  Full skipped details are written to the sync report.")


def print_path_list(title, items, limit=None, show_details=True, intro=None):
    """Print list of planned paths."""
    items = list(items or [])

    if not items:
        return

    print("")
    print(title)

    if intro:
        print("  {}".format(intro))

    count = 0
    for item in items:
        count += 1

        if limit and count > limit:
            print("  ... {} more".format(len(items) - limit))
            print("  Use --show-all-files to show the full list.")
            break

        if isinstance(item, dict):
            path = item.get("path") or item.get("name") or str(item)
            reason = item.get("reason")
            action = item.get("action")

            if show_details and reason and action:
                print("  - {} ({}, {})".format(path, reason, action))
            elif show_details and reason:
                print("  - {} ({})".format(path, reason))
            else:
                print("  - {}".format(path))
        else:
            print("  - {}".format(item))


def print_repo_metadata_details(plan):
    """Print repo metadata details for repos section."""
    if plan.get("section") != SECTION_REPOS:
        return

    repo_metadata = plan.get("repo_metadata") or {}

    if not repo_metadata:
        return

    repo_majors = plan.get("repo_majors") or {}
    incoming_majors = repo_majors.get("incoming") or []
    by_major = repo_majors.get("incoming_top_levels_by_major") or {}

    if incoming_majors:
        print("")
        print("Repo RHEL majors:")
        for major in incoming_majors:
            top_levels = by_major.get(major, [])
            if top_levels:
                print("  - {}: {}".format(major, ", ".join(top_levels)))
            else:
                print("  - {}".format(major))

    print("")
    print("Repo metadata:")

    for tree_name, tree_info in sorted(repo_metadata.items()):
        metadata_count = tree_info.get("metadata_count", 0)
        normalized = tree_info.get("normalized_tree") or tree_name
        normalized_major = tree_info.get("normalized_major") or "unknown"

        print("  - {} ({})".format(tree_name, normalized))
        print("      normalized major: {}".format(normalized_major))
        print("      metadata locations: {}".format(metadata_count))

        for path in tree_info.get("metadata_dirs", [])[:5]:
            print("        - {}".format(path))

        extra_count = len(tree_info.get("metadata_dirs", [])) - 5
        if extra_count > 0:
            print("        ... {} more".format(extra_count))


def print_extracted_iso_tree_details(plan):
    """Print extracted ISO current/incoming tree details."""
    if plan.get("section") != SECTION_EXTRACTED_ISOS:
        return

    items = []
    items.extend(plan.get("tree_add", []))
    items.extend(plan.get("tree_replace", []))
    items.extend(plan.get("tree_keep", []))

    if not items:
        return

    print("")
    print("Extracted ISO trees:")

    for item in items:
        path = item.get("path")
        incoming = item.get("incoming")
        current = item.get("current")
        action = item.get("action") or "leave unchanged"

        print("  - {}".format(path))
        print("      action:   {}".format(action))

        if current:
            print("      current:  {}".format(extracted_iso_version_label(current)))
        else:
            print("      current:  none")

        if incoming:
            print("      incoming: {}".format(extracted_iso_version_label(incoming)))

        if item.get("target"):
            print("      target:   {}".format(item.get("target")))

        disk_check = item.get("disk_check")
        if disk_check:
            print("      disk:     free {}, required {}".format(
                disk_check.get("free"),
                disk_check.get("required"),
            ))


def print_plan(
    plan,
    show_files=False,
    show_all_files=False,
    show_skipped=False,
):
    """Print a sync plan."""
    counts = plan_counts(plan)
    limit = plan_display_limit(show_all_files=show_all_files)

    print("AeroLIT sync plan")
    print("")
    print("Section:")
    print("  {}".format(plan["section"]))
    print("")
    print("Source:")
    print("  {}".format(plan["source_path"]))
    print("")
    print("Target:")
    print("  {}".format(plan["target_path"]))
    print("")
    print("Planned changes:")
    print("  add:                    {}".format(counts["add"]))
    print("  update:                 {}".format(counts["update"]))
    print("  bundle-managed updates: {}".format(counts["bundle_managed_update"]))
    print("  remove:                 {}".format(counts["remove"]))
    print("  preserve:               {}".format(counts["preserve"]))
    print("  possible user changes:  {}".format(counts["conflicts"]))
    print("  unchanged:              {}".format(counts["unchanged"]))
    print("  local untracked:        {}".format(counts["local_untracked"]))
    print("  skipped:                {}".format(counts["skipped"]))

    if (
        counts.get("tree_add")
        or counts.get("tree_replace")
        or counts.get("tree_keep")
        or counts.get("tree_skipped")
    ):
        print("  tree add:               {}".format(counts["tree_add"]))
        print("  tree replace:           {}".format(counts["tree_replace"]))
        print("  tree keep:              {}".format(counts["tree_keep"]))
        print("  tree skipped:           {}".format(counts["tree_skipped"]))

    print_repo_metadata_details(plan)
    print_extracted_iso_tree_details(plan)

    if plan.get("warnings"):
        print("")
        print("Warnings:")
        for warning in plan["warnings"]:
            print("  - {}".format(warning))

    if plan.get("notes"):
        print("")
        print("Notes:")
        for note in plan["notes"]:
            print("  - {}".format(note))

    if counts["bundle_managed_update"]:
        print("")
        print("Bundle-managed update note:")
        print(
            "  These are normal bundle-owned collection files that differ from "
            "the incoming bundle."
        )
        print(
            "  They are separated from possible user changes so the plan is easier "
            "to review."
        )

    if counts["conflicts"]:
        print("")
        print("Possible user/manual changes note:")
        print(
            "  These need review because AeroLIT cannot safely prove they are only "
            "old bundle-owned files."
        )

    if counts["skipped"] and not show_skipped:
        print_skipped_summary(plan)

    if show_files:
        print_path_list("Add:", plan.get("add"), limit=limit)
        print_path_list("Update:", plan.get("update"), limit=limit)

        print_path_list(
            "Bundle-managed updates:",
            plan.get("bundle_managed_update"),
            limit=limit,
            show_details=False,
            intro=(
                "Normal vendored collection content that would be refreshed "
                "from the incoming bundle."
            ),
        )

        print_path_list("Remove:", plan.get("remove"), limit=limit)
        print_path_list("Preserve:", plan.get("preserve"), limit=limit)

        print_path_list(
            "Possible user/manual changes:",
            plan.get("conflicts"),
            limit=limit,
        )

        print_path_list(
            "Local untracked files left alone:",
            plan.get("local_untracked"),
            limit=limit,
        )

        if show_skipped:
            print_path_list(
                "Skipped:",
                plan.get("skipped"),
                limit=limit,
                show_details=True,
            )

        print_path_list("Tree add:", plan.get("tree_add"), limit=limit)
        print_path_list("Tree replace:", plan.get("tree_replace"), limit=limit)
        print_path_list("Tree keep:", plan.get("tree_keep"), limit=limit)
        print_path_list("Tree skipped:", plan.get("tree_skipped"), limit=limit)
    else:
        print_path_list(
            "Possible user/manual changes:",
            plan.get("conflicts"),
            limit=20,
        )


def confirm_continue():
    """Prompt user for confirmation."""
    try:
        answer = input("Continue? [y/N] ").strip().lower()
    except EOFError:
        return False

    return answer in ("y", "yes")


def prompt_choice(prompt, valid_choices, default=None):
    """Prompt for one choice."""
    valid_choices = tuple(valid_choices)

    while True:
        try:
            answer = input(prompt).strip().lower()
        except EOFError:
            return default

        if not answer and default:
            return default

        if answer in valid_choices:
            return answer

        print("Please choose one of: {}".format(", ".join(valid_choices)))


def append_unique_plan_item(plan, key, item):
    """Append a plan item if its path is not already present."""
    path = item.get("path")

    for existing in plan.get(key, []):
        if existing.get("path") == path:
            return False

    plan.setdefault(key, []).append(item)
    return True


