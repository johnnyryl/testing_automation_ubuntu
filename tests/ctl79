    return path


def run_sync_rollback(args, raw_args):
    """Run aerolitctl sync rollback."""
    ensure_sync_directories()

    if raw_args and raw_args[0] == "list":
        return print_rollback_report_list()

    bundle_path = resolve_bundle_path(args)
    target_identifier = getattr(args, "rollback_to", None)

    if not target_identifier and raw_args:
        target_identifier = raw_args[0]

    try:
        report_path, report = find_rollback_report(target_identifier)
    except ValueError as exc:
        print("ERROR: {}".format(exc), file=sys.stderr)
        return 1

    if not report_is_rollback_candidate(report):
        print("ERROR: Selected report is not rollback-capable:", file=sys.stderr)
        print("  {}".format(report_path), file=sys.stderr)
        return 1

    sync_lock = SyncLock(sync_lock_file())
    dry_run = bool(getattr(args, "dry_run", False))

    if not dry_run:
        sync_lock.acquire()

    try:
        plan = build_rollback_plan(
            report_path,
            report,
            bundle_path,
            force=getattr(args, "force", False),
        )

        print_rollback_plan(
            plan,
            show_files=getattr(args, "show_files", False),
        )

        if plan.get("conflicts"):
            print("")
            print("Rollback blocked because conflicts were found.")
            print("Review the conflicts above or rerun with --force after confirming.")
            return 2

        if dry_run:
            rollback_report = build_rollback_report(
                report_path,
                plan,
                changed=[],
                current_backup_root=None,
                dry_run=True,
            )
            rollback_report_path = write_rollback_report(rollback_report)

            print("")
            print("Dry run only. No files changed.")
            print("")
            print("Rollback report:")
            print("  {}".format(rollback_report_path))
            return 0

        if not getattr(args, "yes", False):
            print("")
            if not confirm_continue():
                print("Cancelled. No files changed.")
                return 130

        changed, current_backup_root = apply_rollback_plan(
            plan,
            no_backup=getattr(args, "no_backup", False),
        )

        preserve_patterns = load_preserve_patterns(
            sync_preserve_file(bundle_path),
            default_patterns=DEFAULT_COLLECTIONS_HUB_PRESERVE_PATTERNS,
        )

        manifest = load_manifest()
        manifest.setdefault("sections", {})
        manifest["bundle_path"] = str(bundle_path)
        manifest["sections"][SECTION_COLLECTIONS_HUB] = rebuild_section_manifest(
            SECTION_COLLECTIONS_HUB,
            collections_hub_path(bundle_path),
            preserve_patterns,
        )
        save_manifest(manifest)

        rollback_report = build_rollback_report(
            report_path,
            plan,
            changed=changed,
            current_backup_root=current_backup_root,
            dry_run=False,
        )
        rollback_report_path = write_rollback_report(rollback_report)

        print("")
        print("AeroLIT sync rollback completed.")
        print("")
        print("Changed files:")
        print("  {}".format(len(changed)))

        if current_backup_root:
            print("")
            print("Current files backed up before rollback:")
            print("  {}".format(current_backup_root))

        print("")
        print("Updated manifest:")
        print("  {}".format(sync_manifest_file()))
        print("")
        print("Rollback report:")
        print("  {}".format(rollback_report_path))

        return 0

    finally:
        sync_lock.release()


def safe_int(value, default):
    """Return value as int, or default when it cannot be converted."""
    try:
        return int(value)
    except (TypeError, ValueError):
        return default


def cleanup_policy(args):
    """Return cleanup retention policy."""
    sync_config = {}

    try:
        sync_config = load_config().get("sync", {})
    except FileNotFoundError:
        sync_config = {}

    keep = getattr(args, "keep", None)
    days = getattr(args, "days", None)

    if keep is None:
        keep = safe_int(sync_config.get("backup_retention_count"), 5)

    if days is None:
        days = safe_int(sync_config.get("backup_retention_days"), 30)

    if keep < 0:
        keep = 0

    if days < 0:
        days = 0

    return keep, days


def path_mtime(path):
    """Return path mtime, or 0 when unavailable."""
    try:
        return Path(path).stat().st_mtime
    except OSError:
        return 0


def path_size_bytes(path):
    """Return total size for a file or directory."""
    path = Path(path)

    if not path.exists():
        return 0

    if path.is_file():
        try:
            return path.stat().st_size
        except OSError:
            return 0

    total = 0

    for current_root, dirnames, filenames in os.walk(str(path), followlinks=False):
        current_root_path = Path(current_root)

        kept_dirnames = []
        for dirname in dirnames:
            child = current_root_path / dirname
            if child.is_symlink():
                continue
            kept_dirnames.append(dirname)

        dirnames[:] = kept_dirnames

        for filename in filenames:
            item = current_root_path / filename

            try:
                if item.is_symlink() or not item.is_file():
                    continue
                total += item.stat().st_size
            except OSError:
                continue

    return total


def format_bytes(size_bytes):
    """Return human-readable byte size."""
    size = float(size_bytes)

    for suffix in ("B", "KiB", "MiB", "GiB", "TiB"):
        if size < 1024.0 or suffix == "TiB":
            if suffix == "B":
                return "{} {}".format(int(size), suffix)
            return "{:.1f} {}".format(size, suffix)

        size = size / 1024.0

    return "{} B".format(size_bytes)


def cleanup_entry(path, kind, reason):
    """Build one cleanup plan entry."""
    path = Path(path)

    return {
        "kind": kind,
        "path": str(path),
        "reason": reason,
        "mtime": path_mtime(path),
        "size_bytes": path_size_bytes(path),
    }


def newest_first(paths):
    """Return paths sorted newest first."""
    return sorted(
        [Path(path) for path in paths],
        key=lambda item: path_mtime(item),
        reverse=True,
    )


def report_cleanup_candidates(keep, days):
    """Return old sync/rollback report files eligible for cleanup."""
    report_dir = sync_log_dir()

    if not report_dir.exists():
        return []

    reports = []
    reports.extend(report_dir.glob("*-sync-report.yml"))
    reports.extend(report_dir.glob("*-rollback-report.yml"))
    reports = [path for path in reports if path.is_file()]
    reports = newest_first(reports)

    cutoff = time.time() - (days * 24 * 60 * 60)
    candidates = []

    for index, report in enumerate(reports):
        if index < keep:
            continue

        if path_mtime(report) > cutoff:
            continue

        candidates.append(
            cleanup_entry(
                report,
                "report",
                "older than {} days and beyond newest {} reports".format(
                    days,
                    keep,
                ),
            )
        )

    return candidates


def backup_cleanup_candidates(keep, days):
    """Return old sync backup directories eligible for cleanup."""
    backup_dir = sync_backup_dir()

    if not backup_dir.exists():
        return []

    backups = [
        path
        for path in backup_dir.iterdir()
        if path.is_dir()
    ]
    backups = newest_first(backups)

    cutoff = time.time() - (days * 24 * 60 * 60)
    candidates = []

    for index, backup in enumerate(backups):
        if index < keep:
            continue

        if path_mtime(backup) > cutoff:
            continue

        candidates.append(
            cleanup_entry(
                backup,
                "backup",
                "older than {} days and beyond newest {} backups".format(
                    days,
                    keep,
                ),
            )
        )

    return candidates


def staging_cleanup_candidates():
    """Return leftover staging entries eligible for cleanup.

    Staging directories are temporary extraction areas. If they still exist,
    a previous sync was interrupted or did not clean up normally.
    """
    staging_dir = sync_staging_dir()

    if not staging_dir.exists():
        return []

    candidates = []

    for path in newest_first(staging_dir.iterdir()):
        candidates.append(
            cleanup_entry(
                path,
                "staging",
                "leftover sync staging entry",
            )
        )

    return candidates


def build_cleanup_plan(args):
    """Build cleanup plan."""
    keep, days = cleanup_policy(args)

    plan = {
        "keep": keep,
        "days": days,
        "items": [],
        "warnings": [],
    }

    plan["items"].extend(staging_cleanup_candidates())
    plan["items"].extend(backup_cleanup_candidates(keep, days))
    plan["items"].extend(report_cleanup_candidates(keep, days))

    return plan


def cleanup_plan_counts(plan):
    """Return cleanup plan counts."""
    counts = {
        "staging": 0,
        "backup": 0,
        "report": 0,
        "other": 0,
    }

    for item in plan.get("items", []):
        kind = item.get("kind")

        if kind in counts:
            counts[kind] += 1
        else:
            counts["other"] += 1

    return counts


def cleanup_plan_size(plan):
    """Return planned reclaimed bytes."""
    total = 0

    for item in plan.get("items", []):
        total += item.get("size_bytes") or 0

    return total


def print_cleanup_plan(plan, show_files=False):
