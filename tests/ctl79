def apply_plan_for_section(args, bundle_path, manifest, plan, pre_sync_manifest):
    """Apply one already-built section plan and update manifest in memory."""
    section = plan["section"]
    changed = []
    backup_root = None
    pre_sync_manifest_path = None

    added_preserve_patterns = []

    if section == SECTION_COLLECTIONS_HUB:
        added_preserve_patterns = ensure_preserve_file_defaults(
            sync_preserve_file(bundle_path),
            DEFAULT_COLLECTIONS_HUB_PRESERVE_PATTERNS,
        )

    if section == SECTION_COLLECTIONS_HUB:
        section_changed, backup_root = apply_collections_hub_plan(
            plan,
            no_backup=getattr(args, "no_backup", False),
        )
    elif section == SECTION_REPOS:
        section_changed, backup_root = apply_bundle_section_plan(
            plan,
            section,
            no_backup=True,
        )
    elif section == SECTION_EXTRACTED_ISOS:
        section_changed, backup_root = apply_extracted_isos_plan(
            plan,
            keep_old=keep_old_iso_tree_requested(args),
        )
    else:
        section_changed, backup_root = apply_bundle_section_plan(
            plan,
            section,
            no_backup=getattr(args, "no_backup", False),
        )

    changed.extend(section_changed)

    if backup_root:
        pre_sync_manifest_path = write_pre_sync_manifest_backup(
            backup_root,
            pre_sync_manifest,
        )

    for pattern in added_preserve_patterns:
        changed.append(
            {
                "action": "preserve-default",
                "path": str(sync_preserve_file(bundle_path)),
                "pattern": pattern,
                "section": section,
            }
        )

    preserve_patterns = section_preserve_patterns(bundle_path, section)

    manifest.setdefault("sections", {})
    manifest["bundle_path"] = str(bundle_path)

    if section == SECTION_EXTRACTED_ISOS:
        manifest["sections"][section] = rebuild_extracted_isos_manifest(
            section_target_path(bundle_path, section),
        )
    else:
        manifest["sections"][section] = rebuild_section_manifest(
            section,
            section_target_path(bundle_path, section),
            preserve_patterns,
        )

    apply_source_version_metadata_to_manifest_section(
        manifest,
        section,
        plan,
    )

    return {
        "section": section,
        "changed": changed,
        "backup_root": backup_root,
        "pre_sync_manifest_path": pre_sync_manifest_path,
    }


def build_multi_apply_report(
    source,
    bundle_path,
    detected_sections,
    plans,
    apply_results,
    backup_infos,
    dry_run,
    started_at=None,
    source_root=None,
    argv=None,
):
    """Build a multi-section sync apply report."""
    duration_seconds = None

    if started_at is not None:
        duration_seconds = round(time.time() - started_at, 3)

    changed = []
    for result in apply_results:
        changed.extend(result.get("changed", []))

    plan_documents = []

    for plan in plans:
        plan_documents.append(
            {
                "section": plan["section"],
                "source_path": plan.get("source_path"),
                "target_path": plan.get("target_path"),
                "counts": plan_counts(plan),
                "warnings": list(plan.get("warnings", [])),
                "notes": list(plan.get("notes", [])),
                "conflicts": report_plan_items(plan, "conflicts"),
                "files": report_plan_files(plan),
                "repo_metadata": report_safe_value(plan.get("repo_metadata", {})),
                "repo_majors": report_safe_value(plan.get("repo_majors", {})),
                "source_version": report_safe_value(
                    plan.get("source_version", {})
                ),
            }
        )

    backups = []
    for info in backup_infos:
        backup_root = info.get("backup_root")
        backups.append(
            {
                "section": info.get("section"),
                "backup_root": str(backup_root) if backup_root else None,
                "pre_sync_manifest": (
                    str(info.get("pre_sync_manifest_path"))
                    if info.get("pre_sync_manifest_path")
                    else None
                ),
                "summary": backup_summary(backup_root),
            }
        )

    return {
        "kind": "AeroLITMultiSectionSyncReport",
        "created_utc": utc_iso(),
        "duration_seconds": duration_seconds,
        "dry_run": bool(dry_run),
        "source": str(source),
        "argv": list(argv or []),
        "source_metadata": source_report_metadata(
            source,
            source_root=source_root,
        ),
        "bundle_path": str(bundle_path),
        "detected_sections": sorted(detected_sections.keys()),
        "detected_section_paths": detected_section_paths(detected_sections),
        "manifest_file": str(sync_manifest_file()),
        "combined_counts": combined_plan_counts(plans),
        "plans": plan_documents,
        "changed": report_safe_value(changed),
        "backups": report_safe_value(backups),
    }


def write_multi_backup_metadata(backup_infos, report_path, report):
    """Write backup metadata files for a multi-section sync."""
    metadata_paths = []

    for info in backup_infos:
        backup_root = info.get("backup_root")

        if not backup_root:
            continue

        fake_report = {
            "source": report.get("source"),
            "plan": {
                "section": info.get("section"),
            },
        }

        metadata_path = write_backup_metadata(
            backup_root,
            report_path,
            fake_report,
            pre_sync_manifest_path=info.get("pre_sync_manifest_path"),
        )

        if metadata_path:
            metadata_paths.append(str(metadata_path))
            info["backup_metadata"] = str(metadata_path)

    return metadata_paths


def record_manifest_multi_sync_report(report_path, report):
    """Record last successful multi-section sync details in the manifest."""
    if report.get("dry_run"):
        return

    manifest = load_manifest()
    source_metadata = report.get("source_metadata", {})
    plans = report.get("plans", [])

    sections = []
    for plan in plans:
        section = plan.get("section")
        if section:
            sections.append(section)

    entry = {
        "created_utc": report.get("created_utc"),
        "report": str(report_path),
        "source": report.get("source"),
        "source_sha256": source_metadata.get("sha256"),
        "section": "all",
        "sections": sections,
    }

    history = list(manifest.get("sync_history", []))
    history.append(entry)

    manifest["last_sync_report"] = str(report_path)
    manifest["last_sync_utc"] = report.get("created_utc")
    manifest["last_sync_source"] = report.get("source")
    manifest["last_sync_source_sha256"] = source_metadata.get("sha256")
    manifest["sync_history"] = history[-20:]

    save_manifest(manifest)


def run_multi_section_plan_only(
    args,
    source,
    bundle_path,
    source_root,
    detected_sections,
    extract_skipped,
):
    """Build, review, and optionally apply a multi-section sync."""
    started_at = time.time()
    dry_run = bool(getattr(args, "dry_run", False))
    manifest = load_manifest()
    pre_sync_manifest = report_safe_value(manifest)

    sections = detected_supported_section_names(detected_sections)

    if not sections:
        print("ERROR: No supported sync sections were detected.", file=sys.stderr)
        return 2

    plans = []

    for section in sections:
        plans.append(
            build_sync_plan_for_section(
                args,
                bundle_path,
                manifest,
                detected_sections,
                source_root,
                extract_skipped,
                section,
            )
        )

    output_format = plan_output_format(args)
    plan_document = build_multi_plan_output_document(
        source,
        bundle_path,
        detected_sections,
        plans,
        source_root=source_root,
        argv=getattr(args, "_aerolitctl_argv", []),
    )

    plan_output_path = write_plan_output_file(
        args,
        plan_document,
        output_format,
    )

    if dry_run:
        report_path = write_multi_plan_report(plan_document)

        if output_format != "text":
            print_machine_plan(plan_document, output_format)
            return 0

        print_combined_sync_plan(
            plans,
            show_files=getattr(args, "show_files", False),
            show_all_files=getattr(args, "show_all_files", False),
        )

        print("")
        print("Multi-section plan report:")
        print("  {}".format(report_path))

        if plan_output_path:
            print("")
            print("Plan output:")
            print("  {}".format(plan_output_path))

        print("")
        print("Dry run only. No files changed.")
        return 0

    if output_format != "text" or plan_output_path:
        print(
            "ERROR: --output json/yaml and --plan-output are plan-only features. "
            "Use them with --dry-run.",
            file=sys.stderr,
        )
        return 2

    print_combined_sync_plan(
        plans,
        show_files=getattr(args, "show_files", False),
        show_all_files=getattr(args, "show_all_files", False),
    )

    preserve_file = sync_preserve_file(bundle_path)

    review_conflicts = (
        getattr(args, "review", False)
        or getattr(args, "review_conflicts", False)
    )
    review_removals = (
        getattr(args, "review", False)
        or getattr(args, "review_removals", False)
    )

    if plans_have_conflicts(plans) and review_conflicts:
        resolved = review_multi_section_conflicts(plans, preserve_file)

        if not resolved:
            print("")
            print("Cancelled during multi-section conflict review. No files changed.")
            return 130

        print("")
        print("Updated multi-section sync plan after conflict review:")
        print_combined_sync_plan(plans, show_files=True)

    if plans_have_conflicts(plans):
        print("")
        print("Multi-section sync blocked because possible user/manual changes were found.")
        print_multi_conflict_resolution_help()
        return 2

    if plans_have_removals(plans) and review_removals:
        reviewed = review_multi_section_removals(plans, preserve_file)

        if not reviewed:
            print("")
            print("Cancelled during multi-section removal review. No files changed.")
            return 130

        print("")
        print("Updated multi-section sync plan after removal review:")
        print_combined_sync_plan(plans, show_files=True)

    if not getattr(args, "yes", False):
        print("")
        print("This will apply the selected sections in this order:")
        for plan in plans:
            print("  - {}".format(plan["section"]))
        print("")
        if not confirm_continue():
            print("Cancelled. No files changed.")
            return 130

    apply_results = []
    backup_infos = []

    for plan in plans:
        result = apply_plan_for_section(
            args,
            bundle_path,
            manifest,
            plan,
            pre_sync_manifest,
        )
        apply_results.append(result)

        if result.get("backup_root"):
            backup_infos.append(
                {
                    "section": result.get("section"),
                    "backup_root": result.get("backup_root"),
                    "pre_sync_manifest_path": result.get(
                        "pre_sync_manifest_path"
                    ),
                }
            )

    save_manifest(manifest)

    report = build_multi_apply_report(
        source,
        bundle_path,
        detected_sections,
        plans,
        apply_results,
        backup_infos,
        dry_run=False,
        started_at=started_at,
        source_root=source_root,
        argv=getattr(args, "_aerolitctl_argv", []),
    )
    report_path = write_multi_apply_report(report)

    backup_metadata_paths = write_multi_backup_metadata(
        backup_infos,
        report_path,
        report,
    )

    record_manifest_multi_sync_report(report_path, report)

    changed_count = 0
    for result in apply_results:
        changed_count += len(result.get("changed", []))

    print("")
    print("AeroLIT multi-section sync completed.")
    print("")
    print("Applied sections:")
    for plan in plans:
        print("  - {}".format(plan["section"]))

    print("")
    print("Changed items:")
    print("  {}".format(changed_count))

    if backup_infos:
        print("")
        print("Backups:")
        for info in backup_infos:
            backup_root = info.get("backup_root")
            summary = backup_summary(backup_root)
            print("  - {}: {}".format(info.get("section"), backup_root))
            print("      size: {}".format(summary.get("size", "unknown")))
            print("      files: {}".format(summary.get("file_count", 0)))

    if backup_metadata_paths:
        print("")
        print("Backup metadata:")
        for path in backup_metadata_paths:
            print("  - {}".format(path))

    print("")
    print("Sync report:")
    print("  {}".format(report_path))

    print("")
    print("Updated manifest:")
    print("  {}".format(sync_manifest_file()))

    return 0


def selected_sections(args, detected_sections):
    """Return sections selected for this run."""
    requested = getattr(args, "section", None)

    if requested == "extracted-isos":
        requested = "extracted_isos"

    if not requested or requested == "all":
        return [
            item
            for item in sorted(detected_sections.keys())
            if item in SUPPORTED_SECTIONS
        ]

    return [requested]


def path_mtime_utc(path):
    """Return path modification time as UTC ISO string."""
    path = Path(path)

    try:
        return datetime.utcfromtimestamp(path.stat().st_mtime).replace(
            microsecond=0
        ).isoformat() + "Z"
    except OSError:
        return "unknown"


def newest_file(paths):
    """Return newest existing file from a list of paths."""
    files = [Path(path) for path in paths if Path(path).is_file()]

    if not files:
        return None

    return sorted(files, key=lambda item: item.stat().st_mtime, reverse=True)[0]


def newest_directory(paths):
    """Return newest existing directory from a list of paths."""
    dirs = [Path(path) for path in paths if Path(path).is_dir()]

    if not dirs:
        return None

    return sorted(dirs, key=lambda item: item.stat().st_mtime, reverse=True)[0]


def newest_sync_report():
    """Return newest sync report path."""
    report_dir = sync_log_dir()

    if not report_dir.exists():
        return None

    return newest_file(report_dir.glob("*-sync-report.yml"))


def newest_backup_dir():
    """Return newest sync backup directory."""
    backup_dir = sync_backup_dir()

    if not backup_dir.exists():
        return None

    return newest_directory(backup_dir.iterdir())


def immediate_child_dirs(path):
    """Return immediate child directories."""
    path = Path(path)

    if not path.exists() or not path.is_dir():
        return []

    try:
        return sorted([item for item in path.iterdir() if item.is_dir()])
    except OSError:
        return []


def immediate_child_files(path):
    """Return immediate child files."""
    path = Path(path)

    if not path.exists() or not path.is_dir():
        return []

    try:
        return sorted([item for item in path.iterdir() if item.is_file()])
    except OSError:
        return []


def status_staging_summary():
    """Return staging directory summary."""
    items = immediate_child_dirs(sync_staging_dir())
    total_size = 0

    for item in items:
        total_size += directory_size_bytes(item)

    return {
        "count": len(items),
        "size_bytes": total_size,
        "size": format_bytes(total_size),
        "items": items,
    }


def status_backup_summary():
    """Return backup directory summary."""
    items = immediate_child_dirs(sync_backup_dir())
    total_size = 0

    for item in items:
        total_size += directory_size_bytes(item)

    return {
        "count": len(items),
        "size_bytes": total_size,
        "size": format_bytes(total_size),
        "items": items,
    }


def status_report_summary():
    """Return report file summary."""
    report_dir = sync_log_dir()

    if not report_dir.exists():
        return {
            "count": 0,
            "size_bytes": 0,
            "size": format_bytes(0),
            "items": [],
        }

    items = []
    for pattern in ("*-sync-report.yml", "*-cleanup-report.yml", "*-rollback-report.yml"):
        items.extend(immediate_child_files(report_dir))

    unique = []
    seen = set()
    for item in items:
        if str(item) in seen:
            continue
        seen.add(str(item))
        unique.append(item)

    total_size = 0
    for item in unique:
        try:
            total_size += item.stat().st_size
        except OSError:
            pass

    return {
        "count": len(unique),
        "size_bytes": total_size,
        "size": format_bytes(total_size),
        "items": unique,
    }


def configured_sync_retention():
    """Return configured sync retention values."""
    try:
        config = load_config()
    except Exception:
        config = {}

    sync_config = config.get("sync", {})

    return {
        "keep": sync_config.get("backup_retention_count", 5),
        "days": sync_config.get("backup_retention_days", 30),
    }


def manifest_locally_modified_files(bundle_path, manifest, limit=20):
    """Return tracked files that no longer match the installed manifest."""
    modified = []

    for section_name, section in sorted(manifest.get("sections", {}).items()):
        if section_name == SECTION_EXTRACTED_ISOS:
            continue

        files = section.get("files", {})
        if not files:
            continue

        try:
            root = section_target_path(bundle_path, section_name)
        except ValueError:
            root = Path(section.get("root") or "")

        if not root:
            continue

        for relative, meta in sorted(files.items()):
            expected = meta.get("checksum")
            if not expected:
                continue

            path = Path(root) / relative

            if not path.exists():
                modified.append(
                    {
                        "section": section_name,
                        "path": relative,
                        "status": "missing",
                    }
                )
                if len(modified) >= limit:
                    return modified
                continue

            if not path.is_file():
                modified.append(
                    {
                        "section": section_name,
                        "path": relative,
                        "status": "not regular file",
                    }
                )
                if len(modified) >= limit:
                    return modified
                continue

            try:
                current = sha256_file(path)
            except OSError:
                modified.append(
                    {
                        "section": section_name,
                        "path": relative,
                        "status": "could not checksum",
                    }
                )
                if len(modified) >= limit:
                    return modified
                continue

            if current != expected:
                modified.append(
                    {
                        "section": section_name,
                        "path": relative,
                        "status": "modified",
                    }
                )
                if len(modified) >= limit:
                    return modified

    return modified


