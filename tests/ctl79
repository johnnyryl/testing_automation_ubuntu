def utc_stamp():
    """Return a filesystem-safe UTC timestamp."""
    return datetime.utcnow().strftime("%Y%m%d-%H%M%S")


def utc_iso():
    """Return an ISO UTC timestamp."""
    return datetime.utcnow().replace(microsecond=0).isoformat() + "Z"


def ensure_sync_directories():
    """Create sync state directories."""
    for path in (
        sync_staging_dir(),
        sync_backup_dir(),
        sync_log_dir(),
        sync_manifest_file().parent,
    ):
        Path(path).mkdir(parents=True, exist_ok=True)


def read_yaml_file(path, default=None):
    """Read YAML from a path, returning default when missing."""
    path = Path(path)

    if not path.exists():
        return default

    with path.open("r") as handle:
        return yaml_load(handle) or default


def write_yaml_file(path, data):
    """Write YAML to a path."""
    path = Path(path)
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(yaml_dump(data))


def sha256_file(path):
    """Return SHA256 checksum for one file."""
    digest = hashlib.sha256()

    with Path(path).open("rb") as handle:
        while True:
            chunk = handle.read(1024 * 1024)
            if not chunk:
                break
            digest.update(chunk)

    return digest.hexdigest()


def normalize_relative_path(path):
    """Normalize relative paths to forward-slash format."""
    return str(Path(path)).replace(os.sep, "/")


def relpath(path, root):
    """Return normalized relative path."""
    return normalize_relative_path(Path(path).relative_to(Path(root)))


def is_safe_relative_name(name):
    """Return True if an archive member name is safe to extract."""
    if not name:
        return False

    path = Path(name)

    if path.is_absolute():
        return False

    for part in path.parts:
        if part == "..":
            return False

    return True


def safe_extract_tar(archive_path, destination):
    """Safely extract a tar archive into destination."""
    destination = Path(destination)
    skipped = []

    with tarfile.open(str(archive_path), "r:*") as tar:
        members = tar.getmembers()

        for member in members:
            if not is_safe_relative_name(member.name):
                skipped.append(
                    {
                        "name": member.name,
                        "reason": "unsafe path",
                    }
                )
                continue

            if member.issym() or member.islnk():
                skipped.append(
                    {
                        "name": member.name,
                        "reason": "link member",
                    }
                )
                continue

            if not member.isfile() and not member.isdir():
                skipped.append(
                    {
                        "name": member.name,
                        "reason": "special tar member",
                    }
                )
                continue

            with warnings.catch_warnings():
                warnings.simplefilter("ignore", RuntimeWarning)
                tar.extract(member, str(destination))

    return skipped


def source_is_tar(path):
    """Return True if path looks like a tar archive."""
    path = Path(path)

    if not path.is_file():
        return False

    try:
        return tarfile.is_tarfile(str(path))
    except (OSError, tarfile.TarError):
        return False


def source_basename(path):
    """Return a useful name for source reporting."""
    return Path(path).name.rstrip("/")


def prepare_source(source):
    """Prepare a sync source and return source root plus cleanup path."""
    source = Path(source).expanduser()

    if not source.exists():
        raise FileNotFoundError("Sync source not found: {}".format(source))

    if source.is_dir():
        return source, None, []

    if not source_is_tar(source):
        raise ValueError(
            "Unsupported sync source. Expected a directory or tar archive: {}".format(
                source
            )
        )

    ensure_sync_directories()

    staging_root = (
        sync_staging_dir()
        / "{}-{}".format(utc_stamp(), source_basename(source).replace("/", "_"))
    )
    staging_root.mkdir(parents=True, exist_ok=False)

    skipped = safe_extract_tar(source, staging_root)

    return staging_root, staging_root, skipped


def cleanup_prepared_source(cleanup_path):
    """Remove temporary source staging path."""
    if cleanup_path:
        shutil.rmtree(str(cleanup_path), ignore_errors=True)


def _children(path):
    """Return immediate child directories for a path."""
    path = Path(path)

    try:
        return [item for item in path.iterdir() if item.is_dir()]
    except OSError:
        return []


def candidate_roots(root):
    """Return possible roots to inspect for bundle sections."""
    root = Path(root)
    candidates = [root]

    for child in _children(root):
        candidates.append(child)

    return candidates


def is_collections_hub_like(path):
    """Return True if a path looks like a collections-hub root."""
    path = Path(path)

    if not path.is_dir():
        return False

    if not (path / "ansible").is_dir():
        return False

    if (path / "collections").is_dir():
        return True

    if (path / "templates").is_dir():
        return True

    if (path / "docs").is_dir():
        return True

    return False


def first_existing_directory(paths):
    """Return first existing directory from paths."""
    for path in paths:
        path = Path(path)
        if path.is_dir():
            return path

    return None


def detect_sections(source_root):
    """Detect sync sections present in a prepared source."""
    source_root = Path(source_root)
    detected = {}

    for root in candidate_roots(source_root):
        collections_candidate = first_existing_directory(
            (
                root / "collections-hub",
                root / "collections_hub",
            )
        )

        if collections_candidate:
            detected[SECTION_COLLECTIONS_HUB] = collections_candidate
            break

        if is_collections_hub_like(root):
            detected[SECTION_COLLECTIONS_HUB] = root
            break

    for root in candidate_roots(source_root):
        if "files" not in detected and (root / "files").is_dir():
            detected["files"] = root / "files"

        if "repos" not in detected and (root / "repos").is_dir():
            detected["repos"] = root / "repos"

        if "extracted_isos" not in detected:
            extracted_isos = first_existing_directory(
                (
                    root / "extracted_isos",
                    root / "extracted-isos",
                    root / "extractedisos",
                )
            )
            if extracted_isos:
                detected["extracted_isos"] = extracted_isos

    return detected


def skipped_entry_name(item):
    """Return normalized skipped entry name."""
    if not isinstance(item, dict):
        return normalize_relative_path(str(item))

    return normalize_relative_path(
        item.get("path") or item.get("name") or ""
    )


def extract_skipped_for_section(extract_skipped, source_root, section_source_path):
    """Return skipped archive entries that belong to the active section."""
    if not extract_skipped:
        return []

    try:
        section_prefix = relpath(section_source_path, source_root)
    except ValueError:
        return list(extract_skipped)

    section_prefix = normalize_relative_path(section_prefix).rstrip("/")
    filtered = []

    for item in extract_skipped:
        name = skipped_entry_name(item)

        if name == section_prefix or name.startswith(section_prefix + "/"):
            filtered.append(item)

    return filtered


def load_manifest():
    """Load installed sync manifest."""
    data = read_yaml_file(sync_manifest_file(), default=None)

    if not data:
        return {
            "kind": MANIFEST_KIND,
            "version": 1,
            "created_utc": utc_iso(),
            "updated_utc": None,
            "bundle_path": None,
            "sections": {},
        }

    if not isinstance(data, dict):
        raise ValueError("Sync manifest is not a YAML mapping: {}".format(sync_manifest_file()))

    return data


def save_manifest(manifest):
    """Save installed sync manifest."""
    manifest["kind"] = MANIFEST_KIND
    manifest["version"] = manifest.get("version", 1)
    manifest["updated_utc"] = utc_iso()
    write_yaml_file(sync_manifest_file(), manifest)


def load_preserve_patterns(preserve_file, default_patterns=None):
    """Load line-based preserve patterns.

    The collections-hub .sync-preserve file is intentionally treated as a
    simple line-based pattern file so it remains portable for GitLab/rsync use.
    """
    patterns = []

    for pattern in list(default_patterns or []):
        if pattern not in patterns:
            patterns.append(pattern)

    preserve_file = Path(preserve_file)

    if not preserve_file.exists():
        return patterns

    with preserve_file.open("r") as handle:
        for raw_line in handle:
            line = raw_line.strip()

            if not line:
                continue

            if line.startswith("#"):
                continue

            if line not in patterns:
                patterns.append(line)

    return patterns


def ensure_preserve_file_defaults(preserve_file, default_patterns):
    """Append missing default preserve patterns to the portable preserve file."""
    preserve_file = Path(preserve_file)
    existing_patterns = []
    existing_text = ""

    if preserve_file.exists():
        existing_text = preserve_file.read_text()
        for raw_line in existing_text.splitlines():
            line = raw_line.strip()
            if line and not line.startswith("#"):
                existing_patterns.append(line)

    missing = []
    for pattern in default_patterns:
        if pattern not in existing_patterns:
            missing.append(pattern)

    if not missing:
        return []

    preserve_file.parent.mkdir(parents=True, exist_ok=True)

    with preserve_file.open("a") as handle:
        if existing_text and not existing_text.endswith("\n"):
            handle.write("\n")

        handle.write("\n")
        handle.write("# AeroLIT default sync preserve rules\n")
        handle.write("# Added by aerolitctl sync on {}\n".format(utc_iso()))

        for pattern in missing:
            handle.write("{}\n".format(pattern))

    return missing


def normalize_preserve_pattern(pattern):
    """Normalize a preserve pattern for storage in collections-hub .sync-preserve."""
    pattern = str(pattern).strip()

    while pattern.startswith("./"):
        pattern = pattern[2:]

    if pattern.startswith("collections-hub/"):
        pattern = pattern[len("collections-hub/"):]

    pattern = pattern.lstrip("/")

    return pattern


def read_preserve_file_entries(preserve_file):
    """Return comments, patterns, and raw lines from the preserve file."""
    preserve_file = Path(preserve_file)

    if not preserve_file.exists():
        return {
            "exists": False,
            "comments": [],
            "patterns": [],
            "lines": [],
        }

    lines = preserve_file.read_text().splitlines()
    comments = []
    patterns = []

    for line in lines:
        stripped = line.strip()

        if not stripped:
            continue

        if stripped.startswith("#"):
            comments.append(stripped)
            continue

        patterns.append(stripped)

    return {
        "exists": True,
        "comments": comments,
        "patterns": patterns,
        "lines": lines,
    }


def write_preserve_file_patterns(preserve_file, patterns):
    """Write preserve patterns to the portable preserve file."""
    preserve_file = Path(preserve_file)
    preserve_file.parent.mkdir(parents=True, exist_ok=True)

    unique_patterns = []
    for pattern in patterns:
        pattern = normalize_preserve_pattern(pattern)
        if pattern and pattern not in unique_patterns:
            unique_patterns.append(pattern)

    lines = [
        "# AeroLIT collections-hub sync preserve file",
        "# Patterns are relative to the collections-hub directory.",
        "# Example: ansible/inventory/**",
        "",
    ]

    lines.extend(unique_patterns)
    preserve_file.write_text("\n".join(lines) + "\n")


def add_preserve_pattern(preserve_file, pattern):
    """Add one preserve pattern if missing."""
    pattern = normalize_preserve_pattern(pattern)

    if not pattern:
        raise ValueError("Preserve pattern cannot be empty.")

    entries = read_preserve_file_entries(preserve_file)
    patterns = list(entries["patterns"])

    if pattern in patterns:
        return False, pattern

    patterns.append(pattern)

    if entries["exists"]:
        preserve_file = Path(preserve_file)
        existing_text = preserve_file.read_text()

        with preserve_file.open("a") as handle:
            if existing_text and not existing_text.endswith("\n"):
                handle.write("\n")
            handle.write("{}\n".format(pattern))
    else:
        write_preserve_file_patterns(preserve_file, patterns)

    return True, pattern


def remove_preserve_pattern(preserve_file, pattern):
    """Remove one preserve pattern if present."""
    pattern = normalize_preserve_pattern(pattern)
    entries = read_preserve_file_entries(preserve_file)
    patterns = list(entries["patterns"])

    if pattern not in patterns:
        return False, pattern

    patterns = [item for item in patterns if item != pattern]
    write_preserve_file_patterns(preserve_file, patterns)

    return True, pattern


def print_preserve_patterns(bundle_path, include_defaults=False):
    """Print preserve patterns for the active collections-hub."""
    preserve_file = sync_preserve_file(bundle_path)
    entries = read_preserve_file_entries(preserve_file)

    print("AeroLIT sync preserve rules")
    print("")
    print("Bundle path:")
    print("  {}".format(bundle_path))
    print("")
    print("Preserve file:")
    print("  {}".format(preserve_file))
    print("")

    if entries["patterns"]:
        print("User/project preserve patterns:")
        for pattern in entries["patterns"]:
            print("  - {}".format(pattern))
    else:
        print("User/project preserve patterns:")
        print("  none")

    if include_defaults:
        print("")
        print("Built-in default preserve patterns:")
        for pattern in DEFAULT_COLLECTIONS_HUB_PRESERVE_PATTERNS:
            print("  - {}".format(pattern))

    return 0


def run_sync_preserve(args, raw_args):
    """Run aerolitctl sync preserve commands."""
    bundle_path = resolve_bundle_path(args)
    preserve_file = sync_preserve_file(bundle_path)

    if not raw_args:
        print("ERROR: Missing preserve command.", file=sys.stderr)
        print("", file=sys.stderr)
        print("Examples:", file=sys.stderr)
        print("  aerolitctl sync preserve list", file=sys.stderr)
        print("  aerolitctl sync preserve add ansible/group_vars/all/site.yml", file=sys.stderr)
        print("  aerolitctl sync preserve remove ansible/group_vars/all/site.yml", file=sys.stderr)
        print("  aerolitctl sync preserve defaults", file=sys.stderr)
        return 2

    command = raw_args[0]

    if command == "list":
        include_defaults = (
            getattr(args, "defaults", False)
            or getattr(args, "all", False)
            or "--defaults" in raw_args
            or "--all" in raw_args
        )
        return print_preserve_patterns(
            bundle_path,
            include_defaults=include_defaults,
        )

    if command == "defaults":
        added = ensure_preserve_file_defaults(
            preserve_file,
            DEFAULT_COLLECTIONS_HUB_PRESERVE_PATTERNS,
        )

        print("AeroLIT sync preserve defaults")
        print("")
        print("Preserve file:")
        print("  {}".format(preserve_file))
        print("")

        if not added:
            print("No changes made. Default preserve rules are already present.")
            return 0

        print("Added default preserve patterns:")
        for pattern in added:
            print("  - {}".format(pattern))

        return 0

    if command == "add":
        if len(raw_args) < 2:
            print("ERROR: Missing preserve pattern to add.", file=sys.stderr)
            return 2

        changed_any = False

        for pattern in raw_args[1:]:
            changed, normalized = add_preserve_pattern(preserve_file, pattern)
            changed_any = changed_any or changed

            if changed:
                print("Added preserve pattern:")
            else:
                print("Preserve pattern already exists:")

            print("  {}".format(normalized))

        print("")
        print("Preserve file:")
        print("  {}".format(preserve_file))

        return 0 if changed_any else 0

    if command == "remove":
        if len(raw_args) < 2:
            print("ERROR: Missing preserve pattern to remove.", file=sys.stderr)
            return 2

        changed_any = False

        for pattern in raw_args[1:]:
            changed, normalized = remove_preserve_pattern(preserve_file, pattern)
            changed_any = changed_any or changed

            if changed:
                print("Removed preserve pattern:")
            else:
                print("Preserve pattern not found:")

            print("  {}".format(normalized))

        print("")
        print("Preserve file:")
        print("  {}".format(preserve_file))

        return 0 if changed_any else 1

    print("ERROR: Unknown preserve command: {}".format(command), file=sys.stderr)
    print("", file=sys.stderr)
    print("Valid commands:", file=sys.stderr)
    print("  list", file=sys.stderr)
    print("  add", file=sys.stderr)
    print("  remove", file=sys.stderr)
    print("  defaults", file=sys.stderr)
    return 2


def pattern_variants(pattern):
    """Return useful variants for one preserve pattern."""
    pattern = normalize_relative_path(pattern.strip())

    if pattern.startswith("./"):
        pattern = pattern[2:]

    variants = [pattern]

    if pattern.startswith("collections-hub/"):
        variants.append(pattern[len("collections-hub/"):])

    return variants


def path_matches_pattern(relative_path, pattern):
    """Return True when a relative path matches one preserve pattern."""
    relative_path = normalize_relative_path(relative_path)

    for variant in pattern_variants(pattern):
        if fnmatch.fnmatchcase(relative_path, variant):
            return True

        if variant.endswith("/**"):
            prefix = variant[:-3]
            if relative_path == prefix or relative_path.startswith(prefix + "/"):
                return True

        if variant.endswith("/"):
            prefix = variant.rstrip("/")
            if relative_path == prefix or relative_path.startswith(prefix + "/"):
                return True

    return False


def is_preserved(relative_path, patterns):
    """Return True when a relative path is protected by preserve rules."""
    for pattern in patterns:
        if path_matches_pattern(relative_path, pattern):
            return True

    return False


def is_bundle_managed_collections_path(relative_path):
    """Return True when a collections-hub path is normal bundle-managed content."""
    for pattern in BUNDLE_MANAGED_COLLECTIONS_PATTERNS:
        if path_matches_pattern(relative_path, pattern):
            return True

    return False


def scan_files(root, preserve_patterns=None):
    """Scan regular files under root and return metadata by relative path."""
    root = Path(root)
    preserve_patterns = list(preserve_patterns or [])
    files = {}
    skipped = []

    if not root.exists():
        return files, skipped

    for current_root, dirnames, filenames in os.walk(
        str(root),
        topdown=True,
        followlinks=False,
    ):
        current_root_path = Path(current_root)

        kept_dirnames = []
        for dirname in sorted(dirnames):
            child_dir = current_root_path / dirname
            relative = relpath(child_dir, root)

            if child_dir.is_symlink():
                skipped.append(
                    {
                        "path": relative,
                        "reason": "symlink directory",
                    }
                )
                continue

            if is_preserved(relative, preserve_patterns):
                skipped.append(
                    {
                        "path": relative,
                        "reason": "preserved directory",
                    }
                )
                continue

            kept_dirnames.append(dirname)

        dirnames[:] = kept_dirnames

        for filename in sorted(filenames):
            path = current_root_path / filename
            relative = relpath(path, root)

            try:
                if path.is_symlink():
                    skipped.append(
                        {
                            "path": relative,
                            "reason": "symlink",
                        }
                    )
                    continue

                if not path.is_file():
                    skipped.append(
                        {
                            "path": relative,
                            "reason": "not a regular file",
                        }
                    )
                    continue

                stat_result = path.stat()
                preserved = is_preserved(relative, preserve_patterns)

                if preserved:
                    files[relative] = {
                        "path": path,
                        "checksum": None,
                        "size_bytes": stat_result.st_size,
                        "mode": stat_result.st_mode & 0o777,
                        "preserved": True,
                    }
                    continue

                files[relative] = {
                    "path": path,
                    "checksum": sha256_file(path),
                    "size_bytes": stat_result.st_size,
                    "mode": stat_result.st_mode & 0o777,
                    "preserved": False,
                }
            except OSError as exc:
                skipped.append(
                    {
                        "path": relative,
                        "reason": "could not inspect file: {}".format(exc),
                    }
                )

    return files, skipped


def empty_plan(section, source_path, target_path):
    """Return an empty sync plan."""
    return {
        "section": section,
        "source_path": str(source_path),
        "target_path": str(target_path),
        "add": [],
        "update": [],
        "bundle_managed_update": [],
        "remove": [],
        "preserve": [],
        "conflicts": [],
        "unchanged": [],
        "local_untracked": [],
        "skipped": [],
        "warnings": [],
    }


def manifest_section_files(manifest, section):
    """Return manifest file mapping for a section."""
    return (
        manifest
        .get("sections", {})
        .get(section, {})
        .get("files", {})
    )


def build_collections_hub_plan(source_path, target_path, manifest, force=False):
    """Build collections-hub smart sync plan."""
    preserve_patterns = load_preserve_patterns(
        sync_preserve_file(target_path.parent),
        default_patterns=DEFAULT_COLLECTIONS_HUB_PRESERVE_PATTERNS,
    )

    source_files, source_skipped = scan_files(source_path, preserve_patterns=preserve_patterns)
    target_files, target_skipped = scan_files(target_path, preserve_patterns=preserve_patterns)

    plan = empty_plan(SECTION_COLLECTIONS_HUB, source_path, target_path)
    plan["skipped"].extend(source_skipped)
    plan["skipped"].extend(target_skipped)

    previous_files = manifest_section_files(manifest, SECTION_COLLECTIONS_HUB)
    previous_exists = bool(previous_files)

    if not previous_exists:
        plan["warnings"].append(
            "No installed collections-hub sync manifest exists yet. "
            "Existing changed files will be treated carefully. "
            "Use --force to replace differing files after reviewing the plan."
        )

    for relative in sorted(source_files):
        source_meta = source_files[relative]
        target_meta = target_files.get(relative)

        if source_meta.get("preserved"):
            plan["preserve"].append(
                {
                    "path": relative,
                    "reason": "preserve rule",
                    "action": "skip incoming file",
                }
            )
            continue

        if target_meta is None:
            plan["add"].append({"path": relative})
            continue

        if target_meta["checksum"] == source_meta["checksum"]:
            plan["unchanged"].append({"path": relative})
            continue

        previous_meta = previous_files.get(relative)
        previous_checksum = None
        if previous_meta:
            previous_checksum = previous_meta.get("checksum")

        if previous_checksum and target_meta["checksum"] != previous_checksum and not force:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "local file changed since last sync",
                    "action": "would update from incoming source",
                }
            )
            continue

        if not previous_checksum and not force:
            if is_bundle_managed_collections_path(relative):
                plan["bundle_managed_update"].append(
                    {
                        "path": relative,
                        "reason": (
                            "bundle-managed collection content; no previous "
                            "sync baseline exists yet"
                        ),
                        "action": "would update from incoming source",
                    }
                )
                continue

            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": (
                        "existing file differs and no previous sync checksum "
                        "is available"
                    ),
                    "action": "would update from incoming source",
                }
            )
            continue

        if is_bundle_managed_collections_path(relative):
            plan["bundle_managed_update"].append(
                {
                    "path": relative,
                    "reason": "bundle-managed collection content",
                    "action": "would update from incoming source",
                }
            )
            continue

        plan["update"].append({"path": relative})

    for relative in sorted(previous_files):
        if relative in source_files:
            continue

        target_meta = target_files.get(relative)
        if target_meta is None:
            continue

        if is_preserved(relative, preserve_patterns):
            plan["preserve"].append(
                {
                    "path": relative,
                    "reason": "preserve rule",
                    "action": "skip removal",
                }
            )
            continue

        previous_checksum = previous_files[relative].get("checksum")

        if previous_checksum and target_meta["checksum"] == previous_checksum:
            plan["remove"].append({"path": relative})
        else:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "file removed from incoming source but changed locally",
                    "action": "would remove old bundle-owned file",
                }
            )

    for relative in sorted(target_files):
        if relative in source_files:
            continue

        if relative in previous_files:
            continue

        if target_files[relative].get("preserved"):
            continue

        plan["local_untracked"].append({"path": relative})

    return plan, source_files


def build_files_plan(source_path, target_path, manifest, force=False, mode="additive"):
    """Build files/ sync plan."""
    preserve_patterns = load_preserve_patterns(
        sync_preserve_file(target_path.parent),
        default_patterns=DEFAULT_FILES_PRESERVE_PATTERNS,
    )

    source_files, source_skipped = scan_files(
        source_path,
        preserve_patterns=preserve_patterns,
    )
    target_files, target_skipped = scan_files(
        target_path,
        preserve_patterns=preserve_patterns,
    )

    plan = empty_plan(SECTION_FILES, source_path, target_path)
    plan["skipped"].extend(source_skipped)
    plan["skipped"].extend(target_skipped)

    previous_files = manifest_section_files(manifest, SECTION_FILES)
    previous_exists = bool(previous_files)

    if not previous_exists:
        plan["warnings"].append(
            "No installed files/ sync manifest exists yet. "
            "Existing differing files will be treated carefully. "
            "Use --force only after reviewing the plan."
        )

    if mode == "mirror":
        plan["warnings"].append(
            "files/ mirror mode can remove old tracked files missing from the "
            "incoming source. Review removals before applying."
        )

    for relative in sorted(source_files):
        source_meta = source_files[relative]
        target_meta = target_files.get(relative)

        if source_meta.get("preserved"):
            plan["preserve"].append(
                {
                    "path": relative,
                    "reason": "preserve rule",
                    "action": "skip incoming file",
                }
            )
            continue

        if target_meta is None:
            plan["add"].append({"path": relative})
            continue

        if target_meta.get("preserved"):
            plan["preserve"].append(
                {
                    "path": relative,
                    "reason": "preserve rule",
                    "action": "keep local file",
                }
            )
            continue

        if target_meta["checksum"] == source_meta["checksum"]:
            plan["unchanged"].append({"path": relative})
            continue

        previous_meta = previous_files.get(relative)
        previous_checksum = None
        if previous_meta:
            previous_checksum = previous_meta.get("checksum")

        if previous_checksum and target_meta["checksum"] != previous_checksum and not force:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "local files/ item changed since last sync",
                    "action": "would update from incoming source",
                }
            )
            continue

        if not previous_checksum and not force:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "existing files/ item differs and no previous sync checksum is available",
                    "action": "would update from incoming source",
                }
            )
            continue

        plan["update"].append({"path": relative})

    for relative in sorted(target_files):
        if relative in source_files:
            continue

        target_meta = target_files[relative]

        if target_meta.get("preserved"):
            continue

        previous_meta = previous_files.get(relative)

        if mode != "mirror":
            plan["local_untracked"].append(
                {
                    "path": relative,
                    "reason": "kept by files additive mode",
                }
            )
            continue

        if not previous_meta:
            plan["local_untracked"].append(
                {
                    "path": relative,
                    "reason": "local file not tracked by previous files sync",
                }
            )
            continue

        previous_checksum = previous_meta.get("checksum")

        if previous_checksum and target_meta["checksum"] == previous_checksum:
            plan["remove"].append(
                {
                    "path": relative,
                    "reason": "files mirror mode",
                }
            )
        else:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "file missing from incoming source but changed locally",
                    "action": "would remove old tracked files/ item",
                }
            )

    return plan, source_files


def top_level_name(relative_path):
    """Return the first path component for a relative path."""
    parts = normalize_relative_path(relative_path).split("/")

    if not parts:
        return ""

    return parts[0]


def top_level_names(file_map):
    """Return top-level names from scanned file paths."""
    names = set()

    for relative in file_map:
        name = top_level_name(relative)

        if name:
            names.add(name)

    return names


def build_repos_plan(source_path, target_path, manifest, force=False, mode="additive"):
    """Build repos/ sync plan.

    Additive mode keeps older local packages and metadata.

    Mirror mode only removes tracked files under repo top-level trees that are
    present in the incoming source. That prevents a RHEL 8-only repo update from
    deleting existing RHEL 9 or RHEL 10 repo trees.
    """
    source_files, source_skipped = scan_files(source_path, preserve_patterns=[])
    target_files, target_skipped = scan_files(target_path, preserve_patterns=[])

    plan = empty_plan(SECTION_REPOS, source_path, target_path)
    plan["skipped"].extend(source_skipped)
    plan["skipped"].extend(target_skipped)

    previous_files = manifest_section_files(manifest, SECTION_REPOS)
    previous_exists = bool(previous_files)
    incoming_top_levels = top_level_names(source_files)

    if not previous_exists:
        plan["warnings"].append(
            "No installed repos/ sync manifest exists yet. "
            "Existing differing repo files will be treated carefully. "
            "Use --force only after reviewing the plan."
        )

    if mode == "additive":
        plan["warnings"].append(
            "repos/ additive mode keeps local repo files that are missing from "
            "the incoming source. Older RPMs are not removed."
        )

    if mode == "mirror":
        plan["warnings"].append(
            "repos/ mirror mode can remove old tracked repo files, but only "
            "inside repo trees present in the incoming source."
        )

    for relative in sorted(source_files):
        source_meta = source_files[relative]
        target_meta = target_files.get(relative)

        if target_meta is None:
            plan["add"].append({"path": relative})
            continue

        if target_meta["checksum"] == source_meta["checksum"]:
            plan["unchanged"].append({"path": relative})
            continue

        previous_meta = previous_files.get(relative)
        previous_checksum = None

        if previous_meta:
            previous_checksum = previous_meta.get("checksum")

        if previous_checksum and target_meta["checksum"] != previous_checksum and not force:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "local repo file changed since last sync",
                    "action": "would update from incoming source",
                }
            )
            continue

        if not previous_checksum and not force:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "existing repo file differs and no previous sync checksum is available",
                    "action": "would update from incoming source",
                }
            )
            continue

        plan["update"].append({"path": relative})

    for relative in sorted(target_files):
        if relative in source_files:
            continue

        relative_top_level = top_level_name(relative)
        previous_meta = previous_files.get(relative)

        if mode != "mirror":
            plan["local_untracked"].append(
                {
                    "path": relative,
                    "reason": "kept by repos additive mode",
                }
            )
            continue

        if relative_top_level not in incoming_top_levels:
            plan["local_untracked"].append(
                {
                    "path": relative,
                    "reason": (
                        "repo tree not present in incoming source; "
                        "unrelated repo content left alone"
                    ),
                }
            )
            continue

        if not previous_meta:
            plan["local_untracked"].append(
                {
                    "path": relative,
                    "reason": "local repo file not tracked by previous repos sync",
                }
            )
            continue

        previous_checksum = previous_meta.get("checksum")
        target_meta = target_files[relative]

        if previous_checksum and target_meta["checksum"] == previous_checksum:
            plan["remove"].append(
                {
                    "path": relative,
                    "reason": "repos mirror mode",
                }
            )
        else:
            plan["conflicts"].append(
                {
                    "path": relative,
                    "reason": "repo file missing from incoming source but changed locally",
                    "action": "would remove old tracked repo file",
                }
            )

    return plan, source_files


def normalized_rhel_tree_name(name):
    """Return normalized rhelN tree name, or None when not recognized."""
    cleaned = str(name).strip().lower()
    cleaned = cleaned.replace("-", "").replace("_", "")

    if cleaned.startswith("rhel"):
        suffix = cleaned[len("rhel"):]
    elif cleaned.startswith("el"):
        suffix = cleaned[len("el"):]
    else:
        return None

    if suffix.endswith("isos"):
        suffix = suffix[:-4]
    elif suffix.endswith("iso"):
        suffix = suffix[:-3]

    if not suffix.isdigit():
        return None

    return "rhel{}".format(suffix)


def rhel_major_from_tree_name(name):
    """Return RHEL major from a tree name like rhel9."""
    normalized = normalized_rhel_tree_name(name)

    if not normalized:
        return None

    return normalized[len("rhel"):]


def extracted_iso_tree_dirs(root):
    """Return recognized extracted ISO tree directories by normalized name."""
    root = Path(root)
    result = {}

    if not root.exists() or not root.is_dir():
        return result

    for child in sorted(root.iterdir()):
        if not child.is_dir():
            continue

        normalized = normalized_rhel_tree_name(child.name)

        if not normalized:
            continue

        result[normalized] = child

    return result


def read_discinfo_version(tree_path):
    """Return best-effort version details from .discinfo."""
    discinfo = Path(tree_path) / ".discinfo"

    if not discinfo.exists():
        return None

    try:
        lines = discinfo.read_text(errors="replace").splitlines()
    except TypeError:
        try:
            with discinfo.open("r") as handle:
                lines = handle.read().splitlines()
        except OSError:
            return None
    except OSError:
        return None

    cleaned = [line.strip() for line in lines if line.strip()]

    if not cleaned:
        return None

    for line in cleaned:
        lowered = line.lower()
        if "red hat" in lowered or "rhel" in lowered:
            return line

    if len(cleaned) > 1:
        return cleaned[1]

    return cleaned[0]


def extracted_iso_tree_info(tree_path):
    """Return basic extracted ISO tree metadata."""
    tree_path = Path(tree_path)

    return {
        "path": str(tree_path),
        "exists": tree_path.exists(),
        "version": read_discinfo_version(tree_path),
        "has_discinfo": (tree_path / ".discinfo").exists(),
        "has_baseos": (tree_path / "BaseOS").is_dir(),
        "has_appstream": (tree_path / "AppStream").is_dir(),
    }


def selected_rhel_tree_names(args, incoming_trees):
    """Return incoming RHEL tree names selected by args."""
    requested_major = getattr(args, "rhel_major", None)

    if requested_major:
        requested_name = "rhel{}".format(requested_major)

        if requested_name in incoming_trees:
            return [requested_name]

        return []

    return sorted(incoming_trees.keys())


def build_extracted_isos_plan(source_path, target_path, args):
    """Build extracted_isos replace-by-RHEL-major plan."""
    source_path = Path(source_path)
    target_path = Path(target_path)

    incoming_trees = extracted_iso_tree_dirs(source_path)
    current_trees = extracted_iso_tree_dirs(target_path)
    selected_names = selected_rhel_tree_names(args, incoming_trees)

    plan = empty_plan(SECTION_EXTRACTED_ISOS, source_path, target_path)
    plan["tree_add"] = []
    plan["tree_replace"] = []
    plan["tree_keep"] = []
    plan["tree_skipped"] = []

    if getattr(args, "rhel_major", None) and not selected_names:
        plan["warnings"].append(
            "Incoming extracted_isos source does not contain rhel{}.".format(
                getattr(args, "rhel_major", None)
            )
        )

    if not incoming_trees:
        plan["warnings"].append(
            "No recognized extracted ISO trees were found. Expected directories like rhel8, rhel9, or rhel10."
        )

    plan["warnings"].append(
        "extracted_isos sync replaces entire RHEL major trees. It does not perform file-by-file backup."
    )

    if getattr(args, "keep_old_isos", False):
        plan["warnings"].append(
            "--keep-old-isos is enabled. Existing trees will be moved to extracted_isos/archive before replacement."
        )

    for name in selected_names:
        source_tree = incoming_trees[name]
        target_tree = current_trees.get(name)

        if target_tree:
            planned_target = target_tree
        else:
            planned_target = target_path / source_tree.name

        item = {
            "path": name,
            "source": str(source_tree),
            "target": str(planned_target),
            "incoming": extracted_iso_tree_info(source_tree),
            "current": extracted_iso_tree_info(target_tree) if target_tree else None,
        }

        if target_tree:
            item["reason"] = "replace existing extracted ISO tree"
            item["action"] = "archive then replace" if getattr(args, "keep_old_isos", False) else "delete then replace"
            plan["tree_replace"].append(item)
        else:
            item["reason"] = "add new extracted ISO tree"
            item["action"] = "copy incoming tree"
            plan["tree_add"].append(item)

    selected_set = set(selected_names)

    for name in sorted(current_trees):
        if name not in selected_set:
            plan["tree_keep"].append(
                {
                    "path": name,
                    "reason": "RHEL major not present/selected in incoming source",
                    "action": "leave unchanged",
                    "current": extracted_iso_tree_info(current_trees[name]),
                }
            )

    return plan


def plan_counts(plan):
    """Return plan count summary."""
    return {
        "add": len(plan.get("add", [])),
        "update": len(plan.get("update", [])),
        "bundle_managed_update": len(plan.get("bundle_managed_update", [])),
        "remove": len(plan.get("remove", [])),
        "preserve": len(plan.get("preserve", [])),
        "conflicts": len(plan.get("conflicts", [])),
        "unchanged": len(plan.get("unchanged", [])),
        "local_untracked": len(plan.get("local_untracked", [])),
        "skipped": len(plan.get("skipped", [])),
        "warnings": len(plan.get("warnings", [])),
        "tree_add": len(plan.get("tree_add", [])),
        "tree_replace": len(plan.get("tree_replace", [])),
        "tree_keep": len(plan.get("tree_keep", [])),
        "tree_skipped": len(plan.get("tree_skipped", [])),
    }


def print_path_list(title, items, limit=None):
    """Print list of planned paths."""
    items = list(items or [])

    if not items:
        return

    print("")
    print(title)

    count = 0
    for item in items:
        count += 1

        if limit and count > limit:
            print("  ... {} more".format(len(items) - limit))
            break

        if isinstance(item, dict):
            path = item.get("path") or item.get("name") or str(item)
            reason = item.get("reason")
            action = item.get("action")

            if reason and action:
                print("  - {} ({}, {})".format(path, reason, action))
            elif reason:
                print("  - {} ({})".format(path, reason))
            else:
                print("  - {}".format(path))
        else:
            print("  - {}".format(item))


