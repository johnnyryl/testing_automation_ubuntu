    manifest["kind"] = MANIFEST_KIND
    manifest["version"] = manifest.get("version", 1)
    manifest["updated_utc"] = utc_iso()
    write_yaml_file(sync_manifest_file(), manifest)


def load_preserve_patterns(preserve_file, default_patterns=None):
    """Load line-based preserve patterns.

    The collections-hub .sync-preserve file is intentionally treated as a
    simple line-based pattern file so it remains portable for GitLab/rsync use.
    """
    patterns = []

    for pattern in list(default_patterns or []):
        if pattern not in patterns:
            patterns.append(pattern)

    preserve_file = Path(preserve_file)

    if not preserve_file.exists():
        return patterns

    with preserve_file.open("r") as handle:
        for raw_line in handle:
            line = raw_line.strip()

            if not line:
                continue

            if line.startswith("#"):
                continue

            if line not in patterns:
                patterns.append(line)

    return patterns


def ensure_preserve_file_defaults(preserve_file, default_patterns):
    """Append missing default preserve patterns to the portable preserve file."""
    preserve_file = Path(preserve_file)
    existing_patterns = []
    existing_text = ""

    if preserve_file.exists():
        existing_text = preserve_file.read_text()
        for raw_line in existing_text.splitlines():
            line = raw_line.strip()
            if line and not line.startswith("#"):
                existing_patterns.append(line)

    missing = []
    for pattern in default_patterns:
        if pattern not in existing_patterns:
            missing.append(pattern)

    if not missing:
        return []

    preserve_file.parent.mkdir(parents=True, exist_ok=True)

    with preserve_file.open("a") as handle:
        if existing_text and not existing_text.endswith("\n"):
            handle.write("\n")

        handle.write("\n")
        handle.write("# AeroLIT default sync preserve rules\n")
        handle.write("# Added by aerolitctl sync on {}\n".format(utc_iso()))

        for pattern in missing:
            handle.write("{}\n".format(pattern))

    return missing


def normalize_preserve_pattern(pattern):
    """Normalize a preserve pattern for storage in collections-hub .sync-preserve."""
    pattern = str(pattern).strip()

    while pattern.startswith("./"):
        pattern = pattern[2:]

    if pattern.startswith("collections-hub/"):
        pattern = pattern[len("collections-hub/"):]

    pattern = pattern.lstrip("/")

    return pattern


def read_preserve_file_entries(preserve_file):
    """Return comments, patterns, and raw lines from the preserve file."""
    preserve_file = Path(preserve_file)

    if not preserve_file.exists():
        return {
            "exists": False,
            "comments": [],
            "patterns": [],
            "lines": [],
        }

    lines = preserve_file.read_text().splitlines()
    comments = []
    patterns = []

    for line in lines:
        stripped = line.strip()

        if not stripped:
            continue

        if stripped.startswith("#"):
            comments.append(stripped)
            continue

        patterns.append(stripped)

    return {
        "exists": True,
        "comments": comments,
        "patterns": patterns,
        "lines": lines,
    }


def write_preserve_file_patterns(preserve_file, patterns):
    """Write preserve patterns to the portable preserve file."""
    preserve_file = Path(preserve_file)
    preserve_file.parent.mkdir(parents=True, exist_ok=True)

    unique_patterns = []
    for pattern in patterns:
        pattern = normalize_preserve_pattern(pattern)
        if pattern and pattern not in unique_patterns:
            unique_patterns.append(pattern)

    lines = [
        "# AeroLIT collections-hub sync preserve file",
        "# Patterns are relative to the collections-hub directory.",
        "# Example: ansible/inventory/**",
        "",
    ]

    lines.extend(unique_patterns)
    preserve_file.write_text("\n".join(lines) + "\n")


def preserve_defaults_for_section(section):
    """Return built-in preserve defaults for one section."""
    if section == SECTION_FILES:
        return DEFAULT_FILES_PRESERVE_PATTERNS

    return DEFAULT_COLLECTIONS_HUB_PRESERVE_PATTERNS


def normalize_preserve_section_name(section):
    """Normalize preserve section name."""
    section = str(section or "all").strip()

    if section == "extracted-isos":
        section = SECTION_EXTRACTED_ISOS

    if section == "collections_hub":
        section = SECTION_COLLECTIONS_HUB

    if section == "all":
        return None

    if section in PRESERVE_SUPPORTED_SECTIONS:
        return section

    raise ValueError(
        "Preserve rules currently support only collections-hub and files."
    )


def preserve_sections_for_display(args):
    """Return preserve sections selected for display/defaults."""
    requested = normalize_preserve_section_name(
        getattr(args, "section", "all")
    )

    if requested:
        return [requested]

    return list(PRESERVE_SUPPORTED_SECTIONS)


def infer_preserve_section(args, pattern=None):
    """Infer preserve section from --section or pattern prefix."""
    requested = normalize_preserve_section_name(
        getattr(args, "section", "all")
    )

    if requested:
        return requested

    pattern = str(pattern or "").strip()

    while pattern.startswith("./"):
        pattern = pattern[2:]

    pattern = pattern.lstrip("/")

    if pattern.startswith("files/"):
        return SECTION_FILES

    return SECTION_COLLECTIONS_HUB


def normalize_preserve_pattern_for_section(pattern, section):
    """Normalize a preserve pattern relative to one section root."""
    pattern = str(pattern).strip()

    while pattern.startswith("./"):
        pattern = pattern[2:]

    pattern = pattern.lstrip("/")

    if section == SECTION_FILES and pattern.startswith("files/"):
        pattern = pattern[len("files/"):]

    if section == SECTION_COLLECTIONS_HUB:
        if pattern.startswith("collections-hub/"):
            pattern = pattern[len("collections-hub/"):]
        if pattern.startswith("collections_hub/"):
            pattern = pattern[len("collections_hub/"):]

    return pattern


def normalize_preserve_path_for_section(path, section):
    """Normalize a user path for preserve explain."""
    return normalize_preserve_pattern_for_section(path, section)


def ensure_preserve_file_exists(preserve_file):
    """Create an empty preserve file if missing."""
    preserve_file = Path(preserve_file)

    if preserve_file.exists():
        return

    write_preserve_file_patterns(preserve_file, [])


def validate_preserve_file(preserve_file):
    """Validate preserve file syntax."""
    entries = read_preserve_file_entries(preserve_file)
    errors = []
    warnings = []

    for pattern in entries["patterns"]:
        normalized = normalize_relative_path(pattern)

        if not normalized:
            errors.append("empty preserve pattern")
            continue

        if Path(normalized).is_absolute():
            errors.append("absolute paths are not allowed: {}".format(pattern))

        parts = Path(normalized).parts
        if ".." in parts:
            errors.append("parent traversal is not allowed: {}".format(pattern))

        if normalized.startswith("repos/"):
            warnings.append(
                "repos/ preserve patterns are not currently used by sync: {}".format(
                    pattern
                )
            )

        if normalized.startswith("extracted_isos/") or normalized.startswith(
            "extracted-isos/"
        ):
            warnings.append(
                "extracted_isos/ preserve patterns are not currently used by sync: {}".format(
                    pattern
                )
            )

    return entries, errors, warnings


