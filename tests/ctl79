        for warning in plan["warnings"]:
            print("  - {}".format(warning))


def apply_baseline_plan(plan):
    """Apply baseline plan by rebuilding manifest sections from current bundle."""
    manifest = load_manifest()
    bundle_path = Path(plan["bundle_path"])

    manifest.setdefault("sections", {})
    manifest["bundle_path"] = str(bundle_path)

    changed = []

    for item in plan.get("sections", []):
        if not item.get("exists"):
            continue

        section = item["section"]
        target = section_target_path(bundle_path, section)

        if section == SECTION_EXTRACTED_ISOS:
            manifest["sections"][section] = rebuild_extracted_isos_manifest(target)
        else:
            preserve_patterns = section_preserve_patterns(bundle_path, section)
            manifest["sections"][section] = rebuild_section_manifest(
                section,
                target,
                preserve_patterns,
            )

        changed.append(
            {
                "action": "baseline",
                "section": section,
                "target": str(target),
            }
        )

    save_manifest(manifest)
    return changed


def manifest_validation_result():
    """Return an empty manifest validation result."""
    return {
        "ok": [],
        "warnings": [],
        "errors": [],
    }


def add_manifest_validation(result, level, message, section=None, path=None):
    """Add one manifest validation finding."""
    item = {
        "message": message,
    }

    if section:
        item["section"] = section

    if path:
        item["path"] = str(path)

    result.setdefault(level, []).append(item)


def validate_manifest_header(manifest, result):
    """Validate top-level sync manifest fields."""
    if not isinstance(manifest, dict):
        add_manifest_validation(
            result,
            "errors",
            "Sync manifest is not a YAML mapping.",
        )
        return

    if manifest.get("kind") != MANIFEST_KIND:
        add_manifest_validation(
            result,
            "warnings",
            "Sync manifest kind is missing or unexpected: {}".format(
                manifest.get("kind")
            ),
        )
    else:
        add_manifest_validation(
            result,
            "ok",
            "Sync manifest kind is valid.",
        )

    if not manifest.get("version"):
        add_manifest_validation(
            result,
            "warnings",
            "Sync manifest version is missing.",
        )

    if "sections" not in manifest:
        add_manifest_validation(
            result,
            "errors",
            "Sync manifest has no sections mapping.",
        )
    elif not isinstance(manifest.get("sections"), dict):
        add_manifest_validation(
            result,
            "errors",
            "Sync manifest sections field is not a mapping.",
        )


def manifest_section_root(bundle_path, section_name, section_data):
    """Return best known root for one manifest section."""
    configured_root = section_data.get("root")

    if configured_root:
        return Path(configured_root)

    try:
        return section_target_path(bundle_path, section_name)
    except ValueError:
        return None


def validate_manifest_file_section(
    bundle_path,
    section_name,
    section_data,
    result,
    check_checksums=False,
    max_findings=50,
):
    """Validate one file-based manifest section."""
    files = section_data.get("files", {})

    if not isinstance(files, dict):
        add_manifest_validation(
            result,
            "errors",
            "Section files field is not a mapping.",
            section=section_name,
        )
        return

    root = manifest_section_root(bundle_path, section_name, section_data)

    if not root:
        add_manifest_validation(
            result,
            "errors",
            "Cannot determine section root.",
            section=section_name,
        )
        return

    if not root.exists():
        add_manifest_validation(
            result,
            "errors",
            "Section root does not exist.",
            section=section_name,
            path=root,
        )
        return

    add_manifest_validation(
        result,
        "ok",
        "Section root exists.",
        section=section_name,
        path=root,
    )

    missing_count = 0
    changed_count = 0
    checked_count = 0
    limited = False

    for relative, meta in sorted(files.items()):
        path = root / relative
        checked_count += 1

        if not path.exists():
            missing_count += 1

            if missing_count <= max_findings:
                add_manifest_validation(
                    result,
                    "errors",
                    "Tracked file is missing.",
                    section=section_name,
                    path=relative,
                )
            else:
                limited = True

            continue

        if not path.is_file():
            add_manifest_validation(
                result,
                "errors",
                "Tracked path is not a regular file.",
                section=section_name,
                path=relative,
            )
            continue

        if not check_checksums:
            continue

        expected_checksum = None

        if isinstance(meta, dict):
            expected_checksum = meta.get("checksum")

        if not expected_checksum:
            continue

        try:
            actual_checksum = sha256_file(path)
        except OSError as exc:
            add_manifest_validation(
                result,
                "warnings",
                "Could not checksum tracked file: {}".format(exc),
                section=section_name,
                path=relative,
            )
            continue

        if actual_checksum != expected_checksum:
            changed_count += 1

            if changed_count <= max_findings:
                add_manifest_validation(
                    result,
                    "warnings",
                    "Tracked file checksum differs from manifest.",
                    section=section_name,
                    path=relative,
                )
            else:
                limited = True

    add_manifest_validation(
        result,
        "ok",
        "Checked {} tracked file(s).".format(checked_count),
        section=section_name,
    )

    if limited:
        add_manifest_validation(
            result,
            "warnings",
            "Additional findings were hidden after {} listed items.".format(
                max_findings
            ),
            section=section_name,
        )


def validate_manifest_extracted_isos_section(
    bundle_path,
    section_name,
    section_data,
    result,
):
    """Validate extracted_isos manifest section."""
    root = manifest_section_root(bundle_path, section_name, section_data)

    if not root:
        add_manifest_validation(
            result,
            "errors",
            "Cannot determine extracted_isos root.",
            section=section_name,
        )
        return

    if not root.exists():
        add_manifest_validation(
            result,
            "errors",
            "Extracted ISOs root does not exist.",
            section=section_name,
            path=root,
        )
        return

    trees = section_data.get("trees", {})

    if not isinstance(trees, dict):
        add_manifest_validation(
            result,
            "errors",
            "Extracted ISOs trees field is not a mapping.",
            section=section_name,
        )
        return

    if not trees:
        add_manifest_validation(
            result,
            "warnings",
            "Extracted ISOs section has no tracked trees.",
            section=section_name,
            path=root,
        )
        return

    for tree_name, tree_data in sorted(trees.items()):
        tree_path = None

        if isinstance(tree_data, dict):
            tree_path = tree_data.get("path")

        if tree_path:
            tree_path = Path(tree_path)
        else:
            tree_path = root / tree_name

        if tree_path.exists() and tree_path.is_dir():
            add_manifest_validation(
                result,
                "ok",
                "Tracked extracted ISO tree exists.",
                section=section_name,
                path=tree_path,
            )
        else:
            add_manifest_validation(
                result,
                "errors",
                "Tracked extracted ISO tree is missing.",
                section=section_name,
                path=tree_path,
            )


def validate_installed_manifest(bundle_path, check_checksums=False):
    """Validate installed sync manifest against the current bundle."""
    manifest = load_manifest()
    result = manifest_validation_result()

    validate_manifest_header(manifest, result)

    sections = manifest.get("sections", {})

    if not isinstance(sections, dict):
        return result

    if not sections:
        add_manifest_validation(
            result,
            "warnings",
            "No sections are currently tracked in the sync manifest.",
        )
        return result

    for section_name, section_data in sorted(sections.items()):
        if section_name not in SUPPORTED_SECTIONS:
            add_manifest_validation(
                result,
                "warnings",
                "Manifest tracks an unknown section.",
                section=section_name,
            )
            continue

        if not isinstance(section_data, dict):
            add_manifest_validation(
                result,
                "errors",
                "Section manifest data is not a mapping.",
                section=section_name,
            )
            continue

        if section_name == SECTION_EXTRACTED_ISOS:
            validate_manifest_extracted_isos_section(
                bundle_path,
                section_name,
                section_data,
                result,
            )
        else:
            validate_manifest_file_section(
                bundle_path,
                section_name,
                section_data,
                result,
                check_checksums=check_checksums,
            )

    return result


