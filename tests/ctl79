def build_sync_plan_for_section(
    args,
    bundle_path,
    manifest,
    detected_sections,
    source_root,
    extract_skipped,
    section,
):
    """Build a sync plan for one section without applying it."""
    if section not in detected_sections:
        raise ValueError("Section not found in source: {}".format(section))

    source_path = detected_sections[section]
    target_path = section_target_path(bundle_path, section)

    if section == SECTION_COLLECTIONS_HUB:
        plan, _source_files = build_collections_hub_plan(
            source_path,
            target_path,
            manifest,
            force=getattr(args, "force", False),
        )
    elif section == SECTION_FILES:
        plan, _source_files = build_files_plan(
            source_path,
            target_path,
            manifest,
            force=getattr(args, "force", False),
            mode=section_files_mode(args),
        )
    elif section == SECTION_REPOS:
        plan, _source_files = build_repos_plan(
            source_path,
            target_path,
            manifest,
            force=getattr(args, "force", False),
            mode=section_repos_mode(args),
        )
    elif section == SECTION_EXTRACTED_ISOS:
        plan = build_extracted_isos_plan(
            source_path,
            target_path,
            args,
        )
    else:
        raise ValueError("Unsupported section: {}".format(section))

    if extract_skipped:
        for item in extract_skipped_for_section(
            extract_skipped,
            source_root,
            source_path,
        ):
            plan["skipped"].append(item)

    add_requested_option_notes(plan, args)
    add_source_version_metadata_to_plan(plan, source_root)
    plan["_diff_lines"] = resolve_diff_line_limit(args)

    return plan


def combined_plan_counts(plans):
    """Return combined count summary for multiple plans."""
    totals = {}

    for plan in plans:
        counts = plan_counts(plan)

        for key, value in counts.items():
            totals[key] = totals.get(key, 0) + value

    return totals


