def parse_number_selection(answer, maximum):
    """Parse a comma-separated number selection."""
    selected = []

    for part in answer.split(","):
        part = part.strip()

        if not part:
            continue

        if "-" in part:
            start_text, end_text = part.split("-", 1)

            try:
                start = int(start_text)
                end = int(end_text)
            except ValueError:
                continue

            for value in range(start, end + 1):
                if 1 <= value <= maximum and value not in selected:
                    selected.append(value)

            continue

        try:
            value = int(part)
        except ValueError:
            continue

        if 1 <= value <= maximum and value not in selected:
            selected.append(value)

    return selected


