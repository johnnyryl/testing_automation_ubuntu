def resolve_diff_line_limit(args):
    """Return configured diff line limit."""
    value = getattr(args, "diff_lines", None)

    if value is None:
        return DEFAULT_DIFF_LINE_LIMIT

    try:
        value = int(value)
    except (TypeError, ValueError):
        return DEFAULT_DIFF_LINE_LIMIT

    if value < 1:
        return DEFAULT_DIFF_LINE_LIMIT

    return value


def is_probably_binary_file(path):
    """Return True when a file appears to be binary."""
    path = Path(path)

    if not path.exists() or not path.is_file():
        return False

    try:
        with path.open("rb") as handle:
            chunk = handle.read(BINARY_SCAN_BYTES)
    except OSError:
        return False

    return b"\0" in chunk


def normalize_diff_path(path, section=None):
    """Normalize a user-provided diff path."""
    path = normalize_relative_path(str(path).strip())

    while path.startswith("./"):
        path = path[2:]

    path = path.lstrip("/")

    prefixes = [
        "collections-hub/",
        "collections_hub/",
        "files/",
        "repos/",
        "extracted_isos/",
        "extracted-isos/",
    ]

    if section:
        prefixes.insert(0, str(section).rstrip("/") + "/")

    for prefix in prefixes:
        if path.startswith(prefix):
            return path[len(prefix):]

    return path


def plan_item_path(item):
    """Return path from one plan item."""
    if isinstance(item, dict):
        return normalize_relative_path(item.get("path") or item.get("name") or "")

    return normalize_relative_path(str(item))


def plan_item_matches_path(item, path_filter):
    """Return True when one plan item matches a path filter."""
    item_path = plan_item_path(item)
    path_filter = normalize_relative_path(path_filter)

    if item_path == path_filter:
        return True

    if item_path.startswith(path_filter + "/"):
        return True

    if path_filter.startswith(item_path + "/"):
        return True

    return False


def filter_plan_to_path(plan, path_filter):
    """Return a copy of a plan filtered to one path."""
    path_filter = normalize_relative_path(path_filter)
    filtered = dict(plan)

    list_keys = (
        "add",
        "update",
        "bundle_managed_update",
        "remove",
        "preserve",
        "conflicts",
        "unchanged",
        "local_untracked",
        "skipped",
        "tree_add",
        "tree_replace",
        "tree_keep",
        "tree_skipped",
    )

    matched_any = False

    for key in list_keys:
        original = list(plan.get(key, []))
        kept = [
            item
            for item in original
            if plan_item_matches_path(item, path_filter)
        ]

        if kept:
            matched_any = True

        filtered[key] = kept

    filtered["notes"] = list(plan.get("notes", []))
    filtered["warnings"] = list(plan.get("warnings", []))

    filtered["notes"].append(
        "Plan output is filtered to path: {}".format(path_filter)
    )

    if not matched_any:
        filtered["warnings"].append(
            "No planned item matched path filter: {}".format(path_filter)
        )

    return filtered


def diffable_plan_item_for_path(plan, path_filter):
    """Return a diffable item for a path filter, if one exists."""
    for key in (
        "conflicts",
        "update",
        "bundle_managed_update",
        "preserve",
        "unchanged",
        "add",
        "remove",
    ):
        for item in plan.get(key, []):
            if plan_item_matches_path(item, path_filter):
                return key, item

    return None, None


def show_diff_for_path(plan, path_filter, max_lines):
