class SyncLock(object):
    """Simple file lock for sync runs."""

    def __init__(self, path):
        self.path = Path(path)
        self.acquired = False

    def acquire(self):
        """Acquire lock or raise RuntimeError."""
        self.path.parent.mkdir(parents=True, exist_ok=True)

        flags = os.O_CREAT | os.O_EXCL | os.O_WRONLY

        try:
            fd = os.open(str(self.path), flags)
        except OSError as exc:
            if exc.errno == errno.EEXIST:
                raise RuntimeError(
                    "Another aerolitctl sync appears to be running: {}".format(
                        self.path
                    )
                )
            raise

        with os.fdopen(fd, "w") as handle:
            handle.write("pid: {}\n".format(os.getpid()))
            handle.write("created_utc: {}\n".format(utc_iso()))

        self.acquired = True

    def release(self):
        """Release lock."""
        if self.acquired:
            try:
                self.path.unlink()
            except OSError:
                pass
            self.acquired = False


def resolve_bundle_path(args):
    """Resolve active bundle path."""
    if getattr(args, "bundle_path", None):
        return Path(args.bundle_path).expanduser()

    config = load_config()
    bundle_path = get_bundle_path(config)

    if not bundle_path:
        raise RuntimeError(
            "No bundle path is configured. Run: aerolitctl configure init"
        )

    return Path(bundle_path).expanduser()


