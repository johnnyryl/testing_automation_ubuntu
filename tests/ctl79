ROLLBACK_REPORT_KIND = "AeroLITSyncRollbackReport"


def sync_report_files():
    """Return sync report files newest first."""
    report_dir = sync_log_dir()

    if not report_dir.exists():
        return []

    reports = [
        path
        for path in report_dir.glob("*-sync-report.yml")
        if path.is_file()
    ]

    return sorted(reports, reverse=True)


def load_sync_report(path):
    """Load one sync report."""
    data = read_yaml_file(path, default=None)

    if not isinstance(data, dict):
        raise ValueError("Sync report is not a YAML mapping: {}".format(path))

    return data


def report_is_rollback_candidate(report):
    """Return True if a report has data useful for rollback."""
    if report.get("dry_run"):
        return False

    plan = report.get("plan", {})
    if plan.get("section") != SECTION_COLLECTIONS_HUB:
        return False

    for item in report.get("changed", []):
        if item.get("action") in (
            "add",
            "update",
            "bundle-managed-update",
            "remove",
        ):
            return True

    return False


def find_rollback_report(identifier=None):
    """Find a rollback report by timestamp/path, or return latest candidate."""
    reports = sync_report_files()

    if identifier:
        identifier_path = Path(identifier).expanduser()

        if identifier_path.exists():
            report = load_sync_report(identifier_path)
            return identifier_path, report

        matches = []
        for path in reports:
            if path.name.startswith(identifier):
                matches.append(path)
                continue

            if identifier in path.name:
                matches.append(path)

        if not matches:
            raise ValueError(
                "No sync report matched rollback target: {}".format(identifier)
            )

        report_path = matches[0]
        return report_path, load_sync_report(report_path)

    for report_path in reports:
        report = load_sync_report(report_path)

        if report_is_rollback_candidate(report):
            return report_path, report

    raise ValueError("No rollback-capable sync reports were found.")


def print_rollback_report_list():
    """Print rollback-capable sync reports."""
    reports = sync_report_files()

    print("AeroLIT sync rollback points")
    print("")

    if not reports:
        print("No sync reports found.")
        return 0

    found = False

    for report_path in reports:
        try:
            report = load_sync_report(report_path)
        except Exception as exc:
            print("  {} (unreadable: {})".format(report_path, exc))
            continue

        if not report_is_rollback_candidate(report):
            continue

        found = True
        changed = report.get("changed", [])
        backup_root = report.get("backup_root")

        print("  {}".format(report_path.name))
        print("    report: {}".format(report_path))
        print("    source: {}".format(report.get("source") or "unknown"))
        print("    created: {}".format(report.get("created_utc") or "unknown"))
        print("    changed files: {}".format(len(changed)))
        print("    backup: {}".format(backup_root or "none"))
        print("")

    if not found:
        print("No rollback-capable sync reports found.")

    return 0


def current_file_checksum(path):
    """Return checksum for current file, or None when missing/not regular."""
    path = Path(path)

    if not path.exists() or not path.is_file():
        return None

    return sha256_file(path)


def current_matches_manifest(target_root, relative_path, manifest_files):
    """Return True if current target file matches the active manifest."""
    target = Path(target_root) / relative_path

    if not target.exists():
        return False

    manifest_meta = manifest_files.get(relative_path)
    if not manifest_meta:
        return False

    expected_checksum = manifest_meta.get("checksum")
    if not expected_checksum:
        return False

    return current_file_checksum(target) == expected_checksum


def empty_rollback_plan(report_path, report, bundle_path):
    """Return an empty rollback plan."""
    backup_root = report.get("backup_root")

    return {
        "report_path": str(report_path),
        "source_report": report,
        "bundle_path": str(bundle_path),
        "target_path": str(collections_hub_path(bundle_path)),
        "backup_root": backup_root,
        "restore": [],
        "remove_added": [],
        "noop": [],
        "conflicts": [],
        "skipped": [],
    }


def build_rollback_plan(report_path, report, bundle_path, force=False):
    """Build a rollback plan from a sync report."""
    target_root = collections_hub_path(bundle_path)
    backup_root = report.get("backup_root")
    backup_root_path = Path(backup_root) if backup_root else None

    manifest = load_manifest()
    manifest_files = manifest_section_files(manifest, SECTION_COLLECTIONS_HUB)

    plan = empty_rollback_plan(report_path, report, bundle_path)

    changed = list(report.get("changed", []))
    changed.reverse()

    for item in changed:
        action = item.get("action")
        relative = item.get("path")

        if action == "preserve-default":
            plan["skipped"].append(
                {
                    "path": relative or item.get("pattern") or "preserve-default",
                    "reason": "preserve-default metadata entry",
                }
            )
            continue

        if not relative:
            plan["skipped"].append(
                {
                    "path": "unknown",
                    "reason": "changed item had no path",
                }
            )
            continue

        target = target_root / relative

        if action == "add":
            if not target.exists():
                plan["noop"].append(
                    {
                        "path": relative,
                        "reason": "added file is already absent",
                    }
                )
                continue

            if not force and not current_matches_manifest(
                target_root,
                relative,
                manifest_files,
            ):
                plan["conflicts"].append(
                    {
                        "path": relative,
                        "reason": (
                            "added file changed after sync; not removing without --force"
                        ),
                    }
                )
                continue

            plan["remove_added"].append(
                {
                    "path": relative,
                    "reason": "remove file that was added by sync",
                }
            )
            continue

        if action in ("update", "bundle-managed-update", "remove"):
            if not backup_root_path:
                plan["conflicts"].append(
                    {
                        "path": relative,
                        "reason": "sync report does not include a backup_root",
                    }
                )
                continue

            backup_file = backup_root_path / SECTION_COLLECTIONS_HUB / relative

            if not backup_file.exists() or not backup_file.is_file():
                plan["conflicts"].append(
                    {
                        "path": relative,
                        "reason": "backup file is missing: {}".format(backup_file),
                    }
                )
                continue

            if action in ("update", "bundle-managed-update"):
                if target.exists() and not force and not current_matches_manifest(
                    target_root,
                    relative,
                    manifest_files,
                ):
                    plan["conflicts"].append(
                        {
                            "path": relative,
                            "reason": (
                                "updated file changed after sync; "
                                "not overwriting without --force"
                            ),
                        }
                    )
                    continue

                plan["restore"].append(
                    {
                        "path": relative,
                        "reason": "restore previous version from backup",
                        "backup": str(backup_file),
                    }
                )
                continue

            if action == "remove":
                if target.exists() and not force:
                    plan["conflicts"].append(
                        {
                            "path": relative,
                            "reason": (
                                "removed file exists again locally; "
                                "not overwriting without --force"
                            ),
                        }
                    )
                    continue

                plan["restore"].append(
                    {
                        "path": relative,
                        "reason": "restore removed file from backup",
                        "backup": str(backup_file),
                    }
                )
                continue

        plan["skipped"].append(
            {
                "path": relative,
                "reason": "unsupported changed action: {}".format(action),
            }
        )

    return plan


def rollback_plan_counts(plan):
