            print("    version: {}".format(section.get("version")))

        if section.get("version_source"):
            print("    version source: {}".format(section.get("version_source")))

        if trees:
            print("    trees: {}".format(len(trees)))
            for tree_name in sorted(trees):
                tree = trees[tree_name]
                version = tree.get("version") or "unknown version"
                print("      - {}: {}".format(tree_name, version))
        else:
            print("    files: {}".format(len(files)))

    print("")
    print_status_repo_versions(bundle_path)
    print_status_extracted_isos(bundle_path)

    if verbose:
        print_status_local_modifications(bundle_path, manifest)
    else:
        print("Tracked local changes:")
        print("  run with --verbose to scan tracked files for local modifications")
        print("")

    return 0


def run_sync_apply_or_diff(args, source, diff_mode=False):
    """Run sync apply or diff for a source."""
    started_at = time.time()
    ensure_sync_directories()

    source_root = None
    cleanup_path = None
    extract_skipped = []

    bundle_path = resolve_bundle_path(args)
    target_collections_hub = collections_hub_path(bundle_path)

    sync_lock = SyncLock(sync_lock_file())

    if not diff_mode and not getattr(args, "dry_run", False):
        sync_lock.acquire()

    try:
        source_root, cleanup_path, extract_skipped = prepare_source(source)
        detected_sections = detect_sections(source_root)

        if not detected_sections:
            print("ERROR: No syncable AeroLIT bundle sections were detected.", file=sys.stderr)
            print("", file=sys.stderr)
            print("Source inspected:", file=sys.stderr)
            print("  {}".format(source), file=sys.stderr)
            return 1

        output_format = plan_output_format(args)

        if output_format == "text":
            print_detected_sections(
                detected_sections,
                show_paths=getattr(args, "verbose", False),
            )

        if multi_section_requested(args):
            return run_multi_section_plan_only(
                args,
                source,
                bundle_path,
                source_root,
                detected_sections,
                extract_skipped,
            )

        selected = selected_sections(args, detected_sections)

        if getattr(args, "section", None) in (None, "all"):
            ignored_sections = [
                item
                for item in sorted(detected_sections.keys())
                if item not in SUPPORTED_SECTIONS
            ]

            if ignored_sections:
                print("Note: these detected sections are not implemented yet and will be skipped:")
                for item in ignored_sections:
                    print("  - {}".format(item))
                print("")

        unsupported_selected = [
            item for item in selected if item not in SUPPORTED_SECTIONS
        ]
        if unsupported_selected:
            print("ERROR: These sections are detected/planned but not implemented yet:", file=sys.stderr)
            for item in unsupported_selected:
                print("  - {}".format(item), file=sys.stderr)
            print("", file=sys.stderr)
            print(
                "This sync implementation currently supports collections-hub, files, repos, and extracted_isos.",
                file=sys.stderr,
            )
            return 2

        active_section = choose_active_section(args, selected, detected_sections)

        if not active_section:
            print("No supported section selected for this run.")
            return 0

        if active_section not in detected_sections:
            print(
                "ERROR: Source does not contain selected section: {}".format(
                    active_section
                ),
                file=sys.stderr,
            )
            return 1

        if (
            getattr(args, "section", None) in (None, "all")
            and len(selected) > 1
        ):
            print(
                "Note: multiple supported sections were detected. "
                "This run will process only '{}'. Use --section to sync another section.".format(
                    active_section
                )
            )
            print("")

        manifest = load_manifest()
        target_section_path = section_target_path(bundle_path, active_section)

        if active_section == SECTION_COLLECTIONS_HUB:
            plan, _source_files = build_collections_hub_plan(
                detected_sections[active_section],
                target_section_path,
                manifest,
                force=getattr(args, "force", False),
            )
        elif active_section == SECTION_FILES:
            plan, _source_files = build_files_plan(
                detected_sections[active_section],
                target_section_path,
                manifest,
                force=getattr(args, "force", False),
                mode=resolve_files_mode(args),
            )
        elif active_section == SECTION_REPOS:
            plan, _source_files = build_repos_plan(
                detected_sections[active_section],
                target_section_path,
                manifest,
                force=getattr(args, "force", False),
                mode=resolve_repo_mode(args),
            )
        elif active_section == SECTION_EXTRACTED_ISOS:
            plan = build_extracted_isos_plan(
                detected_sections[active_section],
                target_section_path,
                args,
            )
            _source_files = {}
        else:
            print(
                "ERROR: Unsupported active sync section: {}".format(active_section),
                file=sys.stderr,
            )
            return 2

        if extract_skipped:
            for item in extract_skipped_for_section(
                extract_skipped,
                source_root,
                detected_sections[active_section],
            ):
                plan["skipped"].append(item)

        add_requested_option_notes(plan, args)
        add_source_version_metadata_to_plan(plan, source_root)

        plan["_diff_lines"] = resolve_diff_line_limit(args)

        diff_path = getattr(args, "path", None)

        if diff_path and not diff_mode:
            print(
                "ERROR: --path is currently supported only with 'aerolitctl sync diff'.",
                file=sys.stderr,
            )
            return 2

        if diff_path:
            diff_path = normalize_diff_path(
                diff_path,
                section=active_section,
            )
            plan = filter_plan_to_path(plan, diff_path)

        dry_run = bool(getattr(args, "dry_run", False) or diff_mode)
        plan_output_requested = bool(getattr(args, "plan_output", None))

        if (output_format != "text" or plan_output_requested) and not dry_run:
            print(
                "ERROR: --output json/yaml and --plan-output are plan-only features. "
                "Use them with --dry-run or 'aerolitctl sync diff'.",
                file=sys.stderr,
            )
            return 2

        plan_document = build_plan_output_document(
            source,
            bundle_path,
            detected_sections,
            plan,
            dry_run=dry_run,
            diff_mode=diff_mode,
            source_root=source_root,
            argv=getattr(args, "_aerolitctl_argv", []),
        )

        plan_output_path = write_plan_output_file(
            args,
            plan_document,
            output_format,
        )

        if output_format != "text":
            print_machine_plan(plan_document, output_format)
            return 0

        print_plan(
            plan,
            show_files=getattr(args, "show_files", False) or diff_mode,
            show_all_files=getattr(args, "show_all_files", False),
            show_skipped=getattr(args, "show_skipped", False),
        )

        if plan_output_path:
            print("")
            print("Plan output:")
            print("  {}".format(plan_output_path))

        if diff_mode and diff_path:
            show_diff_for_path(
                plan,
                diff_path,
                max_lines=plan.get("_diff_lines", DEFAULT_DIFF_LINE_LIMIT),
            )

        preserve_file = sync_preserve_file(bundle_path)

        review_conflicts = (
            getattr(args, "review", False)
            or getattr(args, "review_conflicts", False)
        )
        review_removals = (
            getattr(args, "review", False)
            or getattr(args, "review_removals", False)
        )

        if plan.get("conflicts") and not dry_run and review_conflicts:
            resolved = resolve_conflicts_interactively(plan, preserve_file)

            if not resolved:
                print("")
                print("Cancelled during conflict review. No files changed.")
                return 130

            print("")
            print("Updated sync plan after conflict review:")
            print_plan(plan, show_files=True)

        if plan.get("conflicts"):
            print("")
            print("Sync blocked because possible user/manual changes were found.")
            print_conflict_resolution_help()
            return 2

        if dry_run:
            report = build_report(
                source,
                bundle_path,
                detected_sections,
                plan,
                changed=[],
                backup_root=None,
                dry_run=True,
                started_at=started_at,
                source_root=source_root,
                argv=getattr(args, "_aerolitctl_argv", []),
            )
            report_path = write_report(report)
            print("")
            print("Dry run only. No files changed.")
            print("")
            print("Sync report:")
            print("  {}".format(report_path))
            return 0

        if plan.get("remove") and not dry_run and review_removals:
            reviewed = review_removals_interactively(plan, preserve_file)

            if not reviewed:
                print("")
                print("Cancelled during removal review. No files changed.")
                return 130

            print("")
            print("Updated sync plan after removal review:")
            print_plan(plan, show_files=True)

        if not getattr(args, "yes", False):
            print("")
            if not confirm_continue():
                print("Cancelled. No files changed.")
                return 130

        added_preserve_patterns = []

        if active_section == SECTION_COLLECTIONS_HUB:
            added_preserve_patterns = ensure_preserve_file_defaults(
                sync_preserve_file(bundle_path),
                DEFAULT_COLLECTIONS_HUB_PRESERVE_PATTERNS,
            )

        if active_section == SECTION_COLLECTIONS_HUB:
            changed, backup_root = apply_collections_hub_plan(
                plan,
                no_backup=getattr(args, "no_backup", False),
            )
        elif active_section == SECTION_REPOS:
            changed, backup_root = apply_bundle_section_plan(
                plan,
                active_section,
                no_backup=True,
            )
        elif active_section == SECTION_EXTRACTED_ISOS:
            changed, backup_root = apply_extracted_isos_plan(
                plan,
                keep_old=keep_old_iso_tree_requested(args),
            )
        else:
            changed, backup_root = apply_bundle_section_plan(
                plan,
                active_section,
                no_backup=getattr(args, "no_backup", False),
            )

        pre_sync_manifest_path = None

        if backup_root:
            pre_sync_manifest_path = write_pre_sync_manifest_backup(
                backup_root,
                manifest,
            )

        for pattern in added_preserve_patterns:
            changed.append(
                {
                    "action": "preserve-default",
                    "path": str(sync_preserve_file(bundle_path)),
                    "pattern": pattern,
                }
            )

        preserve_patterns = section_preserve_patterns(bundle_path, active_section)

        manifest.setdefault("sections", {})
        manifest["bundle_path"] = str(bundle_path)

        if active_section == SECTION_EXTRACTED_ISOS:
            manifest["sections"][active_section] = rebuild_extracted_isos_manifest(
                section_target_path(bundle_path, active_section),
            )
        else:
            manifest["sections"][active_section] = rebuild_section_manifest(
                active_section,
                section_target_path(bundle_path, active_section),
                preserve_patterns,
            )

        apply_source_version_metadata_to_manifest_section(
            manifest,
            active_section,
            plan,
        )

        save_manifest(manifest)

        report = build_report(
            source,
            bundle_path,
            detected_sections,
            plan,
            changed=changed,
            backup_root=backup_root,
            dry_run=False,
            started_at=started_at,
            source_root=source_root,
            argv=getattr(args, "_aerolitctl_argv", []),
        )
        report_path = write_report(report)
        backup_metadata_path = write_backup_metadata(
            backup_root,
            report_path,
            report,
            pre_sync_manifest_path=pre_sync_manifest_path,
        )
        record_manifest_sync_report(report_path, report)

        print("")
        print("AeroLIT sync completed.")
        print("")
        print("Changed files:")
        print("  {}".format(len(changed)))

        if backup_root:
            print("")
            print("Backup:")
            print("  {}".format(backup_root))

            summary = backup_summary(backup_root)
            print("  size: {}".format(summary.get("size", "unknown")))
            print("  files: {}".format(summary.get("file_count", 0)))

            if backup_metadata_path:
                print("")
                print("Backup metadata:")
                print("  {}".format(backup_metadata_path))

        print("")
        print("Updated manifest:")
        print("  {}".format(sync_manifest_file()))
        print("")
        print("Sync report:")
        print("  {}".format(report_path))

        return 0

    finally:
        sync_lock.release()
        cleanup_prepared_source(cleanup_path)


