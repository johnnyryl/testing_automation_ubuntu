def run_sync_manifest(args, raw_args):
    """Run aerolitctl sync manifest commands."""
    ensure_sync_directories()

    if not raw_args:
        print("ERROR: Missing manifest command.", file=sys.stderr)
        print("", file=sys.stderr)
        print("Valid commands:", file=sys.stderr)
        print("  validate", file=sys.stderr)
        print("  repair", file=sys.stderr)
        return 2

    command = raw_args[0]
    bundle_path = resolve_bundle_path(args)

    if command == "validate":
        result = validate_installed_manifest(
            bundle_path,
            check_checksums=getattr(args, "verbose", False),
        )

        if not getattr(args, "verbose", False):
            print("Note: run with --verbose to also checksum tracked files.")
            print("")

        return print_manifest_validation_result(result)

    if command == "repair":
        try:
            plan = build_baseline_plan(args)
        except ValueError as exc:
            print("ERROR: {}".format(exc), file=sys.stderr)
            return 2

        print_manifest_repair_plan(plan)

        if getattr(args, "dry_run", False):
            print("")
            print("Dry run only. No manifest changed.")
            return 0

        if not getattr(args, "yes", False):
            print("")
            print("This will rebuild the sync manifest from the current installed bundle.")
            print("No bundle files will be changed.")
            print("")
            if not confirm_continue():
                print("Cancelled. No files changed.")
                return 130

        changed = apply_baseline_plan(plan)

        print("")
        print("AeroLIT sync manifest repair completed.")
        print("")
        print("Updated manifest:")
        print("  {}".format(sync_manifest_file()))
        print("")
        print("Sections repaired:")
        print("  {}".format(len(changed)))

        return 0

    print("ERROR: Unknown manifest command: {}".format(command), file=sys.stderr)
    print("", file=sys.stderr)
    print("Valid commands:", file=sys.stderr)
    print("  validate", file=sys.stderr)
    print("  repair", file=sys.stderr)
    return 2


