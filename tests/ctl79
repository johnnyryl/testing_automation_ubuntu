def remove_cleanup_item(item):
    """Remove one cleanup item."""
    path = Path(item["path"])

    if not path.exists():
        return False

    if path.is_dir():
        shutil.rmtree(str(path))
        return True

    if path.is_file():
        path.unlink()
        return True

    return False


def apply_cleanup_plan(plan):
    """Apply cleanup plan."""
    changed = []

    for item in plan.get("items", []):
        removed = remove_cleanup_item(item)

        if removed:
            changed.append(
                {
                    "action": "cleanup-remove",
                    "kind": item.get("kind"),
                    "path": item.get("path"),
                    "size_bytes": item.get("size_bytes"),
                }
            )

    return changed


def build_cleanup_report(plan, changed, dry_run):
