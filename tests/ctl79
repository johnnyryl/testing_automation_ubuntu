def source_top_level_directories(source_root):
    """Return top-level directories found in the prepared source root."""
    source_root = Path(source_root)
    directories = []

    if not source_root.exists() or not source_root.is_dir():
        return directories

    try:
        for item in sorted(source_root.iterdir()):
            if item.is_dir():
                directories.append(item.name)
    except OSError:
        return directories

    return directories


def source_file_sha256(path):
    """Return SHA256 for a source file, or None when unavailable."""
    path = Path(path)

    if not path.exists() or not path.is_file():
        return None

    try:
        return sha256_file(path)
    except OSError:
        return None


def find_source_bundle_manifest(source_root):
    """Return source aerolit-bundle.yml path if found."""
    source_root = Path(source_root)

    for root in candidate_roots(source_root):
        manifest = root / "aerolit-bundle.yml"

        if manifest.is_file():
            return manifest

    return None


def source_bundle_metadata(source_root):
    """Return best-effort bundle metadata from aerolit-bundle.yml."""
    manifest = find_source_bundle_manifest(source_root)

    metadata = {
        "manifest_path": str(manifest) if manifest else None,
        "manifest_found": bool(manifest),
        "version": None,
    }

    if not manifest:
        return metadata

    try:
        with manifest.open("r") as handle:
            data = yaml_load(handle) or {}
    except Exception as exc:
        metadata["error"] = str(exc)
        return metadata

    if not isinstance(data, dict):
        metadata["error"] = "bundle manifest is not a YAML mapping"
        return metadata

    metadata["version"] = (
        data.get("version")
        or data.get("bundle_version")
        or data.get("aerolit_bundle_version")
    )

    if "name" in data:
        metadata["name"] = data.get("name")

    if "created" in data:
        metadata["created"] = data.get("created")

    if "created_utc" in data:
        metadata["created_utc"] = data.get("created_utc")

    return metadata


def section_name_variants(section):
    """Return possible section name variants used in bundle metadata."""
    section = str(section)

    variants = [
        section,
        section.replace("-", "_"),
        section.replace("_", "-"),
    ]

    unique = []
    for variant in variants:
        if variant not in unique:
            unique.append(variant)

    return unique


def section_version_from_manifest_data(data, section):
    """Return section-specific version metadata from loaded bundle manifest data."""
    if not isinstance(data, dict):
        return None

    variants = section_name_variants(section)

    candidate_sections = []

    for key in ("sections", "components", "contents"):
        value = data.get(key)

        if value:
            candidate_sections.append(value)

    for candidate in candidate_sections:
        if isinstance(candidate, dict):
            for variant in variants:
                item = candidate.get(variant)

                if isinstance(item, dict):
                    return {
                        "name": item.get("name") or variant,
                        "version": (
                            item.get("version")
                            or item.get("bundle_version")
                            or item.get("component_version")
                        ),
                        "raw": item,
                    }

                if isinstance(item, str):
                    return {
                        "name": variant,
                        "version": item,
                        "raw": item,
                    }

        if isinstance(candidate, list):
            for item in candidate:
                if not isinstance(item, dict):
                    continue

                item_name = (
                    item.get("name")
                    or item.get("section")
                    or item.get("id")
                    or item.get("component")
                )

                if item_name not in variants:
                    continue

                return {
                    "name": item_name,
                    "version": (
                        item.get("version")
                        or item.get("bundle_version")
                        or item.get("component_version")
                    ),
                    "raw": item,
                }

    return None


def source_section_version_metadata(source_root, section):
    """Return source/bundle version metadata for one sync section."""
    bundle_metadata = source_bundle_metadata(source_root)

    result = {
        "section": section,
        "manifest_found": bundle_metadata.get("manifest_found", False),
        "manifest_path": bundle_metadata.get("manifest_path"),
        "bundle_name": bundle_metadata.get("name"),
        "bundle_version": bundle_metadata.get("version"),
        "bundle_created": bundle_metadata.get("created"),
        "bundle_created_utc": bundle_metadata.get("created_utc"),
        "section_name": None,
        "section_version": None,
        "version": bundle_metadata.get("version"),
        "version_source": "bundle" if bundle_metadata.get("version") else None,
    }

    manifest_path = bundle_metadata.get("manifest_path")

    if not manifest_path:
        return result

    try:
        with Path(manifest_path).open("r") as handle:
            data = yaml_load(handle) or {}
    except Exception as exc:
        result["error"] = str(exc)
        return result

    section_metadata = section_version_from_manifest_data(data, section)

    if section_metadata:
        result["section_name"] = section_metadata.get("name")
        result["section_version"] = section_metadata.get("version")

        if section_metadata.get("version"):
            result["version"] = section_metadata.get("version")
            result["version_source"] = "section"

    return result


def add_source_version_metadata_to_plan(plan, source_root):
    """Attach source version metadata to a sync plan."""
    metadata = source_section_version_metadata(
        source_root,
        plan.get("section"),
    )

    plan["source_version"] = metadata

    if metadata.get("version"):
        plan["notes"].append(
            "Incoming {} version detected from {} metadata: {}.".format(
                plan.get("section"),
                metadata.get("version_source"),
                metadata.get("version"),
            )
        )
    elif metadata.get("manifest_found"):
        plan["notes"].append(
            "Incoming bundle manifest was found, but no version was detected for {}.".format(
                plan.get("section")
            )
        )

    return metadata


def apply_source_version_metadata_to_manifest_section(manifest, section, plan):
    """Store source version metadata on an installed manifest section."""
    source_version = plan.get("source_version")

    if not source_version:
        return

    sections = manifest.setdefault("sections", {})

    if section not in sections or not isinstance(sections[section], dict):
        return

    sections[section]["source_version"] = report_safe_value(source_version)

    if source_version.get("version"):
        sections[section]["version"] = source_version.get("version")
        sections[section]["version_source"] = source_version.get("version_source")


def source_report_metadata(source, source_root=None):
    """Return source metadata for reports."""
    path = Path(source).expanduser()

    metadata = {
        "path": str(path),
        "exists": path.exists(),
        "kind": "missing",
        "size_bytes": None,
        "sha256": None,
        "prepared_source_root": str(source_root) if source_root else None,
        "top_level_directories": [],
        "bundle": {},
    }

    if path.is_dir():
        metadata["kind"] = "directory"
    elif path.is_file():
        metadata["kind"] = "file"

        try:
            metadata["size_bytes"] = path.stat().st_size
        except OSError:
            metadata["size_bytes"] = None

        metadata["sha256"] = source_file_sha256(path)

        try:
            if source_is_tar(path):
                metadata["archive_type"] = "tar"
        except Exception:
            metadata["archive_type"] = "unknown"
    else:
        return metadata

    if source_root:
        metadata["top_level_directories"] = source_top_level_directories(source_root)
        metadata["bundle"] = source_bundle_metadata(source_root)

    return metadata


