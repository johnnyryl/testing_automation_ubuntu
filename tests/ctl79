def source_report_metadata(source):
    """Return basic source metadata without expensive checksum work."""
    path = Path(source).expanduser()

    metadata = {
        "path": str(path),
        "exists": path.exists(),
        "kind": "missing",
        "size_bytes": None,
    }

    if path.is_dir():
        metadata["kind"] = "directory"
        return metadata

    if path.is_file():
        metadata["kind"] = "file"

        try:
            metadata["size_bytes"] = path.stat().st_size
        except OSError:
            metadata["size_bytes"] = None

        return metadata

    return metadata


