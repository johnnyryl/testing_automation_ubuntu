def apply_rollback_plan(plan, no_backup=False):
    """Apply a rollback plan."""
    target_root = Path(plan["target_path"])
    changed = []

    rollback_backup_root = None
    if not no_backup and (plan.get("restore") or plan.get("remove_added")):
        rollback_backup_root = sync_backup_dir() / "{}-rollback-current".format(
            utc_stamp()
        )
        rollback_backup_root.mkdir(parents=True, exist_ok=True)

    for item in plan.get("remove_added", []):
        relative = item["path"]
        target = target_root / relative

        if rollback_backup_root:
            backup_current_before_rollback(
                target_root,
                relative,
                rollback_backup_root,
            )

        if target.exists() and target.is_file():
            target.unlink()
            remove_empty_parents(target, target_root)

        changed.append(
            {
                "action": "rollback-remove-added",
                "path": relative,
            }
        )

    for item in plan.get("restore", []):
        relative = item["path"]
        backup_file = Path(item["backup"])
        target = target_root / relative

        if rollback_backup_root:
            backup_current_before_rollback(
                target_root,
                relative,
                rollback_backup_root,
            )

        target.parent.mkdir(parents=True, exist_ok=True)
        shutil.copy2(str(backup_file), str(target))

        changed.append(
            {
                "action": "rollback-restore",
                "path": relative,
                "backup": str(backup_file),
            }
        )

    return changed, rollback_backup_root


def build_rollback_report(source_report_path, plan, changed, current_backup_root, dry_run):
    """Build rollback report data."""
    return {
        "kind": ROLLBACK_REPORT_KIND,
        "created_utc": utc_iso(),
        "source_report": str(source_report_path),
        "bundle_path": plan.get("bundle_path"),
        "target_path": plan.get("target_path"),
        "backup_root": plan.get("backup_root"),
        "current_backup_root": str(current_backup_root) if current_backup_root else None,
        "dry_run": bool(dry_run),
        "manifest_file": str(sync_manifest_file()),
        "plan": {
            "counts": rollback_plan_counts(plan),
            "files": {
                "restore": report_safe_value(plan.get("restore", [])),
                "remove_added": report_safe_value(plan.get("remove_added", [])),
                "noop": report_safe_value(plan.get("noop", [])),
                "conflicts": report_safe_value(plan.get("conflicts", [])),
                "skipped": report_safe_value(plan.get("skipped", [])),
            },
            "conflicts": report_safe_value(plan.get("conflicts", [])),
            "skipped": report_safe_value(plan.get("skipped", [])),
        },
        "changed": report_safe_value(changed),
    }


