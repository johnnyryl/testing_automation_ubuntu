def report_safe_value(value):
    """Return a YAML-safe value for reports."""
    if isinstance(value, Path):
        return str(value)

    if isinstance(value, dict):
        cleaned = {}
        for key, item in value.items():
            cleaned[str(key)] = report_safe_value(item)
        return cleaned

    if isinstance(value, (list, tuple)):
        return [report_safe_value(item) for item in value]

    return value


def report_plan_items(plan, key):
    """Return report-safe plan items for one plan list."""
    return report_safe_value(list(plan.get(key, [])))


def report_plan_files(plan):
    """Return full file/tree-level plan details for reports."""
    return {
        "add": report_plan_items(plan, "add"),
        "update": report_plan_items(plan, "update"),
        "bundle_managed_update": report_plan_items(
            plan,
            "bundle_managed_update",
        ),
        "remove": report_plan_items(plan, "remove"),
        "preserve": report_plan_items(plan, "preserve"),
        "conflicts": report_plan_items(plan, "conflicts"),
        "unchanged": report_plan_items(plan, "unchanged"),
        "local_untracked": report_plan_items(plan, "local_untracked"),
        "skipped": report_plan_items(plan, "skipped"),
        "tree_add": report_plan_items(plan, "tree_add"),
        "tree_replace": report_plan_items(plan, "tree_replace"),
        "tree_keep": report_plan_items(plan, "tree_keep"),
        "tree_skipped": report_plan_items(plan, "tree_skipped"),
    }


def plan_output_format(args):
    """Return requested plan output format."""
    output = getattr(args, "output", "text") or "text"
    output = str(output).strip().lower()

    if output not in ("text", "json", "yaml"):
        return "text"

    return output


def plan_file_format(path, requested_format):
    """Return output format for a plan file."""
    requested_format = requested_format or "text"

    if requested_format in ("json", "yaml"):
        return requested_format

    suffix = Path(path).suffix.lower()

    if suffix == ".json":
        return "json"

    return "yaml"


def dump_machine_output(data, output_format):
    """Return machine-readable output text."""
    safe_data = report_safe_value(data)

    if output_format == "json":
        return json.dumps(safe_data, indent=2, sort_keys=False) + "\n"

    return yaml_dump(safe_data)


