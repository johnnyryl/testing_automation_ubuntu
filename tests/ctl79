def configured_sync_value(name, default):
    """Return one configured sync value."""
    try:
        config = load_config()
    except FileNotFoundError:
        return default

    return config.get("sync", {}).get(name, default)


def resolve_files_mode(args):
    """Return files sync mode."""
    mode = getattr(args, "files_mode", None)

    if not mode:
        mode = configured_sync_value("files_mode", "additive")

    if mode not in ("additive", "mirror"):
        return "additive"

    return mode


def resolve_repo_mode(args):
    """Return repos sync mode."""
    mode = getattr(args, "repo_mode", None)

    if not mode:
        mode = configured_sync_value("repos_mode", "additive")

    if mode not in ("additive", "mirror"):
        return "additive"

    return mode


def section_target_path(bundle_path, section):
    """Return target path for a sync section."""
    if section == SECTION_COLLECTIONS_HUB:
        return collections_hub_path(bundle_path)

    if section == SECTION_FILES:
        return bundle_files_dir(bundle_path)

    if section == SECTION_REPOS:
        return bundle_repos_dir(bundle_path)

    if section == SECTION_EXTRACTED_ISOS:
        return bundle_extracted_isos_dir(bundle_path)

    raise ValueError("Unsupported sync section: {}".format(section))


def section_preserve_patterns(bundle_path, section):
    """Return preserve patterns for a sync section."""
    if section == SECTION_COLLECTIONS_HUB:
        return load_preserve_patterns(
            sync_preserve_file(bundle_path),
            default_patterns=DEFAULT_COLLECTIONS_HUB_PRESERVE_PATTERNS,
        )

    if section == SECTION_FILES:
        return load_preserve_patterns(
            sync_preserve_file(bundle_path),
            default_patterns=DEFAULT_FILES_PRESERVE_PATTERNS,
        )

    if section == SECTION_REPOS:
        return []

    if section == SECTION_EXTRACTED_ISOS:
        return []

    return []


def choose_active_section(args, selected, detected_sections):
    """Choose the single section this run will process."""
    requested = getattr(args, "section", None)

    if requested == "extracted-isos":
        requested = "extracted_isos"

    if requested and requested != "all":
        return requested

    for section in (
        SECTION_COLLECTIONS_HUB,
        SECTION_FILES,
        SECTION_REPOS,
        SECTION_EXTRACTED_ISOS,
    ):
        if section in selected and section in detected_sections:
            return section

    return None


def selected_baseline_sections(args):
    """Return sections selected for baseline."""
    requested = getattr(args, "section", "all")

    if requested == "extracted-isos":
        requested = SECTION_EXTRACTED_ISOS

    if requested == "all":
        return list(SUPPORTED_SECTIONS)

    if requested not in SUPPORTED_SECTIONS:
        raise ValueError("Unsupported baseline section: {}".format(requested))

    return [requested]


def build_baseline_plan(args):
    """Build baseline plan for current installed bundle."""
    bundle_path = resolve_bundle_path(args)
    sections = selected_baseline_sections(args)

    plan = {
        "bundle_path": str(bundle_path),
        "sections": [],
        "warnings": [],
    }

    for section in sections:
        target = section_target_path(bundle_path, section)

        item = {
            "section": section,
            "target": str(target),
            "exists": target.exists(),
            "action": "baseline current installed content",
        }

        if not target.exists():
            item["action"] = "skip missing section"
            plan["warnings"].append(
                "Skipping missing section {}: {}".format(section, target)
            )

        plan["sections"].append(item)

    return plan


def print_baseline_plan(plan):
    """Print baseline plan."""
    print("AeroLIT sync baseline plan")
    print("")
    print("Bundle path:")
    print("  {}".format(plan["bundle_path"]))
    print("")
    print("Sections:")

    for item in plan.get("sections", []):
        print("  - {}".format(item["section"]))
        print("      target: {}".format(item["target"]))
        print("      action: {}".format(item["action"]))

    if plan.get("warnings"):
