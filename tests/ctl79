        print_removal_review_summary(
            len(removals),
            remove_count=len(kept_removals),
            skip_count=0,
            preserve_count=preserved_count,
        )
        return True

    return True


def backup_target_file(target_root, relative_path, backup_root):
    """Back up one target file before changing it."""
    source = Path(target_root) / relative_path

    if not source.exists():
        return None

    destination = Path(backup_root) / SECTION_COLLECTIONS_HUB / relative_path
    destination.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(str(source), str(destination))
    return destination


def copy_incoming_file(source_root, target_root, relative_path):
    """Copy one incoming file into target."""
    source = Path(source_root) / relative_path
    target = Path(target_root) / relative_path
    target.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(str(source), str(target))


def remove_target_file(target_root, relative_path):
    """Remove one target file."""
    target = Path(target_root) / relative_path

    if target.exists() and target.is_file():
        target.unlink()


def remove_empty_parents(path, stop_root):
    """Remove empty parent directories up to stop_root."""
    path = Path(path).parent
    stop_root = Path(stop_root)

    while path != stop_root and str(path).startswith(str(stop_root)):
        try:
            path.rmdir()
        except OSError:
            return

        path = path.parent


def apply_collections_hub_plan(plan, no_backup=False):
    """Apply collections-hub sync plan."""
    source_root = Path(plan["source_path"])
    target_root = Path(plan["target_path"])
    changed = []

    backup_root = None
    if (
        (
            not no_backup
            and (
                plan.get("update")
                or plan.get("bundle_managed_update")
                or plan.get("remove")
            )
        )
        or plan_has_force_backup(plan)
    ):
        backup_root = sync_backup_dir() / utc_stamp()
        backup_root.mkdir(parents=True, exist_ok=True)

    for item in plan.get("add", []):
        relative = item["path"]
        copy_incoming_file(source_root, target_root, relative)
        changed.append({"action": "add", "path": relative})

    update_items = []
    update_items.extend(plan.get("update", []))
    update_items.extend(plan.get("bundle_managed_update", []))

    for item in update_items:
        relative = item["path"]

        if backup_root:
            backup_target_file(target_root, relative, backup_root)

        copy_incoming_file(source_root, target_root, relative)

        if item in plan.get("bundle_managed_update", []):
            action = "bundle-managed-update"
        else:
            action = "update"

        changed.append({"action": action, "path": relative})

    for item in plan.get("remove", []):
        relative = item["path"]

        if backup_root:
            backup_target_file(target_root, relative, backup_root)

        remove_target_file(target_root, relative)
        remove_empty_parents(target_root / relative, target_root)
        changed.append({"action": "remove", "path": relative})

    return changed, backup_root


def backup_target_file_for_section(target_root, relative_path, backup_root, section):
    """Back up one target file before changing it for a section."""
    source = Path(target_root) / relative_path

    if not source.exists():
        return None

    destination = Path(backup_root) / section / relative_path
    destination.parent.mkdir(parents=True, exist_ok=True)
    shutil.copy2(str(source), str(destination))
    return destination


def apply_bundle_section_plan(plan, section, no_backup=False):
    """Apply a generic bundle section sync plan."""
    source_root = Path(plan["source_path"])
    target_root = Path(plan["target_path"])
    changed = []

    backup_root = None
    if (
        (
            not no_backup
            and (
                plan.get("update")
                or plan.get("bundle_managed_update")
                or plan.get("remove")
            )
        )
        or plan_has_force_backup(plan)
    ):
        backup_root = sync_backup_dir() / utc_stamp()
        backup_root.mkdir(parents=True, exist_ok=True)

    for item in plan.get("add", []):
        relative = item["path"]
        copy_incoming_file(source_root, target_root, relative)
