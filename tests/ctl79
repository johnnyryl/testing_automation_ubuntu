def unique_archive_path(archive_root, name):
    """Return a unique archive path for an old extracted ISO tree."""
    archive_root = Path(archive_root)
    base = archive_root / "{}-{}".format(name, utc_stamp())

    if not base.exists():
        return base

    counter = 1
    while True:
        candidate = archive_root / "{}-{}-{}".format(name, utc_stamp(), counter)
        if not candidate.exists():
            return candidate
        counter += 1


def copy_tree(source, target):
    """Copy one directory tree to a target that must not already exist."""
    source = Path(source)
    target = Path(target)

    if target.exists():
        raise RuntimeError("Target tree already exists: {}".format(target))

    target.parent.mkdir(parents=True, exist_ok=True)
    shutil.copytree(str(source), str(target))


def replace_extracted_iso_tree(source, target, keep_old=False):
    """Replace one extracted ISO tree."""
    source = Path(source)
    target = Path(target)
    archived_to = None

    if target.exists():
        if keep_old:
            archive_root = target.parent / "archive"
            archive_root.mkdir(parents=True, exist_ok=True)
            archived_to = unique_archive_path(archive_root, target.name)
            shutil.move(str(target), str(archived_to))
        else:
            shutil.rmtree(str(target))

    copy_tree(source, target)
    return archived_to


def apply_extracted_isos_plan(plan, keep_old=False):
    """Apply extracted_isos sync plan."""
    changed = []

    for item in plan.get("tree_add", []):
        source = item["source"]
        target = item["target"]

        copy_tree(source, target)

        changed.append(
            {
                "action": "tree-add",
                "section": SECTION_EXTRACTED_ISOS,
                "path": item["path"],
                "source": source,
                "target": target,
            }
        )

    for item in plan.get("tree_replace", []):
        source = item["source"]
        target = item["target"]
        archived_to = replace_extracted_iso_tree(
            source,
            target,
            keep_old=keep_old,
        )

        changed.append(
            {
                "action": "tree-replace",
                "section": SECTION_EXTRACTED_ISOS,
                "path": item["path"],
                "source": source,
                "target": target,
                "archived_to": str(archived_to) if archived_to else None,
            }
        )

    return changed, None


def rebuild_section_manifest(section, target_root, preserve_patterns):
    """Rebuild manifest data for a synced section from the target root."""
    target_files, skipped = scan_files(target_root, preserve_patterns=preserve_patterns)
    manifest_files = {}

    for relative, meta in sorted(target_files.items()):
        if meta.get("preserved"):
            continue

        manifest_files[relative] = {
            "checksum": meta["checksum"],
            "size_bytes": meta["size_bytes"],
            "mode": meta["mode"],
        }

    return {
        "updated_utc": utc_iso(),
        "root": str(target_root),
        "files": manifest_files,
        "skipped": skipped,
    }


def rebuild_extracted_isos_manifest(target_root):
