    assert_contains(controller_output, "Would run Run ansible_controller.yml", "deploy controller")
    assert_contains(controller_output, "PXE playbook skipped", "deploy controller")
    assert_not_contains(controller_output, "Would run Run pxe_server.yml", "deploy controller")
    assert_firewall_action_expectations(args, controller_output, "controller")

    full_output = configure_and_capture_deploy(args, "full", "deploy-full.log")
    assert_regex(full_output, r"Mode\s*: full", "deploy full")
    assert_contains(full_output, "Would run Run pxe_server.yml", "deploy full")
