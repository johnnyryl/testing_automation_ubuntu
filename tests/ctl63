def test_deploy_missing_repo_vars_guard(args):
    """Confirm deploy fails clearly when repo vars refresh is skipped and vars are missing."""
    repo_vars_path = Path(args.repos_generated_vars_path)
    backup_path = Path(args.log_dir) / "aerolitctl_repos_generated.yml.test-backup"

    if repo_vars_path.exists():
        shutil.copy2(str(repo_vars_path), str(backup_path))

    try:
        if repo_vars_path.exists():
            repo_vars_path.unlink()

        output = run_cmd(
            [
                "aerolitctl",
                "deploy",
                "server",
                "--dry-run",
                "--skip-repo-vars-refresh",
            ],
            expected_rc=1,
            log_path=Path(args.log_dir) / "deploy-missing-repo-vars.log",
        )

        assert_contains_any(
            output,
            [
                "aerolitctl_repos_generated.yml",
                "repo vars",
                "repository vars",
            ],
            "missing repo vars failure",
        )
        assert_contains(
            output,
            "--skip-repo-vars-refresh",
            "missing repo vars failure",
        )

    finally:
        if backup_path.exists():
            if not repo_vars_path.parent.exists():
                repo_vars_path.parent.mkdir(parents=True)
            shutil.copy2(str(backup_path), str(repo_vars_path))


