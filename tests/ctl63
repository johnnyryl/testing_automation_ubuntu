    assert_contains(dry_run_output, "Skipped paths:", "backup dry-run")
    assert_contains(dry_run_output, str(args.config_file), "backup dry-run")

    dry_run_archives = list(backup_output_dir.glob("aerolit-config-*.tar.gz"))
    if dry_run_archives:
        raise TestFailure(
            "backup config --dry-run unexpectedly created archive(s): {}".format(
                ", ".join(str(path) for path in dry_run_archives)
            )
        )

    real_output = run_cmd(
        [
