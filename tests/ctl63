class TestFailure(Exception):
    """Raised when a merge-readiness check fails."""


CURRENT_TEST_NUMBER = None
CURRENT_TEST_TOTAL = None
CURRENT_TEST_NAME = None
CURRENT_COMMAND_NUMBER = 0

RUN_LOG_PATH = None
LAST_COMMAND_LOG_PATH = None
LAST_PROGRESS_WIDTH = 0


def append_text(path, content):
    """Append text to path, creating parent directories if needed."""
    path = Path(path)
    if not path.parent.exists():
        path.parent.mkdir(parents=True)
    with open(str(path), "a", encoding="utf-8") as handle:
        handle.write(content)


def append_run_log(content):
    """Append text to the full run log when it is available."""
    if RUN_LOG_PATH is not None:
        append_text(RUN_LOG_PATH, content)


def set_run_log_path(log_dir):
    """Set the full run log path and reset the file."""
    global RUN_LOG_PATH

    RUN_LOG_PATH = Path(log_dir) / "merge-readiness-full.log"
    write_text(RUN_LOG_PATH, "")


def print_test_header(test_number, total_tests, name):
    """Track and log the current top-level test header."""
    global CURRENT_TEST_NUMBER
    global CURRENT_TEST_TOTAL
    global CURRENT_TEST_NAME
    global CURRENT_COMMAND_NUMBER

    CURRENT_TEST_NUMBER = test_number
    CURRENT_TEST_TOTAL = total_tests
    CURRENT_TEST_NAME = name
    CURRENT_COMMAND_NUMBER = 0

    append_run_log("\n")
    append_run_log("#" * 80 + "\n")
    append_run_log("# TEST {} of {}: {}\n".format(test_number, total_tests, name))
    append_run_log("#" * 80 + "\n")


def current_test_label():
    """Return a readable label for the current test."""
    if CURRENT_TEST_NUMBER is None:
        return "no active test"

    return "TEST {} of {}: {}".format(
        CURRENT_TEST_NUMBER,
        CURRENT_TEST_TOTAL,
        CURRENT_TEST_NAME,
    )


def current_command_label():
    """Return a readable label for the most recent command."""
    if CURRENT_COMMAND_NUMBER == 0:
        return "no command has run in this test yet"

    if CURRENT_TEST_NUMBER is None:
        return "COMMAND {}".format(CURRENT_COMMAND_NUMBER)

    return "TEST {} / COMMAND {}".format(
        CURRENT_TEST_NUMBER,
        CURRENT_COMMAND_NUMBER,
    )


def command_log_path_for_current_command():
    """Return the standard per-command log path."""
    if RUN_LOG_PATH is None:
        return None

    commands_dir = RUN_LOG_PATH.parent / "commands"

    test_number = CURRENT_TEST_NUMBER or 0
    command_number = CURRENT_COMMAND_NUMBER or 0

    return commands_dir / "test-{:02d}-command-{:03d}.log".format(
        test_number,
        command_number,
    )


def print_command_header(command):
    """Track and log the current command without printing to the terminal."""
    global CURRENT_COMMAND_NUMBER
    global LAST_COMMAND_LOG_PATH

    CURRENT_COMMAND_NUMBER += 1
    LAST_COMMAND_LOG_PATH = command_log_path_for_current_command()

    append_run_log("\n")
    append_run_log("[TEST {} / COMMAND {}]\n".format(
        CURRENT_TEST_NUMBER,
        CURRENT_COMMAND_NUMBER,
    ))
    append_run_log("$ {}\n".format(render_cmd(command)))

    if LAST_COMMAND_LOG_PATH is not None:
        append_run_log("Command log: {}\n".format(LAST_COMMAND_LOG_PATH))

    return LAST_COMMAND_LOG_PATH


def render_command_log(command, cwd, rc, stdout, stderr):
    """Render one command log entry."""
    content = []
    content.append("=" * 80)
    content.append(current_test_label())
    content.append(current_command_label())
    content.append("Command: {}".format(render_cmd(command)))
    content.append("CWD: {}".format(cwd or os.getcwd()))
    content.append("Return code: {}".format(rc))
    content.append("")
    content.append("[stdout]")
    content.append(stdout or "")
    content.append("")
    content.append("[stderr]")
    content.append(stderr or "")
    content.append("")
    return "\n".join(content)


def write_command_logs(command_log_path, extra_log_path, command, cwd, rc, stdout, stderr):
    """Write per-command, full-run, and optional named command logs."""
    detailed_content = render_command_log(command, cwd, rc, stdout, stderr)

    combined = stdout or ""
    if stderr:
        combined += "\n[stderr]\n{}".format(stderr)

    if command_log_path is not None:
        write_text(command_log_path, detailed_content)

    if RUN_LOG_PATH is not None:
        append_text(RUN_LOG_PATH, detailed_content + "\n")

    if extra_log_path:
        write_text(extra_log_path, combined)


def progress_bar(completed, total, width=30):
    """Return a simple text progress bar."""
    if total <= 0:
        percent = 100
        filled = width
    else:
        percent = int(round((completed * 100.0) / total))
        filled = int(round((completed * width * 1.0) / total))

    return "[{}{}] {}%".format(
        "#" * filled,
        "-" * (width - filled),
        percent,
    )


def print_progress(completed, total):
    """Print test-level progress on one updating terminal line."""
    global LAST_PROGRESS_WIDTH

    message = "Progress: {} ({} of {} tests passed)".format(
        progress_bar(completed, total),
        completed,
        total,
    )

    LAST_PROGRESS_WIDTH = max(LAST_PROGRESS_WIDTH, len(message))
    sys.stdout.write("\r" + message.ljust(LAST_PROGRESS_WIDTH))
    sys.stdout.flush()


def finish_progress_line():
    """Finish the live progress line before printing normal output."""
    global LAST_PROGRESS_WIDTH

    if LAST_PROGRESS_WIDTH:
        sys.stdout.write("\n")
        sys.stdout.flush()
        LAST_PROGRESS_WIDTH = 0


def timestamp():
    """Return a filesystem-safe timestamp."""
    return datetime.datetime.now().strftime("%Y%m%d-%H%M%S")


def quote_cmd_part(value):
    """Quote one shell command part for display."""
    value = str(value)
    if re.search(r"[^A-Za-z0-9_@%+=:,./-]", value):
        return "'" + value.replace("'", "'\"'\"'") + "'"
    return value


def shell_quote(value):
    """Quote one value for use inside a generated POSIX shell script."""
    return "'" + str(value).replace("'", "'\"'\"'") + "'"


def render_cmd(command):
    """Render a command list for readable logging."""
    return " ".join(quote_cmd_part(item) for item in command)


def read_text(path):
    """Read text from path while tolerating non-UTF8 bytes."""
    with open(str(path), "r", encoding="utf-8", errors="ignore") as handle:
        return handle.read()


def write_text(path, content):
    """Write text to path, creating parent directories if needed."""
    path = Path(path)
    if not path.parent.exists():
        path.parent.mkdir(parents=True)
    with open(str(path), "w", encoding="utf-8") as handle:
        handle.write(content)


def command_env(env=None):
    """Return subprocess env with AeroLIT command logs isolated to this test run."""
    if env is None:
        command_environment = os.environ.copy()
    else:
        command_environment = env.copy()

    if "AEROLITCTL_LOG_DIR" not in command_environment and RUN_LOG_PATH is not None:
        command_environment["AEROLITCTL_LOG_DIR"] = str(
            RUN_LOG_PATH.parent / "aerolitctl-command-logs-all"
        )

    return command_environment


def run_cmd(command, cwd=None, expected_rc=0, log_path=None, env=None):
    """Run a command, save output to logs, and return combined output."""
    command_log_path = print_command_header(command)

    process = subprocess.Popen(
        command,
        cwd=cwd,
        env=command_env(env),
        stdout=subprocess.PIPE,
        stderr=subprocess.PIPE,
        universal_newlines=True,
    )
    stdout, stderr = process.communicate()

    stdout = stdout or ""
    stderr = stderr or ""

    combined = stdout
    if stderr:
        combined += "\n[stderr]\n{}".format(stderr)

    write_command_logs(
        command_log_path,
        log_path,
        command,
        cwd,
        process.returncode,
        stdout,
        stderr,
    )

    if expected_rc is None:
        append_run_log("Return code: {}\n".format(process.returncode))
    elif process.returncode == expected_rc:
        append_run_log("Return code: {} expected\n".format(process.returncode))
    else:
        append_run_log(
            "Return code: {} expected {}\n".format(
                process.returncode,
                expected_rc,
            )
        )

    if expected_rc is not None and process.returncode != expected_rc:
        raise TestFailure(
            "Command failed with rc={}: {}".format(
                process.returncode,
                render_cmd(command),
            )
        )

    lowered = combined.lower()
    if "unrecognized arguments" in lowered:
        raise TestFailure(
            "Command output contained 'unrecognized arguments': {}".format(
                render_cmd(command)
            )
        )

    if "distributionnotfound" in lowered and "aerolitctl" in lowered:
        raise TestFailure(
            "aerolitctl failed with pkg_resources DistributionNotFound. "
            "The test wrapper should avoid the installed console-script wrapper; "
            "check the generated wrapper under the log directory."
        )

    return combined


def command_output(command, cwd=None):
    """Return rc/stdout/stderr for a command without printing it."""
    try:
        process = subprocess.Popen(
            command,
            cwd=cwd,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            universal_newlines=True,
        )
        stdout, stderr = process.communicate()
        return process.returncode, stdout or "", stderr or ""
    except OSError as exc:
        return 127, "", str(exc)


def assert_contains(text, expected, label=None):
    """Assert text contains expected string."""
    if expected not in text:
        raise TestFailure(
            "Missing expected text{}: {}".format(
                " in {}".format(label) if label else "",
                expected,
            )
        )


def assert_not_contains(text, unexpected, label=None):
    """Assert text does not contain unexpected string."""
    if unexpected in text:
        raise TestFailure(
            "Unexpected text found{}: {}".format(
                " in {}".format(label) if label else "",
                unexpected,
            )
        )


def assert_contains_any(text, expected_values, label=None):
    """Assert text contains at least one expected string."""
    for expected in expected_values:
        if expected in text:
            return

    raise TestFailure(
        "Missing any expected text{}: {}".format(
            " in {}".format(label) if label else "",
            ", ".join(expected_values),
        )
    )


def assert_regex(text, pattern, label=None):
    """Assert text matches regex pattern."""
    if not re.search(pattern, text, re.MULTILINE):
        raise TestFailure(
            "Missing expected pattern{}: {}".format(
                " in {}".format(label) if label else "",
                pattern,
            )
        )


def assert_not_regex(text, pattern, label=None):
    """Assert text does not match regex pattern."""
    if re.search(pattern, text, re.MULTILINE):
        raise TestFailure(
            "Unexpected pattern found{}: {}".format(
                " in {}".format(label) if label else "",
                pattern,
            )
        )


def assert_path_exists(path, label=None):
    """Assert a path exists."""
    path = Path(path)
    if not path.exists():
        raise TestFailure(
            "Missing expected path{}: {}".format(
                " for {}".format(label) if label else "",
                path,
            )
        )


def assert_path_missing(path, label=None):
    """Assert a path does not exist."""
    path = Path(path)
    if path.exists():
        raise TestFailure(
            "Unexpected path exists{}: {}".format(
                " for {}".format(label) if label else "",
                path,
            )
        )


def sha256_file(path):
    """Return sha256 line for a path, or MISSING when absent."""
    path = Path(path)
    if not path.exists():
        return "MISSING  {}".format(path)

    digest = hashlib.sha256()
    with open(str(path), "rb") as handle:
        for chunk in iter(lambda: handle.read(1024 * 1024), b""):
            digest.update(chunk)

    return "{}  {}".format(digest.hexdigest(), path)


def sha256_paths(paths):
    """Return sha256 lines for all supplied paths."""
    return "\n".join(sha256_file(path) for path in paths) + "\n"


def assert_hashes_same(before, after, label):
    """Assert a before/after sha256 listing is unchanged."""
    if before == after:
        return

    diff = "".join(
        difflib.unified_diff(
            before.splitlines(True),
            after.splitlines(True),
            fromfile="before-{}".format(label),
            tofile="after-{}".format(label),
        )
    )
    raise TestFailure("{} changed files unexpectedly:\n{}".format(label, diff))


def cleanup_python_artifacts(repo_root):
    """Remove bytecode/cache junk without deleting editable-install metadata."""
    repo_root = Path(repo_root)

    for cache_dir in repo_root.rglob("__pycache__"):
        if ".git" in cache_dir.parts:
            continue
        shutil.rmtree(str(cache_dir), ignore_errors=True)

    for pyc_file in repo_root.rglob("*.pyc"):
        if ".git" in pyc_file.parts:
            continue
        try:
            pyc_file.unlink()
        except OSError:
            pass


def create_local_aerolitctl_wrapper(repo_root, log_dir):
    """Create a temporary aerolitctl wrapper that runs the checked-out source."""
    repo_root = Path(repo_root)
    src_dir = repo_root / "src"
    wrapper_dir = Path(log_dir) / "bin"
    wrapper_dir.mkdir(parents=True, exist_ok=True)

    wrapper_path = wrapper_dir / "aerolitctl"
    inline_python = (
        "import sys; "
        "from aerolitctl.cli import main; "
        "sys.argv[0] = 'aerolitctl'; "
        "sys.exit(main())"
    )

    script = """#!/bin/sh
if [ -n "${{PYTHONPATH:-}}" ]; then
    export PYTHONPATH={src_dir}:$PYTHONPATH
else
    export PYTHONPATH={src_dir}
fi
exec {python_exe} -c {inline_python} "$@"
""".format(
        src_dir=shell_quote(src_dir),
        python_exe=shell_quote(sys.executable),
        inline_python=shell_quote(inline_python),
    )

    wrapper_path.write_text(script)
    os.chmod(str(wrapper_path), 0o755)

    return wrapper_path


def snapshot_files(paths, backup_dir):
    """Snapshot important files so real configure tests can be restored."""
    backup_dir = Path(backup_dir)
    backup_dir.mkdir(parents=True, exist_ok=True)

    snapshot = {}

    for path in paths:
        path = Path(path)
        key = str(path)
        if path.exists():
            data = path.read_bytes()
            snapshot[key] = data

            safe_name = key.strip("/").replace("/", "__")
            backup_path = backup_dir / safe_name
            backup_path.write_bytes(data)
        else:
            snapshot[key] = None

    return snapshot


def restore_snapshot(snapshot):
    """Restore files captured by snapshot_files."""
    for key, data in snapshot.items():
        path = Path(key)

        if data is None:
            if path.exists():
                try:
                    path.unlink()
                except OSError:
                    pass
            continue

        if not path.parent.exists():
            path.parent.mkdir(parents=True)

        path.write_bytes(data)


def parse_generated_vars(path):
    """Parse simple top-level generated YAML scalars into a dict."""
    values = {}
    content = read_text(path)

    for line in content.splitlines():
        match = re.match(r"^\s*([A-Za-z0-9_]+):\s*(.*?)\s*$", line)
        if not match:
            continue

        key = match.group(1)
        value = match.group(2).strip().strip("'").strip('"')
        values[key] = value

    return values


def expect_generated_vars(path, expected):
    """Assert generated vars contain expected key/value pairs."""
    values = parse_generated_vars(path)

    for key, expected_value in expected.items():
        actual_value = values.get(key)
        if actual_value is None:
            raise TestFailure("Generated vars missing key: {}".format(key))

        if str(actual_value).lower() != str(expected_value).lower():
            raise TestFailure(
                "Generated vars mismatch for {}: expected {}, got {}".format(
                    key,
                    expected_value,
                    actual_value,
                )
            )


def expected_server_vars_for_mode(mode, no_nfs=False, firewall_manage=True):
    """Return expected generated server vars for one configure server mode."""
    pxe_enabled = mode in ("pxe", "full")
    controller_enabled = mode in ("controller", "full")
    nfs_enabled = bool(controller_enabled and not no_nfs)

    return {
        "aerolit_server_mode": mode,
        "aerolit_pxe_enabled": str(pxe_enabled).lower(),
        "aerolit_controller_enabled": str(controller_enabled).lower(),
        "aerolit_nfs_enabled": str(nfs_enabled).lower(),
        "pxe_content_manage_firewall": str(
            bool(firewall_manage and pxe_enabled)
        ).lower(),
        "pxe_dnsmasq_manage_firewall": str(
            bool(firewall_manage and pxe_enabled)
        ).lower(),
        "nfs_server_manage_exports": str(nfs_enabled).lower(),
        "nfs_server_manage_services": str(nfs_enabled).lower(),
        "nfs_server_manage_firewall": str(
            bool(firewall_manage and nfs_enabled)
        ).lower(),
    }


def expect_no_python_firewall_actions(output, label):
    """Assert deploy output does not show old Python-owned firewall actions."""
    assert_not_regex(output, r"Would run Open firewall service:", label)
    assert_not_regex(output, r"Would run Open firewall port:", label)
    assert_not_regex(output, r"firewall-cmd.*--add-service", label)
    assert_not_regex(output, r"firewall-cmd.*--add-port", label)


def assert_role_owned_firewall_plan(output, label):
    """Assert deploy output reflects role-owned firewall management."""
    assert_contains(output, "Rules owner", label)
    assert_contains(output, "functional Ansible roles", label)
    assert_contains(output, "Effective deploy mode", label)
    assert_contains(output, "enabled from configure server", label)
    expect_no_python_firewall_actions(output, label)


def bundle_manifest_path(args):
    """Return the expected AeroLIT bundle manifest path."""
    return Path(args.bundle_path) / "aerolit-bundle.yml"


def managed_ansible_state_paths(args):
    """Return aerolitctl-managed Ansible files that should be snapshotted."""
    group_vars_root = (
        Path(args.bundle_path)
        / "collections-hub"
        / "ansible"
        / "group_vars"
    )

    paths = [
        Path(args.ansible_inventory_path),
        Path(args.ansible_generated_vars_path),
        Path(args.ansible_test_group_vars_path),
    ]

    if group_vars_root.exists():
        for path in group_vars_root.glob("*/aerolitctl.yml"):
            if path not in paths:
                paths.append(path)

    return paths


