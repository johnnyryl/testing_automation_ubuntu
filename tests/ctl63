def test_standardized_source_wording(args):
    """Catch old user-facing wording in Python source."""
    src_root = Path(args.repo_root) / "src"

    bad_strings = [
        "NFS/controller",
    ]

    required_strings = [
        "PXE Server",
        "Ansible Controller / NFS",
    ]

    all_python_text = []
    for path in src_root.rglob("*.py"):
        if "__pycache__" in path.parts:
            continue
        all_python_text.append((path, read_text(path)))

    for bad in bad_strings:
        offenders = [str(path) for path, content in all_python_text if bad in content]
        if offenders:
            raise TestFailure(
                "Old/non-standard wording '{}' found in:\n{}".format(
                    bad,
                    "\n".join(offenders),
                )
            )

    combined = "\n".join(content for path, content in all_python_text)
    for required in required_strings:
        if required not in combined:
            raise TestFailure(
                "Expected standardized wording not found in Python source: {}".format(
                    required
                )
            )


def test_server_dhcp_range_math(args):
    """Confirm guided DHCP pool math matches the requested client count."""
    src_path = str(Path(args.repo_root) / "src")
    if src_path not in sys.path:
        sys.path.insert(0, src_path)

    from aerolitctl.server import (
        dhcp_end_from_start,
        dhcp_range_size,
        parse_ipv4_address,
        parse_ipv4_network,
        suggested_dhcp_range,
        validate_dhcp_range,
    )

    network = parse_ipv4_network("192.168.109.0/24", "test network")
    server_ip = parse_ipv4_address("192.168.109.69", "test server IP")

    start, end = suggested_dhcp_range(
        network,
        server_ip=server_ip,
        gateway=None,
        requested_clients=69,
    )

    if start != "192.168.109.100" or end != "192.168.109.168":
        raise TestFailure(
            "Expected 69-client suggested DHCP range 192.168.109.100 - "
            "192.168.109.168, got {} - {}".format(start, end)
        )

    if dhcp_range_size(start, end) != 69:
        raise TestFailure(
            "Expected suggested DHCP range size 69, got {}".format(
                dhcp_range_size(start, end)
            )
        )

    shifted_end = dhcp_end_from_start("192.168.109.169", 69)

    if shifted_end != "192.168.109.237":
        raise TestFailure(
            "Expected shifted 69-client DHCP end 192.168.109.237, got {}".format(
                shifted_end
            )
        )

    validate_dhcp_range(
        "192.168.109.169",
        shifted_end,
        network,
        server_ip=server_ip,
        gateway=None,
    )

    old_size = dhcp_range_size("192.168.109.100", "192.168.109.149")
    if old_size != 50:
        raise TestFailure(
            "Expected old .100-.149 range size 50, got {}".format(old_size)
        )


