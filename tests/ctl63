    assert_contains(ansible_help, "--ensure-standard-groups", "configure ansible help")
    assert_contains(ansible_help, "--set-global-var", "configure ansible help")
    assert_contains(ansible_help, "--set-group-var", "configure ansible help")
    assert_contains(ansible_help, "--add-k3s-cluster", "configure ansible help")
    assert_contains(ansible_help, "--add-host-range", "configure ansible help")

    for command in commands:
        run_cmd(command)


def test_standardized_source_wording(args):
    """Catch old user-facing wording in Python source."""
    src_root = Path(args.repo_root) / "src"

    bad_strings = [
        "NFS/controller",
        "PXE:",
    ]

    required_strings = [
        "PXE Server",
        "Ansible Controller / NFS",
    ]

    all_python_text = []
    for path in src_root.rglob("*.py"):
        if "__pycache__" in path.parts:
            continue
        all_python_text.append((path, read_text(path)))

    for bad in bad_strings:
        offenders = [str(path) for path, content in all_python_text if bad in content]
        if offenders:
            raise TestFailure(
                "Old/non-standard wording '{}' found in:\n{}".format(
                    bad,
                    "\n".join(offenders),
                )
            )

    combined = "\n".join(content for path, content in all_python_text)
    for required in required_strings:
        if required not in combined:
            raise TestFailure(
                "Expected standardized wording not found in Python source: {}".format(
                    required
                )
            )


def test_configure_show_modes(args, hash_paths):
    """Confirm configure server --show is mode-aware and read-only."""
    before = sha256_paths(hash_paths)

    expectations = {
        "pxe": [
            r"Mode\s*: pxe",
            r"PXE Server:",
            r"Enabled\s*: yes",
            r"Ansible Controller / NFS:",
            r"Reason\s*: disabled by mode pxe",
            r"Show complete\. No files were changed\.",
        ],
        "controller": [
            r"Mode\s*: controller",
            r"PXE Server:",
            r"Reason\s*: disabled by mode controller",
            r"Ansible Controller / NFS:",
            r"Enabled\s*: yes",
            r"Show complete\. No files were changed\.",
        ],
        "full": [
            r"Mode\s*: full",
            r"PXE Server:",
            r"Enabled\s*: yes",
            r"Ansible Controller / NFS:",
            r"Enabled\s*: yes",
            r"Show complete\. No files were changed\.",
        ],
    }

    for mode, patterns in expectations.items():
        output = run_cmd(
            ["aerolitctl", "configure", "server", "--dry-run", "--mode", mode, "--show"]
        )
        for pattern in patterns:
            assert_regex(output, pattern, "configure server --show {}".format(mode))
        assert_not_contains(output, "NFS/controller", "configure server --show {}".format(mode))

    after = sha256_paths(hash_paths)
    assert_hashes_same(before, after, "configure-server-show")


def test_configure_dry_run_modes(args, hash_paths):
    """Confirm configure server --dry-run is mode-aware and read-only."""
    before = sha256_paths(hash_paths)

    for mode in ("pxe", "controller", "full"):
        output = run_cmd(["aerolitctl", "configure", "server", "--dry-run", "--mode", mode])
        assert_regex(output, r"Mode\s*: {}".format(mode), "configure dry-run {}".format(mode))
        assert_contains(
            output,
            "Dry run complete. No files were changed.",
            "configure dry-run {}".format(mode),
        )
        assert_not_contains(output, "NFS/controller", "configure dry-run {}".format(mode))

    after = sha256_paths(hash_paths)
    assert_hashes_same(before, after, "configure-server-dry-run")


