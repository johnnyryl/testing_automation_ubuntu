        "--no-require-firewalld",
        action="store_true",
        help=(
            "Compatibility option. Firewalld is no longer required for merge-readiness "
            "because firewall rules are owned by Ansible roles."
        ),
    )

    return parser


def main():
    """Run the merge-readiness regression suite."""
    parser = build_parser()
    args = parser.parse_args()

    args.repo_root = str(Path(args.repo_root).resolve())
    args.bundle_path = str(Path(args.bundle_path))
    args.nfs_export_path = args.bundle_path
    args.generated_vars_path = str(
        Path(args.bundle_path)
