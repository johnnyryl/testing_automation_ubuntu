    print("Generate playbook  : {}".format(args.generate_playbook_path))
    print("Generate profile   : {}".format(args.generate_pxe_profile_path))
    print("Generate template  : {}".format(args.generate_pxe_template_path))
    print("Log dir            : {}".format(args.log_dir))
    print("Full run log       : {}".format(RUN_LOG_PATH))
    print("Command logs       : {}".format(Path(args.log_dir) / "commands"))
    print("Local CLI wrapper  : {}".format(args.aerolitctl_wrapper))
    print("Keep state         : {}".format(args.keep_state))
    print("Skip write tests   : {}".format(args.skip_write_tests))
    print("Require firewalld  : {}".format(args.require_firewalld))
    print("")

    if not args.skip_write_tests:
        if hasattr(os, "geteuid") and os.geteuid() != 0:
            raise TestFailure(
                "Write tests update /etc/aerolit and bundle-generated files. Run as root, "
                "or use --skip-write-tests."
            )

        state_snapshot = snapshot_files(
            hash_paths,
            Path(args.log_dir) / "backups-before-tests",
        )

    tests = [
        ("environment preflight", lambda: test_environment_preflight(args)),
        ("basic repo/code sanity", lambda: test_basic_repo_sanity(args)),
        ("CLI help and parser", lambda: test_cli_help_and_parser(args)),
        ("generate help and parser", lambda: test_generate_help_and_parser(args)),
        ("logs command behavior", lambda: test_logs_command_behavior(args)),
        ("command logging behavior", lambda: test_command_logging_behavior(args)),
        ("backup config command behavior", lambda: test_backup_config_command_behavior(args, hash_paths)),
        ("settings command behavior", lambda: test_settings_command_behavior(args, hash_paths)),
        ("standardized source wording", lambda: test_standardized_source_wording(args)),
        ("server DHCP range math", lambda: test_server_dhcp_range_math(args)),
        ("configure all read-only behavior", lambda: test_configure_all_read_only(args, hash_paths)),
        ("configure server --show mode behavior", lambda: test_configure_show_modes(args, hash_paths)),
        ("configure server dry-run mode behavior", lambda: test_configure_dry_run_modes(args, hash_paths)),
        ("configure repos help/parser", lambda: test_configure_repos_help_and_parser(args)),
        ("configure repos guided non-interactive guard", lambda: test_configure_repos_guided_noninteractive_guard(args)),
        ("configure repos dry-run read-only", lambda: test_configure_repos_dry_run_read_only(args, hash_paths)),
        ("configure ansible dry-run read-only", lambda: test_configure_ansible_dry_run_read_only(args, hash_paths)),
        ("configure ansible sensitive var guard", lambda: test_configure_ansible_sensitive_var_guard(args)),
        ("configure pxe option guard", lambda: test_configure_pxe_option_guard(args)),
        ("configure pxe dry-run read-only", lambda: test_configure_pxe_dry_run_read_only(args, hash_paths)),
        ("generate dry-run read-only", lambda: test_generate_dry_run_read_only(args, hash_paths)),
    ]

    if not args.skip_write_tests:
        tests.extend(
            [
                ("real configure repos refresh/generated vars", lambda: test_real_configure_repos_refresh(args)),
                ("deploy repo vars handoff", lambda: test_deploy_repo_vars_handoff(args)),
                ("deploy missing repo vars guard", lambda: test_deploy_missing_repo_vars_guard(args)),
                ("real configure ansible managed writes", lambda: test_real_configure_ansible_writes(args)),
                ("real configure server mode writes", lambda: test_real_configure_modes(args)),
                ("real configure pxe managed writes/status/doctor", lambda: test_real_configure_pxe_writes(args)),
                ("real generate managed writes/guards", lambda: test_real_generate_writes(args)),
                ("deploy server mode dry-run matrix", lambda: test_deploy_mode_matrix(args)),
                ("deploy server skip flags", lambda: test_deploy_skip_flags(args)),
                ("deploy skip-firewall generated vars toggle", lambda: test_deploy_skip_firewall_generated_vars_toggle(args)),
                ("deploy show vs dry-run", lambda: test_deploy_show_vs_dry_run(args, hash_paths)),
                ("status read-only", lambda: test_status_read_only(args, hash_paths)),
                ("configure server dry-run read-only", lambda: test_configure_dry_run_read_only(args, hash_paths)),
                ("bundle manifest lifecycle", lambda: test_bundle_manifest_lifecycle(args)),
            ]
        )

    tests.extend(
        [
            ("path/bundle/doctor checks", lambda: test_path_bundle_doctor(args)),
            ("configure init dry-run", lambda: test_configure_init_dry_run(args)),
            ("provision wrapper read-only", lambda: test_provision_wrapper_read_only(args, hash_paths)),
            ("final merge gate", lambda: test_final_merge_gate(args)),
        ]
    )
    passed = []
    total_tests = len(tests)

    try:
        print_progress(0, total_tests)

        for test_number, item in enumerate(tests, 1):
            name, test_func = item

            print_test_header(test_number, total_tests, name)

            test_func()
            passed.append(name)

            append_run_log(
                "PASS TEST {} of {}: {}\n".format(
                    test_number,
                    total_tests,
                    name,
                )
            )

            print_progress(test_number, total_tests)

        finish_progress_line()

        print("")
        print("=" * 80)
        print("PASS: AeroLIT aerolitctl merge-readiness regression test passed")
        print("=" * 80)
        print("")
        print("Passed tests:")
        for name in passed:
            print("  - {}".format(name))
        print("")
        print("Logs saved under:")
        print("  {}".format(args.log_dir))
        print("")
        print("Full run log:")
        print("  {}".format(RUN_LOG_PATH))
        print("")
        print("Command logs:")
        print("  {}".format(Path(args.log_dir) / "commands"))
        print("")
        print("AeroLIT cmd logs:")
        print("  {}".format(Path(args.log_dir) / "aerolitctl-command-logs-all"))
        print("")

        return 0

    finally:
        finish_progress_line()
        cleanup_python_artifacts(args.repo_root)

        if state_snapshot is not None and not args.keep_state:
            print("")
            print("Restoring saved AeroLIT config/generated-vars/manifest/Ansible state...")
            try:
                restore_snapshot(state_snapshot)
                print("State restored.")
            except Exception as exc:
                print("")
                print("WARNING: failed to restore saved state: {}".format(exc))
                print("Manual backups are under:")
                print("  {}".format(Path(args.log_dir) / "backups-before-tests"))
                raise
        elif state_snapshot is not None and args.keep_state:
            print("")
            print("Keeping final test state because --keep-state was used.")


if __name__ == "__main__":
    try:
        sys.exit(main())
    except TestFailure as exc:
        finish_progress_line()

        print("")
        print("=" * 80)
        print("FAIL in {}".format(current_test_label()))
        print("Last command context: {}".format(current_command_label()))
        print("FAIL: {}".format(exc))

        if RUN_LOG_PATH is not None:
            print("")
            print("Full run log:")
            print("  {}".format(RUN_LOG_PATH))

        if LAST_COMMAND_LOG_PATH is not None:
            print("")
            print("Last command log:")
            print("  {}".format(LAST_COMMAND_LOG_PATH))

        print("=" * 80)
        print("")
        sys.exit(1)
