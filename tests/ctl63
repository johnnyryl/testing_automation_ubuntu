    set_run_log_path(args.log_dir)

    args.aerolitctl_wrapper = create_local_aerolitctl_wrapper(
        args.repo_root,
        args.log_dir,
    )

    old_path = os.environ.get("PATH", "")
    wrapper_bin = str(Path(args.aerolitctl_wrapper).parent)
    os.environ["PATH"] = wrapper_bin + os.pathsep + old_path

    src_dir = str(Path(args.repo_root) / "src")
    old_pythonpath = os.environ.get("PYTHONPATH", "")
    if old_pythonpath:
        os.environ["PYTHONPATH"] = src_dir + os.pathsep + old_pythonpath
    else:
        os.environ["PYTHONPATH"] = src_dir

    hash_paths = [
        Path(args.config_file),
        Path(args.state_file),
        bundle_manifest_path(args),
        Path(args.bundle_path) / "collections-hub" / ".sync-preserve",
        Path(args.bundle_path) / "collections-hub" / ".gitlab-ci.yml",
        Path(args.generated_vars_path),
        *managed_repo_state_paths(args),
        *managed_ansible_state_paths(args),
        *managed_pxe_state_paths(args),
        *generate_state_paths(args),
    ]

    state_snapshot = None

    print("")
    print("=" * 80)
    print("AeroLIT aerolitctl merge-readiness regression test")
    print("=" * 80)
    print("")
    print("Repo root          : {}".format(args.repo_root))
    print("Bundle path        : {}".format(args.bundle_path))
    print("Config file        : {}".format(args.config_file))
