        / "ansible"
        / "group_vars"
        / "all"
        / "aerolitctl_server_generated.yml"
    )
    args.ansible_inventory_path = str(
        Path(args.bundle_path)
        / "collections-hub"
        / "ansible"
        / "inventory"
        / "90_aerolitctl.ini"
    )
    args.ansible_generated_vars_path = str(
