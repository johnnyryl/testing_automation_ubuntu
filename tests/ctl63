def configure_server_command(args, mode, no_nfs=False):
    """Build a real configure server command for the requested mode."""
    command = [
        "aerolitctl",
        "configure",
        "server",
        "--mode",
        mode,
        "--interface",
        args.interface,
        "--server-ip",
        args.server_ip,
        "--network",
        args.network,
        "--gateway",
        args.gateway,
        "--nfs-export-path",
        args.nfs_export_path,
        "--nfs-allow-clients",
        args.allowed_clients,
        "--target-mount-path",
        args.target_mount_path,
    ]

    if mode in ("pxe", "full"):
        command.extend(
            [
                "--dhcp-start",
                args.dhcp_start,
                "--dhcp-end",
                args.dhcp_end,
            ]
        )

    if no_nfs:
        command.append("--no-nfs")

    return command


def test_environment_preflight(args):
    """Fail early when the VM/repo is not ready for this regression test."""
    aerolitctl_path = shutil.which("aerolitctl")
    if aerolitctl_path is None:
        raise TestFailure("aerolitctl command was not found in PATH")

    repo_root = Path(args.repo_root)
    expected_src = repo_root / "src" / "aerolitctl"
    expected_cli = expected_src / "cli.py"

    if not expected_src.exists():
        raise TestFailure(
            "Repo root does not look correct. Missing: {}".format(expected_src)
        )

    if not expected_cli.exists():
        raise TestFailure(
            "Repo root does not look correct. Missing: {}".format(expected_cli)
        )

    if not Path(args.config_file).exists():
        raise TestFailure("AeroLIT config file is missing: {}".format(args.config_file))

    if not Path(args.bundle_path).exists():
        raise TestFailure("AeroLIT bundle path is missing: {}".format(args.bundle_path))

    generated_parent = Path(args.generated_vars_path).parent
    if not generated_parent.exists():
        raise TestFailure(
            "Generated vars parent directory is missing: {}".format(generated_parent)
        )

    rc, stdout, stderr = command_output(["aerolitctl", "--help"])
    if rc != 0:
        raise TestFailure(
            "Temporary aerolitctl wrapper failed preflight rc={}.\nstdout:\n{}\nstderr:\n{}".format(
                rc,
                stdout,
                stderr,
            )
        )

    if args.require_firewalld:
        if shutil.which("firewall-cmd") is None:
            raise TestFailure(
                "firewall-cmd was not found. Use --no-require-firewalld to skip "
                "strict firewall action assertions on this host."
            )

        rc, stdout, stderr = command_output(["systemctl", "is-active", "--quiet", "firewalld"])
        if rc != 0:
            raise TestFailure(
                "firewalld is not active. Use --no-require-firewalld to skip "
                "strict firewall action assertions on this host."
            )

    print("aerolitctl path : {}".format(aerolitctl_path))
    print("source wrapper  : {}".format(args.aerolitctl_wrapper))


def test_basic_repo_sanity(args):
    """Check Python syntax and git whitespace sanity."""
    cleanup_python_artifacts(args.repo_root)

    run_cmd(["git", "diff", "--check"], cwd=args.repo_root)
    run_cmd(["python3", "-m", "compileall", "src"], cwd=args.repo_root)

    cleanup_python_artifacts(args.repo_root)

    status = run_cmd(["git", "status", "--porcelain"], cwd=args.repo_root)
    bad_lines = [
        line
        for line in status.splitlines()
        if "__pycache__" in line or line.endswith(".pyc")
    ]

    if bad_lines:
        raise TestFailure(
            "Python cache/build artifacts are present in git status:\n{}".format(
                "\n".join(bad_lines)
            )
        )


def test_cli_help_and_parser(args):
    """Confirm command parser and help paths still work."""
    commands = [
        ["aerolitctl", "--help"],
        ["aerolitctl", "version"],
        ["aerolitctl", "doctor"],
        ["aerolitctl", "status", "--help"],
        ["aerolitctl", "configure", "--help"],
        ["aerolitctl", "configure", "init", "--help"],
        ["aerolitctl", "configure", "server", "--help"],
        ["aerolitctl", "deploy", "--help"],
        ["aerolitctl", "deploy", "server", "--help"],
        ["aerolitctl", "path", "--help"],
        ["aerolitctl", "bundle", "--help"],
        ["aerolitctl", "--verbose", "status"],
        ["aerolitctl", "status", "--verbose"],
        ["aerolitctl", "deploy", "server", "--dry-run", "--verbose"],
        ["aerolitctl", "deploy", "server", "--verbose", "--dry-run"],
        ["aerolitctl", "configure", "init", "--dry-run", "--non-interactive", "--verbose"],
        ["aerolitctl", "configure", "server", "--dry-run", "--mode", "pxe", "--verbose"],
        ["aerolitctl", "configure", "server", "--dry-run", "--mode", "pxe", "--show", "--verbose"],
        ["aerolitctl", "configure", "ansible", "--help"],
        ["aerolitctl", "configure", "ansible", "--show"],
    ]

    help_output = run_cmd(["aerolitctl", "configure", "server", "--help"])
    assert_not_contains(help_output, "NFS/controller", "configure server help")
