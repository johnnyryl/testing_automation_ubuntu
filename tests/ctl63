    assert_contains(real_output, str(args.config_file), "backup real")

    archives = sorted(backup_output_dir.glob("aerolit-config-*.tar.gz"))
    if len(archives) != 1:
        raise TestFailure(
            "Expected exactly one backup archive, found {}: {}".format(
                len(archives),
                ", ".join(str(path) for path in archives),
            )
        )

    archive = archives[0]
    assert_path_exists(archive, "backup archive")

    with tarfile.open(str(archive), "r:gz") as tar:
        names = tar.getnames()

        if "aerolit-backup-manifest.json" not in names:
