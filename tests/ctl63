def test_environment_preflight(args):
    """Fail early when the VM/repo is not ready for this regression test."""
    aerolitctl_path = shutil.which("aerolitctl")
    if aerolitctl_path is None:
        raise TestFailure("aerolitctl command was not found in PATH")

    repo_root = Path(args.repo_root)
    expected_src = repo_root / "src" / "aerolitctl"
    expected_cli = expected_src / "cli.py"

    if not expected_src.exists():
        raise TestFailure(
            "Repo root does not look correct. Missing: {}".format(expected_src)
        )

    if not expected_cli.exists():
        raise TestFailure(
            "Repo root does not look correct. Missing: {}".format(expected_cli)
        )

    if not Path(args.config_file).exists():
        raise TestFailure("AeroLIT config file is missing: {}".format(args.config_file))

    if not Path(args.bundle_path).exists():
        raise TestFailure("AeroLIT bundle path is missing: {}".format(args.bundle_path))

    generated_parent = Path(args.generated_vars_path).parent
    if not generated_parent.exists():
        raise TestFailure(
            "Generated vars parent directory is missing: {}".format(generated_parent)
        )

    rc, stdout, stderr = command_output(["aerolitctl", "--help"])
    if rc != 0:
        raise TestFailure(
            "Temporary aerolitctl wrapper failed preflight rc={}.\nstdout:\n{}\nstderr:\n{}".format(
                rc,
                stdout,
                stderr,
            )
        )

    if args.require_firewalld:
        if shutil.which("firewall-cmd") is None:
            print(
                "NOTE: firewall-cmd was not found. This is no longer fatal for "
                "merge-readiness because firewall rules are applied by Ansible roles."
            )
        else:
            rc, stdout, stderr = command_output(
                ["systemctl", "is-active", "--quiet", "firewalld"]
            )
            if rc != 0:
                print(
                    "NOTE: firewalld is not active. This is no longer fatal for "
                    "merge-readiness because this test validates generated role vars, "
                    "not live firewall state."
                )

    append_run_log("aerolitctl path : {}\n".format(aerolitctl_path))
    append_run_log("source wrapper  : {}\n".format(args.aerolitctl_wrapper))


