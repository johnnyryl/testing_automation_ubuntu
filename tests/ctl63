    empty_log_root = Path(args.log_dir) / "empty-aerolit-logs"

    log_root.mkdir(parents=True, exist_ok=True)
    empty_log_root.mkdir(parents=True, exist_ok=True)

    old_log = log_root / "old-command.log"
    latest_log = log_root / "latest-command.log"
    nested_dir = log_root / "nested"
    nested_dir.mkdir(parents=True, exist_ok=True)
    nested_log = nested_dir / "nested-command.out"

    write_text(old_log, "old line 1\nold line 2\n")
    write_text(latest_log, "latest line 1\nlatest line 2\nlatest line 3\n")
    write_text(nested_log, "nested line 1\n")

    old_time = datetime.datetime.now().timestamp() - 300
    nested_time = datetime.datetime.now().timestamp() - 200
    latest_time = datetime.datetime.now().timestamp() - 100

    os.utime(str(old_log), (old_time, old_time))
    os.utime(str(nested_log), (nested_time, nested_time))
    os.utime(str(latest_log), (latest_time, latest_time))

    dir_output = run_cmd(
        ["aerolitctl", "logs", "--dir", "--log-dir", str(log_root)]
    )
    assert_contains(dir_output, str(log_root), "logs --dir")

    list_output = run_cmd(
        ["aerolitctl", "logs", "--list", "--log-dir", str(log_root)]
    )
    assert_contains(list_output, "AeroLIT logs", "logs --list")
    assert_contains(list_output, str(latest_log), "logs --list")
    assert_contains(list_output, str(old_log), "logs --list")
    assert_contains(list_output, str(nested_log), "logs --list")

    pattern_output = run_cmd(
        [
            "aerolitctl",
            "logs",
            "--list",
            "--limit",
            "1",
            "--pattern",
            "*.log",
            "--log-dir",
            str(log_root),
        ]
    )
    assert_contains(pattern_output, "AeroLIT logs", "logs --pattern")
    assert_contains(pattern_output, str(latest_log), "logs --pattern")
    assert_not_contains(pattern_output, str(nested_log), "logs --pattern")

    tail_output = run_cmd(
        ["aerolitctl", "logs", "--tail", "2", "--log-dir", str(log_root)]
    )
    assert_contains(tail_output, "AeroLIT log:", "logs tail")
    assert_contains(tail_output, str(latest_log), "logs tail")
    assert_contains(tail_output, "latest line 2", "logs tail")
    assert_contains(tail_output, "latest line 3", "logs tail")
    assert_not_contains(tail_output, "latest line 1", "logs tail")

    relative_path_output = run_cmd(
        [
            "aerolitctl",
            "logs",
            "--path",
            "nested/nested-command.out",
            "--tail",
            "1",
            "--log-dir",
            str(log_root),
        ]
    )
    assert_contains(relative_path_output, str(nested_log), "logs relative path")
    assert_contains(relative_path_output, "nested line 1", "logs relative path")

    missing_output = run_cmd(
        ["aerolitctl", "logs", "--log-dir", str(empty_log_root)],
        expected_rc=1,
    )
    assert_contains(missing_output, "No AeroLIT log files found in:", "logs empty")
    assert_contains(missing_output, "aerolitctl logs --list", "logs empty")
    assert_contains(missing_output, "aerolitctl logs --dir", "logs empty")

    bad_tail_output = run_cmd(
