def assert_firewall_action_expectations(args, output, mode_label):
    """Assert firewall dry-run actions when strict firewall assertions are enabled."""
    if not args.require_firewalld:
        return

    if mode_label == "pxe":
        assert_regex(output, r"Would run Open firewall port:.*18080/tcp", "deploy pxe")
        assert_not_regex(output, r"Would run Open firewall service:.*--add-service=nfs", "deploy pxe")
        return

    if mode_label == "controller":
        assert_regex(output, r"Would run Open firewall service:.*--add-service=nfs", "deploy controller")
        assert_regex(output, r"Would run Open firewall service:.*--add-service=mountd", "deploy controller")
        assert_regex(output, r"Would run Open firewall service:.*--add-service=rpc-bind", "deploy controller")
        assert_not_regex(output, r"Would run Open firewall port:.*18080/tcp", "deploy controller")
        return

    if mode_label == "full":
        assert_regex(output, r"Would run Open firewall service:.*--add-service=nfs", "deploy full")
        assert_regex(output, r"Would run Open firewall service:.*--add-service=mountd", "deploy full")
        assert_regex(output, r"Would run Open firewall service:.*--add-service=rpc-bind", "deploy full")
        assert_regex(output, r"Would run Open firewall port:.*18080/tcp", "deploy full")


def test_deploy_mode_matrix(args):
    """Confirm deploy dry-run only runs actions for the saved mode."""
    pxe_output = configure_and_capture_deploy(args, "pxe", "deploy-pxe.log")
    assert_regex(pxe_output, r"Mode\s*: pxe", "deploy pxe")
    assert_contains(pxe_output, "PXE Server:", "deploy pxe")
    assert_regex(pxe_output, r"Enabled\s*: yes", "deploy pxe")
    assert_contains(pxe_output, "Would run Run pxe_server.yml", "deploy pxe")
    assert_contains(pxe_output, "Controller playbook skipped", "deploy pxe")
    assert_regex(
        pxe_output,
        r"Ansible Controller / NFS:[\s\S]*?Reason\s*: disabled by mode pxe",
        "deploy pxe controller/NFS disabled reason",
    )
    assert_not_contains(pxe_output, "Would run Run ansible_controller.yml", "deploy pxe")
    assert_not_contains(pxe_output, "Would run Enable and start NFS services", "deploy pxe")
    assert_firewall_action_expectations(args, pxe_output, "pxe")

    controller_output = configure_and_capture_deploy(args, "controller", "deploy-controller.log")
    assert_regex(controller_output, r"Mode\s*: controller", "deploy controller")
