    print("=" * 80)
    print("")
    print("Repo root          : {}".format(args.repo_root))
    print("Bundle path        : {}".format(args.bundle_path))
    print("Config file        : {}".format(args.config_file))
    print("State file         : {}".format(args.state_file))
    print("Bundle manifest    : {}".format(bundle_manifest_path(args)))
    print("Generated vars     : {}".format(args.generated_vars_path))
    print("Ansible inventory  : {}".format(args.ansible_inventory_path))
    print("Ansible gen vars   : {}".format(args.ansible_generated_vars_path))
    print("Ansible test vars  : {}".format(args.ansible_test_group_vars_path))
    print("Log dir            : {}".format(args.log_dir))
    print("Local CLI wrapper  : {}".format(args.aerolitctl_wrapper))
    print("Keep state         : {}".format(args.keep_state))
    print("Skip write tests   : {}".format(args.skip_write_tests))
    print("Require firewalld  : {}".format(args.require_firewalld))
    print("")

    if not args.skip_write_tests:
        if hasattr(os, "geteuid") and os.geteuid() != 0:
            raise TestFailure(
                "Write tests update /etc/aerolit and bundle-generated files. Run as root, "
                "or use --skip-write-tests."
            )

        state_snapshot = snapshot_files(
            hash_paths,
            Path(args.log_dir) / "backups-before-tests",
        )

    tests = [
        ("environment preflight", lambda: test_environment_preflight(args)),
        ("basic repo/code sanity", lambda: test_basic_repo_sanity(args)),
        ("CLI help and parser", lambda: test_cli_help_and_parser(args)),
        ("standardized source wording", lambda: test_standardized_source_wording(args)),
        ("configure server --show mode behavior", lambda: test_configure_show_modes(args, hash_paths)),
        ("configure server dry-run mode behavior", lambda: test_configure_dry_run_modes(args, hash_paths)),
        ("configure ansible dry-run read-only", lambda: test_configure_ansible_dry_run_read_only(args, hash_paths)),
        ("configure ansible sensitive var guard", lambda: test_configure_ansible_sensitive_var_guard(args)),
    ]

    if not args.skip_write_tests:
        tests.extend(
            [
                ("real configure ansible managed writes", lambda: test_real_configure_ansible_writes(args)),
                ("real configure server mode writes", lambda: test_real_configure_modes(args)),
                ("deploy server mode dry-run matrix", lambda: test_deploy_mode_matrix(args)),
                ("deploy server skip flags", lambda: test_deploy_skip_flags(args)),
                ("deploy show vs dry-run", lambda: test_deploy_show_vs_dry_run(args, hash_paths)),
                ("status read-only", lambda: test_status_read_only(args, hash_paths)),
                ("configure server dry-run read-only", lambda: test_configure_dry_run_read_only(args, hash_paths)),
                ("bundle manifest lifecycle", lambda: test_bundle_manifest_lifecycle(args)),
            ]
        )

    tests.extend(
        [
            ("path/bundle/doctor checks", lambda: test_path_bundle_doctor(args)),
            ("configure init dry-run", lambda: test_configure_init_dry_run(args)),
            ("final merge gate", lambda: test_final_merge_gate(args)),
        ]
    )

    passed = []

    try:
        for name, test_func in tests:
            print("")
            print("=" * 80)
            print("TEST: {}".format(name))
            print("=" * 80)
            test_func()
            passed.append(name)
            print("")
            print("PASS: {}".format(name))

        print("")
        print("=" * 80)
        print("PASS: AeroLIT aerolitctl merge-readiness regression test passed")
        print("=" * 80)
        print("")
        print("Passed tests:")
        for name in passed:
            print("  - {}".format(name))
        print("")
        print("Logs saved under:")
        print("  {}".format(args.log_dir))
        print("")

        return 0

    finally:
        cleanup_python_artifacts(args.repo_root)

        if state_snapshot is not None and not args.keep_state:
            print("")
            print("Restoring saved AeroLIT config/generated-vars/manifest/Ansible state...")
            try:
                restore_snapshot(state_snapshot)
                print("State restored.")
            except Exception as exc:
                print("")
                print("WARNING: failed to restore saved state: {}".format(exc))
                print("Manual backups are under:")
                print("  {}".format(Path(args.log_dir) / "backups-before-tests"))
                raise
        elif state_snapshot is not None and args.keep_state:
            print("")
            print("Keeping final test state because --keep-state was used.")


