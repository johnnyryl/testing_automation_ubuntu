    parser.add_argument("--interface", default="ens160")
    parser.add_argument("--server-ip", default="192.168.109.10")
    parser.add_argument("--network", default="192.168.109.0/24")
    parser.add_argument("--dhcp-start", default="192.168.109.100")
    parser.add_argument("--dhcp-end", default="192.168.109.149")
    parser.add_argument("--gateway", default="none")
    parser.add_argument("--allowed-clients", default="192.168.109.0/24")
    parser.add_argument("--target-mount-path", default="/home/unix/sysadmin")

    parser.add_argument(
        "--log-dir",
        default=None,
        help="Directory for captured logs. Default: /tmp/aerolitctl-merge-test-<timestamp>",
    )
    parser.add_argument(
        "--keep-state",
        action="store_true",
        help="Do not restore /etc/aerolit/aerolitctl.yml and generated vars at the end.",
    )
    parser.add_argument(
        "--skip-write-tests",
        action="store_true",
        help="Skip real configure ansible, configure server, and configure init write tests.",
    )
