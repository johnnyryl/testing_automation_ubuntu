Name:           aerolitctl
Version:        0.1.0
Release:        1%{?dist}
Summary:        Command and control interface for AeroLIT bundles

License:        Proprietary
URL:            https://gitlab.example.com/lit/aerolitctl
Source0:        %{name}-%{version}.tar.gz

BuildArch:      noarch

BuildRequires:  python3-devel
BuildRequires:  python3-rpm-macros
BuildRequires:  python3-setuptools
BuildRequires:  python3-wheel

Requires:       python3
Requires:       python3dist(pyyaml)

Recommends:     bash-completion

%description
aerolitctl is the command and control interface for AeroLIT bundles.

%prep
%autosetup

%build
%py3_build

%install
%py3_install

install -d -m 0755 %{buildroot}%{_sysconfdir}/aerolit
install -d -m 0755 %{buildroot}%{_localstatedir}/log/aerolit
install -d -m 0755 %{buildroot}%{_localstatedir}/lib/aerolit

install -m 0644 packaging/etc/aerolit/aerolitctl.yml \
  %{buildroot}%{_sysconfdir}/aerolit/aerolitctl.yml

install -m 0644 packaging/etc/aerolit/aerolitctl.yml.example \
  %{buildroot}%{_sysconfdir}/aerolit/aerolitctl.yml.example

install -Dm0644 completions/aerolitctl.bash \
  %{buildroot}%{_datadir}/bash-completion/completions/aerolitctl

%files
%license LICENSE
%doc README.md

%{_bindir}/aerolitctl
%{python3_sitelib}/aerolitctl*

%dir %{_sysconfdir}/aerolit
%config(noreplace) %{_sysconfdir}/aerolit/aerolitctl.yml
%config(noreplace) %{_sysconfdir}/aerolit/aerolitctl.yml.example

%dir %{_localstatedir}/log/aerolit
%dir %{_localstatedir}/lib/aerolit

%dir %{_datadir}/bash-completion
%dir %{_datadir}/bash-completion/completions
%{_datadir}/bash-completion/completions/aerolitctl

