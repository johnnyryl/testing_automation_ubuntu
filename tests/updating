5. Change your .gitlab-ci.yml bundle job

Instead of:

bundle_profile_path: bundle-profiles/rhel8_standard.yml

use:

bundle_item_catalog_dir: bundle-items
bundle_item_ids: |
  files
  collections-hub
  rhel8iso
  third-party-rhel8-rpms
  bootstrap

