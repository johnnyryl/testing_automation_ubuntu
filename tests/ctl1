"""Safe file and directory helpers for aerolitctl."""
import shutil
from datetime import datetime
from pathlib import Path
from .paths import BACKUP_DIR
class InitReport(object):
    """Collect actions taken during initialization."""
    def __init__(self, verbose=False):
        self.verbose = verbose
        self.created = []
        self.updated = []
        self.existing = []
        self.backed_up = []
        self.warnings = []
        self.errors = []
        self.dry_run = []
    def add(self, category, message):
        getattr(self, category).append(message)
    def print_summary(self):
        print("")
        print("AeroLIT initialization summary")
        print("")
        sections = [
            ("Created", self.created),
            ("Updated", self.updated),
            ("Already existed", self.existing),
            ("Backed up", self.backed_up),
            ("Dry-run actions", self.dry_run),
            ("Warnings", self.warnings),
            ("Errors", self.errors),
        ]
        for title, values in sections:
            if not values:
                continue
            print("{}:".format(title))
            for value in values:
                print("  - {}".format(value))
            print("")
def timestamp():
    """Return filesystem-safe UTC timestamp."""
    return datetime.utcnow().strftime("%Y%m%d-%H%M%S")
def ensure_directory(path, report, dry_run=False):
    """Create a directory if needed."""
    path = Path(path)
    if path.exists():
        if path.is_dir():
            report.add("existing", str(path))
            return
        report.add("errors", "{} exists but is not a directory".format(path))
        return
    if dry_run:
        report.add("dry_run", "Would create directory {}".format(path))
        return
    path.mkdir(parents=True, exist_ok=True)
    report.add("created", str(path))
def backup_existing(path, report, dry_run=False):
    """Back up an existing file or directory under /var/lib/aerolit/backups."""
    path = Path(path)
    if not path.exists():
        return None
    backup_name = "{}.{}".format(str(path).lstrip("/").replace("/", "_"), timestamp())
    backup_path = BACKUP_DIR / backup_name
    if dry_run:
        report.add("dry_run", "Would back up {} to {}".format(path, backup_path))
        return backup_path
    BACKUP_DIR.mkdir(parents=True, exist_ok=True)
    if path.is_dir():
        shutil.copytree(str(path), str(backup_path))
    else:
        shutil.copy2(str(path), str(backup_path))
    report.add("backed_up", "{} -> {}".format(path, backup_path))
    return backup_path
def write_text_file(path, content, report, overwrite=False, backup=True, dry_run=False):
    """Write a text file safely."""
    path = Path(path)
    if path.exists() and not overwrite:
        report.add("existing", str(path))
        return False
    if path.exists() and backup:
        backup_existing(path, report, dry_run=dry_run)
    if dry_run:
        action = "Would update" if path.exists() else "Would create"
        report.add("dry_run", "{} file {}".format(action, path))
        return True
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)
    if path.exists() and overwrite:
        report.add("updated", str(path))
    else:
        report.add("created", str(path))
    return True

