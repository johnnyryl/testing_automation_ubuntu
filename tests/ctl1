"""Full AeroLIT initialization workflow."""
from pathlib import Path
from .config import config_text
from .files import InitReport, ensure_directory, write_text_file
from .paths import (
    ANSIBLE_CFG_FILE,
    ANSIBLE_GROUP_VARS_FILE,
    ANSIBLE_INVENTORY_FILE,
    CONFIG_FILE,
    DEFAULT_BUNDLE_PATH,
    GENERATED_BOOTSTRAP_VARS_FILE,
    STATE_FILE,
    SYNC_PRESERVE_FILE,
    required_directories,
)
from .state import state_text
ANSIBLE_INVENTORY_CONTENT = """# AeroLIT inventory
# This file is created by aerolitctl configure init.
# Update host/group entries as needed for your environment.
[localhost]
localhost ansible_connection=local
"""
ANSIBLE_GROUP_VARS_CONTENT = """---
# AeroLIT Ansible group variables
# This file is created by aerolitctl configure init.
# Site-specific values can be added here.
aerolit_managed: true
"""
ANSIBLE_CFG_CONTENT = """[defaults]
inventory = /etc/aerolit/ansible/inventory
roles_path = /opt/aerolit/aerolit-bundle/collections-hub/roles:/etc/aerolit/overrides/roles
collections_paths = /opt/aerolit/aerolit-bundle/collections-hub/collections
host_key_checking = False
retry_files_enabled = False
stdout_callback = yaml
"""
GENERATED_BOOTSTRAP_VARS_CONTENT = """---
# Generated AeroLIT bootstrap variables
# Created by aerolitctl configure init.
# Later configure commands may update this file.
aerolit_generated_by: aerolitctl
aerolit_generated_reason: configure init
"""
SYNC_PRESERVE_CONTENT = """# AeroLIT preserve manifest
# Created by aerolitctl configure init.
#
# Paths listed here are preserved during future sync/update workflows.
# These are rsync exclude-style patterns, not .gitignore syntax.
# Use exact file paths for files.
# Use trailing / for directories.
# Blank lines and lines beginning with # are ignored.
# AeroLIT control/config content
/etc/aerolit/
/var/lib/aerolit/
/var/log/aerolit/
# User-owned overrides and generated content
/etc/aerolit/overrides/
/etc/aerolit/generated/
/etc/aerolit/ansible/
# Legacy/local content patterns, used if sync tooling operates inside a bundle/repo
.gitlab-ci.yml
ansible/ansible.cfg
ansible/inventory
ansible/group_vars/
ansible/playbooks/site_local.yml
ansible/network_local/
docs/local/
"""
def resolve_bundle_path(bundle_path=None, non_interactive=False):
    """Resolve bundle path from arg, prompt, or default."""
    if bundle_path:
        return Path(bundle_path)
    if non_interactive:
        return DEFAULT_BUNDLE_PATH
    prompt = "AeroLIT bundle path [{}]: ".format(DEFAULT_BUNDLE_PATH)
    value = input(prompt).strip()
    if not value:
        return DEFAULT_BUNDLE_PATH
    return Path(value)
def validate_basic_bundle_layout(bundle_path, report):
    """Warn about obvious bundle layout problems."""
    bundle_path = Path(bundle_path)
    if not bundle_path.exists():
        report.add(
            "warnings",
            "Bundle path does not exist yet: {}".format(bundle_path),
        )
        return
    expected = [
        bundle_path / "collections-hub",
        bundle_path / "repos",
        bundle_path / "files",
        bundle_path / "extracted_isos",
    ]
    for path in expected:
        if not path.exists():
            report.add("warnings", "Expected bundle path not found: {}".format(path))
    manifest = bundle_path / "aerolit-bundle.yml"
    if not manifest.exists():
        report.add(
            "warnings",
            "Bundle manifest not found yet: {}".format(manifest),
        )
    bootstrap = bundle_path / "bootstrap.sh"
    if not bootstrap.exists():
        report.add(
            "warnings",
            "Compatibility bootstrap.sh not found: {}".format(bootstrap),
        )
def maybe_create_bundle_preserve_file(bundle_path, report, force=False, dry_run=False):
    """Create a bundle-local .sync-preserve if the bundle exists."""
    bundle_path = Path(bundle_path)
    if not bundle_path.exists():
        report.add(
            "warnings",
            "Skipping bundle-local .sync-preserve because bundle path does not exist: {}".format(
                bundle_path
            ),
        )
        return
    preserve_file = bundle_path / ".sync-preserve"
    write_text_file(
        preserve_file,
        SYNC_PRESERVE_CONTENT,
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
    )
def run_configure_init(
    bundle_path=None,
    force=False,
    dry_run=False,
    non_interactive=False,
    verbose=False,
):
    """Run full AeroLIT initialization."""
    report = InitReport(verbose=verbose)
    resolved_bundle_path = resolve_bundle_path(
        bundle_path=bundle_path,
        non_interactive=non_interactive,
    )
    for directory in required_directories():
        ensure_directory(directory, report, dry_run=dry_run)
    write_text_file(
        CONFIG_FILE,
        config_text(resolved_bundle_path),
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
    )
    write_text_file(
        STATE_FILE,
        state_text(),
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
    )
    write_text_file(
        SYNC_PRESERVE_FILE,
        SYNC_PRESERVE_CONTENT,
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
    )
    maybe_create_bundle_preserve_file(
        resolved_bundle_path,
        report,
        force=force,
        dry_run=dry_run,
    )
    write_text_file(
        ANSIBLE_INVENTORY_FILE,
        ANSIBLE_INVENTORY_CONTENT,
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
    )
    write_text_file(
        ANSIBLE_GROUP_VARS_FILE,
        ANSIBLE_GROUP_VARS_CONTENT,
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
    )
    write_text_file(
        ANSIBLE_CFG_FILE,
        ANSIBLE_CFG_CONTENT,
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
    )
    write_text_file(
        GENERATED_BOOTSTRAP_VARS_FILE,
        GENERATED_BOOTSTRAP_VARS_CONTENT,
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
    )
    validate_basic_bundle_layout(resolved_bundle_path, report)
    print("AeroLIT initialization complete.")
    print("")
    print("Configured bundle path:")
    print("  {}".format(resolved_bundle_path))
    print("")
    print("Primary config:")
    print("  {}".format(CONFIG_FILE))
    print("")
    print("Runtime state:")
    print("  {}".format(STATE_FILE))
    report.print_summary()
    return 1 if report.errors else 0

