def pxe_status_snapshot(bundle_path):
    """Return concise PXE generator/profile status values for status/doctor/deploy --show."""
    bundle_path = Path(bundle_path)

    state = load_managed_pxe_state(bundle_path)

    generated_vars = aerolitctl_pxe_generated_vars_file(bundle_path)
    override_root = aerolitctl_pxe_overrides_dir()
    profile_root = aerolitctl_pxe_profile_overrides_dir()
    template_root = aerolitctl_pxe_template_overrides_dir()

    generated_vars_present = generated_vars.exists()
    generated_vars_managed = (
        generated_vars_present
        and file_looks_managed(generated_vars, "generated_vars")
    )

    managed_profile_files = existing_managed_profile_files()

    return OrderedDict(
        [
            ("bundle_path", str(bundle_path)),
            ("configured", generated_vars_managed or bool(managed_profile_files)),
            ("enabled_profiles", state.enabled_profiles()),
            ("implemented_profiles", state.implemented_profiles()),
            ("generated_vars", str(generated_vars)),
            ("generated_vars_present", generated_vars_present),
            ("generated_vars_managed", generated_vars_managed),
            ("override_root", str(override_root)),
            ("override_root_present", override_root.exists()),
            ("profile_override_root", str(profile_root)),
            ("profile_override_root_present", profile_root.exists()),
            ("template_override_root", str(template_root)),
            ("template_override_root_present", template_root.exists()),
            ("managed_profile_file_count", len(managed_profile_files)),
            ("watch_interval", state.watch_interval),
            ("generated_ks_edit_policy", state.generated_ks_edit_policy),
            ("validation_failure_policy", state.validation_failure_policy),
        ]
    )


