    """Render aerolitctl_pxe_generated.yml."""
    override_root = aerolitctl_pxe_overrides_dir()
    profile_root = aerolitctl_pxe_profile_overrides_dir()
    template_root = aerolitctl_pxe_template_overrides_dir()

    enabled_profiles = state.enabled_profiles()
    implemented_profiles = state.implemented_profiles()

    lines = [
        "---",
        GENERATED_VARS_MARKER,
        "# Created by aerolitctl configure pxe.",
        "# This file lives in group_vars/all and feeds the PXE Ansible/container roles.",
        "# Do not store secrets in this file.",
        "",
        "aerolitctl_pxe_generated: true",
        "aerolitctl_pxe_override_root: {}".format(yaml_value(str(override_root))),
        "aerolitctl_pxe_override_profile_root: {}".format(yaml_value(str(profile_root))),
        "aerolitctl_pxe_override_template_root: {}".format(yaml_value(str(template_root))),
        "",
    ]

    render_yaml_list(lines, "aerolitctl_pxe_enabled_profiles", enabled_profiles)
    lines.append("")
    render_yaml_list(lines, "aerolitctl_pxe_implemented_profiles", implemented_profiles)

    if state.pxe_content_iso_root:
        lines.extend(
            [
                "",
