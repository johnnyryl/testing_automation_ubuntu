    )

    profiles["security_luks"] = standard_profile(
        "security_luks",
        "Security + LUKS Installs",
        "Security + LUKS",
        "security_luks",
        False,
        "ks/{{ os_id }}-security-luks.ks.j2",
    )

    profiles["small_disk"] = standard_profile(
        "small_disk",
        "Small Disk Installs",
