    return profiles


class ManagedPxeState(object):
    """In-memory representation of aerolitctl-managed PXE state."""

    def __init__(self):
        self.profiles = default_profile_definitions()
        self.pxe_content_iso_root = None
        self.watch_interval = DEFAULT_WATCH_INTERVAL
        self.generated_ks_edit_policy = DEFAULT_GENERATED_KS_EDIT_POLICY
        self.validation_failure_policy = DEFAULT_VALIDATION_FAILURE_POLICY

        self.pxe_server_ip = None
        self.pxe_http_port = None

        self.dnsmasq_interface = None
        self.dnsmasq_enable_dhcp = None
        self.dnsmasq_enable_tftp = None
        self.dnsmasq_dhcp_range_start = None
        self.dnsmasq_dhcp_range_end = None
        self.dnsmasq_dhcp_netmask = None
        self.dnsmasq_gateway = None
        self.dnsmasq_dns_servers = None
        self.dnsmasq_manage_firewall = None
        self.dnsmasq_firewall_zone = None

    def ensure_profile(self, profile_id):
        profile_id = normalize_profile_id(profile_id)

        if profile_id not in self.profiles:
            title = profile_id.replace("_", " ").title()
            self.profiles[profile_id] = OrderedDict(
                [
                    ("profile_id", profile_id),
                    ("title", title),
                    ("install_label", title),
                    ("menu_target", profile_id),
                    ("implemented", False),
                    ("show_in_main_menu", True),
                    ("uefi", True),
                    ("bios", True),
                    ("supported_os", list(STANDARD_OS_IDS)),
                    (
                        "kickstart_template",
                        "ks/{{ os_id }}-{}.ks.j2".format(
                            profile_id.replace("_", "-")
                        ),
                    ),
                    ("kernel_args", list(DEFAULT_KERNEL_ARGS)),
                ]
            )

        return self.profiles[profile_id]

    def get_profile(self, profile_id):
        profile_id = normalize_profile_id(profile_id)

        if profile_id not in self.profiles:
            raise PxeConfigError(
                "PXE profile '{}' is not currently known. "
                "Use --enable-profile first if this is a new custom profile.".format(
                    profile_id
                )
            )

        return self.profiles[profile_id]

    def enable_profile(self, profile_id):
        profile = self.ensure_profile(profile_id)
        profile["show_in_main_menu"] = True

    def disable_profile(self, profile_id):
        profile = self.get_profile(profile_id)
        profile["show_in_main_menu"] = False

    def implement_profile(self, profile_id):
        profile = self.ensure_profile(profile_id)
        profile["implemented"] = True
        profile["show_in_main_menu"] = True

    def placeholder_profile(self, profile_id):
        profile = self.get_profile(profile_id)
        profile["implemented"] = False

    def remove_profile(self, profile_id):
        """Remove a custom managed PXE profile from aerolitctl state."""
        profile_id = normalize_profile_id(profile_id)
        standard_profiles = default_profile_definitions()

        if profile_id in standard_profiles:
            raise PxeConfigError(
                "PXE profile '{}' is a standard profile. "
                "Use --disable-profile {} to hide it from the boot menu, "
                "or --placeholder-profile {} to keep it visible but non-bootable.".format(
                    profile_id,
                    profile_id,
                    profile_id,
                )
            )

        if profile_id not in self.profiles:
            raise PxeConfigError(
                "PXE profile '{}' is not currently known.".format(profile_id)
            )

        del self.profiles[profile_id]

    def set_profile_title(self, profile_id, title):
        profile = self.ensure_profile(profile_id)
        title = str(title).strip()

        if not title:
            raise PxeConfigError(
                "PXE profile {} title cannot be empty".format(profile_id)
            )

        profile["title"] = title

    def set_profile_label(self, profile_id, install_label):
        profile = self.ensure_profile(profile_id)
        install_label = str(install_label).strip()

        if not install_label:
            raise PxeConfigError(
                "PXE profile {} install_label cannot be empty".format(profile_id)
            )

        profile["install_label"] = install_label

    def set_profile_menu_target(self, profile_id, menu_target):
        profile = self.ensure_profile(profile_id)
        menu_target = normalize_profile_id(menu_target)

        if menu_target in RESERVED_MENU_TARGETS:
            raise PxeConfigError(
                "PXE profile {} cannot use reserved menu target: {}".format(
                    profile_id,
                    menu_target,
                )
            )

        profile["menu_target"] = menu_target

    def set_profile_template(self, profile_id, template):
        profile = self.ensure_profile(profile_id)
        profile["kickstart_template"] = validate_template_path(
            template,
            profile_id,
            field="kickstart_template",
        )

    def set_profile_os(self, profile_id, os_list):
        profile = self.ensure_profile(profile_id)
        profile["supported_os"] = normalize_supported_os_values(os_list)

    def set_profile_kernel_args(self, profile_id, kernel_args):
        profile = self.ensure_profile(profile_id)
        profile["kernel_args"] = normalize_kernel_args_values(
            profile_id,
            kernel_args,
        )

    def set_profile_uefi(self, profile_id, enabled):
        profile = self.ensure_profile(profile_id)
        profile["uefi"] = bool(enabled)

    def set_profile_bios(self, profile_id, enabled):
        profile = self.ensure_profile(profile_id)
        profile["bios"] = bool(enabled)

    def set_pxe_server_ip(self, value):
        self.pxe_server_ip = normalize_ipv4_address(value, "PXE server IP")

    def set_pxe_http_port(self, value):
        self.pxe_http_port = normalize_port(value, "PXE HTTP port")

    def set_dnsmasq_interface(self, value):
        self.dnsmasq_interface = normalize_simple_string(value, "dnsmasq interface")

    def set_dnsmasq_enable_dhcp(self, enabled):
        self.dnsmasq_enable_dhcp = bool(enabled)

    def set_dnsmasq_enable_tftp(self, enabled):
        self.dnsmasq_enable_tftp = bool(enabled)

    def set_dnsmasq_dhcp_range(self, start, end, netmask):
        self.dnsmasq_dhcp_range_start = normalize_ipv4_address(
            start,
            "dnsmasq DHCP range start",
        )
        self.dnsmasq_dhcp_range_end = normalize_ipv4_address(
            end,
            "dnsmasq DHCP range end",
        )
        self.dnsmasq_dhcp_netmask = normalize_ipv4_address(
            netmask,
            "dnsmasq DHCP netmask",
        )

    def set_dnsmasq_gateway(self, value):
        self.dnsmasq_gateway = normalize_ipv4_address(
            value,
            "dnsmasq gateway",
            allow_empty=True,
        )

    def set_dnsmasq_dns_servers(self, value):
        self.dnsmasq_dns_servers = normalize_ipv4_csv_list(
            value,
            "dnsmasq DNS servers",
        )

    def set_dnsmasq_manage_firewall(self, enabled):
        self.dnsmasq_manage_firewall = bool(enabled)

    def set_dnsmasq_firewall_zone(self, value):
        self.dnsmasq_firewall_zone = normalize_simple_string(
            value,
            "dnsmasq firewall zone",
        )

    def enabled_profiles(self):
        return [
            profile_id
            for profile_id, profile in self.profiles.items()
            if profile.get("show_in_main_menu") is True
        ]

    def implemented_profiles(self):
        return [
            profile_id
            for profile_id, profile in self.profiles.items()
            if profile.get("implemented") is True
        ]


def normalize_profile_id(value):
    """Validate and return a PXE profile identifier."""
    value = str(value).strip()

    if not value:
        raise PxeConfigError("PXE profile id cannot be empty")

    allowed = "abcdefghijklmnopqrstuvwxyz0123456789_"

    if value[0] not in "abcdefghijklmnopqrstuvwxyz0123456789":
        raise PxeConfigError(
            "Invalid PXE profile id '{}'. It must start with lowercase letter or number.".format(
                value
            )
        )

    for character in value:
        if character not in allowed:
            raise PxeConfigError(
                "Invalid PXE profile id '{}'. Use lowercase letters, numbers, and underscore.".format(
                    value
                )
            )

    return value


def split_csv_values(value, field):
    """Split comma-separated CLI values."""
    values = [
        item.strip()
        for item in str(value).split(",")
        if item.strip()
    ]

    if not values:
        raise PxeConfigError("{} cannot be empty".format(field))

    return values


def validate_template_path(value, profile_id, field="kickstart_template"):
    """Validate a relative Kickstart template path."""
    value = str(value).strip()

    if not value:
        raise PxeConfigError(
            "PXE profile {} {} cannot be empty".format(profile_id, field)
        )

    if "\n" in value or "\r" in value:
        raise PxeConfigError(
            "PXE profile {} {} must be a single-line value".format(
                profile_id,
                field,
            )
        )

    path = Path(value)

    if path.is_absolute():
        raise PxeConfigError(
            "PXE profile {} {} must be relative, got: {}".format(
                profile_id,
                field,
                value,
            )
        )

    if ".." in path.parts:
        raise PxeConfigError(
            "PXE profile {} {} must not contain '..', got: {}".format(
                profile_id,
                field,
                value,
            )
        )

    return value


def normalize_supported_os_values(value):
    """Normalize comma-separated supported OS values."""
    values = split_csv_values(value, "supported OS list")
    result = []

    for os_id in values:
        os_id = str(os_id).strip().lower()

        if os_id not in STANDARD_OS_IDS:
            raise PxeConfigError(
                "Unsupported OS id '{}'. Supported values: {}".format(
                    os_id,
                    ", ".join(STANDARD_OS_IDS),
                )
            )

        if os_id not in result:
            result.append(os_id)

    return result


def validate_kernel_arg(profile_id, arg):
    """Validate one PXE kernel argument."""
    arg = str(arg).strip()

    if not arg:
        raise PxeConfigError(
            "PXE profile {} kernel_args cannot contain empty values".format(
                profile_id
            )
        )

    if "\n" in arg or "\r" in arg:
        raise PxeConfigError(
            "PXE profile {} kernel arg must be single-line: {}".format(
                profile_id,
                arg,
            )
        )

    if any(character.isspace() for character in arg):
        raise PxeConfigError(
            "PXE profile {} kernel arg must not contain whitespace: {}".format(
                profile_id,
                arg,
            )
        )

    for prefix in RESERVED_KERNEL_ARG_PREFIXES:
        if arg.startswith(prefix):
            raise PxeConfigError(
                "PXE profile {} kernel arg must not set generated arg '{}': {}".format(
                    profile_id,
                    prefix,
                    arg,
                )
            )

    return arg


def normalize_kernel_args_values(profile_id, value):
    """Normalize comma-separated kernel args."""
    values = split_csv_values(value, "kernel args")
    return [
        validate_kernel_arg(profile_id, item)
        for item in values
    ]


def normalize_simple_string(value, field):
    """Validate a simple one-line string."""
    value = str(value).strip()

    if not value:
        raise PxeConfigError("{} cannot be empty".format(field))

    if "\n" in value or "\r" in value:
        raise PxeConfigError("{} must be a single-line value".format(field))

    return value


def normalize_ipv4_address(value, field, allow_empty=False):
    """Validate an IPv4 address."""
    value = str(value).strip()

    if not value:
        if allow_empty:
            return ""

        raise PxeConfigError("{} cannot be empty".format(field))

    try:
        ipaddress.IPv4Address(value)
    except ValueError:
        raise PxeConfigError("{} must be a valid IPv4 address: {}".format(field, value))

    return value


def normalize_ipv4_csv_list(value, field):
    """Normalize a comma-separated IPv4 address list."""
    if value is None or str(value).strip() == "":
        return []

    values = split_csv_values(value, field)
    result = []

    for item in values:
        address = normalize_ipv4_address(item, field)

        if address not in result:
            result.append(address)

    return result


def normalize_port(value, field):
    """Validate a TCP/UDP port number."""
    try:
        port = int(value)
    except (TypeError, ValueError):
        raise PxeConfigError("{} must be a number".format(field))

    if port < 1 or port > 65535:
        raise PxeConfigError("{} must be between 1 and 65535".format(field))

    return port


def require_bool(value, field, source):
    """Return a strict YAML-style boolean."""
    if isinstance(value, bool):
        return value

    raise PxeConfigError(
        "{} field {} must be a YAML boolean true/false, not {!r}".format(
            source,
            field,
            value,
        )
    )


def require_string_list(value, field, source):
    """Return a list of strings."""
    if not isinstance(value, list):
        raise PxeConfigError("{} field {} must be a YAML list".format(source, field))

    result = []

    for item in value:
        item = str(item).strip()

        if not item:
            raise PxeConfigError(
                "{} field {} cannot contain empty values".format(source, field)
            )

        result.append(item)

    return result


def timestamp():
    """Return a filesystem-safe timestamp."""
    return datetime.datetime.now().strftime("%Y%m%d-%H%M%S")


def read_text(path):
    """Read text while tolerating non-UTF8 bytes."""
    with open(str(path), "r", encoding="utf-8", errors="ignore") as handle:
        return handle.read()


def write_text(path, content):
    """Write text and create parent directories."""
    path = Path(path)

    if not path.parent.exists():
        path.parent.mkdir(parents=True)

    with open(str(path), "w", encoding="utf-8") as handle:
        handle.write(content)


def configured_bundle_path():
    """Return configured bundle path from aerolitctl config."""
    config = load_config()
    bundle_path = get_bundle_path(config)

    if not bundle_path:
        raise PxeConfigError(
            "No bundle path is configured. Run: aerolitctl configure init"
        )

    return Path(bundle_path)


def bool_text(value):
    """Return YAML boolean text."""
    return "true" if value else "false"


def yaml_quote(value):
    """Quote a scalar as a YAML string."""
    value = str(value)
    return "'" + value.replace("'", "''") + "'"


def yaml_value(value):
    """Render a simple YAML scalar value."""
    if isinstance(value, bool):
        return bool_text(value)

    if value is None:
        return "null"

    if isinstance(value, int):
        return str(value)

    return yaml_quote(value)


def parse_scalar_value(value):
    """Parse simple YAML scalar text for fallback loading."""
    value = str(value).strip()

    if value == "true":
        return True

    if value == "false":
        return False

    if value.startswith("'") and value.endswith("'"):
        return value[1:-1].replace("''", "'")

    if value.startswith('"') and value.endswith('"'):
        return value[1:-1]

    if value == "[]":
        return []

    try:
        return int(value)
    except ValueError:
        return value


def load_yaml_mapping(path):
    """Load a small YAML mapping."""
    path = Path(path)

    try:
        import yaml
    except ImportError:
        yaml = None

    if yaml is not None:
        try:
            with open(str(path), "r", encoding="utf-8") as handle:
                data = yaml.safe_load(handle) or {}
        except Exception as exc:
            raise PxeConfigError(
                "Could not parse YAML file {}: {}".format(path, exc)
            )

        if not isinstance(data, dict):
            raise PxeConfigError("YAML file should contain a mapping: {}".format(path))

        return data

    data = OrderedDict()
    current_key = None

    for raw_line in read_text(path).splitlines():
        if not raw_line.strip() or raw_line.lstrip().startswith("#"):
            continue

        if not raw_line.startswith(" "):
            if ":" not in raw_line:
                continue

            key, raw_value = raw_line.split(":", 1)
            key = key.strip()
            raw_value = raw_value.strip()

            if not key:
                continue

            if raw_value:
                data[key] = parse_scalar_value(raw_value)
                current_key = None
            else:
                data[key] = OrderedDict()
                current_key = key

            continue

        if current_key is None:
            continue

        stripped = raw_line.strip()

        if stripped.startswith("- "):
            if not isinstance(data.get(current_key), list):
                data[current_key] = []

            data[current_key].append(parse_scalar_value(stripped[2:].strip()))
            continue

        if ":" in stripped:
            if not isinstance(data.get(current_key), dict):
                data[current_key] = OrderedDict()

            key, raw_value = stripped.split(":", 1)
            data[current_key][key.strip()] = parse_scalar_value(raw_value.strip())

    return data


def file_looks_managed(path, managed_kind):
    """Return True when an existing file appears safe for aerolitctl to update."""
    path = Path(path)

    if not path.exists():
        return True

    content = read_text(path)

    if managed_kind == "generated_vars":
        return (
            GENERATED_VARS_MARKER in content
            and "aerolitctl_pxe_generated:" in content
        )

    if managed_kind == "profile":
        return PROFILE_MARKER in content

    return False


def ensure_file_is_safe_to_update(path, managed_kind, force=False):
    """Refuse to overwrite a non-managed file unless force=True."""
    path = Path(path)

    if force or not path.exists():
        return

    if file_looks_managed(path, managed_kind):
        return

    raise PxeConfigError(
        "{} exists but does not look like an aerolitctl-managed {} file. "
        "Refusing to overwrite it without --force: {}".format(
            path,
            managed_kind.replace("_", " "),
            path,
        )
    )


def backup_file(path, dry_run=False, no_backup=False, label=None):
    """Create a timestamped backup next to an existing file."""
    path = Path(path)
    label = label or str(path)

    if no_backup or not path.exists():
        return None

    backup_path = path.with_name(
        "{}.aerolit-backup-{}".format(path.name, timestamp())
    )

    if dry_run:
        print("Would back up {} to {}".format(label, backup_path))
        return backup_path

    shutil.copy2(str(path), str(backup_path))
    print("Backed up {} to {}".format(label, backup_path))
    return backup_path


def write_if_changed(
    path,
    content,
    dry_run=False,
    label=None,
    managed_kind=None,
    force=False,
    no_backup=False,
):
    """Create/update a file only when content differs."""
    path = Path(path)
    label = label or str(path)

    exists = path.exists()
    current = read_text(path) if exists else None

    if current == content:
        print("Already current: {}".format(label))
        return "unchanged"

    if managed_kind:
        ensure_file_is_safe_to_update(path, managed_kind, force=force)

    if dry_run:
        if exists:
            backup_file(path, dry_run=True, no_backup=no_backup, label=label)
            print("Would update: {}".format(label))
            return "would_update"

        print("Would create: {}".format(label))
        return "would_create"

    backup_file(path, dry_run=False, no_backup=no_backup, label=label)
    write_text(path, content)

    if exists:
        print("Updated: {}".format(label))
        return "updated"

    print("Created: {}".format(label))
    return "created"


def remove_if_exists(
    path,
    dry_run=False,
    label=None,
    managed_kind=None,
    force=False,
    no_backup=False,
):
    """Remove an aerolitctl-managed file when it is no longer needed."""
    path = Path(path)
    label = label or str(path)

    if not path.exists():
        return "absent"

    if managed_kind:
        ensure_file_is_safe_to_update(path, managed_kind, force=force)

    if dry_run:
        backup_file(path, dry_run=True, no_backup=no_backup, label=label)
        print("Would remove: {}".format(label))
        return "would_remove"

    backup_file(path, dry_run=False, no_backup=no_backup, label=label)
    path.unlink()
    print("Removed: {}".format(label))
    return "removed"


def ensure_pxe_directories(dry_run=False):
    """Create PXE override directories when writing configuration."""
    directories = [
        aerolitctl_pxe_overrides_dir(),
        aerolitctl_pxe_profile_overrides_dir(),
        aerolitctl_pxe_template_overrides_dir(),
    ]

    for path in directories:
        path = Path(path)

        if path.exists():
            continue

        if dry_run:
            print("Would create directory: {}".format(path))
            continue

        path.mkdir(parents=True, exist_ok=True)
        print("Created directory: {}".format(path))


def profile_from_mapping(data, source):
    """Normalize a profile YAML mapping."""
    profile_id = normalize_profile_id(data.get("profile_id", ""))

    title = str(data.get("title", profile_id.replace("_", " ").title())).strip()
    install_label = str(
        data.get("install_label", profile_id.replace("_", " ").title())
    ).strip()
    menu_target = normalize_profile_id(data.get("menu_target", profile_id))

    if not title:
        raise PxeConfigError("{} title cannot be empty".format(source))

    if not install_label:
        raise PxeConfigError("{} install_label cannot be empty".format(source))

    supported_os = data.get("supported_os", list(STANDARD_OS_IDS))
    kernel_args = data.get("kernel_args", list(DEFAULT_KERNEL_ARGS))

    profile = OrderedDict()
    profile["profile_id"] = profile_id
    profile["title"] = title
    profile["install_label"] = install_label
    profile["menu_target"] = menu_target
    profile["implemented"] = require_bool(
        data.get("implemented", False),
        "implemented",
        source,
    )
    profile["show_in_main_menu"] = require_bool(
        data.get("show_in_main_menu", True),
        "show_in_main_menu",
        source,
    )
    profile["uefi"] = require_bool(data.get("uefi", True), "uefi", source)
    profile["bios"] = require_bool(data.get("bios", True), "bios", source)
    profile["supported_os"] = require_string_list(
        supported_os,
        "supported_os",
        source,
    )
    profile["kickstart_template"] = str(data.get("kickstart_template", "")).strip()
    profile["kernel_args"] = require_string_list(
        kernel_args,
        "kernel_args",
        source,
    )

    return profile


def load_existing_profile_overrides(state):
    """Load existing aerolitctl-managed PXE profile override files."""
    profile_dir = aerolitctl_pxe_profile_overrides_dir()

    if not profile_dir.exists():
        return

    for path in sorted(profile_dir.glob("*.yml")):
        if not file_looks_managed(path, "profile"):
            continue

        data = load_yaml_mapping(path)
        profile = profile_from_mapping(data, str(path))
        state.profiles[profile["profile_id"]] = profile


def load_existing_generated_vars(state, bundle_path):
