def pxe_doctor_lines(bundle_path):
    """Return PXE doctor checks as (level, message) tuples."""
    snapshot = pxe_status_snapshot(bundle_path)
    lines = []

    if not snapshot["configured"] and not snapshot["generated_vars_present"]:
        lines.append(
            (
                "WARN",
                "PXE configuration has not been saved yet. Run: aerolitctl configure pxe --guided",
            )
        )
        lines.append(
            (
                "WARN",
                "PXE generated vars not created yet: {}".format(
                    snapshot["generated_vars"]
                ),
            )
        )
        return lines

    if snapshot["generated_vars_managed"]:
        lines.append(
            (
                "OK",
                "PXE generated vars found: {}".format(snapshot["generated_vars"]),
            )
        )
    elif snapshot["generated_vars_present"]:
        lines.append(
            (
                "FAIL",
                "PXE generated vars exists but is not aerolitctl-managed: {}".format(
                    snapshot["generated_vars"]
                ),
            )
        )
    else:
        lines.append(
            (
                "WARN",
                "PXE generated vars not created yet: {}".format(
                    snapshot["generated_vars"]
                ),
            )
        )

    if snapshot["override_root_present"]:
        lines.append(
            (
                "OK",
                "PXE override root found: {}".format(snapshot["override_root"]),
            )
        )
    else:
        lines.append(
            (
                "WARN",
                "PXE override root missing: {}".format(snapshot["override_root"]),
            )
        )

    if snapshot["profile_override_root_present"]:
        lines.append(
            (
                "OK",
                "PXE profile override root found: {}".format(
                    snapshot["profile_override_root"]
                ),
            )
        )
    else:
        lines.append(
            (
                "WARN",
                "PXE profile override root missing: {}".format(
                    snapshot["profile_override_root"]
                ),
            )
        )

    if snapshot["template_override_root_present"]:
        lines.append(
            (
                "OK",
                "PXE template override root found: {}".format(
                    snapshot["template_override_root"]
                ),
            )
        )
    else:
        lines.append(
            (
                "WARN",
                "PXE template override root missing: {}".format(
                    snapshot["template_override_root"]
                ),
            )
        )

    if snapshot["managed_profile_file_count"] > 0:
        lines.append(
            (
                "OK",
                "PXE profile overrides found: {} managed file(s)".format(
                    snapshot["managed_profile_file_count"]
                ),
            )
        )
    else:
        lines.append(
            (
                "WARN",
                "No aerolitctl-managed PXE profile override files found.",
            )
        )

    if snapshot["enabled_profiles"]:
        lines.append(
            (
                "OK",
                "PXE profiles enabled: {}".format(
                    ", ".join(snapshot["enabled_profiles"])
                ),
            )
        )
    else:
        lines.append(("FAIL", "No PXE profiles are enabled."))

    if snapshot["implemented_profiles"]:
        lines.append(
            (
                "OK",
                "PXE profiles implemented: {}".format(
                    ", ".join(snapshot["implemented_profiles"])
                ),
            )
        )
    else:
        lines.append(("WARN", "No PXE profiles are marked implemented."))

    lines.append(
        (
            "OK",
            "PXE server IP, HTTP port, dnsmasq, firewall, ISO root, and container mounts are managed by configure server.",
        )
    )

    return lines


def stdin_is_interactive():
    """Return True when guided mode can prompt the user."""
    try:
        return sys.stdin.isatty()
    except AttributeError:
        return False


def prompt_line(question, default=None):
    """Prompt for one line of guided input."""
    if not stdin_is_interactive():
        raise PxeConfigError(
            "Guided mode requires an interactive terminal. "
            "Use explicit configure pxe flags instead."
        )

    if default is None:
        prompt = "{}: ".format(question)
    else:
        prompt = "{} [{}]: ".format(question, default)

    try:
        try:
            input_function = raw_input
        except NameError:
            input_function = input

        value = input_function(prompt)
    except EOFError:
        raise PxeConfigError("Guided mode input ended unexpectedly")

    value = str(value).strip()

    if not value and default is not None:
        return str(default)

    return value


def prompt_yes_no(question, default=True):
    """Prompt for a yes/no answer."""
    default_text = "Y/n" if default else "y/N"

    while True:
        value = prompt_line("{} ({})".format(question, default_text)).strip().lower()

        if not value:
            return bool(default)

        if value in ["y", "yes"]:
            return True

        if value in ["n", "no"]:
            return False

        print("Please answer yes or no.")


def prompt_choice(question, choices, default):
    """Prompt for one value from a list."""
    choices = list(choices)

    if default not in choices:
        raise PxeConfigError(
            "Internal guided mode error: default '{}' is not in {}".format(
                default,
                ", ".join(choices),
            )
        )

    while True:
        value = prompt_line(
            "{} ({})".format(question, "/".join(choices)),
            default,
        ).strip().lower()

        if value in choices:
            return value

        print("Please choose one of: {}".format(", ".join(choices)))


def prompt_int(question, default, minimum=1):
    """Prompt for an integer value."""
    while True:
        value = prompt_line(question, default)

        try:
            number = int(value)
        except (TypeError, ValueError):
            print("Please enter a number.")
            continue

        if number < minimum:
            print("Please enter a number greater than or equal to {}.".format(minimum))
            continue

        return number


def guided_profile_default(state, profile_id):
    """Return guided default mode for one standard PXE profile."""
    profile = state.profiles.get(profile_id, {})

    if profile.get("show_in_main_menu") is not True:
        return "hidden"

    if profile.get("implemented") is True:
        return "real"

    return "placeholder"


def apply_guided_profile_mode(state, profile_id, mode):
    """Apply hidden/placeholder/real guided profile choice."""
    if mode == "hidden":
        state.disable_profile(profile_id)
        return

    if mode == "placeholder":
        state.enable_profile(profile_id)
        state.placeholder_profile(profile_id)
        return

    if mode == "real":
        state.implement_profile(profile_id)
        return

    raise PxeConfigError(
        "Internal guided mode error: unsupported profile mode '{}'".format(mode)
    )


def run_guided_pxe_config(state):
    """Prompt for common PXE generator/profile configuration choices."""
    print("")
    print("AeroLIT guided PXE configuration")
    print("")
    print("Press Enter to accept the default shown in brackets.")
    print("")

    print("PXE menu profile choices:")
    print("  hidden      = do not show in the PXE menu")
    print("  placeholder = show in the menu but do not make it bootable")
    print("  real        = show in the menu as a real boot option")
    print("")

    for profile_id in GUIDED_STANDARD_PROFILE_IDS:
        profile = state.profiles.get(profile_id, {})
        label = profile.get("install_label") or profile_id.replace("_", " ").title()

        mode = prompt_choice(
            "How should {} appear in the PXE menu".format(label),
            ["hidden", "placeholder", "real"],
            guided_profile_default(state, profile_id),
        )

        apply_guided_profile_mode(state, profile_id, mode)

    state.watch_interval = prompt_int(
        "How often should the PXE content watcher regenerate, in seconds",
        state.watch_interval,
        minimum=1,
    )

    preserve_kickstarts = prompt_yes_no(
        "Should manually edited generated Kickstarts be preserved",
        default=state.generated_ks_edit_policy != "overwrite",
    )

    if preserve_kickstarts:
        state.generated_ks_edit_policy = "preserve"
    else:
        state.generated_ks_edit_policy = "overwrite"

    print("")
    print("Server IP, PXE HTTP port, dnsmasq, firewall, ISO root, and container")
    print("mount settings are managed by aerolitctl configure server.")

    print("")
    print("Guided PXE choices applied.")


def has_write_actions(args):
    """Return True if CLI args request a managed-file change."""
    list_fields = [
        "enable_profile",
        "disable_profile",
        "remove_profile",
        "implement_profile",
        "placeholder_profile",
        "set_profile_title",
        "set_profile_label",
        "set_profile_menu_target",
        "set_profile_template",
        "set_profile_os",
        "set_profile_kernel_args",
        "profile_uefi",
        "no_profile_uefi",
        "profile_bios",
        "no_profile_bios",
    ]

    for field in list_fields:
        if getattr(args, field, None):
            return True

    value_fields = [
        "watch_interval",
        "generated_ks_edit_policy",
        "validation_failure_policy",
    ]

    for field in value_fields:
        if getattr(args, field, None) is not None:
            return True

    if getattr(args, "reset_standard_profiles", False):
        return True

    if getattr(args, "guided", False):
        return True

    return False


def profiles_removed_and_modified(args):
    """Return profiles requested for removal and another profile mutation."""
    removed = set()

    for profile_id in getattr(args, "remove_profile", None) or []:
        removed.add(normalize_profile_id(profile_id))

    if not removed:
        return []

    modified = set()

    profile_list_fields = [
        "enable_profile",
        "disable_profile",
        "implement_profile",
        "placeholder_profile",
        "profile_uefi",
        "no_profile_uefi",
        "profile_bios",
        "no_profile_bios",
    ]

    for field in profile_list_fields:
        for profile_id in getattr(args, field, None) or []:
            modified.add(normalize_profile_id(profile_id))

    profile_pair_fields = [
        "set_profile_title",
        "set_profile_label",
        "set_profile_menu_target",
        "set_profile_template",
        "set_profile_os",
        "set_profile_kernel_args",
    ]

    for field in profile_pair_fields:
        for item in getattr(args, field, None) or []:
            profile_id = item[0]
            modified.add(normalize_profile_id(profile_id))

    return sorted(removed.intersection(modified))


def validate_cli_option_combinations(args):
    """Reject confusing or unsafe configure pxe option combinations."""
    if getattr(args, "guided", False) and getattr(args, "reset_standard_profiles", False):
        raise PxeConfigError(
            "Do not use --guided and --reset-standard-profiles together. "
            "Run 'aerolitctl configure pxe --reset-standard-profiles' first, "
            "then run 'aerolitctl configure pxe --guided'."
        )


def apply_cli_changes(state, args):
    """Apply requested CLI changes to the managed PXE state."""
    conflicts = profiles_removed_and_modified(args)
    if conflicts:
        raise PxeConfigError(
            "Cannot remove and modify the same PXE profile in one command: {}".format(
                ", ".join(conflicts)
            )
        )

    if getattr(args, "reset_standard_profiles", False):
        state.profiles = default_profile_definitions()

    for profile_id in getattr(args, "remove_profile", None) or []:
        state.remove_profile(profile_id)

    for profile_id in getattr(args, "enable_profile", None) or []:
        state.enable_profile(profile_id)

    for profile_id in getattr(args, "disable_profile", None) or []:
        state.disable_profile(profile_id)

    for profile_id in getattr(args, "implement_profile", None) or []:
        state.implement_profile(profile_id)

    for profile_id in getattr(args, "placeholder_profile", None) or []:
        state.placeholder_profile(profile_id)

    for item in getattr(args, "set_profile_title", None) or []:
        profile_id, title = item
        state.set_profile_title(profile_id, title)

    for item in getattr(args, "set_profile_label", None) or []:
        profile_id, install_label = item
        state.set_profile_label(profile_id, install_label)

    for item in getattr(args, "set_profile_menu_target", None) or []:
        profile_id, menu_target = item
        state.set_profile_menu_target(profile_id, menu_target)

    for item in getattr(args, "set_profile_template", None) or []:
        profile_id, template = item
        state.set_profile_template(profile_id, template)

    for item in getattr(args, "set_profile_os", None) or []:
        profile_id, os_list = item
        state.set_profile_os(profile_id, os_list)

    for item in getattr(args, "set_profile_kernel_args", None) or []:
        profile_id, kernel_args = item
        state.set_profile_kernel_args(profile_id, kernel_args)

    for profile_id in getattr(args, "profile_uefi", None) or []:
        state.set_profile_uefi(profile_id, True)

    for profile_id in getattr(args, "no_profile_uefi", None) or []:
        state.set_profile_uefi(profile_id, False)

    for profile_id in getattr(args, "profile_bios", None) or []:
        state.set_profile_bios(profile_id, True)

    for profile_id in getattr(args, "no_profile_bios", None) or []:
        state.set_profile_bios(profile_id, False)

    if getattr(args, "watch_interval", None) is not None:
        state.watch_interval = int(args.watch_interval)

    if getattr(args, "generated_ks_edit_policy", None) is not None:
        state.generated_ks_edit_policy = args.generated_ks_edit_policy

    if getattr(args, "validation_failure_policy", None) is not None:
        state.validation_failure_policy = args.validation_failure_policy


def run_configure_pxe(args):
    """Run aerolitctl configure pxe."""
    bundle_path = getattr(args, "bundle_path", None)

    if bundle_path:
        bundle_path = Path(bundle_path)
    else:
        bundle_path = configured_bundle_path()

    force = getattr(args, "force", False)
    dry_run = getattr(args, "dry_run", False)
    no_backup = getattr(args, "no_backup", False)
    show_only = getattr(args, "show", False)
    validate_requested = getattr(args, "validate", False)

    validate_cli_option_combinations(args)

    state = load_managed_pxe_state(bundle_path)

    if getattr(args, "guided", False):
        run_guided_pxe_config(state)

    apply_cli_changes(state, args)

    if not has_write_actions(args) and not show_only and not validate_requested:
        show_only = True

    if show_only:
        print_pxe_summary(bundle_path, state)

    if has_write_actions(args):
        print("")
        print("AeroLIT configure pxe plan")
        print("")
        print("{:<30} {}".format("Dry run:", dry_run))
        print("{:<30} {}".format("Bundle path:", bundle_path))
        print("{:<30} {}".format("Generated vars:", aerolitctl_pxe_generated_vars_file(bundle_path)))
        print("{:<30} {}".format("PXE override root:", aerolitctl_pxe_overrides_dir()))
        print("{:<30} {}".format("Profile overrides:", aerolitctl_pxe_profile_overrides_dir()))
        print("{:<30} {}".format("Template overrides:", aerolitctl_pxe_template_overrides_dir()))
        print("{:<30} {}".format("Backups enabled:", not no_backup))
        print("{:<30} {}".format("Force overwrite:", force))
        print("")

        pre_write_report = validate_pxe_state(
            bundle_path,
            state,
            check_files=True,
            force=force,
        )

        if pre_write_report.errors:
            print("")
            print("Refusing to write invalid managed PXE configuration.")
            print("")
            pre_write_report.print_report()
            return pre_write_report.exit_code()

        ensure_pxe_directories(dry_run=dry_run)

        write_if_changed(
            aerolitctl_pxe_generated_vars_file(bundle_path),
            render_generated_vars(bundle_path, state),
            dry_run=dry_run,
            label="generated PXE vars",
            managed_kind="generated_vars",
            force=force,
            no_backup=no_backup,
        )

        write_profile_files(
            state,
            dry_run=dry_run,
            force=force,
            no_backup=no_backup,
        )

        if dry_run:
            print("")
            print("Dry run complete. No files were changed.")
        else:
            print("")
            print("AeroLIT PXE configuration saved.")

    if validate_requested or has_write_actions(args) or show_only:
        print("")
        report = validate_pxe_state(
            bundle_path,
            state,
            check_files=True,
            force=force,
        )
        report.print_report()
        return report.exit_code()

    return 0
