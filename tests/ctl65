def existing_managed_profile_files():
    """Return existing aerolitctl-managed PXE profile override files."""
    profile_dir = aerolitctl_pxe_profile_overrides_dir()

    if not profile_dir.exists():
        return []

    return [
        path
        for path in sorted(profile_dir.glob("*.yml"))
        if file_looks_managed(path, "profile")
    ]


def write_profile_files(state, dry_run=False, force=False, no_backup=False):
    """Write current managed PXE profile files and remove stale managed ones."""
    expected_paths = []

    for profile_id, profile in state.profiles.items():
        path = aerolitctl_pxe_profile_file(profile_id)
        expected_paths.append(path)

        write_if_changed(
            path,
            render_profile(profile),
            dry_run=dry_run,
            label="PXE profile {}".format(profile_id),
            managed_kind="profile",
            force=force,
            no_backup=no_backup,
        )

    for path in existing_managed_profile_files():
        if path not in expected_paths:
            remove_if_exists(
                path,
                dry_run=dry_run,
                label="stale PXE profile {}".format(path.name),
                managed_kind="profile",
                force=force,
                no_backup=no_backup,
            )


def validate_pxe_state(bundle_path, state, check_files=True, force=False):
    """Validate managed PXE configuration."""
    report = PxeReport()

    group_vars_all = ansible_group_vars_all_dir(bundle_path)
    generated_vars = aerolitctl_pxe_generated_vars_file(bundle_path)
    override_root = aerolitctl_pxe_overrides_dir()
    profile_root = aerolitctl_pxe_profile_overrides_dir()
    template_root = aerolitctl_pxe_template_overrides_dir()

    if group_vars_all.exists():
        report.add_ok("group_vars/all directory found: {}".format(group_vars_all))
    else:
        report.add_error("group_vars/all directory missing: {}".format(group_vars_all))

    if override_root.exists():
        report.add_ok("PXE override root found: {}".format(override_root))
    else:
        report.add_warning("PXE override root will be created: {}".format(override_root))

    if profile_root.exists():
        report.add_ok("PXE profile override directory found: {}".format(profile_root))
    else:
        report.add_warning(
            "PXE profile override directory will be created: {}".format(profile_root)
        )

    if template_root.exists():
        report.add_ok("PXE template override directory found: {}".format(template_root))
    else:
        report.add_warning(
            "PXE template override directory will be created: {}".format(template_root)
        )

    if state.watch_interval < 1:
        report.add_error("PXE watch interval must be 1 or greater")

    if state.generated_ks_edit_policy not in VALID_GENERATED_KS_EDIT_POLICIES:
        report.add_error(
            "Invalid generated Kickstart edit policy: {}".format(
                state.generated_ks_edit_policy
            )
        )

    if state.validation_failure_policy not in VALID_VALIDATION_FAILURE_POLICIES:
        report.add_error(
            "Invalid validation failure policy: {}".format(
                state.validation_failure_policy
            )
        )

    if state.pxe_server_ip:
        try:
            normalize_ipv4_address(state.pxe_server_ip, "PXE server IP")
        except PxeConfigError as exc:
            report.add_error(str(exc))

    if state.pxe_http_port is not None:
        try:
            normalize_port(state.pxe_http_port, "PXE HTTP port")
        except PxeConfigError as exc:
            report.add_error(str(exc))

    dhcp_range_values = [
        state.dnsmasq_dhcp_range_start,
        state.dnsmasq_dhcp_range_end,
        state.dnsmasq_dhcp_netmask,
    ]

    if any(value is not None for value in dhcp_range_values):
        if not all(value is not None for value in dhcp_range_values):
            report.add_error(
                "dnsmasq DHCP range requires start, end, and netmask"
            )
        else:
            for field, value in [
                ("dnsmasq DHCP range start", state.dnsmasq_dhcp_range_start),
                ("dnsmasq DHCP range end", state.dnsmasq_dhcp_range_end),
                ("dnsmasq DHCP netmask", state.dnsmasq_dhcp_netmask),
            ]:
                try:
                    normalize_ipv4_address(value, field)
                except PxeConfigError as exc:
                    report.add_error(str(exc))

    if state.dnsmasq_gateway is not None:
        try:
            normalize_ipv4_address(
                state.dnsmasq_gateway,
                "dnsmasq gateway",
                allow_empty=True,
            )
        except PxeConfigError as exc:
            report.add_error(str(exc))

    if state.dnsmasq_dns_servers is not None:
        if not isinstance(state.dnsmasq_dns_servers, list):
            report.add_error("dnsmasq DNS servers must be a list")
        else:
            for server in state.dnsmasq_dns_servers:
                try:
                    normalize_ipv4_address(server, "dnsmasq DNS server")
                except PxeConfigError as exc:
                    report.add_error(str(exc))

    if state.dnsmasq_enable_dhcp is False and any(
        value is not None for value in dhcp_range_values
    ):
        report.add_warning(
            "dnsmasq DHCP range is configured but dnsmasq DHCP is disabled"
        )

    if not state.enabled_profiles():
        report.add_error("At least one PXE profile must be enabled")

    seen_menu_targets = {}

    for profile_id, profile in state.profiles.items():
        try:
            normalized_id = normalize_profile_id(profile_id)
            normalized_profile_id = normalize_profile_id(profile.get("profile_id", ""))
            menu_target = normalize_profile_id(profile.get("menu_target", ""))
        except PxeConfigError as exc:
            report.add_error(str(exc))
            continue

        if normalized_id != normalized_profile_id:
            report.add_error(
                "PXE profile key '{}' does not match profile_id '{}'".format(
                    normalized_id,
                    normalized_profile_id,
                )
            )

        if menu_target in RESERVED_MENU_TARGETS:
            report.add_error(
                "PXE profile {} uses reserved menu target: {}".format(
                    profile_id,
                    menu_target,
                )
            )

        if menu_target in seen_menu_targets:
            report.add_error(
                "PXE profiles {} and {} use duplicate menu target: {}".format(
                    seen_menu_targets[menu_target],
                    profile_id,
                    menu_target,
                )
            )
        else:
            seen_menu_targets[menu_target] = profile_id

        if not str(profile.get("title", "")).strip():
            report.add_error("PXE profile {} title cannot be empty".format(profile_id))

        if not str(profile.get("install_label", "")).strip():
            report.add_error(
                "PXE profile {} install_label cannot be empty".format(profile_id)
            )

        if not profile.get("uefi", True) and not profile.get("bios", True):
            report.add_error(
                "PXE profile {} must enable UEFI and/or BIOS".format(profile_id)
            )

        if profile.get("implemented") is True and not profile.get("kickstart_template"):
            report.add_error(
                "PXE profile {} is implemented but has no kickstart_template".format(
                    profile_id
                )
            )

        if profile.get("kickstart_template"):
            try:
                validate_template_path(
                    profile.get("kickstart_template"),
                    profile_id,
                    field="kickstart_template",
                )
            except PxeConfigError as exc:
                report.add_error(str(exc))

        supported_os = profile.get("supported_os", [])
        if not isinstance(supported_os, list):
            report.add_error(
                "PXE profile {} supported_os must be a list".format(profile_id)
            )
        else:
            seen_os = []
            for os_id in supported_os:
                os_id = str(os_id).strip()

                if os_id not in STANDARD_OS_IDS:
                    report.add_error(
                        "PXE profile {} references unsupported OS id: {}".format(
                            profile_id,
                            os_id,
                        )
                    )

                if os_id in seen_os:
                    report.add_error(
                        "PXE profile {} has duplicate supported OS id: {}".format(
                            profile_id,
                            os_id,
                        )
                    )
                else:
                    seen_os.append(os_id)

        kernel_args = profile.get("kernel_args", [])
        if not isinstance(kernel_args, list):
            report.add_error(
                "PXE profile {} kernel_args must be a list".format(profile_id)
            )
        else:
            for arg in kernel_args:
                try:
                    validate_kernel_arg(profile_id, arg)
                except PxeConfigError as exc:
                    report.add_error(str(exc))

        if profile.get("implemented") is True and profile_id != "minimal":
            report.add_warning(
                "PXE profile {} is marked implemented. Make sure its Kickstart template exists in the pxe-content image or override templates.".format(
                    profile_id
                )
            )

        if check_files:
            path = aerolitctl_pxe_profile_file(profile_id)
            if path.exists() and not file_looks_managed(path, "profile"):
                if force:
                    report.add_warning(
                        "PXE profile path will be replaced with --force: {}".format(path)
                    )
                else:
                    report.add_error(
                        "PXE profile path exists but is missing aerolitctl markers: {}".format(
                            path
                        )
                    )

    if check_files and generated_vars.exists():
        if file_looks_managed(generated_vars, "generated_vars"):
            report.add_ok("Generated PXE vars file found: {}".format(generated_vars))
        elif force:
            report.add_warning(
                "Generated PXE vars path will be replaced with --force: {}".format(
                    generated_vars
                )
            )
        else:
            report.add_error(
                "Generated PXE vars path exists but is missing aerolitctl markers: {}".format(
                    generated_vars
                )
            )
    elif check_files:
        report.add_warning(
            "Generated PXE vars file not created yet: {}".format(generated_vars)
        )

    return report


