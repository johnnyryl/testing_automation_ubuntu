def load_managed_pxe_state(bundle_path):
    """Load managed PXE state from active files."""
    state = ManagedPxeState()
    load_existing_generated_vars(state, bundle_path)
    load_existing_profile_overrides(state)
    return state


def render_yaml_list(lines, key, values):
    """Render a YAML list."""
    if values:
        lines.append("{}:".format(key))
        for value in values:
            lines.append("  - {}".format(yaml_value(value)))
    else:
        lines.append("{}: []".format(key))


def render_profile(profile):
    """Render a PXE profile override YAML file."""
    lines = [
        "---",
        PROFILE_MARKER,
        "# Created by aerolitctl configure pxe.",
        "# This file is consumed by the pxe-content generator through /overrides/profiles.",
        "",
    ]

    for key, value in profile.items():
        if isinstance(value, list):
            render_yaml_list(lines, key, value)
            continue

        lines.append("{}: {}".format(key, yaml_value(value)))

    lines.append("")
    return "\n".join(lines)


