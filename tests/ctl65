"""AeroLIT PXE profile/configuration planning helpers.

`aerolitctl configure pxe` manages AeroLIT-owned PXE generator inputs:

  collections-hub/ansible/group_vars/all/aerolitctl_pxe_generated.yml
  /etc/aerolit/overrides/pxe/profiles/<profile>.yml

It does not directly render boot.ipxe or generated Kickstarts. The pxe-content
container owns rendering. This command writes PXE profile and generator-behavior
inputs. Server-owned role variables such as server IP, HTTP port, dnsmasq, firewall,
ISO root, and container mounts are generated by aerolitctl configure server.
"""

from __future__ import print_function

import datetime
import shutil
import sys
from collections import OrderedDict
from pathlib import Path

from .config import get_bundle_path, load_config
from .paths import (
    ansible_group_vars_all_dir,
    aerolitctl_pxe_generated_vars_file,
    aerolitctl_pxe_overrides_dir,
    aerolitctl_pxe_profile_file,
    aerolitctl_pxe_profile_overrides_dir,
    aerolitctl_pxe_template_overrides_dir,
)


GENERATED_VARS_MARKER = "# Generated AeroLIT PXE variables"
PROFILE_MARKER = "# Generated AeroLIT PXE profile override"

DEFAULT_WATCH_INTERVAL = 15
DEFAULT_GENERATED_KS_EDIT_POLICY = "preserve"
DEFAULT_VALIDATION_FAILURE_POLICY = "warn"

VALID_GENERATED_KS_EDIT_POLICIES = [
    "preserve",
    "overwrite",
]

VALID_VALIDATION_FAILURE_POLICIES = [
    "warn",
    "fail",
]

RESERVED_MENU_TARGETS = [
    "main",
    "rescue",
    "shell",
]

STANDARD_OS_IDS = [
    "rhel10",
    "rhel9",
    "rhel8",
    "rhel7",
]

DEFAULT_KERNEL_ARGS = [
    "inst.text",
    "nomodeset",
]

RESERVED_KERNEL_ARG_PREFIXES = [
    "initrd=",
    "ip=",
    "inst.repo=",
    "inst.stage2=",
    "inst.ks=",
]

GUIDED_STANDARD_PROFILE_IDS = [
    "minimal",
    "small_disk",
    "security_baseline",
    "security_luks",
    "developer_workstation",
    "embedded_edge",
]


class PxeConfigError(Exception):
    """Raised when configure pxe input is invalid."""


class PxeReport(object):
    """Collect configure pxe validation results."""

    def __init__(self):
        self.ok = []
        self.warnings = []
        self.errors = []

    def add_ok(self, message):
        self.ok.append(message)

    def add_warning(self, message):
        self.warnings.append(message)

    def add_error(self, message):
        self.errors.append(message)

    def print_report(self):
        print("AeroLIT PXE validation")
        print("")

        for message in self.ok:
            print("[OK] {}".format(message))

        for message in self.warnings:
            print("[WARN] {}".format(message))

        for message in self.errors:
            print("[FAIL] {}".format(message))

        print("")
        print("Summary:")
        print("  OK: {}".format(len(self.ok)))
        print("  Warnings: {}".format(len(self.warnings)))
        print("  Failures: {}".format(len(self.errors)))

    def exit_code(self):
        return 1 if self.errors else 0


def standard_profile(
    profile_id,
    title,
    install_label,
    menu_target,
    implemented,
    kickstart_template,
):
    """Return one standard PXE profile mapping."""
    return OrderedDict(
        [
            ("profile_id", profile_id),
            ("title", title),
            ("install_label", install_label),
            ("menu_target", menu_target),
            ("implemented", implemented),
            ("show_in_main_menu", True),
            ("uefi", True),
            ("bios", True),
            ("supported_os", list(STANDARD_OS_IDS)),
            ("kickstart_template", kickstart_template),
            ("kernel_args", list(DEFAULT_KERNEL_ARGS)),
        ]
    )


