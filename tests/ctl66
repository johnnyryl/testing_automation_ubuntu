class RepoPreflightArgs(object):
    """Minimal args object used by repos.build_repo_plan during deploy."""


    def __init__(self):
        self.no_auto_discovery = False
        self.disable_auto_discovery = False
        self.server_baseos_source = None
        self.server_appstream_source = None
        self.provision_repo = []
        self.provision_extra_repo = []


def repo_client_path_from_plan(plan):
    """Return client-visible bundle path for generated provisioning repo vars."""
    nfs = plan.get("nfs", {}) or {}

    if nfs.get("enabled") and nfs.get("target_mount_path"):
        return nfs.get("target_mount_path")

    return DEFAULT_PATH_FOR_ANSIBLE


def record_repo_write_result(report, result, repo_vars_path):
    """Record generated repo vars write result in the deploy summary."""
    if result in ("created", "updated"):
        report.add(
            "changed",
            "Refreshed provisioning repo vars: {}".format(repo_vars_path),
        )
    elif result == "unchanged":
        report.add(
            "existing",
            "Provisioning repo vars already current: {}".format(repo_vars_path),
        )
    elif result in ("would_create", "would_update"):
        report.add(
            "dry_run",
            "Would refresh provisioning repo vars: {}".format(repo_vars_path),
        )


def deploy_repository_preflight(
    plan,
    report,
    bundle_path,
    dry_run=False,
    skip_repo_prep=False,
    skip_server_prereqs=False,
    skip_repo_vars_refresh=False,
    server_bootstrap_only=False,
):
    """Prepare repos before applying server deployment.

    This is Phase 5 wiring:
    - discover bundle repos
    - ensure server prerequisite packages are available
    - refresh generated provisioning repo vars
    """
    repo_vars_path = repos_generated_vars_file(bundle_path)

    if skip_repo_prep:
        report.add("skipped", "Repository preflight skipped by option")
        return repo_vars_path

    path_for_ansible = repo_client_path_from_plan(plan)
    repo_args = RepoPreflightArgs()

    entries = build_repo_plan(
        bundle_path,
        path_for_ansible=path_for_ansible,
        args=repo_args,
    )

    validation = validate_repos_state(
        bundle_path,
        path_for_ansible,
        entries,
        requested_os_keys=set(),
    )

    if validation.errors:
        validation.print_report()
        raise RuntimeError(
            "Repository preflight failed because repository state is invalid."
        )

    print("")
    print("#" * 80)
    print("# AeroLIT deploy repository preflight")
    print("#" * 80)
    print("")
    print_plan_value("Client bundle path", path_for_ansible)
    print_plan_value("Repo vars file", repo_vars_path)
    print_plan_value("Repos discovered", len(entries))
    print_plan_value("Ensure server prereqs", not skip_server_prereqs)
    print_plan_value("Refresh repo vars", not skip_repo_vars_refresh)
    print_plan_value("Server bootstrap only", server_bootstrap_only)
    print("")

    if skip_repo_vars_refresh and not Path(repo_vars_path).exists():
        raise RuntimeError(
            "Repository vars refresh was skipped, but repo vars file is missing: {}\n"
            "Run deploy without --skip-repo-vars-refresh so AeroLIT can generate it, or run:\n"
            "  aerolitctl configure repos --refresh".format(repo_vars_path)
        )

    if skip_server_prereqs:
        report.add("skipped", "Server prerequisite package handling skipped by option")
    else:
        try:
            ensure_server_prerequisites_with_repo_fallback(
                entries,
                repo_file=None,
                packages=None,
                dry_run=dry_run,
                force=False,
                no_backup=False,
                bootstrap_only=server_bootstrap_only,
                firewall_manage=plan.get("firewall", {}).get("manage", True),
            )
            if dry_run:
                report.add(
                    "dry_run",
                    "Would ensure server prerequisite packages are installed",
                )
            else:
                report.add(
                    "existing",
                    "Server prerequisite packages are installed or were installed",
                )
        except RepoConfigError as exc:
            raise RuntimeError(str(exc))

    if skip_repo_vars_refresh:
        report.add("skipped", "Provisioning repo vars refresh skipped by option")
    else:
        try:
            content = render_repos_generated_vars(
                bundle_path,
                path_for_ansible,
                entries,
            )
            result = write_if_changed(
                repo_vars_path,
                content,
                dry_run=dry_run,
                force=False,
                no_backup=False,
            )
            record_repo_write_result(report, result, repo_vars_path)
        except RepoConfigError as exc:
            raise RuntimeError(str(exc))

    return repo_vars_path


def find_nmcli_connection_for_interface(interface):
    """Return the active NetworkManager connection name for an interface."""
    rc, stdout, stderr = run_command(
        ["nmcli", "-t", "-f", "NAME,DEVICE", "connection", "show", "--active"]
    )
    if rc != 0:
        return None

    for line in stdout.splitlines():
        parts = line.rsplit(":", 1)
        if len(parts) != 2:
            continue
        name, device = parts
        if device == interface:
            return name.replace("\\:", ":")

    return None


def nmcli_empty_value(value):
    """Return True when nmcli renders a field as empty."""
    if value is None:
        return True

    value = str(value).strip()
    return value in ("", "--")


def nmcli_connection_ipv4_settings(connection):
    """Return selected IPv4 settings for a NetworkManager connection."""
    fields = [
        "ipv4.method",
        "ipv4.addresses",
        "ipv4.gateway",
        "ipv4.dns",
        "ipv4.ignore-auto-routes",
        "ipv4.ignore-auto-dns",
        "ipv4.never-default",
    ]

    rc, stdout, stderr = run_command(
        [
            "nmcli",
            "-t",
            "-f",
            ",".join(fields),
            "connection",
            "show",
            connection,
        ]
    )

    if rc != 0:
        return None

    settings = {}

    for line in stdout.splitlines():
        if ":" not in line:
            continue

        key, value = line.split(":", 1)
        settings[key.strip()] = value.strip()

    for field in fields:
        settings.setdefault(field, "")

    return settings


def nmcli_connection_matches_dedicated_interface(connection, planned):
    """Return True when the NM profile already matches AeroLIT provisioning intent."""
    settings = nmcli_connection_ipv4_settings(connection)

    if settings is None:
        return False

    return (
        settings.get("ipv4.method") == "manual"
        and settings.get("ipv4.addresses") == planned
        and nmcli_empty_value(settings.get("ipv4.gateway"))
        and nmcli_empty_value(settings.get("ipv4.dns"))
        and settings.get("ipv4.ignore-auto-routes") == "yes"
        and settings.get("ipv4.ignore-auto-dns") == "yes"
        and settings.get("ipv4.never-default") == "yes"
    )


def deploy_interface(plan, report, dry_run=False, skip=False):
    """Apply interface IP configuration intent.

    This makes the selected provisioning interface match the saved AeroLIT
    server IP instead of appending the AeroLIT IP on top of DHCP.

    Important: this treats the selected interface as a dedicated provisioning
    interface. It sets a static IPv4 address, disables DHCP for that connection,
    and prevents the connection from becoming the system default route.
    """
    if skip:
        report.add("skipped", "Interface configuration skipped by option")
        return

    if not plan.get("configure_interface"):
        report.add("skipped", "Interface configuration intent is disabled")
        return

    interface = plan.get("interface")
    server_ip = plan.get("server_ip")
    prefix = plan.get("prefix")
    planned = "{}/{}".format(server_ip, prefix)

    if not command_exists("nmcli"):
        raise RuntimeError(
            "nmcli is required to configure the interface persistently. "
            "Install NetworkManager or configure {} with {} manually.".format(
                interface,
                planned,
            )
        )

    connection = find_nmcli_connection_for_interface(interface)
    if not connection:
        raise RuntimeError(
            "No active NetworkManager connection was found for interface {}. "
            "Configure {} manually or create/activate a NetworkManager connection first.".format(
                interface,
                planned,
            )
        )

    if (
        interface_has_ip(interface, server_ip)
        and nmcli_connection_matches_dedicated_interface(connection, planned)
    ):
        report.add(
            "existing",
            "{} already has dedicated provisioning IP {}".format(
                interface,
                planned,
            ),
        )
        return

    run_logged_command(
        report,
        [
            "nmcli",
            "connection",
            "modify",
            connection,
            "ipv4.method",
            "manual",
            "ipv4.addresses",
            planned,
            "ipv4.gateway",
            "",
            "ipv4.dns",
            "",
            "ipv4.ignore-auto-routes",
            "yes",
            "ipv4.ignore-auto-dns",
            "yes",
            "ipv4.never-default",
            "yes",
        ],
        dry_run=dry_run,
        root=True,
        description="Set dedicated provisioning interface IP",
    )

    run_logged_command(
        report,
        ["nmcli", "connection", "up", connection],
        dry_run=dry_run,
        root=True,
        description="Bring NetworkManager connection up",
    )


def ensure_ansible_playbook(report, dry_run=False, package="ansible-core"):
    """Ensure ansible-playbook is available."""
    if command_exists("ansible-playbook"):
        report.add("existing", "ansible-playbook is available")
        return True

    if dry_run:
        report.add(
            "dry_run",
            "Would install {} because ansible-playbook is missing".format(package),
        )
        return False

    if not command_exists("dnf"):
        raise RuntimeError("ansible-playbook is missing and dnf is not available")

    run_logged_command(
        report,
        ["dnf", "install", "-y", package],
        dry_run=False,
        root=True,
        description="Install ansible package",
    )

    if not command_exists("ansible-playbook"):
        raise RuntimeError(
            "ansible-playbook is still missing after installing {}".format(package)
        )

    return True


def install_text_file(report, path, content, dry_run=False, mode="0644"):
    """Install text content to a root-owned path using install."""
    path = Path(path)
    old_content = None

    if path.exists():
        try:
            old_content = path.read_text()
        except IOError:
            old_content = None

    if old_content == content:
        report.add("existing", "{} unchanged".format(path))
        return

    if dry_run:
        action = "Would update" if path.exists() else "Would create"
        report.add("dry_run", "{} {}".format(action, path))
        return

    fd, temp_path = tempfile.mkstemp(prefix="aerolit-deploy-", text=True)
    try:
        with os.fdopen(fd, "w") as handle:
            handle.write(content)

        run_logged_command(
            report,
            ["mkdir", "-p", str(path.parent)],
            dry_run=False,
            root=True,
            description="Create parent directory",
        )

        if path.exists():
            backup_path = "{}.aerolit-backup".format(path)
            run_logged_command(
                report,
                ["cp", "-a", str(path), backup_path],
                dry_run=False,
                root=True,
                description="Back up existing file",
            )

        run_logged_command(
            report,
            ["install", "-m", mode, temp_path, str(path)],
            dry_run=False,
            root=True,
            description="Install file",
        )
    finally:
        try:
            os.unlink(temp_path)
        except OSError:
            pass


def runtime_deploy_plan(plan, skip_firewall=False, skip_nfs=False):
    """Return deploy-time plan with skip flags applied for generated vars."""
    runtime = dict(plan)
    runtime["firewall"] = dict(plan.get("firewall", {}) or {})
    runtime["nfs"] = dict(plan.get("nfs", {}) or {})

    if skip_firewall:
        runtime["firewall"]["manage"] = False

    if skip_nfs:
        runtime["nfs"]["enabled"] = False

    return runtime


def refresh_server_generated_vars(
    plan,
    report,
    generated_vars_path,
    dry_run=False,
):
    """Refresh server generated vars from the active deploy plan."""
    content = generated_vars_text(plan)

    install_text_file(
        report,
        generated_vars_path,
        content,
        dry_run=dry_run,
        mode="0644",
    )


def ansible_environment(playbooks_dir):
    """Build ansible environment for local playbook execution."""
    env = os.environ.copy()
    cfg = Path(playbooks_dir) / "ansible.cfg"
    if cfg.exists():
        env["ANSIBLE_CONFIG"] = str(cfg)
    return env


def run_server_playbook(
    report,
    playbooks_dir,
    playbook_name,
    generated_vars_path,
    dry_run=False,
    extra_vars_files=None,
):
    """Run one existing server playbook."""
    playbooks_dir = Path(playbooks_dir)
    playbook = playbooks_dir / playbook_name
    extra_vars_files = extra_vars_files or []

    if not playbook.exists():
        raise RuntimeError("Required playbook not found: {}".format(playbook))

    command = [
        "ansible-playbook",
        "-i",
        "localhost,",
        "-c",
        "local",
        "-e",
        "@{}".format(generated_vars_path),
    ]

    for vars_file in extra_vars_files:
        if vars_file and Path(vars_file).exists():
            command.extend(["-e", "@{}".format(vars_file)])

    command.append(str(playbook))

    run_logged_command(
        report,
        command,
        dry_run=dry_run,
        root=False,
        cwd=str(playbooks_dir),
        env=ansible_environment(playbooks_dir),
        description="Run {}".format(playbook_name),
    )


def deploy_ansible_playbooks(
    plan,
    report,
    bundle_path,
    generated_vars_path,
    dry_run=False,
    skip_pxe=False,
    skip_controller=False,
    repo_vars_path=None,
):
    """Run PXE/controller playbooks from the bundle."""
    collections_hub = collections_hub_path(bundle_path)
    playbooks_dir = Path(collections_hub) / "ansible"

    if not plan.get("pxe_enabled"):
        skip_pxe = True
    if not plan.get("controller_enabled"):
        skip_controller = True

    if skip_pxe and skip_controller:
        report.add("skipped", "PXE/controller Ansible playbooks skipped")
        return

    ensure_ansible_playbook(report, dry_run=dry_run)

    if not Path(generated_vars_path).exists():
        if dry_run:
            report.add(
                "dry_run",
                "Generated vars would be refreshed before running playbooks: {}".format(
                    generated_vars_path
                ),
            )
        else:
            raise RuntimeError(
                "Generated vars file not found after refresh: {}".format(
                    generated_vars_path
                )
            )

    if not playbooks_dir.exists():
        raise RuntimeError(
            "Ansible playbooks directory not found: {}".format(playbooks_dir)
        )

    extra_vars_files = []
    if repo_vars_path and Path(repo_vars_path).exists():
        extra_vars_files.append(repo_vars_path)
    elif repo_vars_path:
        report.add(
            "warnings",
            "Repository vars file not found; continuing without it: {}".format(
                repo_vars_path
            ),
        )

    if not skip_pxe:
        run_server_playbook(
            report,
            playbooks_dir,
            "pxe_server.yml",
            generated_vars_path,
            dry_run=dry_run,
            extra_vars_files=extra_vars_files,
        )
    else:
        report.add("skipped", "PXE playbook skipped")

    if not skip_controller:
        run_server_playbook(
            report,
            playbooks_dir,
            "ansible_controller.yml",
            generated_vars_path,
            dry_run=dry_run,
            extra_vars_files=extra_vars_files,
        )
    else:
        report.add("skipped", "Controller playbook skipped")


def run_deploy_server(
    dry_run=False,
    show=False,
    skip_interface=False,
    skip_nfs=False,
    skip_firewall=False,
    skip_pxe=False,
    skip_controller=False,
    skip_repo_prep=False,
    skip_server_prereqs=False,
    skip_repo_vars_refresh=False,
    server_bootstrap_only=False,
    verbose=False,
):
    """Deploy the saved AeroLIT server configuration."""
    report = DeployServerReport(verbose=verbose)

    config = load_config()
    bundle_path_value = get_bundle_path(config)

    if not bundle_path_value:
        raise RuntimeError("No bundle path is configured. Run: aerolitctl configure init")

    bundle_path = Path(bundle_path_value)
    generated_vars_path = aerolitctl_server_generated_vars_file(bundle_path)
    plan = load_deploy_plan(config, bundle_path)

    print_deploy_plan(
        plan,
        generated_vars_path,
        skip_firewall=skip_firewall,
    )

    if show:
        print("")
        print_pxe_status_summary(bundle_path)
        print("")
        print("Show complete. No files or services were changed.")
        return 0

    runtime_plan = runtime_deploy_plan(
        plan,
        skip_firewall=skip_firewall,
        skip_nfs=skip_nfs,
    )

    if skip_firewall:
        report.add(
            "skipped",
            "Firewall role variables disabled by deploy option",
        )

    if skip_nfs:
        report.add(
            "skipped",
            "NFS role variables disabled by deploy option",
        )

    repo_vars_path = deploy_repository_preflight(
        runtime_plan,
        report,
        bundle_path,
        dry_run=dry_run,
        skip_repo_prep=skip_repo_prep,
        skip_server_prereqs=skip_server_prereqs,
        skip_repo_vars_refresh=skip_repo_vars_refresh,
        server_bootstrap_only=server_bootstrap_only,
    )

    refresh_server_generated_vars(
        runtime_plan,
        report,
        generated_vars_path,
        dry_run=dry_run,
    )

    deploy_interface(plan, report, dry_run=dry_run, skip=skip_interface)

    deploy_ansible_playbooks(
        runtime_plan,
        report,
        bundle_path,
        generated_vars_path,
        dry_run=dry_run,
        skip_pxe=skip_pxe,
        skip_controller=skip_controller,
        repo_vars_path=repo_vars_path,
    )

    print("")
    if dry_run:
        print("Dry run complete. No files or services were changed.")
    else:
        print("Server deployment complete.")

    report.print_summary()

    return 1 if report.errors else 0
