def guided_add_host_range(inventory, allow_sensitive=False):
    """Interactively add a generated host/IP range."""
    print_guided_section(
        "Add generated host range",
        (
            "Use this when hostnames and IPs follow a simple pattern. "
            "AeroLIT will generate aliases and ansible_host values for you."
        ),
    )

    print_guided_examples(
        [
            "Prefix: node",
            "Start/end: 1 through 10",
            "Width: 3",
            "Starting IP: 192.168.100.101",
            "Result: node001-node010",
        ]
    )

    prefix = prompt_required("Host prefix", default="node")
    start = prompt_int("Range start number", default="1", minimum=0)
    end = prompt_int("Range end number", default=str(start), minimum=start)
    width = prompt_int("Host number width", default="3", minimum=1)
    ip_start = prompt_required("Starting IP address")
    groups = prompt_csv_values(
        "Groups, comma-separated",
        default=DEFAULT_GROUP,
    )

    total = end - start + 1

    if total > 512:
        guided_error("Refusing to generate more than 512 hosts. Requested: {}".format(total))
        return False

    try:
        first_ip = ipaddress.ip_address(ip_start)
        last_ip = first_ip + (total - 1)
    except ValueError as exc:
        guided_error("Generated IP range is invalid: {}".format(exc))
        return False

    hosts = [
        "{}{}".format(prefix, str(number).zfill(width))
        for number in range(start, end + 1)
    ]
    first_host = hosts[0]
    last_host = hosts[-1]

    try:
        for host in hosts:
            normalize_host_name(host)

        for group in groups:
            normalize_group_name(group)
    except AnsibleConfigError as exc:
        guided_error(exc)
        return False

    if not guided_confirm_existing_range_update(inventory, hosts):
        guided_info("Skipped host range.")
        return False

    base_variables = OrderedDict()

    if prompt_yes_no("Apply per-host override variables to every host in this range?", default=False):
        host_vars = guided_collect_host_vars(allow_sensitive=allow_sensitive)

        for key, value in host_vars.items():
            base_variables[key] = value

    print_guided_section("Range preview")
    print("  First host: {} ansible_host={}".format(first_host, first_ip))
    print("  Last host:  {} ansible_host={}".format(last_host, last_ip))
    print("  Groups:     {}".format(", ".join(groups)))
    print("  Count:      {}".format(total))

    if base_variables:
        rendered_vars = [
            display_var_text(key, value)
            for key, value in base_variables.items()
        ]
        print("  Host vars:  {}".format(", ".join(rendered_vars)))
    else:
        print("  Host vars:  none")

    print("")

    if not prompt_yes_no("Add this range?", default=True):
        guided_info("Skipped host range.")
        return False

    try:
        for offset, host in enumerate(hosts):
            variables = OrderedDict(base_variables)
            variables["ansible_host"] = str(first_ip + offset)
            inventory.add_host(host, groups=groups, variables=variables)
    except ValueError as exc:
        guided_error("Generated IP range is invalid: {}".format(exc))
        return False
    except AnsibleConfigError as exc:
        guided_error(exc)
        return False

    guided_ok("Added/updated {} hosts.".format(total))
    return True


def guided_parse_import_row(row, header=None, default_groups=None, allow_sensitive=False):
    """Parse one CSV/text import row into host, ansible_host, groups, and vars."""
    default_groups = default_groups or [DEFAULT_GROUP]

    if header:
        mapped = {}
        for index, key in enumerate(header):
            if index < len(row):
                mapped[str(key).strip().lower()] = str(row[index]).strip()
            else:
                mapped[str(key).strip().lower()] = ""

        host = (
            mapped.get("host")
            or mapped.get("hostname")
            or mapped.get("name")
            or mapped.get("alias")
        )
        ansible_host = mapped.get("ansible_host") or mapped.get("ip") or mapped.get("address")
        raw_groups = mapped.get("groups") or mapped.get("group") or ""
        variables = OrderedDict()

        known_keys = [
            "host",
            "hostname",
            "name",
            "alias",
            "ansible_host",
            "ip",
            "address",
            "groups",
            "group",
        ]

        for key, value in mapped.items():
            if not value or key in known_keys:
                continue

            normalized_key = normalize_var_name(key)

            if is_sensitive_var_name(normalized_key) and not allow_sensitive:
                raise AnsibleConfigError(
                    "Refusing to import sensitive-looking variable '{}' without --allow-sensitive-vars".format(
                        normalized_key
                    )
                )

            variables[normalized_key] = parse_scalar_value(value)

    else:
        host = row[0].strip() if len(row) > 0 else ""
        ansible_host = row[1].strip() if len(row) > 1 else ""
        raw_groups = ",".join(
            item.strip()
            for item in row[2:]
            if item.strip()
        ) if len(row) > 2 else ""
        variables = OrderedDict()

    if not host:
        raise AnsibleConfigError("Import row is missing a host alias")

    host = normalize_host_name(host)

    if raw_groups:
        groups = [
            item.strip()
            for item in re.split(r"[;,]", raw_groups)
            if item.strip()
        ]
    else:
        groups = list(default_groups)

    for group in groups:
        normalize_group_name(group)

    if ansible_host:
        variables["ansible_host"] = ansible_host

    return host, variables, groups


def guided_import_hosts_file(inventory, allow_sensitive=False):
    """Import managed hosts from a CSV or simple text file."""
    print_guided_section(
        "Import hosts from CSV/text file",
        (
            "Import several hosts at once. This updates only the in-memory guided plan "
            "until you finish and save."
        ),
    )

    print("Supported formats:")
    print("  - CSV with header: host,ansible_host,groups")
    print("  - CSV with optional vars: host,ansible_host,groups,ansible_user,ansible_become")
    print("  - Simple rows without header: host,ansible_host,groups")
    print("  - Lines beginning with # are ignored")
    print("")

    print_guided_examples(
        [
            "rhel9-node01,192.168.100.51,provisioned;rhel9;workstations",
            "rhel9-node02,192.168.100.52,provisioned;rhel9;workstations",
        ]
    )

    path_value = prompt_required("Path to CSV/text file")
    path = Path(path_value)

    if not path.exists():
        guided_error("File not found: {}".format(path))
        return False

    default_groups = prompt_csv_values(
        "Default groups when row has no groups",
        default=DEFAULT_GROUP,
    )

    try:
        import csv

        rows = []
        with open(str(path), "r", encoding="utf-8", errors="ignore", newline="") as handle:
            for raw_line in handle:
                if not raw_line.strip() or raw_line.lstrip().startswith("#"):
                    continue
                rows.append(raw_line)

        if not rows:
            guided_warn("No importable rows found.")
            return False

        parsed_rows = list(csv.reader(rows))
    except OSError as exc:
        guided_error("Could not read import file {}: {}".format(path, exc))
        return False

    header = None
    first = [item.strip().lower() for item in parsed_rows[0]]

    if first and first[0] in ("host", "hostname", "name", "alias"):
        header = first
        parsed_rows = parsed_rows[1:]

    parsed = []
    errors = []

    for row_number, row in enumerate(parsed_rows, start=2 if header else 1):
        try:
            host, variables, groups = guided_parse_import_row(
                row,
                header=header,
                default_groups=default_groups,
                allow_sensitive=allow_sensitive,
            )
            parsed.append((host, variables, groups))
        except AnsibleConfigError as exc:
            errors.append("row {}: {}".format(row_number, exc))

    if errors:
        guided_error("Import file has invalid rows.")
        for message in errors[:10]:
            print("  - {}".format(message))
        if len(errors) > 10:
            print("  - ... (+{} more)".format(len(errors) - 10))
        return False

    if not parsed:
        guided_warn("No valid hosts found to import.")
        return False

    hosts = [item[0] for item in parsed]

    if not guided_confirm_existing_range_update(inventory, hosts):
        guided_info("Skipped host import.")
        return False

    print_guided_section("Import preview")
    print("  File:        {}".format(path))
    print("  Hosts:       {}".format(len(parsed)))
    print("  Host sample: {}".format(guided_sample(hosts, limit=8)))
    print("")

    if not prompt_yes_no("Import these hosts?", default=True):
        guided_info("Skipped host import.")
        return False

    for host, variables, groups in parsed:
        inventory.add_host(host, groups=groups, variables=variables)

    guided_ok("Imported/updated {} hosts.".format(len(parsed)))
    return True


