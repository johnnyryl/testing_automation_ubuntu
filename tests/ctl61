    return False


def prompt(default=None, label=None):
    """Prompt for a value."""
    if default is None:
        value = input("{}: ".format(label)).strip()
    else:
        value = input("{} [{}]: ".format(label, default)).strip()
        if not value:
            value = default

    return value


def prompt_yes_no(label, default=False):
    """Prompt for yes/no."""
    suffix = "[Y/n]" if default else "[y/N]"

    while True:
        value = input("{} {}: ".format(label, suffix)).strip().lower()
        if not value:
            return default
        if value in ("y", "yes"):
            return True
        if value in ("n", "no"):
            return False
        print("Please answer yes or no.")


def run_guided(inventory):
    """Interactive configure ansible helper."""
    print("")
    print("AeroLIT configure ansible guided mode")
    print("")

    if prompt_yes_no("Ensure standard AeroLIT groups?", default=True):
        apply_standard_groups(inventory)

    if prompt_yes_no("Add localhost to ansible_controller and pxe_server groups?", default=True):
        apply_local_controller(inventory)

    if prompt_yes_no("Add a managed K3s cluster group structure?", default=False):
        cluster = prompt(default="cluster1", label="K3s cluster name")
