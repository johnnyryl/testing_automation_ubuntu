        ]

        inventory.add_host(host, groups=host_groups, variables=variables)


def scan_existing_inventory_aliases(inventory_dir, managed_inventory_file):
    """Return host aliases found outside the aerolitctl-managed inventory."""
    inventory_dir = Path(inventory_dir)
    managed_inventory_file = Path(managed_inventory_file)
    aliases = {}

    if not inventory_dir.exists():
        return aliases

    for path in inventory_dir.rglob("*.ini"):
        if path == managed_inventory_file:
            continue

        try:
            content = read_text(path)
        except OSError:
            continue

        current_section_type = "hosts"

        for raw_line in content.splitlines():
            line = raw_line.strip()

            if not line or line.startswith("#"):
                continue

            section_match = re.match(r"^\[([^\]]+)\]$", line)
            if section_match:
                section_name = section_match.group(1).strip()
                if section_name.endswith(":vars") or section_name.endswith(":children"):
                    current_section_type = "non_hosts"
                else:
                    current_section_type = "hosts"
                continue

            if current_section_type != "hosts":
                continue

            if "=" in line and " " not in line:
                continue

            try:
                parts = split_inventory_line(line)
            except AnsibleConfigError:
                continue

            if not parts:
                continue

            alias = parts[0].strip()

            if not alias or alias.startswith("#"):
                continue

            aliases.setdefault(alias, []).append(path)

    return aliases


def command_output(command, env=None):
    """Return rc/stdout/stderr for a command."""
    try:
        process = subprocess.Popen(
            command,
            env=env,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            universal_newlines=True,
        )
        stdout, stderr = process.communicate()
        return process.returncode, stdout or "", stderr or ""
    except OSError as exc:
        return 127, "", str(exc)


def detect_child_cycles(children):
    """Return child-group cycle descriptions, if any."""
    cycles = []
    visiting = set()
    visited = set()

    def visit(node, path):
        if node in visiting:
            cycle_start = path.index(node) if node in path else 0
            cycle = path[cycle_start:]
            rendered = " -> ".join(cycle)
            if rendered not in cycles:
                cycles.append(rendered)
            return

        if node in visited:
            return

        visiting.add(node)
        for child in children.get(node, []):
            visit(child, path + [child])
        visiting.remove(node)
        visited.add(node)

    for parent in children.keys():
        visit(parent, [parent])

    return cycles


def validate_managed_inventory(
    bundle_path,
    inventory,
    run_ansible_inventory=False,
    force=False,
    check_files=True,
):
    """Validate managed Ansible configuration."""
    bundle_path = Path(bundle_path)
    report = AnsibleReport()

    inventory_dir = ansible_inventory_dir(bundle_path)
    managed_inventory = aerolitctl_inventory_file(bundle_path)
    group_vars_all = ansible_group_vars_all_dir(bundle_path)
    generated_vars = aerolitctl_ansible_generated_vars_file(bundle_path)
    cfg_file = ansible_cfg_file(bundle_path)

    if inventory_dir.exists():
        report.add_ok("Inventory directory found: {}".format(inventory_dir))
    else:
        report.add_error("Inventory directory missing: {}".format(inventory_dir))

    if cfg_file.exists():
        report.add_ok("ansible.cfg found: {}".format(cfg_file))
    else:
        report.add_warning("ansible.cfg not found: {}".format(cfg_file))

    if group_vars_all.exists():
        report.add_ok("group_vars/all directory found: {}".format(group_vars_all))
    else:
        report.add_error("group_vars/all directory missing: {}".format(group_vars_all))

    if check_files:
        if managed_inventory.exists():
            if file_looks_managed(managed_inventory, "inventory"):
                report.add_ok("Managed inventory file found: {}".format(managed_inventory))
            elif force:
                report.add_warning(
                    "Managed inventory path will be replaced with --force: {}".format(
                        managed_inventory
                    )
                )
            else:
                report.add_error(
                    "Managed inventory path exists but is missing aerolitctl markers: {}".format(
                        managed_inventory
                    )
                )
        else:
            report.add_warning("Managed inventory file not created yet: {}".format(managed_inventory))

        if generated_vars.exists():
            if file_looks_managed(generated_vars, "generated_vars"):
                report.add_ok("Generated Ansible vars file found: {}".format(generated_vars))
            elif force:
                report.add_warning(
                    "Generated Ansible vars path will be replaced with --force: {}".format(
                        generated_vars
                    )
                )
            else:
                report.add_error(
                    "Generated Ansible vars path exists but is missing aerolitctl markers: {}".format(
                        generated_vars
                    )
                )
        else:
            report.add_warning("Generated Ansible vars file not created yet: {}".format(generated_vars))

        for group in inventory.group_vars.keys():
            path = aerolitctl_group_vars_file(bundle_path, group)
            if path.exists() and not file_looks_managed(path, "group_vars"):
                if force:
                    report.add_warning(
                        "Group vars path will be replaced with --force: {}".format(path)
                    )
                else:
                    report.add_error(
                        "Group vars path exists but is missing aerolitctl markers: {}".format(path)
                    )

    existing_aliases = scan_existing_inventory_aliases(inventory_dir, managed_inventory)

    for host in inventory.all_hosts():
        variables = inventory.host_vars.get(host, OrderedDict())
        connection = variables.get("ansible_connection")

        if host != "localhost" and connection != "local" and "ansible_host" not in variables:
            report.add_warning("Managed host has no ansible_host/IP: {}".format(host))

        if host in existing_aliases:
            report.add_warning(
                "Managed host '{}' also appears in existing inventory file(s): {}".format(
                    host,
                    ", ".join(str(path) for path in existing_aliases[host]),
                )
            )

    for host in inventory.host_vars.keys():
        if not inventory.host_groups(host):
            report.add_error("Managed host vars are orphaned for host: {}".format(host))

    host_specific_vars = host_specific_var_names(inventory)
    if host_specific_vars:
        report.add_warning(
            "{} Host-specific vars found: {}".format(
                HOST_VAR_PREFERENCE_WARNING,
                ", ".join(host_specific_vars),
            )
        )

    for parent, children in inventory.children.items():
        if parent not in inventory.groups:
            report.add_error("Child-group parent is missing as managed group: {}".format(parent))

        for child in children:
            if child not in inventory.groups:
                report.add_error(
                    "Child-group '{}' references missing managed group: {}".format(
                        parent,
                        child,
                    )
                )

    for cycle in detect_child_cycles(inventory.children):
        report.add_error("Managed child-group cycle detected: {}".format(cycle))

    child_parent_groups = set(inventory.children.keys())
    child_groups = set(inventory.all_child_groups())

    for group in inventory.groups.keys():
        has_hosts = bool(inventory.groups[group])
        has_children = group in child_parent_groups
        is_child = group in child_groups
        has_vars = group in inventory.group_vars and bool(inventory.group_vars[group])

        if not has_hosts and not has_children and not is_child and not has_vars:
            report.add_warning("Managed group is empty: {}".format(group))

    if run_ansible_inventory:
        if shutil.which("ansible-inventory") is None:
            report.add_warning("ansible-inventory not found; inventory parser check skipped")
        else:
            env = os.environ.copy()
            if cfg_file.exists():
                env["ANSIBLE_CONFIG"] = str(cfg_file)

            code, stdout, stderr = command_output(
                [
                    "ansible-inventory",
                    "-i",
                    str(inventory_dir),
                    "--list",
                ],
                env=env,
            )

            if code == 0:
                report.add_ok("ansible-inventory --list completed successfully")
            else:
                report.add_warning(
                    "ansible-inventory --list returned rc={}:\n{}".format(
                        code,
                        stderr or stdout,
                    )
                )

    return report


def print_inventory_summary(bundle_path, inventory):
    """Print a readable summary of managed Ansible state."""
    bundle_path = Path(bundle_path)

    print("AeroLIT managed Ansible configuration")
    print("")
    print("{:<28} {}".format("Bundle path:", bundle_path))
    print("{:<28} {}".format("Inventory directory:", ansible_inventory_dir(bundle_path)))
    print("{:<28} {}".format("Managed inventory:", aerolitctl_inventory_file(bundle_path)))
    print("{:<28} {}".format("Generated vars:", aerolitctl_ansible_generated_vars_file(bundle_path)))
    print("{:<28} {}".format("Ansible config:", ansible_cfg_file(bundle_path)))
    print("")
    print("Host var guidance:")
    print("  {}".format(HOST_VAR_PREFERENCE_WARNING))
    print("")

    print("Managed global vars:")
    if inventory.global_vars:
        for key, value in inventory.global_vars.items():
            print("  - {}".format(display_var_text(key, value)))
    else:
        print("  none")

    print("")
    print("Managed group vars:")
    if inventory.group_vars:
        for group, variables in inventory.group_vars.items():
            rendered = [
                display_var_text(key, value)
                for key, value in variables.items()
            ]
            print("  - {}: {}".format(group, ", ".join(rendered) if rendered else "none"))
    else:
        print("  none")

    print("")
    print("Managed child groups:")
    if inventory.children:
        for parent, children in inventory.children.items():
            print("  - {} -> {}".format(parent, ", ".join(children) if children else "none"))
    else:
        print("  none")

    print("")
    print("Managed groups:")
    if inventory.groups:
        for group, hosts in inventory.groups.items():
            child_count = len(inventory.children.get(group, []))
            var_count = len(inventory.group_vars.get(group, {}))
            print(
                "  - {} (hosts: {}, children: {}, vars: {})".format(
                    group,
                    len(hosts),
                    child_count,
                    var_count,
                )
            )
    else:
        print("  none")

    print("")
    print("Managed hosts:")
    hosts = inventory.all_hosts()
    if hosts:
        for host in hosts:
            groups = inventory.host_groups(host)
            variables = inventory.host_vars.get(host, OrderedDict())
            print("  - {}".format(host))
            print("      groups: {}".format(", ".join(groups) if groups else "none"))

            if variables:
                rendered_vars = [
                    display_var_text(key, value)
                    for key, value in variables.items()
                ]
                print("      vars: {}".format(", ".join(rendered_vars)))
            else:
                print("      vars: none")
    else:
        print("  none")


def run_configure_ansible(args):
    """Run aerolitctl configure ansible."""
    bundle_path = getattr(args, "bundle_path", None)

    if bundle_path:
        bundle_path = Path(bundle_path)
    else:
        bundle_path = configured_bundle_path()

    inventory_file = aerolitctl_inventory_file(bundle_path)
    generated_vars_file = aerolitctl_ansible_generated_vars_file(bundle_path)
    force = getattr(args, "force", False)

    if inventory_file.exists() and not file_looks_managed(inventory_file, "inventory"):
        if not force:
            raise AnsibleConfigError(
                "{} exists but is not marked as aerolitctl-managed. "
                "Move it, add the managed markers, or rerun with --force to replace it.".format(
                    inventory_file
                )
            )
        inventory = ManagedInventory()
        load_global_vars(generated_vars_file, inventory, force=force)
        load_group_vars(bundle_path, inventory, force=force)
    else:
        inventory = load_managed_state(bundle_path, force=force)

    if getattr(args, "guided", False):
        run_guided(inventory)

    apply_cli_changes(inventory, args)

    show_only = getattr(args, "show", False)
    validate_requested = getattr(args, "validate", False)
    dry_run = getattr(args, "dry_run", False)
    no_backup = getattr(args, "no_backup", False)

    if not has_write_actions(args) and not show_only and not validate_requested:
        show_only = True

    if show_only:
        print_inventory_summary(bundle_path, inventory)

    if has_write_actions(args):
        print("")
        print("AeroLIT configure ansible plan")
        print("")
        print("{:<28} {}".format("Dry run:", dry_run))
        print("{:<28} {}".format("Bundle path:", bundle_path))
        print("{:<28} {}".format("Managed inventory:", inventory_file))
        print("{:<28} {}".format("Generated vars:", generated_vars_file))
        print("{:<28} {}".format("Group vars root:", group_vars_root_dir(bundle_path)))
        print("{:<28} {}".format("Backups enabled:", not no_backup))
        print("{:<28} {}".format("Force overwrite:", force))

        if host_var_options_requested(args):
            print("")
            print("Host var guidance:")
            print("  {}".format(HOST_VAR_PREFERENCE_WARNING))

        print("")

        pre_write_report = validate_managed_inventory(
            bundle_path,
            inventory,
            run_ansible_inventory=False,
            force=force,
            check_files=True,
        )

        if pre_write_report.errors:
            print("")
            print("Refusing to write invalid managed Ansible configuration.")
            print("")
            pre_write_report.print_report()
            return pre_write_report.exit_code()

        inventory_content = render_managed_inventory(inventory)
        generated_vars_content = render_generated_vars(inventory)

        write_if_changed(
            inventory_file,
            inventory_content,
            dry_run=dry_run,
            label="managed inventory",
            managed_kind="inventory",
            force=force,
            no_backup=no_backup,
        )
        write_if_changed(
            generated_vars_file,
            generated_vars_content,
            dry_run=dry_run,
            label="generated Ansible vars/global vars",
            managed_kind="generated_vars",
            force=force,
            no_backup=no_backup,
        )
        write_group_var_files(
            bundle_path,
            inventory,
            dry_run=dry_run,
            force=force,
            no_backup=no_backup,
        )

        if dry_run:
            print("")
            print("Dry run complete. No files were changed.")
        else:
            print("")
            print("AeroLIT Ansible configuration saved.")

    if validate_requested or has_write_actions(args) or show_only:
        print("")
        report = validate_managed_inventory(
            bundle_path,
            inventory,
            run_ansible_inventory=getattr(args, "ansible_inventory_check", False),
            force=force,
            check_files=True,
        )
        report.print_report()
        return report.exit_code()

    return 0
