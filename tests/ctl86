#!/usr/bin/env python3
"""Check aerolitctl bash completion against the real argparse parser.

This script helps keep:

  completions/aerolitctl.bash

in sync with:

  src/aerolitctl/cli.py

It can either import the real aerolitctl parser or read a parser-surface JSON
file created by tools/dump_cli_parser.py.

The check is intentionally practical:
- It verifies commands/subcommands/options/choice values are represented.
- It warns about completion-only options.
- It warns when file/directory/path-or-url/choice options do not appear to have
  special value-completion handling.

Examples:

  # Linux / RHEL:
  python3 tools/check_completion.py --root .

  # Windows PowerShell:
  py -3 tools\\check_completion.py --root .

  # Use a previously generated parser dump:
  python3 tools/check_completion.py --root . --surface-json aerolitctl-cli-surface.json

  # JSON output:
  python3 tools/check_completion.py --root . --format json

  # Write report to a file:
  python3 tools/check_completion.py --root . --output completion-check.txt

  # Treat stale completion-only options as failures:
  python3 tools/check_completion.py --root . --strict-stale

  # Treat missing special value completion as a failure:
  python3 tools/check_completion.py --root . --strict-special

  # Treat all warnings as failures:
  python3 tools/check_completion.py --root . --warnings-as-fail
"""

from __future__ import print_function

import argparse
import json
import re
import shlex
import sys
from pathlib import Path


PROGRAM_NAME = "aerolitctl"

DEFAULT_COMPLETION_PATH = Path("completions") / "aerolitctl.bash"
DEFAULT_SURFACE_JSON_PATH = Path("aerolitctl-cli-surface.json")

# These are allowed because aerolitctl provision passes them through to
# ansible-playbook after the playbook argument. They may not exist as argparse
# options on aerolitctl itself.
DEFAULT_ALLOWED_EXTRA_OPTIONS = {
    "-i",
    "--inventory",
    "--inventory-file",
    "--limit",
    "--check",
    "--diff",
    "--tags",
    "--skip-tags",
    "--extra-vars",
}

DIRECTORY_OPTION_NAMES = {
    "--bundle",
    "--bundle-path",
    "--path-for-ansible",
    "--target-mount-path",
    "--nfs-export-path",
    "--log-dir",
    "--output-dir",
}

FILE_OPTION_NAMES = {
    "--output",
    "-o",
    "--plan-output",
    "--server-bootstrap-repo-file",
    "--ssh-key",
    "--private-key",
    "-i",
    "--inventory",
    "--inventory-file",
    "--to",
    "--path",
    "--nfs-exports-file",
    "--set-profile-template",
}

PATH_OR_URL_OPTION_NAMES = {
    "--server-baseos-source",
    "--server-appstream-source",
    "--provision-repo",
    "--provision-extra-repo",
}


def add_repo_src_to_path(root_path):
    """Add repo src/ to sys.path so this script works from the source tree."""
    src_dir = Path(root_path) / "src"

    if str(src_dir) not in sys.path:
        sys.path.insert(0, str(src_dir))


def is_subparsers_action(action):
    """Return True if an argparse action is a subparsers action."""
    return isinstance(action, argparse._SubParsersAction)


def is_no_value_option(action):
    """Return True if an argparse option does not take a value."""
    if not getattr(action, "option_strings", None):
        return False

    if getattr(action, "nargs", None) == 0:
        return True

    no_value_action_types = (
        argparse._StoreTrueAction,
        argparse._StoreFalseAction,
        argparse._StoreConstAction,
        argparse._AppendConstAction,
        argparse._CountAction,
        argparse._HelpAction,
        argparse._VersionAction,
    )

    return isinstance(action, no_value_action_types)


def action_takes_value(action):
    """Return True if an argparse option action expects a value."""
    if not getattr(action, "option_strings", None):
        return False

    return not is_no_value_option(action)


def normalize_choices(choices):
    """Return argparse choices as a list of strings, or None."""
    if choices is None:
        return None

    try:
        return [str(item) for item in choices]
    except TypeError:
        return [str(choices)]


def option_strings(action):
    """Return option strings for an action."""
    return list(getattr(action, "option_strings", []) or [])


def option_matches(action, names):
    """Return True if the action has one of the given option strings."""
    return bool(set(option_strings(action)).intersection(set(names)))


def infer_completion_type(action):
    """Infer a rough completion type from argparse metadata."""
    if getattr(action, "choices", None):
        return "choice"

    if not action_takes_value(action):
        return "none"

    if option_matches(action, PATH_OR_URL_OPTION_NAMES):
        return "path_or_url"

    if option_matches(action, DIRECTORY_OPTION_NAMES):
        return "directory"

    if option_matches(action, FILE_OPTION_NAMES):
        return "file"

    names = " ".join(option_strings(action))
    dest = getattr(action, "dest", "") or ""
    metavar = getattr(action, "metavar", "") or ""
    help_text = getattr(action, "help", "") or ""

    combined = " ".join(
        [
            str(names).lower(),
            str(dest).lower(),
            str(metavar).lower(),
            str(help_text).lower(),
        ]
    )

    if "path_or_url" in combined or "path or url" in combined:
        return "path_or_url"

    if (
        "url" in combined
        or "http://" in combined
        or "https://" in combined
        or "file://" in combined
    ):
        return "path_or_url"

    if "output file" in combined:
        return "file"

    if "file" in combined or "yaml" in combined or "yml" in combined:
        return "file"

    if "directory" in combined or "output dir" in combined or "log directory" in combined:
        return "directory"

    if "bundle path" in combined or "export path" in combined:
        return "directory"

    return "value"


def serialize_action(action):
    """Serialize one argparse action."""
    return {
        "option_strings": option_strings(action),
        "dest": getattr(action, "dest", None),
        "choices": normalize_choices(getattr(action, "choices", None)),
        "takes_value": action_takes_value(action),
        "completion_type_guess": infer_completion_type(action),
    }


def find_subparsers_action(parser):
    """Return the parser's subparsers action, if present."""
    for action in parser._actions:
        if is_subparsers_action(action):
            return action

    return None


def parser_command_name(path_parts):
    """Return a shell-style command name."""
    return " ".join(path_parts)


def walk_parser(parser, path_parts):
    """Walk parser recursively and return command metadata."""
    subparsers_action = find_subparsers_action(parser)

    option_actions = []
    positional_actions = []

    for action in parser._actions:
        if is_subparsers_action(action):
            continue

        if getattr(action, "option_strings", None):
            option_actions.append(serialize_action(action))
        else:
            positional_actions.append(
                {
                    "dest": getattr(action, "dest", None),
                    "metavar": str(getattr(action, "metavar", "") or ""),
                    "nargs": str(getattr(action, "nargs", "") or ""),
                }
            )

    command_info = {
        "command": parser_command_name(path_parts),
        "path": list(path_parts),
        "options": option_actions,
        "positionals": positional_actions,
        "subcommands": [],
    }

    commands = [command_info]

    if subparsers_action is not None:
        for subcommand_name in sorted(subparsers_action.choices.keys()):
            child_parser = subparsers_action.choices[subcommand_name]
            command_info["subcommands"].append(subcommand_name)
            commands.extend(walk_parser(child_parser, path_parts + [subcommand_name]))

    return commands


def build_surface_from_parser(root_path):
    """Import aerolitctl.cli and build parser surface metadata."""
    add_repo_src_to_path(root_path)

    from aerolitctl.cli import build_parser

    parser = build_parser()
    commands = walk_parser(parser, [PROGRAM_NAME])

    return {
        "program": PROGRAM_NAME,
        "command_count": len(commands),
        "commands": commands,
        "source": "imported_parser",
    }


def load_surface_json(surface_json_path):
    """Load parser surface JSON created by tools/dump_cli_parser.py."""
    path = Path(surface_json_path)

    with path.open("r", encoding="utf-8-sig") as handle:
        data = json.load(handle)

    if "commands" not in data:
        raise ValueError("Surface JSON does not contain a 'commands' key: {}".format(path))

    data["source"] = "surface_json:{}".format(path)
    return data


def resolve_path(root_path, maybe_path):
    """Resolve maybe_path relative to root_path if not absolute."""
    path = Path(maybe_path)

    if not path.is_absolute():
        path = Path(root_path) / path

    return path.resolve()


def split_shell_words(raw_words):
    """Split a shell word list safely enough for simple completion strings."""
    raw_words = raw_words.replace("\n", " ")

    try:
        return shlex.split(raw_words)
    except ValueError:
        return raw_words.split()


def looks_like_option(word):
    """Return True if word looks like a command-line option."""
    return bool(re.match(r"^-{1,2}[A-Za-z0-9][A-Za-z0-9_-]*$", word or ""))


def strip_full_line_comments(text):
    """Remove full-line shell comments."""
    lines = []

    for line in text.splitlines():
        if line.lstrip().startswith("#"):
            continue
        lines.append(line)

    return "\n".join(lines)


def shell_words_from_text(text):
    """Extract shell completion words from quoted word lists."""
    words = set()
    cleaned = strip_full_line_comments(text)

    # Example:
    #   top_commands="backup bundle configure ..."
    assignment_pattern = re.compile(
        r"^\s*[A-Za-z_][A-Za-z0-9_]*=(['\"])(.*?)\1\s*$",
        re.MULTILINE,
    )

    for match in assignment_pattern.finditer(cleaned):
        raw_words = match.group(2)
        words.update(split_shell_words(raw_words))

    # Examples:
    #   compgen -W "word word word"
    #   compgen -W "${top_commands} --verbose -h --help"
    compgen_pattern = re.compile(
        r"compgen\s+-W\s+(['\"])(.*?)\1",
        re.MULTILINE | re.DOTALL,
    )

    for match in compgen_pattern.finditer(cleaned):
        raw_words = match.group(2)
        words.update(split_shell_words(raw_words))

    return words


def shell_case_words_from_text(text):
    """Extract simple case-pattern words such as backup|bundle)."""
    words = set()
    cleaned = strip_full_line_comments(text)

    # Examples:
    #   backup)
    #   doctor|status|version)
    #   --bundle|--bundle-path)
    case_pattern = re.compile(r"^\s*([A-Za-z0-9_|./*?+\-$]+)\)\s*$", re.MULTILINE)

    for match in case_pattern.finditer(cleaned):
        pattern = match.group(1)

        if pattern in ("*", "*)"):
            continue

        for word in pattern.split("|"):
            if word and not word.startswith("$"):
                words.add(word)

    return words


def shell_completion_words(text):
    """Return all obvious completion words in the bash completion file."""
    words = shell_words_from_text(text)
    words.update(shell_case_words_from_text(text))
    return words


def shell_options_from_words(words):
    """Return option-looking strings from extracted completion words only."""
    return set(word for word in words if looks_like_option(word))


def shell_special_value_options_from_text(text):
    """Extract options that appear to have special value-completion handling.

    This looks mostly at case-pattern option names, such as:

      --bundle|--bundle-path)
      --output|-o|--plan-output)

    It does not prove the behavior is perfect, but it catches whether the
    option was given explicit value-completion attention.
    """
    special_options = set()
    cleaned = strip_full_line_comments(text)

    case_pattern = re.compile(r"^\s*([A-Za-z0-9_|./*?+\-$]+)\)\s*$", re.MULTILINE)

    for match in case_pattern.finditer(cleaned):
        pattern = match.group(1)

        for word in pattern.split("|"):
            if looks_like_option(word):
                special_options.add(word)

    return special_options


def collect_parser_expectations(surface):
    """Collect expected commands, subcommands, options, and choices."""
    commands = surface.get("commands", [])

    top_level_subcommands = set()
    all_subcommand_words = set()
    all_command_names = set()
    all_options = set()
    all_choices = set()
    value_options = []
    choice_options = []

    for command in commands:
        command_name = command.get("command", "")
        all_command_names.add(command_name)

        path = command.get("path", [])
        subcommands = command.get("subcommands", [])

        if path == [PROGRAM_NAME]:
            top_level_subcommands.update(subcommands)

        for subcommand in subcommands:
            all_subcommand_words.add(subcommand)

        for option in command.get("options", []):
            option_strings_list = option.get("option_strings", []) or []

            for option_string in option_strings_list:
                all_options.add(option_string)

            if option.get("takes_value"):
                value_options.append(
                    {
                        "command": command_name,
                        "option_strings": option_strings_list,
                        "completion_type_guess": option.get("completion_type_guess"),
                        "choices": option.get("choices"),
                    }
                )

            if option.get("choices"):
                choice_options.append(
                    {
                        "command": command_name,
                        "option_strings": option_strings_list,
                        "choices": option.get("choices") or [],
                    }
                )

                for choice in option.get("choices") or []:
                    all_choices.add(str(choice))

    return {
        "top_level_subcommands": top_level_subcommands,
        "all_subcommand_words": all_subcommand_words,
        "all_command_names": all_command_names,
        "all_options": all_options,
        "all_choices": all_choices,
        "value_options": value_options,
        "choice_options": choice_options,
    }


def check_completion(
    surface,
    completion_path,
    allowed_extra_options=None,
    strict_stale=False,
    strict_special=False,
    warnings_as_fail=False,
):
    """Check completion file against parser surface."""
    if allowed_extra_options is None:
        allowed_extra_options = set()

    completion_path = Path(completion_path)
    text = completion_path.read_text(encoding="utf-8-sig")

    completion_words = shell_completion_words(text)
    completion_options = shell_options_from_words(completion_words)
    special_value_options = shell_special_value_options_from_text(text)

    expected = collect_parser_expectations(surface)

    missing_top_level = sorted(
        expected["top_level_subcommands"] - completion_words
    )

    missing_subcommands = sorted(
        expected["all_subcommand_words"] - completion_words
    )

    missing_options = sorted(
        expected["all_options"] - completion_options
    )

    missing_choices = sorted(
        expected["all_choices"] - completion_words
    )

    allowed_options = set(expected["all_options"])
    allowed_options.update(DEFAULT_ALLOWED_EXTRA_OPTIONS)
    allowed_options.update(allowed_extra_options)

    stale_options = sorted(
        completion_options - allowed_options
    )

    special_value_warnings = []

    for option in expected["value_options"]:
        completion_type = option.get("completion_type_guess")
        if completion_type not in ("directory", "file", "path_or_url", "choice"):
            continue

        option_strings_list = option.get("option_strings") or []

        special_present = [
            item for item in option_strings_list if item in special_value_options
        ]

        missing_special = [
            item for item in option_strings_list if item not in special_value_options
        ]

        if not special_present:
            special_value_warnings.append(
                {
                    "command": option.get("command"),
                    "option_strings": option_strings_list,
                    "completion_type_guess": completion_type,
                    "missing_special_option_strings": missing_special,
                }
            )

    failures = []
    warnings = []

    if missing_top_level:
        failures.append(
            {
                "check": "missing_top_level_commands",
                "items": missing_top_level,
            }
        )

    if missing_subcommands:
        failures.append(
            {
                "check": "missing_subcommands",
                "items": missing_subcommands,
            }
        )

    if missing_options:
        failures.append(
            {
                "check": "missing_options",
                "items": missing_options,
            }
        )

    if missing_choices:
        failures.append(
            {
                "check": "missing_choice_values",
                "items": missing_choices,
            }
        )

    if stale_options:
        stale_record = {
            "check": "stale_or_completion_only_options",
            "items": stale_options,
            "note": (
                "These are present in completion word lists but not in the real "
                "argparse parser. Some may be intentionally allowed pass-through "
                "options, such as ansible-playbook options."
            ),
        }

        if strict_stale:
            failures.append(stale_record)
        else:
            warnings.append(stale_record)

    if special_value_warnings:
        special_record = {
            "check": "special_value_completion_coverage",
            "items": special_value_warnings,
            "note": (
                "These value-taking options were classified as file/directory/"
                "path-or-url/choice options, but no explicit special value "
                "completion pattern was found for them."
            ),
        }

        if strict_special:
            failures.append(special_record)
        else:
            warnings.append(special_record)

    if warnings_as_fail and warnings:
        failures.extend(warnings)
        warnings = []

    return {
        "completion_path": str(completion_path),
        "parser_source": surface.get("source", "unknown"),
        "parser_command_count": surface.get("command_count"),
        "completion_word_count": len(completion_words),
        "completion_option_count": len(completion_options),
        "special_value_option_count": len(special_value_options),
        "failures": failures,
        "warnings": warnings,
        "details": {
            "missing_top_level": missing_top_level,
            "missing_subcommands": missing_subcommands,
            "missing_options": missing_options,
            "missing_choices": missing_choices,
            "stale_options": stale_options,
            "special_value_warnings": special_value_warnings,
            "completion_options": sorted(completion_options),
            "special_value_options": sorted(special_value_options),
        },
    }


def format_warning_item(item):
    """Return a printable warning/failure item."""
    if not isinstance(item, dict):
        return str(item)

    command = item.get("command", "")
    option_strings = ", ".join(item.get("option_strings", []))
    completion_type = item.get("completion_type_guess", "")
    missing_special = ", ".join(item.get("missing_special_option_strings", []))

    pieces = []

    if command:
        pieces.append(command)

    if option_strings:
        pieces.append(option_strings)

    if completion_type:
        pieces.append("completion={}".format(completion_type))

    if missing_special:
        pieces.append("missing_special={}".format(missing_special))

    if pieces:
        return ": ".join(pieces)

    return json.dumps(item, sort_keys=True)


def render_text_report(result):
    """Return a human-readable check report."""
    lines = []

    lines.append("AeroLIT completion check")
    lines.append("")
    lines.append("Completion file:")
    lines.append("  {}".format(result["completion_path"]))
    lines.append("")
    lines.append("Parser source: {}".format(result["parser_source"]))
    lines.append("Parser command count: {}".format(result["parser_command_count"]))
    lines.append("Completion words found: {}".format(result["completion_word_count"]))
    lines.append("Completion options found: {}".format(result["completion_option_count"]))
    lines.append("Special value options found: {}".format(result["special_value_option_count"]))
    lines.append("")

    if not result["failures"]:
        lines.append("Result: PASS")
    else:
        lines.append("Result: FAIL")

    if result["failures"]:
        lines.append("")
        lines.append("Failures:")
        for failure in result["failures"]:
            lines.append("  {}".format(failure["check"]))

            for item in failure.get("items", []):
                lines.append("    {}".format(format_warning_item(item)))

            if failure.get("note"):
                lines.append("    note: {}".format(failure["note"]))

    if result["warnings"]:
        lines.append("")
        lines.append("Warnings:")
        for warning in result["warnings"]:
            lines.append("  {}".format(warning["check"]))

            for item in warning.get("items", []):
                lines.append("    {}".format(format_warning_item(item)))

            if warning.get("note"):
                lines.append("    note: {}".format(warning["note"]))

    lines.append("")
    return "\n".join(lines)


def write_text(path, text):
    """Write text to path using UTF-8."""
    output_path = Path(path)
    output_path.parent.mkdir(parents=True, exist_ok=True)
    output_path.write_text(text, encoding="utf-8")


def load_surface(root_path, surface_json=None, auto_fallback=True):
    """Load parser surface by import or JSON fallback."""
    if surface_json:
        surface_path = resolve_path(root_path, surface_json)
        return load_surface_json(surface_path)

    try:
        return build_surface_from_parser(root_path)
    except Exception as exc:
        if not auto_fallback:
            raise

        fallback_path = Path(root_path) / DEFAULT_SURFACE_JSON_PATH

        if fallback_path.exists():
            data = load_surface_json(fallback_path)
            data["source"] = "{}; fallback after import error: {}".format(
                data.get("source", "surface_json"),
                exc,
            )
            return data

        raise


def main(argv=None):
    """Main entry point."""
    parser = argparse.ArgumentParser(
        description="Check aerolitctl bash completion against argparse.",
    )
    parser.add_argument(
        "--root",
        default=".",
        help="Project root directory. Default: current directory.",
    )
    parser.add_argument(
        "--completion",
        default=None,
        help=(
            "Completion file path. Default: completions/aerolitctl.bash "
            "under --root."
        ),
    )
    parser.add_argument(
        "--surface-json",
        default=None,
        help=(
            "Use parser surface JSON created by tools/dump_cli_parser.py "
            "instead of importing aerolitctl.cli."
        ),
    )
    parser.add_argument(
        "--no-auto-fallback",
        action="store_true",
        help=(
            "Do not automatically fall back to aerolitctl-cli-surface.json "
            "if importing aerolitctl.cli fails."
        ),
    )
    parser.add_argument(
        "--allowed-extra-option",
        action="append",
        default=[],
        help=(
            "Allow an option that appears only in completion. Useful for "
            "intentional pass-through options. Can be used more than once."
        ),
    )
    parser.add_argument(
        "--strict-stale",
        action="store_true",
        help="Treat completion-only/stale options as failures.",
    )
    parser.add_argument(
        "--strict-special",
        action="store_true",
        help="Treat missing special value-completion handling as a failure.",
    )
    parser.add_argument(
        "--warnings-as-fail",
        action="store_true",
        help="Treat all warnings as failures.",
    )
    parser.add_argument(
        "--format",
        choices=("text", "json"),
        default="text",
        help="Output format. Default: text.",
    )
    parser.add_argument(
        "--output",
        default=None,
        help="Write the report to a file instead of stdout.",
    )

    args = parser.parse_args(argv)

    root_path = Path(args.root).resolve()

    if args.completion:
        completion_path = resolve_path(root_path, args.completion)
    else:
        completion_path = root_path / DEFAULT_COMPLETION_PATH

    if not completion_path.exists():
        print("ERROR: completion file not found: {}".format(completion_path), file=sys.stderr)
        return 2

    try:
        surface = load_surface(
            root_path=root_path,
            surface_json=args.surface_json,
            auto_fallback=not args.no_auto_fallback,
        )
    except Exception as exc:
        print("ERROR: could not load aerolitctl parser surface: {}".format(exc), file=sys.stderr)
        print("", file=sys.stderr)
        print("Try using a previously generated parser dump instead:", file=sys.stderr)
        print(
            "  python3 tools/check_completion.py --root . "
            "--surface-json aerolitctl-cli-surface.json",
            file=sys.stderr,
        )
        return 2

    result = check_completion(
        surface=surface,
        completion_path=completion_path,
        allowed_extra_options=set(args.allowed_extra_option),
        strict_stale=args.strict_stale,
        strict_special=args.strict_special,
        warnings_as_fail=args.warnings_as_fail,
    )

    if args.format == "json":
        output_text = json.dumps(result, indent=2, sort_keys=True)
    else:
        output_text = render_text_report(result)

    if args.output:
        write_text(args.output, output_text + "\n")
    else:
        print(output_text)

    if result["failures"]:
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())
