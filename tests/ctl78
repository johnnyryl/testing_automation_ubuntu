    """Build default aerolitctl config."""
    bundle_path = Path(bundle_path)
    paths = bundle_derived_paths(bundle_path)

    return {
        "version": 1,
        "aerolitctl": {
            "version": __version__,
        },
        "paths": {
            **paths,
            "config": str(CONFIG_FILE),
            "state": str(STATE_DIR),
            "logs": str(LOG_DIR),
            "rendered": str(RENDERED_DIR),
            "override_kickstarts": str(OVERRIDE_KICKSTARTS_DIR),
        },
        "server": {
            "interface": None,
            "ip_address": None,
            "prefix": None,
            "gateway": None,
            "dns": [],
            "configure_interface": False,
            "nfs": {
                "enabled": True,
                "export_path": str(bundle_path),
                "allowed_clients": None,
            },
            "pxe_http": {
                "bind_address": "0.0.0.0",
                "port": 18080,
            },
        },
        "repos": {
            "enabled": True,
            "mode": "local",
        },
        "pxe": {
            "enabled": True,
            "default_profile": None,
            "menu_timeout_seconds": 10,
            "watcher_interval_seconds": 15,
            "custom_kickstart_dir": str(OVERRIDE_KICKSTARTS_DIR),
        },
        "ansible": {
            "enabled": True,
            "root": str(ansible_dir(bundle_path)),
            "config_path": str(ansible_cfg_file(bundle_path)),
            "inventory_path": str(ansible_inventory_dir(bundle_path)),
            "group_vars_path": str(ansible_group_vars_dir(bundle_path)),
            "group_vars_all_path": str(ansible_group_vars_all_dir(bundle_path)),
            "generated_vars_path": str(aerolitctl_server_generated_vars_file(bundle_path)),
            "playbook_dir": str(ansible_dir(bundle_path)),
        },
        "sync": {
            "preserve_file": str(sync_preserve_file(bundle_path)),
            "initialization_backup_root": str(initialization_backup_root(bundle_path)),
            "state_dir": str(sync_state_dir()),
            "staging_dir": str(sync_staging_dir()),
            "backup_dir": str(sync_backup_dir()),
            "manifest_file": str(sync_manifest_file()),
            "lock_file": str(sync_lock_file()),
            "log_dir": str(sync_log_dir()),
