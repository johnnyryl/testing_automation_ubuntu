class DoctorReport(object):
    """Collect doctor results."""

    def __init__(self):
        self.ok = []
        self.warnings = []
        self.failures = []

    def add_ok(self, message):
        self.ok.append(message)
        print("[OK] {}".format(message))

    def add_warning(self, message):
        self.warnings.append(message)
        print("[WARN] {}".format(message))

    def add_failure(self, message):
        self.failures.append(message)
        print("[FAIL] {}".format(message))

    def print_summary(self):
        print("")
        print("Summary:")
        print("  OK: {}".format(len(self.ok)))
        print("  Warnings: {}".format(len(self.warnings)))
        print("  Failures: {}".format(len(self.failures)))


def command_exists(command):
    """Return True when command is available."""
    return shutil.which(command) is not None


def read_os_release():
    """Read /etc/os-release into a dict."""
    values = {}

    try:
        with open("/etc/os-release", "r") as handle:
            for line in handle:
                line = line.strip()
                if not line or line.startswith("#") or "=" not in line:
                    continue

                key, value = line.split("=", 1)
                values[key] = value.strip().strip('"')
    except IOError:
        pass

    return values


def check_command(report, command, required=True):
    """Check a command exists."""
    if command_exists(command):
        report.add_ok("Command available: {}".format(command))
        return True

    if required:
        report.add_failure("Required command missing: {}".format(command))
    else:
        report.add_warning("Optional command missing: {}".format(command))

    return False


def check_path(report, label, path, required=True, directory=False):
    """Check file or directory path."""
    path = Path(path)

    if directory:
        exists = path.is_dir()
        kind = "directory"
    else:
        exists = path.exists()
        kind = "path"

    if exists:
        report.add_ok("{} {} found: {}".format(label, kind, path))
        return True

    if required:
        report.add_failure("{} {} missing: {}".format(label, kind, path))
    else:
        report.add_warning("{} {} not found: {}".format(label, kind, path))

    return False


def check_tcp_port_available(report, host, port):
    """Check whether a TCP port can be bound."""
    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)

    try:
        sock.bind((host, int(port)))
        report.add_ok("TCP port available: {}:{}".format(host, port))
        return True
    except socket.error:
        report.add_warning("TCP port may already be in use: {}:{}".format(host, port))
        return False
    finally:
        sock.close()


def check_selinux(report):
    """Check SELinux status when getenforce exists."""
    if not command_exists("getenforce"):
        report.add_warning("SELinux status unknown: getenforce command not found")
        return

    try:
        output = subprocess.check_output(
            ["getenforce"],
            universal_newlines=True,
            stderr=subprocess.STDOUT,
        ).strip()
    except Exception as exc:
        report.add_warning("SELinux status check failed: {}".format(exc))
        return

    if output.lower() == "enforcing":
        report.add_warning(
            "SELinux is Enforcing. Some PXE/container bind mounts may require labels or policy adjustments."
        )
    else:
        report.add_ok("SELinux status: {}".format(output))


def check_firewalld(report):
    """Check firewalld status when available."""
    if not command_exists("systemctl"):
        report.add_warning("firewalld status unknown: systemctl command not found")
        return

    try:
        rc = subprocess.call(
            ["systemctl", "is-active", "--quiet", "firewalld"],
            stdout=subprocess.DEVNULL,
            stderr=subprocess.DEVNULL,
        )
    except Exception as exc:
        report.add_warning("firewalld status check failed: {}".format(exc))
        return

    if rc == 0:
        report.add_ok("firewalld status: running")
    else:
        report.add_warning("firewalld status: not active")


def get_bundle_path_from_config(report):
    """Load configured bundle path."""
    try:
        config = load_config()
    except Exception as exc:
        report.add_failure("Unable to load config {}: {}".format(CONFIG_FILE, exc))
        return None, {}

    paths = config.get("paths", {})
    bundle_path = paths.get("bundle")

    if not bundle_path:
        report.add_failure("Configured bundle path missing from {}".format(CONFIG_FILE))
        return None, config

    report.add_ok("Configured bundle path: {}".format(bundle_path))
    return Path(bundle_path), config


def run_doctor(args=None):
    """Run AeroLIT diagnostics."""
    report = DoctorReport()

    print("AeroLIT Doctor")
    print("Running checks...")
    print("")
    print("AeroLIT Doctor")
    print("")

    os_release = read_os_release()
    pretty_name = os_release.get("PRETTY_NAME")

    if pretty_name:
        report.add_ok("Operating system: {}".format(pretty_name))
    else:
        report.add_warning("Operating system could not be determined from /etc/os-release")

    if os.geteuid() == 0:
        report.add_ok("Running as root")
    else:
        report.add_warning("Not running as root. Some configure/deploy commands may require sudo/root.")

    report.add_ok("Python runtime: {}".format(sys.version.split()[0]))

    if yaml is None:
        report.add_failure("Python YAML support missing. Install python3-pyyaml.")
    else:
        report.add_ok("Python YAML support available")

    check_command(report, "python3", required=True)
    check_command(report, "dnf", required=False)
    check_command(report, "yum", required=False)
    check_command(report, "ansible", required=False)
    check_command(report, "ansible-playbook", required=False)
    check_command(report, "podman", required=False)
    check_command(report, "rsync", required=False)

    check_path(report, "Primary config", CONFIG_FILE, required=True)
    check_path(report, "Runtime state", STATE_FILE, required=False)

    bundle_path, config = get_bundle_path_from_config(report)

    if bundle_path is not None:
        collections_hub = collections_hub_path(bundle_path)

        check_path(report, "Bundle root", bundle_path, required=True, directory=True)
        check_path(report, "collections-hub", collections_hub, required=True, directory=True)
        check_path(report, "collections-hub Ansible", ansible_dir(bundle_path), required=True, directory=True)
        check_path(report, "collections-hub templates", templates_dir(bundle_path), required=True, directory=True)

        check_path(report, "Repos directory", bundle_path / "repos", required=False, directory=True)
        check_path(report, "Files directory", bundle_path / "files", required=False, directory=True)
        check_path(report, "Extracted ISOs directory", bundle_path / "extracted_isos", required=False, directory=True)

        check_path(report, "Ansible inventory template", ansible_inventory_template_file(bundle_path), required=True)
        check_path(report, "Ansible group vars template", ansible_group_vars_template_dir(bundle_path), required=True, directory=True)
        check_path(report, "Ansible config template", ansible_cfg_file(bundle_path).with_name("ansible_template.cfg"), required=True)

        check_path(report, "Provision GitLab CI template", provision_gitlab_template(bundle_path), required=True)
        check_path(report, "Scheduled updater GitLab CI template", scheduled_gitlab_template(bundle_path), required=True)
        check_path(report, "System update GitLab CI template", system_update_gitlab_template(bundle_path), required=True)
        check_path(report, "STIG GitLab CI template", stig_gitlab_template(bundle_path), required=True)

        check_path(report, "Compatibility bootstrap.sh", bundle_path / "bootstrap.sh", required=False)
        check_path(report, "collections-hub .sync-preserve", sync_preserve_file(bundle_path), required=False)
        check_path(report, "collections-hub .gitlab-ci.yml", gitlab_ci_file(bundle_path), required=False)

        check_path(report, "Active ansible.cfg", ansible_cfg_file(bundle_path), required=False)
        check_path(report, "Active inventory", ansible_inventory_file(bundle_path), required=False)
        check_path(report, "Active group_vars", ansible_group_vars_dir(bundle_path), required=False, directory=True)
        check_path(report, "Generated bootstrap vars", generated_bootstrap_vars_file(bundle_path), required=False)

        manifest = bundle_path / "aerolit-bundle.yml"
        check_path(report, "Bundle manifest", manifest, required=False)

        server_config = config.get("server", {})
        pxe_http = server_config.get("pxe_http", {})
        bind_address = pxe_http.get("bind_address", "0.0.0.0")
        port = pxe_http.get("port", 18080)

        check_tcp_port_available(report, bind_address, port)

        try:
            bundle_usage = shutil.disk_usage(str(bundle_path))
            report.add_ok(
                "Bundle path free space: {:.1f} GiB free under {}".format(
                    bundle_usage.free / 1024.0 / 1024.0 / 1024.0,
                    bundle_path,
                )
            )
        except Exception as exc:
            report.add_warning("Could not check bundle path free space: {}".format(exc))

    try:
        state_usage = shutil.disk_usage("/var/lib/aerolit")
        report.add_ok(
            "State path free space: {:.1f} GiB free under /var/lib/aerolit".format(
                state_usage.free / 1024.0 / 1024.0 / 1024.0
            )
        )
    except Exception as exc:
        report.add_warning("Could not check state path free space: {}".format(exc))

    try:
        log_usage = shutil.disk_usage("/var/log/aerolit")
        report.add_ok(
            "Log path free space: {:.1f} GiB free under /var/log/aerolit".format(
                log_usage.free / 1024.0 / 1024.0 / 1024.0
            )
        )
    except Exception as exc:
        report.add_warning("Could not check log path free space: {}".format(exc))

    check_firewalld(report)
    check_selinux(report)

    report.print_summary()

    return 1 if report.failures elsem 0





