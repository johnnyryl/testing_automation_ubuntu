def resolve_bundle_path(bundle_path=None, non_interactive=False):
    """Resolve bundle path from arg, prompt, or default."""
    if bundle_path:
        return Path(bundle_path)

    if non_interactive:
        return DEFAULT_BUNDLE_PATH

    prompt = "AeroLIT bundle path [{}]: ".format(DEFAULT_BUNDLE_PATH)
    value = input(prompt).strip()

    if not value:
        return DEFAULT_BUNDLE_PATH

    return Path(value)


def validate_basic_bundle_layout(
    bundle_path,
    report,
    skip_ansible_files=False,
    skip_ci_file=False,
):
    """Validate paths needed for initialization."""
    bundle_path = Path(bundle_path)
    collections_hub = collections_hub_path(bundle_path)
    active_ansible_dir = ansible_dir(bundle_path)

    if not bundle_path.exists():
        report.add("errors", "Bundle path does not exist: {}".format(bundle_path))
        return False

    if not collections_hub.exists():
        report.add(
            "errors",
            "collections-hub path does not exist: {}".format(collections_hub),
        )
        return False

    if not active_ansible_dir.exists():
        report.add(
            "errors",
            "collections-hub Ansible path does not exist: {}".format(
                active_ansible_dir
            ),
        )
        return False

    expected_bundle_paths = [
        bundle_path / "repos",
        bundle_path / "files",
        bundle_path / "extracted_isos",
    ]

    for path in expected_bundle_paths:
        if not path.exists():
            report.add("warnings", "Expected bundle path not found: {}".format(path))

    manifest = bundle_path / "aerolit-bundle.yml"
    if not manifest.exists():
        report.add("warnings", "Bundle manifest not found yet: {}".format(manifest))

    bootstrap = bundle_path / "bootstrap.sh"
    if not bootstrap.exists():
        report.add(
            "warnings",
            "Compatibility bootstrap.sh not found: {}".format(bootstrap),
        )

    if not skip_ansible_files:
        required_ansible_templates = [
            ansible_cfg_template_file(bundle_path),
            ansible_inventory_template_file(bundle_path),
            ansible_group_vars_template_dir(bundle_path),
        ]

        for template in required_ansible_templates:
            if not template.exists():
                report.add(
                    "errors",
                    "Required Ansible template path not found: {}".format(template),
                )

    if not skip_ci_file:
        required_ci_templates = [
            provision_gitlab_template(bundle_path),
            scheduled_gitlab_template(bundle_path),
            system_update_gitlab_template(bundle_path),
            stig_gitlab_template(bundle_path),
        ]

        for template in required_ci_templates:
            if not template.exists():
                report.add(
                    "errors",
                    "Required GitLab CI template path not found: {}".format(template),
                )

    return len(report.errors) == 0


def initialize_collections_hub_ansible(
    bundle_path,
    report,
    backup_root,
    no_backup=False,
    dry_run=False,
):
    """Initialize active collections-hub Ansible files from templates."""
    collections_hub = collections_hub_path(bundle_path)

    copy_path(
        ansible_inventory_template_file(bundle_path),
        ansible_inventory_file(bundle_path),
        report,
        overwrite=True,
        backup=True,
        dry_run=dry_run,
        backup_root=backup_root,
        base_path=collections_hub,
        no_backup=no_backup,
    )

    copy_path(
        ansible_group_vars_template_dir(bundle_path),
        ansible_group_vars_dir(bundle_path),
        report,
        overwrite=True,
        backup=True,
        dry_run=dry_run,
        backup_root=backup_root,
        base_path=collections_hub,
        no_backup=no_backup,
    )

    copy_path(
        ansible_cfg_template_file(bundle_path),
        ansible_cfg_file(bundle_path),
        report,
        overwrite=True,
        backup=True,
        dry_run=dry_run,
        backup_root=backup_root,
        base_path=collections_hub,
        no_backup=no_backup,
    )

    write_text_file(
        generated_bootstrap_vars_file(bundle_path),
        GENERATED_BOOTSTRAP_VARS_CONTENT,
        report,
        overwrite=True,
        backup=True,
        dry_run=dry_run,
        backup_root=backup_root,
        base_path=collections_hub,
        no_backup=no_backup,
    )


def build_gitlab_ci_content(bundle_path):
    """Build root .gitlab-ci.yml content from template fragments."""
    return "".join(
        [
            fragment_without_last_line(provision_gitlab_template(bundle_path)),
            fragment_without_first_and_last_line(scheduled_gitlab_template(bundle_path)),
            fragment_without_first_and_last_line(
                system_update_gitlab_template(bundle_path)
            ),
            fragment_without_first_line(stig_gitlab_template(bundle_path)),
        ]
    )


def initialize_gitlab_ci(
    bundle_path,
    report,
    backup_root,
    no_backup=False,
    dry_run=False,
):
    """Generate collections-hub .gitlab-ci.yml from template fragments."""
    collections_hub = collections_hub_path(bundle_path)
    content = build_gitlab_ci_content(bundle_path)

    write_text_file(
        gitlab_ci_file(bundle_path),
        content,
        report,
        overwrite=True,
        backup=True,
        dry_run=dry_run,
        backup_root=backup_root,
        base_path=collections_hub,
        no_backup=no_backup,
    )


def initialize_sync_preserve(
    bundle_path,
    report,
    backup_root,
    force=False,
    no_backup=False,
