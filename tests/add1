So the full function becomes:

```python
def runtime_deploy_plan(plan, skip_firewall=False, skip_nfs=False, skip_interface=False):
    """Return deploy-time plan with skip flags applied for generated vars."""
    runtime = dict(plan)
    runtime["firewall"] = dict(plan.get("firewall", {}) or {})
    runtime["nfs"] = dict(plan.get("nfs", {}) or {})

    if skip_firewall:
        runtime["firewall"]["manage"] = False

    if skip_nfs:
        runtime["nfs"]["enabled"] = False

    if skip_interface:
        runtime["configure_interface"] = False

    return runtime
```

### Add a network playbook runner

Add this before `deploy_ansible_playbooks()`:

```python
def deploy_network_playbook(
    plan,
    report,
    bundle_path,
    generated_vars_path,
    dry_run=False,
    repo_vars_path=None,
):
    """Run the network configuration playbook when interface management is enabled."""
    if not plan.get("configure_interface"):
        report.add("skipped", "Network playbook skipped because interface configuration intent is disabled")
        return

    collections_hub = collections_hub_path(bundle_path)
    playbooks_dir = Path(collections_hub) / "ansible"

    ensure_ansible_playbook(report, dry_run=dry_run)

    run_server_playbook(
        report,
        playbooks_dir,
        "configure_network.yml",
        generated_vars_path,
        dry_run=dry_run,
        extra_vars_files=[repo_vars_path] if repo_vars_path else [],
    )
```

