### `tasks/configure.yml`

```yaml
# UNCLASSIFIED

- name: Build planned provisioning address
  ansible.builtin.set_fact:
    configure_network_planned_address: "{{ configure_network_ipv4_address }}/{{ configure_network_ipv4_prefix }}"

- name: List active NetworkManager connections
  ansible.builtin.command:
    argv:
      - nmcli
      - -t
      - -f
      - NAME,DEVICE
      - connection
      - show
      - --active
  register: configure_network_active_connections
  changed_when: false

- name: Discover NetworkManager connection for interface
  ansible.builtin.set_fact:
    configure_network_discovered_connection: >-
      {{
        (
          configure_network_active_connections.stdout_lines
          | select('search', ':' ~ configure_network_interface ~ '$')
          | list
          | first
          | default('')
        )
        | regex_replace(':' ~ configure_network_interface ~ '$', '')
        | replace('\\:', ':')
      }}
  when: configure_network_connection_name | length == 0

- name: Select effective NetworkManager connection
  ansible.builtin.set_fact:
    configure_network_effective_connection: >-
      {{
        configure_network_connection_name
        if (configure_network_connection_name | length > 0)
        else configure_network_discovered_connection
      }}

- name: Validate active NetworkManager connection was found
  ansible.builtin.assert:
    that:
      - configure_network_effective_connection | length > 0
    fail_msg: >-
      No active NetworkManager connection was found for interface
      {{ configure_network_interface }}. Configure it manually or create/activate
      a NetworkManager connection first.

- name: Read current NetworkManager IPv4 settings
  ansible.builtin.command:
    argv:
      - nmcli
      - -t
      - -f
      - ipv4.method,ipv4.addresses,ipv4.gateway,ipv4.dns,ipv4.ignore-auto-routes,ipv4.ignore-auto-dns,ipv4.never-default
      - connection
      - show
      - "{{ configure_network_effective_connection }}"
  register: configure_network_current_raw
  changed_when: false

- name: Build current NetworkManager settings map
  ansible.builtin.set_fact:
    configure_network_current_settings: "{{ configure_network_current_settings | default({}) | combine({ item.split(':', 1)[0]: item.split(':', 1)[1] | default('') }) }}"
  loop: "{{ configure_network_current_raw.stdout_lines | default([]) }}"
  loop_control:
    label: "{{ item.split(':', 1)[0] | default(item) }}"

- name: Decide whether NetworkManager connection needs update
  ansible.builtin.set_fact:
    configure_network_needs_update: >-
      {{
        configure_network_current_settings.get('ipv4.method', '') != configure_network_ipv4_method
        or configure_network_current_settings.get('ipv4.addresses', '') != configure_network_planned_address
        or configure_network_current_settings.get('ipv4.gateway', '') not in ['', '--']
        or configure_network_current_settings.get('ipv4.dns', '') not in ['', '--']
        or configure_network_current_settings.get('ipv4.ignore-auto-routes', '') != ('yes' if configure_network_ignore_auto_routes | bool else 'no')
        or configure_network_current_settings.get('ipv4.ignore-auto-dns', '') != ('yes' if configure_network_ignore_auto_dns | bool else 'no')
        or configure_network_current_settings.get('ipv4.never-default', '') != ('yes' if configure_network_never_default | bool else 'no')
      }}

- name: Configure dedicated provisioning interface
  ansible.builtin.command:
    argv:
      - nmcli
      - connection
      - modify
      - "{{ configure_network_effective_connection }}"
      - ipv4.method
      - "{{ configure_network_ipv4_method }}"
      - ipv4.addresses
      - "{{ configure_network_planned_address }}"
      - ipv4.gateway
      - "{{ configure_network_gateway }}"
      - ipv4.dns
      - "{{ configure_network_dns | join(',') }}"
      - ipv4.ignore-auto-routes
      - "{{ 'yes' if configure_network_ignore_auto_routes | bool else 'no' }}"
      - ipv4.ignore-auto-dns
      - "{{ 'yes' if configure_network_ignore_auto_dns | bool else 'no' }}"
      - ipv4.never-default
      - "{{ 'yes' if configure_network_never_default | bool else 'no' }}"
  register: configure_network_modify_result
  changed_when: true
  when: configure_network_needs_update | bool

- name: Bring NetworkManager connection up
  ansible.builtin.command:
    argv:
      - nmcli
      - connection
      - up
      - "{{ configure_network_effective_connection }}"
  changed_when: true
  when:
    - configure_network_activate | bool
    - configure_network_needs_update | bool

# UNCLASSIFIED
```

