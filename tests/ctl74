"""AeroLIT log viewing helpers."""

from __future__ import print_function

import sys
import time
from collections import deque
from datetime import datetime
from fnmatch import fnmatch
from pathlib import Path

from .command_log import command_log_dir
from .paths import LOG_DIR


def format_size(size):
    """Return human-readable size."""
    size = float(size)

    for unit in ("B", "KB", "MB", "GB"):
        if size < 1024.0:
            return "{:.1f}{}".format(size, unit)
        size = size / 1024.0

    return "{:.1f}TB".format(size)


def is_log_file(path):
    """Return True if path is a regular file that can be treated as a log."""
    try:
        return path.is_file()
    except OSError:
        return False


def path_matches_pattern(path, log_dir, pattern):
    """Return True if a path matches the requested pattern."""
    if not pattern:
        return True

    try:
        relative = str(path.relative_to(log_dir))
    except ValueError:
        relative = str(path)

    return fnmatch(path.name, pattern) or fnmatch(relative, pattern)


def find_log_files(log_dir=LOG_DIR, pattern=None):
    """Return AeroLIT log files sorted newest first."""
    log_dir = Path(log_dir)

    if not log_dir.exists() or not log_dir.is_dir():
        return []

    files = []

    for path in log_dir.rglob("*"):
        if not is_log_file(path):
            continue

        if not path_matches_pattern(path, log_dir, pattern):
            continue

        try:
            path.stat()
        except OSError:
            continue

        files.append(path)

    files.sort(key=lambda path: path.stat().st_mtime, reverse=True)
    return files


def latest_log_file(log_dir=LOG_DIR, pattern=None):
    """Return latest AeroLIT log file or None."""
    files = find_log_files(log_dir=log_dir, pattern=pattern)
    return files[0] if files else None


def print_log_list(log_dir=LOG_DIR, limit=None, pattern=None):
    """Print known AeroLIT log files."""
    files = find_log_files(log_dir=log_dir, pattern=pattern)

    if not files:
        print("No AeroLIT log files found in:")
        print("  {}".format(log_dir))
        return 1

    if limit is not None:
        files = files[:limit]

    print("AeroLIT logs")
    print("")
    for path in files:
        stat = path.stat()
        modified = datetime.fromtimestamp(stat.st_mtime).strftime(
            "%Y-%m-%d %H:%M:%S"
        )
        print("{}  {:>8}  {}".format(modified, format_size(stat.st_size), path))

    return 0


def print_tail(path, line_count):
    """Print last N lines from a file."""
    if line_count <= 0:
        return

    path = Path(path)

    with path.open("r", encoding="utf-8", errors="replace") as handle:
        lines = deque(handle, maxlen=line_count)

    for line in lines:
        print(line, end="")

    if lines and not str(lines[-1]).endswith("\n"):
        print("")


def follow_file(path, line_count):
    """Tail and follow a file."""
    path = Path(path)

    print_tail(path, line_count)

    with path.open("r", encoding="utf-8", errors="replace") as handle:
        handle.seek(0, 2)

        while True:
            line = handle.readline()

            if line:
                print(line, end="")
                sys.stdout.flush()
                continue

            try:
                if path.stat().st_size < handle.tell():
                    handle.seek(0, 0)
            except OSError:
                pass

            time.sleep(1)


def resolve_log_path(path, log_dir):
    """Resolve a requested log path.

    Relative paths are first treated as shell-relative paths. If not found, they
    are treated as relative to the AeroLIT log directory.
    """
    if not path:
        return None

    candidate = Path(path)

    if candidate.exists() or candidate.is_absolute():
        return candidate

    return Path(log_dir) / candidate


def validate_args(args):
    """Validate log command arguments."""
    if args.tail < 0:
        print("ERROR: --tail must be zero or greater.", file=sys.stderr)
        return 1

    if args.limit is not None and args.limit < 0:
        print("ERROR: --limit must be zero or greater.", file=sys.stderr)
        return 1

    return 0


def run_logs(args):
    """Run aerolitctl logs."""
    validation_rc = validate_args(args)
    if validation_rc:
        return validation_rc

    log_dir = Path(args.log_dir) if args.log_dir else command_log_dir()

    if args.dir:
        print(log_dir)
        return 0

    if args.list:
        return print_log_list(
            log_dir=log_dir,
            limit=args.limit,
            pattern=args.pattern,
        )

    path = resolve_log_path(args.path, log_dir) if args.path else latest_log_file(
        log_dir=log_dir,
        pattern=args.pattern,
    )

    if not path:
        print("No AeroLIT log files found in:")
        print("  {}".format(log_dir))
        print("")
        print("Try:")
        print("  aerolitctl logs --list")
        print("  aerolitctl logs --dir")
        return 1

    if not path.exists():
        print("Log file not found: {}".format(path), file=sys.stderr)
        return 1

    if not path.is_file():
        print("Log path is not a file: {}".format(path), file=sys.stderr)
        return 1

    print("AeroLIT log:")
    print("  {}".format(path))
    print("")

    if args.follow:
        try:
            follow_file(path, args.tail)
        except KeyboardInterrupt:
            print("")
            return 130
        return 0

    print_tail(path, args.tail)
    return 0
