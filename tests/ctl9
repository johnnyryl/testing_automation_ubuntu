DEFAULT_MODE = "full"
DEFAULT_HTTP_PORT = 18080
DEFAULT_BIND_ADDRESS = "0.0.0.0"

DEFAULT_TARGET_MOUNT_PATH = "/home/unix/sysadmin"
DEFAULT_MOUNT_MODE = "0755"
DEFAULT_MOUNT_OWNER = "root"
DEFAULT_MOUNT_GROUP = "root"
DEFAULT_NFS_EXPORTS_FILE = "/etc/exports.d/aerolit-bundle.exports"

MIN_RECOMMENDED_USABLE_HOSTS = 20

DANGEROUS_EXPORT_PATHS = (
    "/",
    "/root",
    "/etc",
    "/usr",
    "/bin",
    "/sbin",
    "/boot",
    "/var",
    "/var/log",
)

VIRTUAL_INTERFACE_PREFIXES = (
