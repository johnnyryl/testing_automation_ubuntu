def write_text_if_changed(
    path,
    content,
    report,
    backup_root=None,
    base_path=None,
    dry_run=False,
):
    """Write file only if content changed."""
    path = Path(path)
    old_content = None

    if path.exists():
        try:
            old_content = path.read_text()
        except IOError:
            old_content = None

    if old_content == content:
        report.add("existing", "{} unchanged".format(path))
        return False

    if dry_run:
        action = "Would update" if path.exists() else "Would create"
        report.add("dry_run", "{} {}".format(action, path))
        return True

    if path.exists():
        backup_existing(
            path,
            report,
            dry_run=False,
            backup_root=backup_root,
            base_path=base_path,
            no_backup=False,
        )

    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)

    if old_content is None:
        report.add("created", str(path))
    else:
        report.add("updated", str(path))

    return True


def save_config_if_changed(config, report, dry_run=False):
    """Save /etc/aerolit/aerolitctl.yml only when content changes."""
    path = Path(CONFIG_FILE)
    new_content = dump_yaml(config)

    old_content = None
    if path.exists():
        try:
            old_content = path.read_text()
        except IOError:
            old_content = None

    if old_content == new_content:
        report.add("existing", "{} unchanged".format(path))
        return None

    if dry_run:
        action = "Would update" if path.exists() else "Would create"
        report.add("dry_run", "{} {}".format(action, path))
        return None

    backup_path = save_config(config, backup=True)

    if backup_path:
        report.add("backed_up", "{} -> {}".format(path, backup_path))
        report.add("updated", str(path))
    else:
        report.add("created", str(path))

    return backup_path


def build_plan_from_values(
    config,
    bundle_path,
    mode=None,
    interface=None,
    server_ip=None,
    network=None,
    prefix=None,
    gateway=None,
    dns_servers=None,
    dhcp_start=None,
    dhcp_end=None,
    pxe_http_port=None,
    pxe_http_bind_address=None,
    configure_interface=None,
    nfs_enabled=None,
    nfs_export_path=None,
    nfs_allowed_clients=None,
    nfs_allow_all_clients=None,
    nfs_create_export_path=None,
    nfs_exports_file=None,
    target_mount_path=None,
    mount_mode=None,
    mount_owner=None,
    mount_group=None,
    firewall_manage=None,
):
    """Build and validate a non-interactive server plan."""
    server = current_server_config(config)
    current_nfs = server.get("nfs", {})
    current_firewall = server.get("firewall", {})

    if configure_interface is None:
        configure_interface = server.get("configure_interface", False)

    if nfs_enabled is None:
        nfs_enabled = current_nfs.get("enabled", True)

    if nfs_allow_all_clients is None:
        nfs_allow_all_clients = current_nfs.get("allow_all_clients", False)

    if nfs_create_export_path is None:
        nfs_create_export_path = current_nfs.get("create_export_path", False)

    if firewall_manage is None:
        firewall_manage = current_firewall.get("manage", True)

    mode = normalize_mode(mode or server.get("mode") or DEFAULT_MODE)

    pxe_enabled = mode in ("full", "pxe")
    controller_enabled = mode in ("full", "controller")

    interface = interface or server.get("interface") or default_route_interface()

    if not interface:
        raise ValueError("Interface is required")

    if network:
        network_obj = parse_ipv4_network(network, "Provisioning network")
    else:
        detected_network = interface_ipv4_network(interface)
        if detected_network is not None:
            network_obj = detected_network
        elif prefix and server_ip:
            network_obj = parse_ipv4_network(
                "{}/{}".format(server_ip, prefix),
                "Provisioning network",
            )
        else:
            network_obj = parse_ipv4_network("192.168.98.0/24", "Provisioning network")

    server_ip = server_ip or server.get("ip_address")

    if not server_ip:
        usable_hosts = network_usable_host_count(network_obj)
        if usable_hosts < 1:
            raise ValueError("Provisioning network has no usable host addresses")

        server_ip_int = int(network_obj.network_address) + min(10, usable_hosts)
        server_ip = str(ipaddress.IPv4Address(server_ip_int))

    server_ip_obj = parse_ipv4_address(server_ip, "AeroLIT server IP")

    if server_ip_obj not in network_obj:
        raise ValueError("AeroLIT server IP must be inside {}".format(network_obj))

    prefix = prefix or network_obj.prefixlen
    prefix = parse_prefix(prefix)

    gateway = gateway_value(
        gateway if gateway is not None else server.get("gateway"),
        network=network_obj,
        server_ip=server_ip_obj,
    )

    dns_servers = parse_dns_servers(
        dns_servers if dns_servers is not None else server.get("dns", [])
    )

    if pxe_enabled:
        dhcp_start, dhcp_end = validate_dhcp_range(
            dhcp_start or config.get("pxe", {}).get("dhcp_start"),
            dhcp_end or config.get("pxe", {}).get("dhcp_end"),
            network_obj,
            server_ip=server_ip_obj,
            gateway=gateway,
        )

        if not dhcp_start or not dhcp_end:
            dhcp_start, dhcp_end = suggested_dhcp_range(
                network_obj,
                server_ip=server_ip_obj,
                gateway=gateway,
            )
    else:
        dhcp_start = None
        dhcp_end = None

    nfs = {
        "enabled": bool(controller_enabled and nfs_enabled),
        "server_ip": str(server_ip_obj),
        "export_path": validate_absolute_path(
            nfs_export_path or current_nfs.get("export_path") or str(bundle_path),
            "NFS export path",
        ),
        "allowed_clients": None,
        "allow_all_clients": bool(nfs_allow_all_clients),
        "create_export_path": bool(nfs_create_export_path),
        "exports_file": validate_absolute_path(
            nfs_exports_file
            or current_nfs.get("exports_file")
            or DEFAULT_NFS_EXPORTS_FILE,
            "NFS exports file",
        ),
        "target_mount_path": validate_absolute_path(
            target_mount_path
            or current_nfs.get("target_mount_path")
            or DEFAULT_TARGET_MOUNT_PATH,
            "Target/client mount path",
        ),
        "mount_mode": mount_mode or current_nfs.get("mount_mode") or DEFAULT_MOUNT_MODE,
        "mount_owner": mount_owner or current_nfs.get("mount_owner") or DEFAULT_MOUNT_OWNER,
        "mount_group": mount_group or current_nfs.get("mount_group") or DEFAULT_MOUNT_GROUP,
    }

    if nfs["enabled"]:
        default_clients = (
            nfs_allowed_clients
            or current_nfs.get("allowed_clients")
            or str(network_obj)
        )
        nfs["allowed_clients"] = parse_clients(
            default_clients,
            allow_all_clients=nfs["allow_all_clients"],
        )

    pxe_http = server.get("pxe_http", {})
    pxe_http_port = int(pxe_http_port or pxe_http.get("port") or DEFAULT_HTTP_PORT)

    if pxe_http_port < 1 or pxe_http_port > 65535:
        raise ValueError("PXE HTTP port must be between 1 and 65535")

    pxe_http_bind_address = (
        pxe_http_bind_address
        or pxe_http.get("bind_address")
        or DEFAULT_BIND_ADDRESS
    )

    if pxe_http_bind_address != "0.0.0.0":
        parse_ipv4_address(pxe_http_bind_address, "PXE HTTP bind address")

    plan = {
        "mode": mode,
        "pxe_enabled": pxe_enabled,
        "controller_enabled": controller_enabled,
        "interface": interface,
        "network": str(network_obj),
        "server_ip": str(server_ip_obj),
        "prefix": prefix,
        "gateway": gateway,
        "dns_servers": dns_servers,
        "dhcp_start": dhcp_start,
        "dhcp_end": dhcp_end,
        "dhcp_netmask": str(network_obj.netmask),
        "pxe_http_port": pxe_http_port,
        "pxe_http_bind_address": pxe_http_bind_address,
        "configure_interface": bool(configure_interface),
        "nfs": nfs,
    }

    plan["firewall"] = build_firewall_intent(plan, manage=firewall_manage)

    return plan


def build_guided_plan(config, bundle_path):
    """Build server plan interactively."""
    server = current_server_config(config)

    mode = choose_mode(current=server.get("mode"))
    pxe_enabled = mode in ("full", "pxe")
    controller_enabled = mode in ("full", "controller")

    interface = choose_interface(current=server.get("interface"))
    network = choose_network(current_network=None, interface=interface)
    server_ip = choose_server_ip(current=server.get("ip_address"), network=network)
    server_ip_obj = parse_ipv4_address(server_ip, "AeroLIT server IP")

    gateway = choose_gateway(
        current=server.get("gateway"),
        network=network,
        server_ip=server_ip_obj,
    )

    dns_servers = choose_dns(current=server.get("dns", []))

    if pxe_enabled:
        dhcp_start, dhcp_end = choose_dhcp_range(
            current_start=config.get("pxe", {}).get("dhcp_start"),
            current_end=config.get("pxe", {}).get("dhcp_end"),
            network=network,
            server_ip=server_ip_obj,
            gateway=gateway,
        )
    else:
        dhcp_start = None
        dhcp_end = None

    pxe_http = server.get("pxe_http", {})
    pxe_http_port = int(
        text_prompt(
            "PXE HTTP port",
            default=pxe_http.get("port", DEFAULT_HTTP_PORT),
        )
    )

    pxe_http_bind_address = text_prompt(
        "PXE HTTP bind address",
        default=pxe_http.get("bind_address", DEFAULT_BIND_ADDRESS),
    )

    configure_interface = yes_no_prompt(
        "Should a later deploy step configure this interface?",
        default=server.get("configure_interface", False),
    )

    if controller_enabled:
        nfs = choose_nfs_settings(config, bundle_path, server_ip, network)
    else:
        nfs = {
            "enabled": False,
            "server_ip": server_ip,
            "export_path": str(bundle_path),
            "allowed_clients": None,
            "allow_all_clients": False,
            "create_export_path": False,
            "exports_file": DEFAULT_NFS_EXPORTS_FILE,
            "target_mount_path": DEFAULT_TARGET_MOUNT_PATH,
            "mount_mode": DEFAULT_MOUNT_MODE,
            "mount_owner": DEFAULT_MOUNT_OWNER,
            "mount_group": DEFAULT_MOUNT_GROUP,
        }

    firewall_manage = yes_no_prompt(
        "Should a later deploy step manage required firewall rules?",
        default=server.get("firewall", {}).get("manage", True),
    )

    plan = {
        "mode": mode,
        "pxe_enabled": pxe_enabled,
        "controller_enabled": controller_enabled,
        "interface": interface,
        "network": str(network),
        "server_ip": server_ip,
        "prefix": network.prefixlen,
        "gateway": gateway,
        "dns_servers": dns_servers,
        "dhcp_start": dhcp_start,
        "dhcp_end": dhcp_end,
        "dhcp_netmask": str(network.netmask),
        "pxe_http_port": pxe_http_port,
        "pxe_http_bind_address": pxe_http_bind_address,
        "configure_interface": configure_interface,
        "nfs": nfs,
    }

    plan["firewall"] = build_firewall_intent(plan, manage=firewall_manage)

    return plan


