)


class ServerConfigReport(object):
    """Collect configure server actions."""

    def __init__(self, verbose=False):
        self.verbose = verbose
        self.created = []
        self.updated = []
        self.existing = []
        self.backed_up = []
        self.warnings = []
        self.errors = []
        self.dry_run = []

    def add(self, category, message):
        getattr(self, category).append(message)

    def print_summary(self):
        """Print action summary."""
        print("")
        print("AeroLIT server configuration summary")
        print("")

        sections = [
            ("Created", self.created),
            ("Updated", self.updated),
            ("Already current / skipped", self.existing),
            ("Backed up", self.backed_up),
            ("Dry-run actions", self.dry_run),
            ("Warnings", self.warnings),
            ("Errors", self.errors),
        ]

        for title, values in sections:
