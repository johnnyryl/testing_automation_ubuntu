def run_configure_server(
    guided=False,
    dry_run=False,
    show=False,
    mode=None,
    interface=None,
    server_ip=None,
    network=None,
    prefix=None,
    gateway=None,
    dns_servers=None,
    dhcp_start=None,
    dhcp_end=None,
    pxe_http_port=None,
    pxe_http_bind_address=None,
    configure_interface=None,
    nfs_enabled=None,
    nfs_export_path=None,
    nfs_allowed_clients=None,
    nfs_allow_all_clients=None,
    nfs_create_export_path=None,
    nfs_exports_file=None,
    target_mount_path=None,
    mount_mode=None,
    mount_owner=None,
    mount_group=None,
    firewall_manage=None,
):
    """Configure AeroLIT server values and generated Ansible vars."""
    report = ServerConfigReport()

    config = load_config()
    bundle_path_value = get_bundle_path(config)

    if not bundle_path_value:
        raise RuntimeError(
            "No bundle path is configured. Run: aerolitctl configure init"
        )

    bundle_path = Path(bundle_path_value)
    generated_vars_path = generated_bootstrap_vars_file(bundle_path)
    backup_root = initialization_backup_root(bundle_path) / timestamp()
    collections_hub = collections_hub_path(bundle_path)

    if show:
        server = current_server_config(config)
        plan = build_plan_from_values(
            config,
            bundle_path,
            mode=server.get("mode"),
            interface=server.get("interface"),
            server_ip=server.get("ip_address"),
            prefix=server.get("prefix"),
            gateway=server.get("gateway"),
            dns_servers=server.get("dns", []),
            dhcp_start=config.get("pxe", {}).get("dhcp_start"),
            dhcp_end=config.get("pxe", {}).get("dhcp_end"),
            pxe_http_port=server.get("pxe_http", {}).get("port"),
            pxe_http_bind_address=server.get("pxe_http", {}).get("bind_address"),
            configure_interface=server.get("configure_interface", False),
            nfs_enabled=server.get("nfs", {}).get("enabled", True),
            nfs_export_path=server.get("nfs", {}).get("export_path"),
            nfs_allowed_clients=server.get("nfs", {}).get("allowed_clients"),
            nfs_allow_all_clients=server.get("nfs", {}).get("allow_all_clients", False),
            nfs_create_export_path=server.get("nfs", {}).get(
                "create_export_path",
                False,
            ),
            nfs_exports_file=server.get("nfs", {}).get("exports_file"),
            target_mount_path=server.get("nfs", {}).get("target_mount_path"),
            mount_mode=server.get("nfs", {}).get("mount_mode"),
            mount_owner=server.get("nfs", {}).get("mount_owner"),
            mount_group=server.get("nfs", {}).get("mount_group"),
            firewall_manage=server.get("firewall", {}).get("manage", True),
        )
        print_plan(plan, bundle_path)
        print("Generated vars path:")
        print("  {}".format(generated_vars_path))
        return 0

    if guided:
        plan = build_guided_plan(config, bundle_path)
    else:
        plan = build_plan_from_values(
            config,
            bundle_path,
            mode=mode,
            interface=interface,
            server_ip=server_ip,
            network=network,
            prefix=prefix,
            gateway=gateway,
            dns_servers=dns_servers,
            dhcp_start=dhcp_start,
            dhcp_end=dhcp_end,
            pxe_http_port=pxe_http_port,
            pxe_http_bind_address=pxe_http_bind_address,
            configure_interface=configure_interface,
            nfs_enabled=nfs_enabled,
            nfs_export_path=nfs_export_path,
            nfs_allowed_clients=nfs_allowed_clients,
            nfs_allow_all_clients=nfs_allow_all_clients,
            nfs_create_export_path=nfs_create_export_path,
            nfs_exports_file=nfs_exports_file,
            target_mount_path=target_mount_path,
            mount_mode=mount_mode,
            mount_owner=mount_owner,
            mount_group=mount_group,
            firewall_manage=firewall_manage,
        )

    print_plan(plan, bundle_path)

    for warning in collect_plan_warnings(plan):
        report.add("warnings", warning)

    config = update_config_with_plan(config, plan)
    generated_text = generated_vars_text(plan)

    save_config_if_changed(config, report, dry_run=dry_run)

    write_text_if_changed(
        generated_vars_path,
        generated_text,
        report,
        backup_root=backup_root,
        base_path=collections_hub,
        dry_run=dry_run,
    )

    print("Generated vars path:")
    print("  {}".format(generated_vars_path))
    print("")

    if dry_run:
        print("Dry run complete. No files were changed.")
    else:
        print("Server configuration saved.")
        print("")
        print("No system services were changed.")
        print("A later deploy command will apply network/NFS/PXE service changes.")

    report.print_summary()

    return 1 if report.errors else 0
