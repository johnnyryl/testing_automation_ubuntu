def validation_errors_block_generate(report, args):
    """Return True when validation errors should block this generate run."""
    if not report.errors:
        return False

    if not args.dry_run:
        return True

    # In dry-run mode, let the user preview output even before configure init has
    # created the active group_vars/all directory. Real writes still fail until
    # the bundle has been initialized.
    tolerated = []
    for message in report.errors:
        if "group_vars/all directory missing:" in message:
            tolerated.append(message)
            continue
        return True

    for message in tolerated:
        report.add_warning("Dry run only: {}".format(message))

    report.errors = [
        message
        for message in report.errors
        if message not in tolerated
    ]
    return False


def run_generate_kickstart(args):
    """Run aerolitctl generate kickstart."""
    try:
        bundle_path = configured_bundle_path(args.bundle_path)
        state = load_managed_pxe_state(bundle_path)

        if getattr(args, "list_kickstart_options", False):
            print_kickstart_option_inventory(bundle_path, args, state=state)
            return 0

        if getattr(args, "guided", False):
            run_guided_kickstart(args, bundle_path, state)

        if not getattr(args, "profile", None):
            raise GenerateConfigError(
                "PROFILE is required unless --guided is used. Example: "
                "aerolitctl generate kickstart rhel9_workstation"
            )

        prepare_dynamic_template_args(bundle_path, args)
        profile = build_kickstart_profile(state, args)

        print_kickstart_plan(bundle_path, profile, args)

        report = validate_pxe_state(
            bundle_path,
            state,
            check_files=True,
            force=args.force,
        )

        if validation_errors_block_generate(report, args):
            print("Refusing to write invalid managed PXE configuration.")
            print("")
            report.print_report()
            return report.exit_code()

        ensure_pxe_directories(dry_run=args.dry_run)

        if getattr(args, "_composed_template_content", None):
            write_composed_kickstart_template(profile, args)

        if args.copy_template:
            copy_kickstart_template(profile, args)

        if not args.no_refresh_generated_vars:
            write_pxe_if_changed(
                aerolitctl_pxe_generated_vars_file(bundle_path),
                render_generated_vars(bundle_path, state),
                dry_run=args.dry_run,
                label="generated PXE vars",
                managed_kind="generated_vars",
                force=args.force,
                no_backup=args.no_backup,
            )

        write_pxe_if_changed(
            aerolitctl_pxe_profile_file(profile["profile_id"]),
            render_profile(profile),
            dry_run=args.dry_run,
            label="PXE profile {}".format(profile["profile_id"]),
            managed_kind="profile",
            force=args.force,
            no_backup=args.no_backup,
        )

        print("")
        if args.dry_run:
            print("Dry run complete. No files were changed.")
        else:
            print("Generated PXE/Kickstart profile input saved.")

        if args.validate:
            print("")
            final_report = validate_pxe_state(
                bundle_path,
                state,
                check_files=True,
                force=args.force,
            )
            final_report.print_report()
            return final_report.exit_code()

        return 0
    finally:
        cleanup_container_template_cache(args)


def run_generate(args):
    """Dispatch aerolitctl generate."""
    command = getattr(args, "generate_command", None)

    try:
        if command == "playbook":
            return run_generate_playbook(args)

        if command in ("kickstart", "pxe-profile"):
            return run_generate_kickstart(args)

        return fail("missing generate subcommand; use playbook or kickstart")

    except (GenerateConfigError, PxeConfigError, OSError, IOError) as exc:
        return fail(str(exc))


