        help="Bundle path. Defaults to configured bundle path or /opt/aerolit/aerolit-bundle.",
    )
    kickstart.add_argument(
        "--force",
        action="store_true",
        help="Allow replacement of existing non-aerolitctl-managed output files.",
    )
    kickstart.add_argument(
        "--no-backup",
        action="store_true",
        help="Do not create timestamped backups before changing files.",
    )
    kickstart.add_argument(
        "--dry-run",
        action="store_true",
        help="Preview generated output without writing files.",
    )
    kickstart.set_defaults(func=run_generate, generate_command="kickstart")

    return parser


if __name__ == "__main__":  # pragma: no cover
    root = argparse.ArgumentParser(prog="aerolitctl")
    subs = root.add_subparsers(dest="command")
    add_generate_parser(subs)
    parsed = root.parse_args()

    if not hasattr(parsed, "func"):
        root.print_help()
        sys.exit(2)

    sys.exit(parsed.func(parsed))
