class DoctorReport(object):
    """Collect doctor check results."""

    def __init__(self):
        self.ok = []
        self.warnings = []
        self.failures = []

    def add_ok(self, message):
        self.ok.append(message)

    def add_warning(self, message):
        self.warnings.append(message)

    def add_failure(self, message):
        self.failures.append(message)

    def print_report(self):
        print("AeroLIT Doctor")
        print("")

        for message in self.ok:
            print("[OK] {}".format(message))

        for message in self.warnings:
            print("[WARN] {}".format(message))

        for message in self.failures:
            print("[FAIL] {}".format(message))

        print("")
        print("Summary:")
        print("  OK: {}".format(len(self.ok)))
        print("  Warnings: {}".format(len(self.warnings)))
        print("  Failures: {}".format(len(self.failures)))

    def exit_code(self):
        return 1 if self.failures else 0


def command_exists(name):
    """Return True when command exists in PATH."""
    return shutil.which(name) is not None


def run_command(command, cwd=None):
    """Run a command and return return code and stripped output."""
    try:
        process = subprocess.Popen(
            command,
            cwd=str(cwd) if cwd else None,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            universal_newlines=True,
        )
        stdout, stderr = process.communicate()
        output = "\n".join(
            item.strip() for item in [stdout, stderr] if item and item.strip()
        )
        return process.returncode, output
    except OSError as exc:
        return 127, str(exc)


def read_os_release():
    """Return useful OS release string."""
    path = Path("/etc/os-release")

    if not path.exists():
        return platform.platform()

    values = {}

    with path.open("r") as handle:
        for line in handle:
            line = line.strip()
            if not line or "=" not in line:
                continue

            key, value = line.split("=", 1)
            values[key] = value.strip().strip('"')

    pretty = values.get("PRETTY_NAME")
    if pretty:
        return pretty

    return platform.platform()


def nearest_existing_path(path):
    """Return nearest existing parent path."""
    path = Path(path)

    while not path.exists() and path.parent != path:
        path = path.parent

    return path


def gib(bytes_value):
    """Convert bytes to GiB."""
    return float(bytes_value) / float(1024 ** 3)


def check_path(report, label, path, required=True):
    """Check path exists."""
    path = Path(path)

    if path.exists():
        report.add_ok("{} found: {}".format(label, path))
        return True

    if required:
        report.add_failure("{} missing: {}".format(label, path))
    else:
        report.add_warning("{} not found: {}".format(label, path))

    return False


def check_command(report, command, required=False):
    """Check command availability."""
    if command_exists(command):
        report.add_ok("Command available: {}".format(command))
        return True

    if required:
        report.add_failure("Required command missing: {}".format(command))
    else:
        report.add_warning("Optional command missing: {}".format(command))

    return False


def add_bundle_manifest_findings(report, findings):
    """Add bundle manifest validation findings to doctor output."""
    for level, message in findings:
        if level == "ok":
            report.add_ok(message)
        elif level == "warning":
            report.add_warning(message)
        elif level == "failure":
            report.add_failure(message)
        else:
            report.add_warning(message)


def add_pxe_doctor_findings(report, bundle_path):
    """Add PXE status checks to doctor output."""
    try:
        findings = pxe_doctor_lines(bundle_path)
    except Exception as exc:
        report.add_warning("PXE checks skipped: {}".format(exc))
        return

    for level, message in findings:
        level = str(level).lower()

        if level == "ok":
            report.add_ok("PXE: {}".format(message))
        elif level in ["warn", "warning"]:
            report.add_warning("PXE: {}".format(message))
        elif level in ["fail", "failure", "error"]:
            report.add_failure("PXE: {}".format(message))
        else:
            report.add_warning("PXE: {}".format(message))


def check_root(report):
    """Check whether running as root."""
    if hasattr(os, "geteuid"):
        if os.geteuid() == 0:
            report.add_ok("Running as root")
        else:
            report.add_warning(
                "Not running as root. Some deploy/configure actions may require sudo/root."
            )
    else:
        report.add_warning("Could not determine current user privileges")


def check_python(report):
    """Check Python runtime."""
    version = platform.python_version()
    report.add_ok("Python runtime: {}".format(version))

    try:
        require_yaml()
        report.add_ok("Python YAML support available")
    except Exception as exc:
        report.add_failure(str(exc))


def check_selinux(report):
    """Check SELinux state if available."""
    if not command_exists("getenforce"):
        report.add_warning("SELinux status unavailable: getenforce not found")
        return

    code, output = run_command(["getenforce"])

    if code != 0:
        report.add_warning("SELinux status check failed: {}".format(output))
        return

    if output == "Enforcing":
        report.add_warning(
            "SELinux is Enforcing. Some PXE/container bind mounts may require labels or policy adjustments."
        )
    else:
        report.add_ok("SELinux status: {}".format(output))


def check_firewalld(report):
    """Check firewalld state if available."""
    if command_exists("firewall-cmd"):
        code, output = run_command(["firewall-cmd", "--state"])
        if code == 0:
            report.add_ok("firewalld status: {}".format(output))
        else:
            report.add_warning("firewalld check returned: {}".format(output))
        return

    if command_exists("systemctl"):
        code, output = run_command(["systemctl", "is-active", "firewalld"])
        if code == 0:
            report.add_ok("firewalld status: {}".format(output))
        else:
            report.add_warning("firewalld is not active or status is unavailable")
        return

    report.add_warning("firewalld status unavailable: firewall-cmd/systemctl not found")


def check_disk_space(report, path, label, warn_below_gib=20):
    """Check disk space under path."""
    existing_path = nearest_existing_path(path)

    if not existing_path.exists():
        report.add_warning(
            "{} disk check skipped; path does not exist: {}".format(label, path)
        )
        return

    try:
        usage = shutil.disk_usage(str(existing_path))
    except OSError as exc:
        report.add_warning("{} disk check failed: {}".format(label, exc))
        return

    free_gib = gib(usage.free)

    if free_gib < warn_below_gib:
        report.add_warning(
            "{} free space is low: {:.1f} GiB free under {}".format(
                label,
                free_gib,
                existing_path,
            )
        )
    else:
        report.add_ok(
            "{} free space: {:.1f} GiB free under {}".format(
                label,
                free_gib,
                existing_path,
            )
        )


def http_url_is_reachable(url, timeout=2.0):
    """Return True when a local HTTP URL responds successfully."""
    try:
        from urllib.request import urlopen

        with urlopen(url, timeout=timeout) as response:
            return 200 <= int(response.getcode()) < 400
    except Exception:
        return False


def check_port_available(report, bind_address, port):
    """Check if a TCP port is available or already serving PXE content."""
    try:
        port_number = int(port)
    except (TypeError, ValueError):
        report.add_failure("Invalid TCP port: {}".format(port))
        return

    sock = socket.socket(socket.AF_INET, socket.SOCK_STREAM)

    try:
        sock.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
        sock.bind((bind_address, port_number))
        report.add_ok("TCP port available: {}:{}".format(bind_address, port_number))
    except socket.error as exc:
        pxe_boot_url = "http://127.0.0.1:{}/boot.ipxe".format(port_number)

        if http_url_is_reachable(pxe_boot_url):
            report.add_ok(
                "TCP port {} is already serving PXE content: {}".format(
                    port_number,
                    pxe_boot_url,
                )
            )
        else:
            report.add_failure(
                "TCP port unavailable: {}:{} ({})".format(
                    bind_address,
                    port_number,
                    exc,
                )
            )
    finally:
        sock.close()


def read_text_file(path):
    """Read a text file while tolerating non-UTF8 bytes."""
    with open(str(path), "r", encoding="utf-8", errors="ignore") as handle:
        return handle.read()


def generated_var_value(content, key):
    """Return a simple top-level generated var value as text."""
    prefix = "{}:".format(key)

    for line in content.splitlines():
        if line.startswith(prefix):
            return line.split(":", 1)[1].strip()

    return None


def check_generated_server_vars(report, bundle_path, config):
    """Check that generated server vars are present and aligned enough for deploy."""
    generated_vars_path = aerolitctl_server_generated_vars_file(bundle_path)

    if not generated_vars_path.exists():
        report.add_failure(
            "Generated server vars missing: {}. Run: aerolitctl configure server".format(
                generated_vars_path
            )
        )
        return

    try:
        content = read_text_file(generated_vars_path)
    except IOError as exc:
        report.add_failure(
            "Could not read generated server vars {}: {}".format(
                generated_vars_path,
                exc,
            )
        )
        return

    if generated_vars_look_current(generated_vars_path, config):
        report.add_ok("Generated server vars look current: {}".format(generated_vars_path))
    else:
        report.add_warning(
            "Generated server vars may be stale or incomplete: {}. "
            "Run: aerolitctl configure server".format(generated_vars_path)
        )

    server = config.get("server", {}) or {}
    pxe = config.get("pxe", {}) or {}

    pxe_enabled = pxe_enabled_from_config(server, pxe)
    controller_enabled = controller_enabled_from_config(server)
    nfs_enabled = nfs_enabled_from_config(server)

    expected_keys = []

    if pxe_enabled:
        expected_keys.extend(
            [
                "pxe_content_manage_firewall",
                "pxe_dnsmasq_manage_firewall",
            ]
        )

    if controller_enabled and nfs_enabled:
        expected_keys.extend(
            [
                "nfs_server_manage_exports",
                "nfs_server_manage_services",
                "nfs_server_manage_firewall",
            ]
        )

    for key in expected_keys:
        value = generated_var_value(content, key)

        if value is None:
            report.add_warning(
                "Generated server vars missing expected role variable: {}".format(key)
            )
        else:
            report.add_ok("Generated server var {}: {}".format(key, value))


def check_ansible_playbook_syntax(report, bundle_path, playbook_path, label):
    """Run ansible-playbook --syntax-check for one local playbook."""
    if not command_exists("ansible-playbook"):
        report.add_warning(
            "Ansible syntax check skipped for {}; ansible-playbook not found".format(
                label
            )
        )
        return

    playbook_path = Path(playbook_path)

    if not playbook_path.exists():
        report.add_failure("{} playbook missing: {}".format(label, playbook_path))
        return

    generated_vars_path = aerolitctl_server_generated_vars_file(bundle_path)

    command = [
        "ansible-playbook",
        "--syntax-check",
        "-i",
        "localhost,",
        "-c",
        "local",
    ]

    if generated_vars_path.exists():
        command.extend(["-e", "@{}".format(generated_vars_path)])

    command.append(playbook_path.name)

    code, output = run_command(command, cwd=ansible_dir(bundle_path))

    if code == 0:
        report.add_ok("{} syntax check passed: {}".format(label, playbook_path))
    else:
        report.add_failure(
            "{} syntax check failed: {}; output: {}".format(
                label,
                playbook_path,
                output,
            )
        )


def check_ansible_playbooks(report, bundle_path, config):
    """Check enabled deploy playbooks can parse with generated vars."""
    server = config.get("server", {}) or {}
    pxe = config.get("pxe", {}) or {}

    if pxe_enabled_from_config(server, pxe):
        check_ansible_playbook_syntax(
            report,
            bundle_path,
            pxe_server_playbook(bundle_path),
            "PXE server",
        )
    else:
        report.add_warning("PXE playbook syntax check skipped; PXE is disabled")

    if controller_enabled_from_config(server):
        check_ansible_playbook_syntax(
            report,
            bundle_path,
            ansible_controller_playbook(bundle_path),
            "Ansible controller",
        )
    else:
        report.add_warning(
            "Ansible controller syntax check skipped; controller/NFS is disabled"
        )


