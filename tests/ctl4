GENERATED_BOOTSTRAP_VARS_CONTENT = """---
# Generated AeroLIT bootstrap variables
# Created by aerolitctl configure init.
# Later configure commands may update this file.

aerolit_generated_by: aerolitctl
aerolit_generated_reason: configure init
"""

SYNC_PRESERVE_CONTENT = """# Paths listed here are preserved during scheduled sync.
# These are rsync exclude patterns, not .gitignore syntax.
# Use exact file paths for files.
# Use trailing / for directories.
# Blank lines and lines beginning with # are ignored.

# Core network-specific files
.gitlab-ci.yml
ansible/ansible.cfg
ansible/inventory
ansible/group_vars/

# Add any additional local-only files or folders below.
# Examples:
# ansible/site_local_playbook.yml
# ansible/network_local/
# docs/local/
"""


def resolve_bundle_path(bundle_path=None, non_interactive=False):
    """Resolve bundle path from arg, prompt, or default."""
    if bundle_path:
        return Path(bundle_path)

    if non_interactive:
        return DEFAULT_BUNDLE_PATH

    prompt = "AeroLIT bundle path [{}]: ".format(DEFAULT_BUNDLE_PATH)
    value = input(prompt).strip()

    if not value:
        return DEFAULT_BUNDLE_PATH

    return Path(value)


def validate_basic_bundle_layout(
    bundle_path,
    report,
    skip_ansible_files=False,
    skip_ci_file=False,
):
    """Validate paths needed for initialization."""
    bundle_path = Path(bundle_path)
    collections_hub = collections_hub_path(bundle_path)
    active_ansible_dir = ansible_dir(bundle_path)

    if not bundle_path.exists():
        report.add("errors", "Bundle path does not exist: {}".format(bundle_path))
        return False

    if not collections_hub.exists():
        report.add(
            "errors",
            "collections-hub path does not exist: {}".format(collections_hub),
        )
        return False

    if not active_ansible_dir.exists():
        report.add(
            "errors",
            "collections-hub Ansible path does not exist: {}".format(
                active_ansible_dir
            ),
        )
        return False

    expected_bundle_paths = [
        bundle_path / "repos",
        bundle_path / "files",
        bundle_path / "extracted_isos",
    ]

    for path in expected_bundle_paths:
        if not path.exists():
            report.add("warnings", "Expected bundle path not found: {}".format(path))

    manifest = bundle_path / "aerolit-bundle.yml"
    if not manifest.exists():
        report.add("warnings", "Bundle manifest not found yet: {}".format(manifest))

    bootstrap = bundle_path / "bootstrap.sh"
    if not bootstrap.exists():
        report.add(
            "warnings",
            "Compatibility bootstrap.sh not found: {}".format(bootstrap),
        )

    if not skip_ansible_files:
        required_ansible_templates = [
            ansible_cfg_template_file(bundle_path),
            ansible_inventory_template_file(bundle_path),
            ansible_group_vars_template_dir(bundle_path),
        ]

        for template in required_ansible_templates:
            if not template.exists():
                report.add(
                    "errors",
                    "Required Ansible template path not found: {}".format(template),
                )

    if not skip_ci_file:
        required_ci_templates = [
            provision_gitlab_template(bundle_path),
            scheduled_gitlab_template(bundle_path),
            system_update_gitlab_template(bundle_path),
            stig_gitlab_template(bundle_path),
        ]

        for template in required_ci_templates:
            if not template.exists():
                report.add(
                    "errors",
                    "Required GitLab CI template path not found: {}".format(template),
                )

    return len(report.errors) == 0


def initialize_collections_hub_ansible(
    bundle_path,
    report,
    backup_root,
    force=False,
    no_backup=False,
    dry_run=False,
):
    """Initialize active collections-hub Ansible files from templates."""
    collections_hub = collections_hub_path(bundle_path)

    copy_path(
        ansible_inventory_template_file(bundle_path),
        ansible_inventory_file(bundle_path),
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
        backup_root=backup_root,
        base_path=collections_hub,
        no_backup=no_backup,
    )

    copy_path(
        ansible_group_vars_template_dir(bundle_path),
        ansible_group_vars_dir(bundle_path),
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
        backup_root=backup_root,
        base_path=collections_hub,
        no_backup=no_backup,
    )

    copy_path(
        ansible_cfg_template_file(bundle_path),
        ansible_cfg_file(bundle_path),
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
        backup_root=backup_root,
        base_path=collections_hub,
        no_backup=no_backup,
    )

    write_text_file(
        generated_bootstrap_vars_file(bundle_path),
        GENERATED_BOOTSTRAP_VARS_CONTENT,
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
        backup_root=backup_root,
        base_path=collections_hub,
        no_backup=no_backup,
    )


def build_gitlab_ci_content(bundle_path):
    """Build root .gitlab-ci.yml content from template fragments."""
    return "".join(
        [
            fragment_without_last_line(provision_gitlab_template(bundle_path)),
            fragment_without_first_and_last_line(scheduled_gitlab_template(bundle_path)),
            fragment_without_first_and_last_line(system_update_gitlab_template(bundle_path)),
            fragment_without_first_line(stig_gitlab_template(bundle_path)),
        ]
    )


def initialize_gitlab_ci(
    bundle_path,
    report,
    backup_root,
    force=False,
    no_backup=False,
    dry_run=False,
):
    """Generate collections-hub .gitlab-ci.yml from template fragments."""
    collections_hub = collections_hub_path(bundle_path)
    content = build_gitlab_ci_content(bundle_path)

    write_text_file(
        gitlab_ci_file(bundle_path),
        content,
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
        backup_root=backup_root,
        base_path=collections_hub,
        no_backup=no_backup,
    )


def initialize_sync_preserve(
    bundle_path,
    report,
    backup_root,
    force=False,
    no_backup=False,
    dry_run=False,
):
    """Create collections-hub .sync-preserve."""
    collections_hub = collections_hub_path(bundle_path)

    write_text_file(
        sync_preserve_file(bundle_path),
        SYNC_PRESERVE_CONTENT,
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
        backup_root=backup_root,
        base_path=collections_hub,
        no_backup=no_backup,
    )


def run_configure_init(
    bundle_path=None,
    force=False,
    dry_run=False,
    non_interactive=False,
    verbose=False,
    no_backup=False,
    skip_preserve_file=False,
    skip_ci_file=False,
    skip_ansible_files=False,
):
    """Run full AeroLIT initialization."""
    report = InitReport(verbose=verbose)
    resolved_bundle_path = resolve_bundle_path(
        bundle_path=bundle_path,
        non_interactive=non_interactive,
    )

    run_timestamp = timestamp()
    collections_hub = collections_hub_path(resolved_bundle_path)
    project_backup_root = initialization_backup_root(resolved_bundle_path) / run_timestamp
    control_backup_root = BACKUP_DIR / run_timestamp

    print("Initializing AeroLIT environment in: {}".format(collections_hub))
    print("Backups enabled: {}".format(not no_backup))
    print("Force overwrite: {}".format(force))
    print("Skip preserve file: {}".format(skip_preserve_file))
    print("Skip CI file: {}".format(skip_ci_file))
    print("Skip Ansible files: {}".format(skip_ansible_files))
    print("")

    for directory in required_control_directories():
        ensure_directory(directory, report, dry_run=dry_run)

    layout_ok = validate_basic_bundle_layout(
        resolved_bundle_path,
        report,
        skip_ansible_files=skip_ansible_files,
        skip_ci_file=skip_ci_file,
    )

    write_text_file(
        CONFIG_FILE,
        config_text(resolved_bundle_path),
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
        backup_root=control_backup_root,
        no_backup=no_backup,
    )

    write_text_file(
        STATE_FILE,
        state_text(),
        report,
        overwrite=force,
        backup=True,
        dry_run=dry_run,
        backup_root=control_backup_root,
        no_backup=no_backup,
    )

    if layout_ok:
        if skip_ansible_files:
            report.add("skipped", "Ansible file initialization")
        else:
            initialize_collections_hub_ansible(
                resolved_bundle_path,
                report,
                backup_root=project_backup_root,
                force=force,
                no_backup=no_backup,
                dry_run=dry_run,
            )

        if skip_ci_file:
            report.add("skipped", ".gitlab-ci.yml generation")
        else:
            initialize_gitlab_ci(
                resolved_bundle_path,
                report,
                backup_root=project_backup_root,
                force=force,
                no_backup=no_backup,
                dry_run=dry_run,
            )

        if skip_preserve_file:
            report.add("skipped", ".sync-preserve creation/update")
        else:
            initialize_sync_preserve(
                resolved_bundle_path,
                report,
                backup_root=project_backup_root,
                force=force,
                no_backup=no_backup,
                dry_run=dry_run,
            )
    else:
        report.add(
            "warnings",
            "Skipping collections-hub initialization because required bundle paths/templates are missing.",
        )

    print("")
    print("AeroLIT initialization complete.")
    print("")
    print("Configured bundle path:")
    print("  {}".format(resolved_bundle_path))
    print("")
    print("Primary config:")
    print("  {}".format(CONFIG_FILE))
    print("")
    print("Runtime state:")
    print("  {}".format(STATE_FILE))
    print("")
    print("Active Ansible directory:")
    print("  {}".format(ansible_dir(resolved_bundle_path)))
    print("")
    print("Preserve manifest:")
    print("  {}".format(sync_preserve_file(resolved_bundle_path)))

    if no_backup:
        print("")
        print("Backup creation was disabled with --no-backup.")
    else:
        print("")
        print("Initialization backups:")
        print("  {}".format(project_backup_root))

    report.print_summary()

    return 1 if report.errors else 0










"""CLI entry point for aerolitctl."""

import argparse
import sys

from . import __version__
from .initialize import run_configure_init


def cmd_version(args):
    """Print aerolitctl version."""
    print("aerolitctl {}".format(__version__))
    return 0


def cmd_configure_init(args):
    """Run full initialization workflow."""
    return run_configure_init(
        bundle_path=args.bundle,
        force=args.force,
        dry_run=args.dry_run,
        non_interactive=args.non_interactive,
        verbose=args.verbose,
        no_backup=args.no_backup,
        skip_preserve_file=args.skip_preserve_file,
        skip_ci_file=args.skip_ci_file,
        skip_ansible_files=args.skip_ansible_files,
    )


def build_parser():
    """Build command-line parser."""
    parser = argparse.ArgumentParser(
        prog="aerolitctl",
        description="Command and control interface for AeroLIT bundles.",
    )

    parser.add_argument(
        "--verbose",
        action="store_true",
        help="Show more detailed output.",
    )

    subparsers = parser.add_subparsers(dest="command")

    version_parser = subparsers.add_parser(
        "version",
        help="Show aerolitctl version.",
    )
    version_parser.set_defaults(func=cmd_version)

    configure_parser = subparsers.add_parser(
        "configure",
        help="Configure AeroLIT.",
    )
    configure_subparsers = configure_parser.add_subparsers(dest="configure_command")

    init_parser = configure_subparsers.add_parser(
        "init",
        help="Initialize AeroLIT configuration, state, preserves, CI, and active Ansible files.",
    )
    init_parser.add_argument(
        "--bundle",
        default=None,
        help="Path to AeroLIT bundle. Defaults to /opt/aerolit/aerolit-bundle.",
    )
    init_parser.add_argument(
        "--force",
        action="store_true",
        help="Overwrite existing managed files from templates after backing them up.",
    )
    init_parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would happen without making changes.",
    )
    init_parser.add_argument(
        "--non-interactive",
        action="store_true",
        help="Do not prompt. Use defaults unless options are provided.",
    )
    init_parser.add_argument(
        "--no-backup",
        action="store_true",
        help="Do not create initialization backups before replacing files.",
    )
    init_parser.add_argument(
        "--skip-preserve-file",
        action="store_true",
        help="Do not create or update collections-hub/.sync-preserve.",
    )
    init_parser.add_argument(
        "--skip-ci-file",
        action="store_true",
        help="Do not generate collections-hub/.gitlab-ci.yml.",
    )
    init_parser.add_argument(
        "--skip-ansible-files",
        action="store_true",
        help="Do not create or replace ansible/inventory, ansible/group_vars, or ansible/ansible.cfg.",
    )
    init_parser.set_defaults(func=cmd_configure_init)

    return parser


def main(argv=None):
    """Main entry point."""
    parser = build_parser()
    args = parser.parse_args(argv)

    if not hasattr(args, "func"):
        parser.print_help()
        return 2

    try:
        return args.func(args)
    except KeyboardInterrupt:
        print("")
        print("Cancelled.", file=sys.stderr)
        return 130
    except Exception as exc:
        print("ERROR: {}".format(exc), file=sys.stderr)
        return 1


if __name__ == "__main__":
    sys.exit(main())