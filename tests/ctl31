def yes_no_prompt(prompt, default=False):
    """Ask a yes/no question."""
    default_text = "Y" if default else "N"
    choices = "Y/n" if default else "y/N"

    while True:
        value = input(
            "{} [{}; Enter={}]: ".format(prompt, choices, default_text)
        ).strip().lower()

        if not value:
            return default

        if value in ("y", "yes"):
            return True

        if value in ("n", "no"):
            return False

        print("Please answer yes or no. Valid responses are: y, yes, n, no.")


def text_prompt(prompt, default=None, allow_empty=False, blank_label="blank"):
    """Ask for text input with readable default behavior."""
    if default is not None and str(default) != "":
        rendered = "{} [default: {}; Enter=default]: ".format(prompt, default)
    elif allow_empty:
        rendered = "{} [Enter={}]: ".format(prompt, blank_label)
    else:
        rendered = "{}: ".format(prompt)

    while True:
        value = input(rendered).strip()

        if value:
            return value

        if default is not None:
            return default

        if allow_empty:
            return ""

        print("This value is required. Enter a value or press Ctrl+C to cancel.")


def prompt_int(text, default, minimum=1, maximum=None):
    """Prompt for an integer."""
    while True:
        value = text_prompt(text, default=str(default))

        try:
            parsed = int(value)
        except ValueError:
            print("Invalid value: {}. Enter a whole number.".format(value))
            continue

        if parsed < minimum:
            print(
                "Invalid value: {}. Enter a number greater than or equal to {}.".format(
                    value,
                    minimum,
                )
            )
            continue

        if maximum is not None and parsed > maximum:
            print(
                "Invalid value: {}. Enter a number between {} and {}.".format(
                    value,
                    minimum,
                    maximum,
                )
            )
            continue

        return parsed


def choose_option(text, options, default_index=0):
    """Choose one option from a numbered list."""
    if not options:
        raise ValueError("choose_option requires at least one option")

    default_index = max(0, min(default_index, len(options) - 1))

    print("")
    print(text)

    for idx, option in enumerate(options, start=1):
        marker = "*" if idx - 1 == default_index else " "
        print("{} {}) {}".format(marker, idx, option))

    while True:
        value = input(
            "Choose 1-{} [default: {}; Enter=default]: ".format(
                len(options),
                default_index + 1,
            )
        ).strip()

        if value == "":
            return default_index

        if value.isdigit():
            parsed = int(value)
            if 1 <= parsed <= len(options):
                return parsed - 1

        print(
            "Invalid selection: {}. Choose a number from 1 through {}.".format(
                value,
                len(options),
            )
        )


def prompt_network_value(text, default=None, warn_non_private=True, warn_small=True):
    """Prompt for an IPv4 CIDR network with safety warnings."""
    while True:
        value = text_prompt(text, default=default)

        try:
            network = parse_ipv4_network(value, "Provisioning network")
        except ValueError as exc:
            print(str(exc))
            continue

        if warn_non_private and not network_is_rfc1918(network):
            print("")
            print("WARNING: {} is not RFC1918 private address space.".format(network))
            print("For an isolated lab/provisioning subnet, use 10.0.0.0/8,")
            print("172.16.0.0/12, or 192.168.0.0/16 space.")

            if not yes_no_prompt("Use this non-private network anyway?", default=False):
                continue

        usable_hosts = network_usable_host_count(network)
        if warn_small and usable_hosts < MIN_RECOMMENDED_USABLE_HOSTS:
            print("")
            print(
                "WARNING: {} only has {} usable host addresses.".format(
                    network,
                    usable_hosts,
                )
            )
            print("PXE/DHCP lab networks usually need enough room for the server,")
            print("gateway, and provisioned client addresses.")

            if not yes_no_prompt("Use this small network anyway?", default=False):
                continue

        return network


def choose_mode(current=None):
    """Prompt for configuration mode."""
    print_section("Bootstrap mode")
    print("")
    print("First choose what this server configuration should set up.")
    print("The full setup is the normal all-in-one lab path: PXE server plus")
    print("Ansible controller/NFS.")

    options = [
        "Full setup: PXE server + Ansible controller/NFS",
        "PXE server only",
        "Ansible controller/NFS only",
    ]

    current_mode = normalize_mode(current or DEFAULT_MODE)
    default_index = {"full": 0, "pxe": 1, "controller": 2}.get(current_mode, 0)

    choice = choose_option(
        "What do you want this server configuration to set up?",
