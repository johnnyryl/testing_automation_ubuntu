def choose_nfs_settings(config, bundle_path, server_ip, network):
    """Prompt for NFS settings."""
    print_section("NFS options")

    server = config.get("server", {})
    current_nfs = server.get("nfs", {})

    print("")
    print("NFS is used so provisioned machines can mount/use the AeroLIT bundle")
    print("content.")
    print("")
    print("For the normal all-in-one setup, the same host provides PXE, NFS, and")
    print("the Ansible/controller content.")
    print("The server IP selected for this host is: {}".format(server_ip))

    nfs_enabled = yes_no_prompt(
        "Enable NFS/controller settings?",
        default=current_nfs.get("enabled", True),
    )

    if not nfs_enabled:
        return {
            "enabled": False,
            "server_ip": server_ip,
            "export_path": str(bundle_path),
            "allowed_clients": None,
            "allow_all_clients": False,
            "create_export_path": False,
            "exports_file": current_nfs.get("exports_file") or DEFAULT_NFS_EXPORTS_FILE,
            "target_mount_path": DEFAULT_TARGET_MOUNT_PATH,
            "mount_mode": DEFAULT_MOUNT_MODE,
            "mount_owner": DEFAULT_MOUNT_OWNER,
            "mount_group": DEFAULT_MOUNT_GROUP,
        }

    export_path = text_prompt(
        "NFS export path",
        default=current_nfs.get("export_path") or str(bundle_path),
    )
    export_path = validate_absolute_path(export_path, "NFS export path")

    export_path_obj = Path(export_path)

    if export_path_obj == Path("/"):
        print("")
        print("WARNING: exporting / over NFS is unsafe and should not be used.")
    else:
        for dangerous in DANGEROUS_EXPORT_PATHS:
            dangerous_path = Path(dangerous)

            if dangerous_path == Path("/"):
                continue

            if export_path_obj == dangerous_path or dangerous_path in export_path_obj.parents:
                print("")
                print(
                    "WARNING: {} is under sensitive system path {}.".format(
                        export_path,
                        dangerous,
                    )
                )
                print(
                    "A dedicated bundle path like /opt/aerolit/aerolit-bundle is safer."
                )
                break

    if export_path_obj.exists():
        print("")
        print("The NFS export path already exists.")
        print("A later deploy step does not need to create it.")
        create_export_default = current_nfs.get("create_export_path", False)
    else:
        print("")
        print("NOTE: {} does not currently exist.".format(export_path))
        print("")
        print("If this path is supposed to be your AeroLIT bundle, choose 'no'")
        print("and fix the bundle path instead.")
        print("")
        print("Choose 'yes' only if this is an intentional new export directory")
        print("that a later deploy step should create.")
        create_export_default = current_nfs.get("create_export_path", False)

    create_export_path = yes_no_prompt(
        "Allow a later deploy step to create this NFS export path if missing?",
        default=create_export_default,
    )

    exports_file = text_prompt(
        "NFS exports file for later deploy",
        default=current_nfs.get("exports_file") or DEFAULT_NFS_EXPORTS_FILE,
    )
    exports_file = validate_absolute_path(exports_file, "NFS exports file")

    print("")
    print("Now choose which clients are allowed to mount the NFS export.")
    print("For a normal isolated provisioning network, allowing this subnet is")
    print("usually correct: {}".format(network))

    nfs_options = [
        "Only clients on this provisioning subnet: {}".format(network),
        "Custom CIDR or single client IP",
        "Allow all clients, easy lab test but least restrictive",
    ]

    default_choice = 0
    if current_nfs.get("allow_all_clients", False):
        default_choice = 2
    elif (
        current_nfs.get("allowed_clients")
        and current_nfs.get("allowed_clients") != str(network)
    ):
        print("")
        print(
            "NOTE: the previously configured NFS allowed clients value {} does "
            "not match the selected provisioning network {}.".format(
                current_nfs.get("allowed_clients"),
                network,
            )
        )
        print("Defaulting to the selected provisioning subnet.")

    choice = choose_option(
        "Who should be allowed to mount the NFS export?",
        nfs_options,
        default_choice,
    )

    if choice == 0:
        allowed_clients = str(network)
        allow_all_clients = False
    elif choice == 1:
        while True:
            value = text_prompt(
                "NFS allowed clients CIDR or single IP",
                default=current_nfs.get("allowed_clients") or str(network),
            )

            try:
                allowed_clients = parse_clients(value, allow_all_clients=False)
                allow_all_clients = False
                break
            except ValueError as exc:
                print(str(exc))
    else:
        print("")
        print("WARNING: allow-all NFS clients is convenient for a quick lab,")
        print("but it is too broad for long-term use.")

        if yes_no_prompt("Use allow-all clients anyway?", default=False):
            allowed_clients = "*"
            allow_all_clients = True
        else:
            allowed_clients = str(network)
            allow_all_clients = False

    print("")
    print("The target/client mount path is the path provisioned machines will use")
    print("after mounting the AeroLIT NFS export.")
    print("This value is also written as path_for_ansible.")

    target_mount_path = text_prompt(
        "Target/client mount path for Ansible",
        default=current_nfs.get("target_mount_path") or DEFAULT_TARGET_MOUNT_PATH,
    )
    target_mount_path = validate_absolute_path(
        target_mount_path,
        "Target/client mount path",
    )

    mount_mode = text_prompt(
        "Target/client mount directory mode",
        default=current_nfs.get("mount_mode") or DEFAULT_MOUNT_MODE,
    )

    mount_owner = text_prompt(
        "Target/client mount owner",
        default=current_nfs.get("mount_owner") or DEFAULT_MOUNT_OWNER,
    )

    mount_group = text_prompt(
        "Target/client mount group",
        default=current_nfs.get("mount_group") or DEFAULT_MOUNT_GROUP,
    )

    return {
        "enabled": True,
        "server_ip": server_ip,
        "export_path": export_path,
        "allowed_clients": allowed_clients,
        "allow_all_clients": allow_all_clients,
        "create_export_path": create_export_path,
        "exports_file": exports_file,
        "target_mount_path": target_mount_path,
        "mount_mode": mount_mode,
        "mount_owner": mount_owner,
        "mount_group": mount_group,
    }


