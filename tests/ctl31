def choose_dhcp_range(
    current_start=None,
    current_end=None,
    network=None,
    server_ip=None,
    gateway=None,
):
    """Prompt for DHCP range."""
    print_section("DHCP client range")

    max_clients = max_dhcp_clients(network, server_ip=server_ip, gateway=gateway)

    if max_clients < 1:
        raise ValueError("Network {} is too small for a DHCP range.".format(network))

    default_client_count = min(50, max_clients)

    print("")
    print("The DHCP range is the pool of IPs PXE/provisioned clients will receive.")
    print("The number you enter here becomes the actual DHCP pool size.")
    print("")
    print("Example: entering 75 means the helper suggests 75 DHCP client addresses.")
    print(
        "Maximum available client addresses in this subnet after reservations: {}".format(
            max_clients
        )
    )

    client_count = prompt_int(
        "How many machines should the DHCP range support?",
        default_client_count,
        minimum=1,
        maximum=max_clients,
    )

    suggested_start, suggested_end = suggested_dhcp_range(
        network,
        server_ip=server_ip,
        gateway=gateway,
        requested_clients=client_count,
    )

    default_start = suggested_start
    default_end = suggested_end

    if current_start and current_end:
        try:
            validate_dhcp_range(
                current_start,
                current_end,
                network,
                server_ip=server_ip,
                gateway=gateway,
            )
            default_start = current_start
            default_end = current_end
        except ValueError:
            print("")
            print(
                "NOTE: the previously configured DHCP range {} - {} does not fit "
                "the selected provisioning network {}.".format(
                    current_start,
                    current_end,
                    network,
                )
            )
            print("Using a new suggested DHCP range for this network instead.")

    print("")
    print(
        "Suggested DHCP pool for {} client address(es): {} - {}".format(
            client_count,
            default_start,
            default_end,
        )
    )
    print("Press Enter to accept each suggested value, or type a different IP")
    print("inside {}.".format(network))

    while True:
        start = text_prompt("DHCP range start", default=default_start)
        end = text_prompt("DHCP range end", default=default_end)

        try:
            return validate_dhcp_range(
                start,
                end,
                network,
                server_ip=server_ip,
                gateway=gateway,
            )
        except ValueError as exc:
            print(str(exc))
            print("Re-enter the DHCP range.")


