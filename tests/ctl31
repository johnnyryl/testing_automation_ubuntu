def choose_interface(current=None):
    """Prompt for interface."""
    print_section("Provisioning interface")

    interfaces = discover_interfaces()
    default_iface = current or default_route_interface()

    print("")
    print("Now choose the network interface that provisioning clients will use")
    print("to reach this host.")
    print("")
    print("For physical PXE, this is usually a real Ethernet interface connected")
    print("to the lab/provisioning network.")
    print("Avoid docker, podman, virbr, veth, and container bridge interfaces.")

    if not interfaces:
        print("")
        print("No non-loopback interfaces were detected from /sys/class/net.")
        return text_prompt("Provisioning interface", default=default_iface)

    while True:
        labels = []
        default_index = 0

        for idx, iface in enumerate(interfaces):
            name = iface.get("name")
            state = iface.get("state", "unknown")
            addresses = iface.get("addresses") or []
            address_text = ", ".join(addresses) if addresses else "no IPv4 address detected"
            extra = ""

            if iface.get("virtual"):
                extra = "  (virtual/container; usually not for PXE)"

            labels.append("{}  state={}  {}{}".format(name, state, address_text, extra))

            if name == default_iface:
                default_index = idx

        selected_index = choose_option(
            "Select the interface that PXE/NFS/provisioning clients will connect to:",
            labels,
            default_index,
        )

        selected = interfaces[selected_index]
        selected_name = selected.get("name")

        if selected.get("virtual"):
            print("")
            print(
                "WARNING: {} looks like a virtual/container interface.".format(
                    selected_name
                )
            )
            print("That is usually not the right interface for physical PXE clients.")

            if not yes_no_prompt("Use this interface anyway?", default=False):
                continue

        state = str(selected.get("state", "")).upper()
        if state not in ("UP", "UNKNOWN"):
            print("")
            print(
                "WARNING: interface {} is currently state={}.".format(
                    selected_name,
                    state,
                )
            )
            print("PXE/NFS will not work while the interface is unavailable.")

            if not yes_no_prompt("Use this interface anyway?", default=False):
                continue

        return selected_name


