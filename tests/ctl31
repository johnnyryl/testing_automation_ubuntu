def build_firewall_intent(plan, manage=True):
    """Build firewall intent for later deploy without applying it."""
    services = []
    ports = []

    if plan.get("controller_enabled") and plan.get("nfs", {}).get("enabled", False):
        services.extend(["nfs", "mountd", "rpc-bind"])

    if plan.get("pxe_enabled"):
        ports.append("{}/tcp".format(plan.get("pxe_http_port", DEFAULT_HTTP_PORT)))

    return {
        "manage": bool(manage),
        "services": services,
        "ports": ports,
    }


