    print("For a simple isolated lab, choosing a dedicated lab subnet is usually")
    print("safer than using a shared network.")

    if current_network:
        print("")
        print("Currently configured network: {}".format(current_network))

    if detected_network:
        print("Detected current interface subnet: {}".format(detected_network))

    options = [
        "Plan an isolated lab/provisioning subnet",
        "Use this interface's current IPv4 subnet",
        "Custom subnet",
    ]

    default_index = 0

    while True:
        selected = choose_option(
            "What kind of network should clients use?",
            options,
            default_index,
        )

        if selected == 0:
            lab_options = [
                "{}  {}".format(cidr, description)
                for cidr, description in PRIVATE_LAB_NETWORKS
            ]
            lab_options.append("Custom private subnet")

            lab_choice = choose_option(
                "Pick a private lab/provisioning subnet. Avoid choosing a subnet already used elsewhere on your network.",
                lab_options,
                0,
            )

            if lab_choice < len(PRIVATE_LAB_NETWORKS):
                return parse_ipv4_network(
                    PRIVATE_LAB_NETWORKS[lab_choice][0],
                    "Provisioning network",
                )

            return prompt_network_value(
                "Custom private network CIDR",
                default=DEFAULT_LAB_NETWORK,
                warn_non_private=True,
                warn_small=True,
            )

        if selected == 1:
            if not detected_network:
                print("")
                print("No IPv4 network was detected for interface {}.".format(interface))
                print(
                    "Choose an isolated lab/provisioning subnet or enter a custom subnet instead."
                )
                continue

            if prefer_isolated:
                print("")
                print("WARNING: using PXE/DHCP on an existing shared subnet can accidentally")
                print("hand out addresses to machines that are not part of your lab.")
                print("Only do this on a lab VLAN, isolated switch, direct-cable connection,")
                print("or approved provisioning network.")

                if not yes_no_prompt(
                    "Continue with this existing subnet?",
                    default=False,
                ):
                    continue

            return detected_network

        return prompt_network_value(
            "Custom network CIDR",
            default=DEFAULT_LAB_NETWORK,
            warn_non_private=True,
            warn_small=True,
        )


def choose_server_ip(current=None, network=None):
    """Prompt for server IP."""
    print_section("Server IP")

    default = None

    if current and network is not None:
        try:
            current_ip = parse_ipv4_address(current, "Current AeroLIT server IP")
            if current_ip in network:
                default = str(current_ip)
            else:
                print("")
                print(
                    "NOTE: the previously configured server IP {} is not inside "
                    "the selected provisioning network {}.".format(current, network)
                )
                print("It will not be used as the default for this network.")
        except ValueError:
            print("")
            print(
                "NOTE: the previously configured server IP {} is not valid and "
                "will not be used as the default.".format(current)
            )

    if not default and network is not None:
        usable_hosts = network_usable_host_count(network)
        if usable_hosts < 1:
            raise ValueError("Provisioning network has no usable host addresses")

        host_number = min(10, usable_hosts)
        default = str(ipaddress.IPv4Address(int(network.network_address) + host_number))

    print("")
    print("Choose the IP address this AeroLIT server will use on the")
    print("client/provisioning network.")
    print("")
    print("Press Enter to accept the default shown in brackets, or type another")
    print("IP inside {}.".format(network))

    while True:
        value = text_prompt("Server IP for this host", default=default)
        ip = parse_ipv4_address(value, "AeroLIT server IP")

        if network is not None and ip not in network:
            print("Invalid IP: {} is not inside {}.".format(ip, network))
            continue

        return str(ip)


