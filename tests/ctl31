def write_text_if_changed(
    path,
    content,
    report,
    backup_root=None,
    base_path=None,
    dry_run=False,
):
    """Write file only if content changed."""
    path = Path(path)
    old_content = None

    if path.exists():
        try:
            old_content = path.read_text()
        except IOError:
            old_content = None

    if old_content == content:
        report.add("existing", "{} unchanged".format(path))
        return False

    if dry_run:
        action = "Would update" if path.exists() else "Would create"
        report.add("dry_run", "{} {}".format(action, path))
        return True

    if path.exists():
        backup_existing(
            path,
            report,
            dry_run=False,
            backup_root=backup_root,
            base_path=base_path,
            no_backup=False,
        )

    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)

    if old_content is None:
        report.add("created", str(path))
    else:
        report.add("updated", str(path))

    return True


def save_config_if_changed(config, report, dry_run=False):
    """Save /etc/aerolit/aerolitctl.yml only when content changes."""
    path = Path(CONFIG_FILE)
    new_content = dump_yaml(config)

    old_content = None
    if path.exists():
        try:
            old_content = path.read_text()
        except IOError:
            old_content = None

    if old_content == new_content:
        report.add("existing", "{} unchanged".format(path))
        return None

    if dry_run:
        action = "Would update" if path.exists() else "Would create"
        report.add("dry_run", "{} {}".format(action, path))
        return None

    backup_path = save_config(config, backup=True)

    if backup_path:
        report.add("backed_up", "{} -> {}".format(path, backup_path))
        report.add("updated", str(path))
    else:
        report.add("created", str(path))

    return backup_path


def _network_from_server_ip_and_prefix(server_ip, prefix):
    """Return network from server IP/prefix, or None if inputs are incomplete."""
    if not server_ip or not prefix:
        return None

    try:
        return parse_ipv4_network(
            "{}/{}".format(server_ip, prefix),
            "Provisioning network",
        )
    except ValueError:
        return None


def _stored_ip_inside_network(stored_ip, network):
    """Return stored IP string only when it is valid and inside network."""
    if not stored_ip or network is None:
        return None

    try:
        stored_ip_obj = parse_ipv4_address(stored_ip, "Configured AeroLIT server IP")
    except ValueError:
        return None

    if stored_ip_obj in network:
        return str(stored_ip_obj)

    return None


def build_plan_from_values(
    config,
    bundle_path,
    mode=None,
    interface=None,
    server_ip=None,
    network=None,
    prefix=None,
    gateway=None,
    dns_servers=None,
    dhcp_start=None,
    dhcp_end=None,
    pxe_http_port=None,
    pxe_http_bind_address=None,
    configure_interface=None,
    nfs_enabled=None,
    nfs_export_path=None,
    nfs_allowed_clients=None,
    nfs_allow_all_clients=None,
    nfs_create_export_path=None,
    nfs_exports_file=None,
    target_mount_path=None,
    mount_mode=None,
    mount_owner=None,
    mount_group=None,
    firewall_manage=None,
):
    """Build and validate a non-interactive server plan."""
    server = current_server_config(config)
    current_nfs = server.get("nfs", {})
    current_firewall = server.get("firewall", {})

    if configure_interface is None:
        configure_interface = server.get("configure_interface", False)

    if nfs_enabled is None:
        nfs_enabled = current_nfs.get("enabled", True)

    if nfs_allow_all_clients is None:
        nfs_allow_all_clients = current_nfs.get("allow_all_clients", False)

    if nfs_create_export_path is None:
        nfs_create_export_path = current_nfs.get("create_export_path", False)

    if firewall_manage is None:
        firewall_manage = current_firewall.get("manage", True)

    mode = normalize_mode(mode or server.get("mode") or DEFAULT_MODE)

    pxe_enabled = mode in ("full", "pxe")
    controller_enabled = mode in ("full", "controller")

    interface = interface or server.get("interface") or default_route_interface()

    if not interface:
        raise ValueError("Interface is required")

    stored_network = server.get("network") or config.get("pxe", {}).get("network")
    stored_server_ip = server.get("ip_address")
    stored_prefix = server.get("prefix")
    effective_prefix = prefix or stored_prefix

    network_supplied = network is not None

    if network:
        network_obj = parse_ipv4_network(network, "Provisioning network")
    elif stored_network:
        network_obj = parse_ipv4_network(stored_network, "Provisioning network")
    elif server_ip and effective_prefix:
        network_obj = parse_ipv4_network(
            "{}/{}".format(server_ip, effective_prefix),
            "Provisioning network",
        )
    else:
        stored_ip_network = _network_from_server_ip_and_prefix(
            stored_server_ip,
            effective_prefix,
        )
        if stored_ip_network is not None:
            network_obj = stored_ip_network
        else:
            detected_network = interface_ipv4_network(interface)
            if detected_network is not None:
                network_obj = detected_network
            else:
                network_obj = parse_ipv4_network(
                    DEFAULT_LAB_NETWORK,
                    "Provisioning network",
                )

    explicit_server_ip = server_ip is not None

    if not server_ip:
        server_ip = _stored_ip_inside_network(stored_server_ip, network_obj)

    if not server_ip:
        usable_hosts = network_usable_host_count(network_obj)
        if usable_hosts < 1:
            raise ValueError("Provisioning network has no usable host addresses")

        server_ip_int = int(network_obj.network_address) + min(10, usable_hosts)
        server_ip = str(ipaddress.IPv4Address(server_ip_int))

    server_ip_obj = parse_ipv4_address(server_ip, "AeroLIT server IP")

    if server_ip_obj not in network_obj:
        if explicit_server_ip:
            raise ValueError("AeroLIT server IP must be inside {}".format(network_obj))
        raise ValueError(
            "Configured AeroLIT server IP {} is not inside {}".format(
                server_ip_obj,
                network_obj,
            )
        )

    prefix = prefix or network_obj.prefixlen
    prefix = parse_prefix(prefix)

    gateway = gateway_value(
        gateway if gateway is not None else server.get("gateway"),
        network=network_obj,
        server_ip=server_ip_obj,
    )

    dns_servers = parse_dns_servers(
        dns_servers if dns_servers is not None else server.get("dns", [])
    )

    if pxe_enabled:
        explicit_dhcp = dhcp_start is not None or dhcp_end is not None

        candidate_dhcp_start = dhcp_start
        candidate_dhcp_end = dhcp_end

        if not explicit_dhcp:
            candidate_dhcp_start = config.get("pxe", {}).get("dhcp_start")
            candidate_dhcp_end = config.get("pxe", {}).get("dhcp_end")

        try:
            dhcp_start, dhcp_end = validate_dhcp_range(
                candidate_dhcp_start,
                candidate_dhcp_end,
                network_obj,
                server_ip=server_ip_obj,
                gateway=gateway,
            )
        except ValueError:
            if explicit_dhcp:
                raise
            dhcp_start = None
            dhcp_end = None

        if not dhcp_start or not dhcp_end:
            dhcp_start, dhcp_end = suggested_dhcp_range(
                network_obj,
                server_ip=server_ip_obj,
                gateway=gateway,
            )
    else:
        dhcp_start = None
        dhcp_end = None

    nfs = {
        "enabled": bool(controller_enabled and nfs_enabled),
        "server_ip": str(server_ip_obj),
        "export_path": validate_absolute_path(
            nfs_export_path or current_nfs.get("export_path") or str(bundle_path),
            "NFS export path",
        ),
        "allowed_clients": None,
        "allow_all_clients": bool(nfs_allow_all_clients),
        "create_export_path": bool(nfs_create_export_path),
        "exports_file": validate_absolute_path(
            nfs_exports_file
            or current_nfs.get("exports_file")
            or DEFAULT_NFS_EXPORTS_FILE,
            "NFS exports file",
        ),
        "target_mount_path": validate_absolute_path(
            target_mount_path
            or current_nfs.get("target_mount_path")
            or DEFAULT_TARGET_MOUNT_PATH,
            "Target/client mount path",
        ),
        "mount_mode": mount_mode or current_nfs.get("mount_mode") or DEFAULT_MOUNT_MODE,
        "mount_owner": mount_owner or current_nfs.get("mount_owner") or DEFAULT_MOUNT_OWNER,
        "mount_group": mount_group or current_nfs.get("mount_group") or DEFAULT_MOUNT_GROUP,
    }

    if nfs["enabled"]:
        if nfs_allowed_clients:
            default_clients = nfs_allowed_clients
        elif network_supplied:
            default_clients = str(network_obj)
        else:
            default_clients = current_nfs.get("allowed_clients") or str(network_obj)

        nfs["allowed_clients"] = parse_clients(
            default_clients,
            allow_all_clients=nfs["allow_all_clients"],
        )

    pxe_http = server.get("pxe_http", {})
    pxe_http_port = int(pxe_http_port or pxe_http.get("port") or DEFAULT_HTTP_PORT)

    if pxe_http_port < 1 or pxe_http_port > 65535:
        raise ValueError("PXE HTTP port must be between 1 and 65535")

    pxe_http_bind_address = (
        pxe_http_bind_address
        or pxe_http.get("bind_address")
        or DEFAULT_BIND_ADDRESS
    )

    if pxe_http_bind_address != "0.0.0.0":
        parse_ipv4_address(pxe_http_bind_address, "PXE HTTP bind address")

    plan = {
        "mode": mode,
        "pxe_enabled": pxe_enabled,
        "controller_enabled": controller_enabled,
        "interface": interface,
        "network": str(network_obj),
        "server_ip": str(server_ip_obj),
        "prefix": prefix,
        "gateway": gateway,
        "dns_servers": dns_servers,
        "dhcp_start": dhcp_start,
        "dhcp_end": dhcp_end,
        "dhcp_netmask": str(network_obj.netmask),
        "pxe_http_port": pxe_http_port,
        "pxe_http_bind_address": pxe_http_bind_address,
        "configure_interface": bool(configure_interface),
        "nfs": nfs,
    }

    plan["firewall"] = build_firewall_intent(plan, manage=firewall_manage)

    return plan


def build_guided_plan(config, bundle_path):
    """Build server plan interactively."""
    reset_section_counter()
    print_intro()

    server = current_server_config(config)

    mode = choose_mode(current=server.get("mode"))
    pxe_enabled = mode in ("full", "pxe")
    controller_enabled = mode in ("full", "controller")

    interface = choose_interface(current=server.get("interface"))

    network = choose_network(
        current_network=server.get("network"),
        interface=interface,
        prefer_isolated=pxe_enabled,
    )

    server_ip = choose_server_ip(
        current=server.get("ip_address"),
        network=network,
    )
    server_ip_obj = parse_ipv4_address(server_ip, "AeroLIT server IP")

    if pxe_enabled:
        pxe_http = server.get("pxe_http", {})
        pxe_http_port, pxe_http_bind_address = choose_pxe_http_settings(
            current_port=pxe_http.get("port", DEFAULT_HTTP_PORT),
            current_bind_address=pxe_http.get("bind_address", DEFAULT_BIND_ADDRESS),
        )

        gateway = choose_gateway(
            current=server.get("gateway"),
            network=network,
            server_ip=server_ip_obj,
        )

        dhcp_start, dhcp_end = choose_dhcp_range(
            current_start=config.get("pxe", {}).get("dhcp_start"),
            current_end=config.get("pxe", {}).get("dhcp_end"),
            network=network,
            server_ip=server_ip_obj,
            gateway=gateway,
        )

        dns_servers = choose_dns(current=server.get("dns", []))
    else:
        pxe_http_port = DEFAULT_HTTP_PORT
        pxe_http_bind_address = DEFAULT_BIND_ADDRESS
        gateway = server.get("gateway")
        dns_servers = list(server.get("dns", []))
        dhcp_start = None
        dhcp_end = None

    if controller_enabled:
        nfs = choose_nfs_settings(config, bundle_path, server_ip, network)
    else:
        nfs = {
            "enabled": False,
            "server_ip": server_ip,
            "export_path": str(bundle_path),
            "allowed_clients": None,
            "allow_all_clients": False,
            "create_export_path": False,
            "exports_file": DEFAULT_NFS_EXPORTS_FILE,
            "target_mount_path": DEFAULT_TARGET_MOUNT_PATH,
            "mount_mode": DEFAULT_MOUNT_MODE,
            "mount_owner": DEFAULT_MOUNT_OWNER,
            "mount_group": DEFAULT_MOUNT_GROUP,
        }

    configure_interface = choose_interface_setup(
        interface,
        server_ip_obj,
        network,
        current=server.get("configure_interface"),
    )

    firewall_manage = choose_firewall_settings(config)

    plan = {
        "mode": mode,
        "pxe_enabled": pxe_enabled,
        "controller_enabled": controller_enabled,
        "interface": interface,
        "network": str(network),
        "server_ip": server_ip,
        "prefix": network.prefixlen,
        "gateway": gateway,
        "dns_servers": dns_servers,
        "dhcp_start": dhcp_start,
        "dhcp_end": dhcp_end,
        "dhcp_netmask": str(network.netmask),
        "pxe_http_port": pxe_http_port,
        "pxe_http_bind_address": pxe_http_bind_address,
        "configure_interface": configure_interface,
        "nfs": nfs,
    }

    plan["firewall"] = build_firewall_intent(plan, manage=firewall_manage)

    return plan


def print_plan_value(label, value):
    """Print an aligned plan value."""
    if value is None or value == "":
        value = "none"

    print("  {:<31}: {}".format(label, value))


def print_plan(plan, bundle_path):
    """Print server plan."""
    print_section("Suggested server plan", numbered=False)

    print("")
    print_plan_value("Mode", plan.get("mode"))
    print_plan_value("Bundle path", bundle_path)

    print("")
    print("Network:")
    print_plan_value("Interface", plan.get("interface"))
    print_plan_value("Network", plan.get("network"))
    print_plan_value("Netmask", plan.get("dhcp_netmask"))
    print_plan_value("Server IP", plan.get("server_ip"))
    print_plan_value("Prefix", plan.get("prefix"))
    print_plan_value("Gateway", plan.get("gateway") or "none")
    print_plan_value("DNS servers", ", ".join(plan.get("dns_servers") or []) or "none")
    print_plan_value("Deploy configures interface", plan.get("configure_interface"))

    print("")
    print("PXE:")
    print_plan_value("Enabled", plan.get("pxe_enabled"))
    print_plan_value("HTTP bind address", plan.get("pxe_http_bind_address"))
    print_plan_value("HTTP port", plan.get("pxe_http_port"))
    print_plan_value("DHCP start", plan.get("dhcp_start"))
    print_plan_value("DHCP end", plan.get("dhcp_end"))

    nfs = plan.get("nfs", {})

    print("")
    print("NFS/controller:")
    print_plan_value("Enabled", nfs.get("enabled"))
    print_plan_value("Server IP", nfs.get("server_ip"))
    print_plan_value("Export path", nfs.get("export_path"))
    print_plan_value("Exports file", nfs.get("exports_file"))
    print_plan_value("Allowed clients", nfs.get("allowed_clients"))
    print_plan_value("Allow all clients", nfs.get("allow_all_clients"))
    print_plan_value("Deploy may create export", nfs.get("create_export_path"))
    print_plan_value("Target/client mount path", nfs.get("target_mount_path"))

    firewall = plan.get("firewall", {})

    print("")
    print("Firewall intent for later deploy:")
    print_plan_value("Manage firewall", firewall.get("manage"))
    print_plan_value("Services", ", ".join(firewall.get("services") or []) or "none")
    print_plan_value("Ports", ", ".join(firewall.get("ports") or []) or "none")
    print("")


def run_configure_server(
    guided=False,
    dry_run=False,
    show=False,
    mode=None,
    interface=None,
    server_ip=None,
    network=None,
    prefix=None,
    gateway=None,
    dns_servers=None,
    dhcp_start=None,
    dhcp_end=None,
    pxe_http_port=None,
    pxe_http_bind_address=None,
    configure_interface=None,
    nfs_enabled=None,
    nfs_export_path=None,
    nfs_allowed_clients=None,
    nfs_allow_all_clients=None,
    nfs_create_export_path=None,
    nfs_exports_file=None,
    target_mount_path=None,
    mount_mode=None,
    mount_owner=None,
    mount_group=None,
    firewall_manage=None,
    verbose=False,
):
    """Configure AeroLIT server values and generated Ansible vars."""
    report = ServerConfigReport(verbose=verbose)

    config = load_config()
    bundle_path_value = get_bundle_path(config)

    if not bundle_path_value:
        raise RuntimeError(
            "No bundle path is configured. Run: aerolitctl configure init"
        )

    bundle_path = Path(bundle_path_value)
    generated_vars_path = aerolitctl_server_generated_vars_file(bundle_path)
    backup_root = initialization_backup_root(bundle_path) / timestamp()
    collections_hub = collections_hub_path(bundle_path)

    if guided:
        plan = build_guided_plan(config, bundle_path)
    else:
        plan = build_plan_from_values(
            config,
            bundle_path,
            mode=mode,
            interface=interface,
            server_ip=server_ip,
            network=network,
            prefix=prefix,
            gateway=gateway,
            dns_servers=dns_servers,
            dhcp_start=dhcp_start,
            dhcp_end=dhcp_end,
            pxe_http_port=pxe_http_port,
            pxe_http_bind_address=pxe_http_bind_address,
            configure_interface=configure_interface,
            nfs_enabled=nfs_enabled,
            nfs_export_path=nfs_export_path,
            nfs_allowed_clients=nfs_allowed_clients,
            nfs_allow_all_clients=nfs_allow_all_clients,
            nfs_create_export_path=nfs_create_export_path,
            nfs_exports_file=nfs_exports_file,
            target_mount_path=target_mount_path,
            mount_mode=mount_mode,
            mount_owner=mount_owner,
            mount_group=mount_group,
            firewall_manage=firewall_manage,
        )

    print_plan(plan, bundle_path)

    if show:
        print("Generated vars path:")
        print("  {}".format(generated_vars_path))
        print("")
        print("Show complete. No files were changed.")
        return 0

    for warning in collect_plan_warnings(plan):
        report.add("warnings", warning)

    config = update_config_with_plan(config, plan)
    generated_text = generated_vars_text(plan)

    save_config_if_changed(config, report, dry_run=dry_run)

    write_text_if_changed(
        generated_vars_path,
        generated_text,
        report,
        backup_root=backup_root,
        base_path=collections_hub,
        dry_run=dry_run,
    )

    print("Generated vars path:")
    print("  {}".format(generated_vars_path))
    print("")

    if dry_run:
        print("Dry run complete. No files were changed.")
    else:
        print("Server configuration saved.")
        print("")
        print("No system services were changed.")
        print("A later deploy command will apply network/NFS/PXE service changes.")

    report.print_summary()

    return 1 if report.errors else 0
