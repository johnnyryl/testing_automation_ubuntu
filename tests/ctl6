        },
        "server": {
            "interface": None,
            "ip_address": None,
            "prefix": None,
            "gateway": None,
            "dns": [],
            "configure_interface": False,
            "nfs": {
                "enabled": True,
                "export_path": str(bundle_path),
                "allowed_clients": None,
            },
            "pxe_http": {
                "bind_address": "0.0.0.0",
                "port": 18080,
            },
        },
        "repos": {
            "enabled": True,
            "mode": "local",
        },
        "pxe": {
            "enabled": True,
            "default_profile": None,
            "menu_timeout_seconds": 10,
            "watcher_interval_seconds": 15,
            "custom_kickstart_dir": str(OVERRIDE_KICKSTARTS_DIR),
        },
        "ansible": {
            "enabled": True,
            "root": str(ansible_dir(bundle_path)),
            "config_path": str(ansible_cfg_file(bundle_path)),
            "inventory_path": str(ansible_inventory_dir(bundle_path)),
            "group_vars_path": str(ansible_group_vars_dir(bundle_path)),
            "group_vars_all_path": str(ansible_group_vars_all_dir(bundle_path)),
