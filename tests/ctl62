ROOT_EXAMPLES = (
    "configure init",
    "configure server",
    "deploy server",
    "doctor",
    "provision list",
    "<command> --help",
)


def _format_root_command_groups():
    """Return grouped top-level command help for aerolitctl."""
    lines = []

    for title, commands in ROOT_COMMAND_GROUPS:
        lines.append("{}:".format(title))

        for name, summary in commands:
            lines.append("  {0:<12} {1}".format(name, summary))

        lines.append("")

    return "\n".join(lines).rstrip()


def _format_root_examples(prog):
    """Return root help examples."""
    return "\n".join("  {0} {1}".format(prog, example) for example in ROOT_EXAMPLES)


def _format_root_help(prog):
    """Return polished root help without the giant argparse command list."""
    return """usage: {0} [GLOBAL_OPTIONS] <command> [COMMAND_OPTIONS]

Command and control interface for AeroLIT bundles.

{1}

Global options:
  -h, --help   Show this help message and exit
  --verbose    Show more detailed output

Examples:
{2}

Run '{0} <command> --help' for command-specific help.
""".format(
        prog,
        _format_root_command_groups(),
        _format_root_examples(prog),
    )


class AeroLITRootArgumentParser(argparse.ArgumentParser):
    """Custom top-level help while keeping argparse for command parsing."""

    def format_help(self):
        return _format_root_help(self.prog)


def add_command_verbose(parser):
    """Allow --verbose after a leaf command.

    The root parser already supports:

      aerolitctl --verbose status

    This helper also allows:

      aerolitctl status --verbose
      aerolitctl deploy server --verbose
      aerolitctl configure init --verbose

    default=argparse.SUPPRESS prevents the leaf parser from overwriting the
    root --verbose value when --verbose is not provided at the leaf level.
    """
    parser.add_argument(
        "--verbose",
        action="store_true",
        default=argparse.SUPPRESS,
        help="Show more detailed output.",
    )


