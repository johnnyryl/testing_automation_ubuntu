def cmd_version(args):
    """Print aerolitctl version."""
    print("aerolitctl {}".format(__version__))
    return 0


def cmd_configure_init(args):
    """Run full initialization workflow."""
    return run_configure_init(
        bundle_path=args.bundle,
        force=args.force,
        dry_run=args.dry_run,
        non_interactive=args.non_interactive,
        verbose=getattr(args, "verbose", False),
        no_backup=args.no_backup,
        skip_preserve_file=args.skip_preserve_file,
        skip_ci_file=args.skip_ci_file,
        skip_ansible_files=args.skip_ansible_files,
    )


def cmd_configure_ansible(args):
    """Run configure ansible."""
    return run_configure_ansible(args)


def cmd_path_show(args):
    """Show configured bundle path."""
    config = load_config()
    bundle_path = get_bundle_path(config)

    if not bundle_path:
        print("No bundle path is configured.", file=sys.stderr)
        return 1

    print(bundle_path)
    return 0


def cmd_path_set(args):
    """Set configured bundle path."""
    new_path = Path(args.path)
    config, backup_path, changed = set_bundle_path(
        new_path,
        backup=not args.no_backup,
    )

    if not changed:
        print("AeroLIT bundle path already set:")
        print("  {}".format(get_bundle_path(config)))
        print("")
        print("No changes made.")
        return 0

    print("Updated AeroLIT bundle path:")
    print("  {}".format(get_bundle_path(config)))

    if backup_path:
        print("")
        print("Config backup:")
        print("  {}".format(backup_path))

    if not new_path.exists():
        print("")
        print("WARNING: Bundle path does not currently exist:")
        print("  {}".format(new_path))
        print("")
        print("You can create/place the bundle there, then run:")
        print("  aerolitctl configure init --bundle {}".format(new_path))

    return 0


def cmd_bundle_show(args):
    """Show configured bundle details."""
    return show_bundle(bundle_path=args.path)


def cmd_bundle_validate(args):
    """Validate configured bundle layout."""
    return validate_bundle(bundle_path=args.path)


def cmd_doctor(args):
    """Run doctor checks."""
    return run_doctor()


def cmd_status(args):
    """Show AeroLIT status."""
    return run_status(verbose=getattr(args, "verbose", False))


