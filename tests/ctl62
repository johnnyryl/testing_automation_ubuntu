def main(argv=None):
    """Main entry point."""
    parser = build_parser()
    args = parser.parse_args(argv)

    if not hasattr(args, "func"):
        parser.print_help()
        return 2

    command_argv = list(argv if argv is not None else sys.argv[1:])
    setattr(args, "_aerolitctl_argv", command_argv)

    try:
        result = run_with_command_log(
            args,
            lambda: args.func(args),
            argv=command_argv,
        )

        if getattr(args, "verbose", False):
            log_path = get_last_command_log_path()
            log_error = get_last_command_log_error()

            if log_path:
                print("")
                print("Command log:")
                print("  {}".format(log_path))
            elif log_error:
                print("")
                print("Command log:")
                print("  not written: {}".format(log_error))

        return result

    except KeyboardInterrupt:
        print("")
        print("Cancelled.", file=sys.stderr)

        log_path = get_last_command_log_path()
        log_error = get_last_command_log_error()

        if log_path:
            print("Command log: {}".format(log_path), file=sys.stderr)
        elif log_error:
            print("Command log not written: {}".format(log_error), file=sys.stderr)

        return 130

    except Exception as exc:
        print("ERROR: {}".format(exc), file=sys.stderr)

        log_path = get_last_command_log_path()
        log_error = get_last_command_log_error()

        if log_path:
            print("Command log: {}".format(log_path), file=sys.stderr)
        elif log_error:
            print("Command log not written: {}".format(log_error), file=sys.stderr)

        return 1


if __name__ == "__main__":
    sys.exit(main())
