        "status",
        help="Show AeroLIT configuration and deployment readiness.",
    )
    add_command_verbose(status_parser)
    status_parser.set_defaults(func=cmd_status)

    add_logs_parser(subparsers)
    add_backup_parser(subparsers)
    add_settings_parser(subparsers)
    add_sync_parser(subparsers)
    add_shell_parser(subparsers)
    add_generate_parser(subparsers)

    configure_parser = subparsers.add_parser(
        "configure",
        help="Configure AeroLIT.",
    )
    configure_subparsers = configure_parser.add_subparsers(dest="configure_command")

    init_parser = configure_subparsers.add_parser(
        "init",
        help="Initialize AeroLIT configuration, state, preserves, CI, and active Ansible files.",
    )
    init_parser.add_argument(
        "--bundle",
        default=None,
        help="Path to AeroLIT bundle. Defaults to /opt/aerolit/aerolit-bundle.",
    )
    init_parser.add_argument(
        "--force",
        action="store_true",
        help="Overwrite existing managed files from templates after backing them up.",
    )
    init_parser.add_argument(
        "--dry-run",
        action="store_true",
        help="Show what would happen without making changes.",
    )
    init_parser.add_argument(
        "--non-interactive",
        action="store_true",
        help="Do not prompt. Use defaults unless options are provided.",
    )
    init_parser.add_argument(
        "--no-backup",
        action="store_true",
        help="Do not create initialization backups before replacing files.",
    )
    init_parser.add_argument(
        "--skip-preserve-file",
        action="store_true",
        help="Do not create or update collections-hub/.sync-preserve.",
    )
    init_parser.add_argument(
        "--skip-ci-file",
        action="store_true",
        help="Do not generate collections-hub/.gitlab-ci.yml.",
    )
    init_parser.add_argument(
        "--skip-ansible-files",
        action="store_true",
        help="Do not create or replace ansible/inventory, ansible/group_vars, or ansible/ansible.cfg.",
    )
    add_command_verbose(init_parser)
    init_parser.set_defaults(func=cmd_configure_init)

    ansible_parser = configure_subparsers.add_parser(
        "ansible",
        help="Safely manage AeroLIT-owned Ansible inventory and generated vars.",
    )
    ansible_parser.set_defaults(func=cmd_configure_ansible)

    ansible_parser.add_argument(
        "--bundle-path",
        default=None,
        help="Bundle path. Defaults to configured bundle path.",
    )
