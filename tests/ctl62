        help="Validate a bundle path without changing aerolitctl.yml.",
    )
    add_command_verbose(bundle_validate_parser)
    bundle_validate_parser.set_defaults(func=cmd_bundle_validate)

    return parser


def main(argv=None):
    """Main entry point."""
    parser = build_parser()
    args = parser.parse_args(argv)

    if not hasattr(args, "func"):
        parser.print_help()
        return 2

    try:
        return args.func(args)
    except KeyboardInterrupt:
        print("")
        print("Cancelled.", file=sys.stderr)
        return 130
    except Exception as exc:
        print("ERROR: {}".format(exc), file=sys.stderr)
        return 1


if __name__ == "__main__":
    sys.exit(main())
