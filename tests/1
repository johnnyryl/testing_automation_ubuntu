      test -n "${RELEASE_TOKEN:-}" || {
        echo "ERROR: RELEASE_TOKEN is not available."
        exit 1
      }
      test -f "${CA_CERT:-}" || {
        echo "ERROR: CA_CERT must be configured as a GitLab File variable."
        exit 1
      }
      mkdir -p \
        /kaniko/.docker \
        "$CI_PROJECT_DIR/build-inputs"
      # Make the internal CA available to Kaniko and other HTTPS clients.
      if [ -f /kaniko/ssl/certs/ca-certificates.crt ]; then
        cat "$CA_CERT" >> /kaniko/ssl/certs/ca-certificates.crt
      fi
      if [ -f /etc/ssl/certs/ca-certificates.crt ]; then
        cat "$CA_CERT" >> /etc/ssl/certs/ca-certificates.crt
      fi
      cp "$CA_CERT" "$CI_PROJECT_DIR/build-inputs/lm-ca.pem"
      # Authenticate Kaniko to the internal GitLab registry.
      AUTH_VALUE="$(
        printf 'RELEASE_TOKEN:%s' "$RELEASE_TOKEN" |
        /busybox/base64 |
        /busybox/tr -d '\n'
      )"
      printf '{"auths":{"%s":{"auth":"%s"}}}\n' \
        "$CI_REGISTRY" \
        "$AUTH_VALUE" \
        > /kaniko/.docker/config.json
      chmod 0600 /kaniko/.docker/config.json
      # Select the permanent RHSM/Satellite bundle for this RHEL major.
      case "$RHEL_MAJOR" in
        7)
          RHSM_SECURE_FILE_ID="${RHSM_UBI7_SECURE_FILE_ID:-}"
          ;;
        8)
          RHSM_SECURE_FILE_ID="${RHSM_UBI8_SECURE_FILE_ID:-}"
          ;;
        9)
          RHSM_SECURE_FILE_ID="${RHSM_UBI9_SECURE_FILE_ID:-}"
          ;;
        10)
          RHSM_SECURE_FILE_ID="${RHSM_UBI10_SECURE_FILE_ID:-}"
          ;;
        *)
          echo "ERROR: Unsupported RHEL_MAJOR: $RHEL_MAJOR"
          exit 1
          ;;
      esac
      test -n "$RHSM_SECURE_FILE_ID" || {
        echo "ERROR: Secure File ID is not configured for RHEL $RHEL_MAJOR."
        exit 1
      }
      # Download the protected entitlement bundle from this project's
      # GitLab Secure Files storage.
      /busybox/wget \
        --header="JOB-TOKEN: ${CI_JOB_TOKEN}" \
        --output-document="$CI_PROJECT_DIR/build-inputs/rhsm-bundle.tar.gz" \
        "${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/secure_files/${RHSM_SECURE_FILE_ID}/download"
      test -s "$CI_PROJECT_DIR/build-inputs/rhsm-bundle.tar.gz" || {
        echo "ERROR: RHSM bundle download was empty."
        exit 1
      }
      chmod 0600 "$CI_PROJECT_DIR/build-inputs/rhsm-bundle.tar.gz"
  script:
    - |
      set -eu
      IMAGE_REPOSITORY="${CI_REGISTRY_IMAGE}/ubi${RHEL_MAJOR}-init-satellite"
