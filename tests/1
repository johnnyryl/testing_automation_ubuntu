        "${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/secure_files?per_page=100"

      test -s "${SECURE_FILES_METADATA}" || {
        echo "ERROR: GitLab returned no Secure File metadata."
        exit 1
      }

      # GitLab's download endpoint requires a numeric Secure File ID.
      # Resolve that ID from the known filename without requiring four
      # separate CI/CD ID variables.
      RHSM_SECURE_FILE_ID="$(
        /busybox/tr -d '\n\r\t ' < "${SECURE_FILES_METADATA}" |
        /busybox/tr '{' '\n' |
        /busybox/grep -F "\"name\":\"${RHSM_SECURE_FILE_NAME}\"" |
