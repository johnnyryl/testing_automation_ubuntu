4. scripts/create-satellite-bundle.sh

This script is run once on a real registered RHEL system, not inside a UBI container.

Run it separately on RHEL 7, 8, 9, and 10.

#!/usr/bin/env bash
set -euo pipefail
EXPECTED_MAJOR="${1:-}"
OUTPUT_FILE="${2:-}"
if [[ -z "$EXPECTED_MAJOR" ]]; then
    echo "Usage: sudo $0 <7|8|9|10> [output-file]" >&2
    exit 1
fi
case "$EXPECTED_MAJOR" in
    7|8|9|10)
        ;;
    *)
        echo "ERROR: Major version must be 7, 8, 9, or 10." >&2
        exit 1
        ;;
esac
if [[ "$EUID" -ne 0 ]]; then
    echo "ERROR: Run this script with sudo or as root." >&2
    exit 1
fi
if [[ ! -r /etc/os-release ]]; then
    echo "ERROR: Cannot read /etc/os-release." >&2
    exit 1
fi
# shellcheck disable=SC1091
source /etc/os-release
ACTUAL_MAJOR="${VERSION_ID%%.*}"
if [[ "$ACTUAL_MAJOR" != "$EXPECTED_MAJOR" ]]; then
    echo "ERROR: This is RHEL $ACTUAL_MAJOR, but RHEL $EXPECTED_MAJOR was requested." >&2
    exit 1
fi
if [[ -z "$OUTPUT_FILE" ]]; then
    OUTPUT_FILE="rhsm-ubi${EXPECTED_MAJOR}.tar.gz"
fi
command -v subscription-manager >/dev/null 2>&1 || {
    echo "ERROR: subscription-manager is not installed." >&2
    exit 1
}
subscription-manager identity >/dev/null 2>&1 || {
    echo "ERROR: This RHEL system is not registered." >&2
    exit 1
}
echo "Refreshing registration and repository information..."
subscription-manager refresh
echo
echo "Enabled repositories:"
subscription-manager repos --list-enabled
if command -v dnf >/dev/null 2>&1; then
    dnf -q makecache --refresh
else
    yum -q makecache fast
fi
REPO_FILE="/etc/yum.repos.d/redhat.repo"
if [[ ! -s "$REPO_FILE" ]]; then
    echo "ERROR: Missing or empty $REPO_FILE." >&2
    exit 1
fi
if ! grep -Eq \
    '^[[:space:]]*enabled[[:space:]]*=[[:space:]]*1' \
    "$REPO_FILE"; then
    echo "ERROR: No enabled repositories exist in $REPO_FILE." >&2
    exit 1
fi
if ! compgen -G '/etc/pki/entitlement/*.pem' >/dev/null; then
    echo "ERROR: No entitlement certificates were found." >&2
    exit 1
fi
if ! compgen -G '/etc/pki/entitlement/*-key.pem' >/dev/null; then
    echo "ERROR: No entitlement private key was found." >&2
    exit 1
fi
if [[ ! -d /etc/rhsm/ca ]]; then
    echo "ERROR: /etc/rhsm/ca does not exist." >&2
    exit 1
fi
TEMP_DIRECTORY="$(mktemp -d)"
cleanup()
{
    rm -rf "$TEMP_DIRECTORY"
}
trap cleanup EXIT
install -d -m 0755 \
    "$TEMP_DIRECTORY/etc/pki/entitlement" \
    "$TEMP_DIRECTORY/etc/pki/rpm-gpg" \
    "$TEMP_DIRECTORY/etc/rhsm/ca" \
    "$TEMP_DIRECTORY/etc/yum.repos.d"
cp -a \
    /etc/pki/entitlement/. \
    "$TEMP_DIRECTORY/etc/pki/entitlement/"
cp -a \
    /etc/rhsm/ca/. \
    "$TEMP_DIRECTORY/etc/rhsm/ca/"
if [[ -d /etc/pki/rpm-gpg ]]; then
    cp -a \
        /etc/pki/rpm-gpg/. \
        "$TEMP_DIRECTORY/etc/pki/rpm-gpg/"
fi
install -m 0644 \
    "$REPO_FILE" \
    "$TEMP_DIRECTORY/etc/yum.repos.d/redhat.repo"
tar \
    --numeric-owner \
    -C "$TEMP_DIRECTORY" \
    -czf "$OUTPUT_FILE" \
    .
chmod 0600 "$OUTPUT_FILE"
echo
echo "Created:"
ls -lh "$OUTPUT_FILE"
echo
echo "Upload this file to the image-builder project's GitLab Secure Files:"
echo "  $OUTPUT_FILE"

This intentionally does not copy /etc/pki/consumer. The image receives only what yum or dnf needs to authenticate to the repositories, rather than pretending every container is the registered host.

