      fi

      # This copy becomes the corporate CA installed inside the output image.
      cp \
        "${CA_CERT}" \
        "${CI_PROJECT_DIR}/build-inputs/lm-ca.pem"

      # Authenticate Kaniko for:
      #   1. Pulling the UBI init base image.
      #   2. Pushing the completed Satellite-enabled image.
