3. scripts/verify-satellite.sh

#!/bin/sh
set -eu
SATELLITE_HOST="${SATELLITE_HOST:-orecchiette.external.lmco.com}"
REPO_FILE="/etc/yum.repos.d/redhat.repo"
ENTITLEMENT_DIRECTORY="/etc/pki/entitlement"
SATELLITE_CA_DIRECTORY="/etc/rhsm/ca"
fail()
{
    echo "ERROR: $*" >&2
    exit 1
}
test -s "$REPO_FILE" ||
    fail "Missing or empty $REPO_FILE"
test -d "$ENTITLEMENT_DIRECTORY" ||
    fail "Missing $ENTITLEMENT_DIRECTORY"
test -d "$SATELLITE_CA_DIRECTORY" ||
    fail "Missing $SATELLITE_CA_DIRECTORY"
ls "$ENTITLEMENT_DIRECTORY"/*.pem >/dev/null 2>&1 ||
    fail "No entitlement certificate was found"
ls "$ENTITLEMENT_DIRECTORY"/*-key.pem >/dev/null 2>&1 ||
    fail "No entitlement private key was found"
grep -Fq "$SATELLITE_HOST" "$REPO_FILE" ||
    fail "$REPO_FILE does not reference $SATELLITE_HOST"
grep -Eq \
    '^[[:space:]]*enabled[[:space:]]*=[[:space:]]*1' \
    "$REPO_FILE" ||
    fail "No enabled repositories were found in $REPO_FILE"
echo "Checking Satellite repository access through $SATELLITE_HOST"
if command -v dnf >/dev/null 2>&1; then
    dnf -q repolist --enabled
    dnf -q makecache --refresh
elif command -v yum >/dev/null 2>&1; then
    yum -q repolist enabled
    yum -q makecache fast
else
    fail "Neither dnf nor yum is installed"
fi
echo "Satellite repository verification succeeded."

