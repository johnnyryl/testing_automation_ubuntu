        echo "ERROR: Could not find Secure File ${RHSM_SECURE_FILE_NAME}."
        echo "Confirm that the file is uploaded under Settings > CI/CD > Secure Files."
        echo
        echo "GitLab API response:"
        cat "${SECURE_FILES_METADATA}"
        exit 1
      fi

      echo "Resolved ${RHSM_SECURE_FILE_NAME} to Secure File ID ${RHSM_SECURE_FILE_ID}."

      # Download the protected RHSM/Satellite entitlement bundle.
      /busybox/wget \
        -q \
        --header="PRIVATE-TOKEN: ${SECURE_FILES_TOKEN}" \
        --output-document="${CI_PROJECT_DIR}/build-inputs/rhsm-bundle.tar.gz" \
        "${CI_API_V4_URL}/projects/${CI_PROJECT_ID}/secure_files/${RHSM_SECURE_FILE_ID}/download"

      test -s "${CI_PROJECT_DIR}/build-inputs/rhsm-bundle.tar.gz" || {
        echo "ERROR: Downloaded RHSM bundle is empty."
        exit 1
      }

      # Confirm that the downloaded file is actually a readable gzip
