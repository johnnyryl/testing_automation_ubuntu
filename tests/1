ARG BASE_IMAGE
FROM ${BASE_IMAGE}
ARG BASE_IMAGE
ARG RHEL_MAJOR
ARG SATELLITE_HOST
ARG SOURCE_URL
ARG VCS_REF
ARG BUILD_DATE
LABEL org.opencontainers.image.title="UBI ${RHEL_MAJOR} Init Satellite Builder" \
      org.opencontainers.image.description="Internal UBI init image with persistent Lockheed Martin Satellite repository access" \
      org.opencontainers.image.source="${SOURCE_URL}" \
      org.opencontainers.image.revision="${VCS_REF}" \
      org.opencontainers.image.created="${BUILD_DATE}" \
      org.opencontainers.image.base.name="${BASE_IMAGE}" \
      com.lmco.image.rhel-major="${RHEL_MAJOR}" \
      com.lmco.image.satellite-host="${SATELLITE_HOST}" \
      com.lmco.image.satellite-enabled="true" \
      com.lmco.image.purpose="internal-builder"
ENV SATELLITE_HOST="${SATELLITE_HOST}"
USER 0
# Corporate CA trust.
COPY build-inputs/lm-ca.pem \
     /etc/pki/ca-trust/source/anchors/lm-ca.pem
# This archive contains:
#
#   /etc/pki/entitlement
#   /etc/pki/rpm-gpg
#   /etc/rhsm/ca
#   /etc/yum.repos.d/redhat.repo
#
# ADD automatically extracts a local tar.gz archive.
ADD build-inputs/rhsm-bundle.tar.gz /
COPY scripts/verify-satellite.sh \
     /usr/local/sbin/verify-satellite
RUN set -eux; \
    \
    chmod 0755 /usr/local/sbin/verify-satellite; \
    \
    # UBI images normally look for subscription data mounted from the
    # container host. This image intentionally uses its embedded,
    # dedicated Satellite repository credentials instead.
    rm -rf /etc/rhsm-host; \
    \
    # Disable public/default UBI repository files. The image should use
    # only the redhat.repo captured from the dedicated Satellite host.
    for repo_file in /etc/yum.repos.d/*.repo; do \
        [ -e "${repo_file}" ] || continue; \
        [ "${repo_file}" = "/etc/yum.repos.d/redhat.repo" ] && continue; \
        rm -f "${repo_file}.disabled"; \
        mv "${repo_file}" "${repo_file}.disabled"; \
    done; \
    \
    # Prevent the subscription-manager package-manager plugin from trying
    # to replace or regenerate the static redhat.repo file.
    for plugin_file in \
        /etc/yum/pluginconf.d/subscription-manager.conf \
        /etc/dnf/plugins/subscription-manager.conf; \
    do \
        [ -f "${plugin_file}" ] || continue; \
        if grep -Eq '^[[:space:]]*enabled[[:space:]]*=' "${plugin_file}"; then \
            sed -ri \
                's/^[[:space:]]*enabled[[:space:]]*=.*/enabled=0/' \
                "${plugin_file}"; \
        else \
            printf '\nenabled=0\n' >> "${plugin_file}"; \
        fi; \
    done; \
    \
    update-ca-trust extract; \
    \
    # Fail the image build if the embedded Satellite repositories cannot
    # actually be reached.
    /usr/local/sbin/verify-satellite; \
    \
    if command -v dnf >/dev/null 2>&1; then \
        dnf clean all; \
    elif command -v yum >/dev/null 2>&1; then \
        yum clean all; \
    fi; \
    \
    rm -rf \
        /var/cache/dnf \
        /var/cache/yum \
        /tmp/*
# The original command/entrypoint is inherited from the UBI init base.

