      if ! /busybox/tar \
        -tzf "${CI_PROJECT_DIR}/build-inputs/rhsm-bundle.tar.gz" \
        >/dev/null 2>&1; then
        echo "ERROR: ${RHSM_SECURE_FILE_NAME} is not a valid gzip tar archive."
        exit 1
      fi

      chmod 0600 \
        "${CI_PROJECT_DIR}/build-inputs/rhsm-bundle.tar.gz"

      rm -f "${SECURE_FILES_METADATA}"

      echo "Secure Satellite bundle is ready for the RHEL ${RHEL_MAJOR} build."

  script:
