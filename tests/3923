Phase 8 — Upgrade prepare.yml

Your current prepare.yml is empty. This is where the global setup should begin.

Replace it with this first version:

---
- name: Prepare
  hosts: all
  gather_facts: true
  become: true
  vars:
    aerolit_requires_files: "{{ lookup('env', 'AEROLIT_REQUIRES_FILES') | default('false', true) | bool }}"
    aerolit_requires_repos: "{{ lookup('env', 'AEROLIT_REQUIRES_REPOS') | default('false', true) | bool }}"
    aerolit_prepare_roles_raw: "{{ lookup('env', 'AEROLIT_PREPARE_ROLES') | default('', true) }}"
    aerolit_prepare_roles: "{{ aerolit_prepare_roles_raw.split(',') | map('trim') | reject('equalto', '') | list }}"
  tasks:
    - name: Check AeroLIT files mount
      ansible.builtin.stat:
        path: /opt/aerolit/files
      register: aerolit_files_mount
    - name: Check AeroLIT repos mount
      ansible.builtin.stat:
        path: /opt/aerolit/repos
      register: aerolit_repos_mount
    - name: Fail if files are required but not mounted
      ansible.builtin.assert:
        that:
          - aerolit_files_mount.stat.exists
          - aerolit_files_mount.stat.isdir
        fail_msg: "This role requires /opt/aerolit/files, but the files fixture is not mounted."
      when: aerolit_requires_files
    - name: Fail if repos are required but not mounted
      ansible.builtin.assert:
        that:
          - aerolit_repos_mount.stat.exists
          - aerolit_repos_mount.stat.isdir
        fail_msg: "This role requires /opt/aerolit/repos, but the repos fixture is not mounted."
      when: aerolit_requires_repos
    - name: Configure AeroLIT test repo
      ansible.builtin.copy:
        dest: /etc/yum.repos.d/aerolit-test.repo
        mode: "0644"
        content: |
          [aerolit-test]
          name=AeroLIT Molecule Test Repo
          baseurl=file:///opt/aerolit/repos
          enabled=1
          gpgcheck=0
      when: aerolit_requires_repos
    - name: Run prerequisite roles
      ansible.builtin.include_role:
        name: "{{ item }}"
      loop: "{{ aerolit_prepare_roles }}"
      when: aerolit_prepare_roles | length > 0

For the first test, you can set:

export AEROLIT_REQUIRES_FILES=false
export AEROLIT_REQUIRES_REPOS=false
export AEROLIT_PREPARE_ROLES=""

Later, a role can override those.

