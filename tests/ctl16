def find_nmcli_connection_for_interface(interface):
    """Return the active NetworkManager connection name for an interface."""
    rc, stdout, stderr = run_command(["nmcli", "-t", "-f", "NAME,DEVICE", "connection", "show", "--active"])
    if rc != 0:
        return None

    for line in stdout.splitlines():
        parts = line.rsplit(":", 1)
        if len(parts) != 2:
            continue
        name, device = parts
        if device == interface:
            return name.replace("\\:", ":")

    return None


def deploy_interface(plan, report, dry_run=False, skip=False):
    """Apply interface IP configuration intent."""
    if skip:
        report.add("skipped", "Interface configuration skipped by option")
        return

    if not plan.get("configure_interface"):
        report.add("skipped", "Interface configuration intent is disabled")
        return

    interface = plan.get("interface")
    server_ip = plan.get("server_ip")
    prefix = plan.get("prefix")
    planned = "{}/{}".format(server_ip, prefix)

    if interface_has_ip(interface, server_ip):
        report.add("existing", "{} already has {}".format(interface, planned))
        return

    if not command_exists("nmcli"):
        raise RuntimeError(
            "nmcli is required to configure the interface persistently. "
            "Install NetworkManager or configure {} with {} manually.".format(interface, planned)
        )

    connection = find_nmcli_connection_for_interface(interface)
    if not connection:
        raise RuntimeError(
            "No active NetworkManager connection was found for interface {}. "
            "Configure {} manually or create/activate a NetworkManager connection first.".format(
                interface,
                planned,
            )
        )

    run_logged_command(
        report,
        ["nmcli", "connection", "modify", connection, "+ipv4.addresses", planned],
        dry_run=dry_run,
        root=True,
        description="Add planned server IP to interface connection",
    )
    run_logged_command(
        report,
        ["nmcli", "connection", "up", connection],
        dry_run=dry_run,
        root=True,
        description="Bring NetworkManager connection up",
    )


def ensure_directory(path, report, dry_run=False, root=False):
    """Ensure a directory exists."""
    path = Path(path)
    if path.exists():
        if not path.is_dir():
            raise RuntimeError("{} exists but is not a directory".format(path))
        report.add("existing", "{} directory exists".format(path))
        return

    run_logged_command(
        report,
        ["mkdir", "-p", str(path)],
        dry_run=dry_run,
        root=root,
        description="Create directory",
    )


def ensure_nfs_utils(report, dry_run=False):
    """Ensure exportfs is available."""
    if command_exists("exportfs"):
        report.add("existing", "exportfs is available")
        return

    if not command_exists("dnf"):
        raise RuntimeError("exportfs is missing and dnf is not available to install nfs-utils")

    run_logged_command(
        report,
        ["dnf", "install", "-y", "nfs-utils"],
        dry_run=dry_run,
        root=True,
        description="Install nfs-utils",
    )


def ensure_ansible_playbook(report, dry_run=False, package="ansible-core"):
    """Ensure ansible-playbook is available."""
    if command_exists("ansible-playbook"):
        report.add("existing", "ansible-playbook is available")
        return True

    if dry_run:
        report.add("dry_run", "Would install {} because ansible-playbook is missing".format(package))
        return False

    if not command_exists("dnf"):
        raise RuntimeError("ansible-playbook is missing and dnf is not available")

    run_logged_command(
        report,
        ["dnf", "install", "-y", package],
        dry_run=False,
        root=True,
        description="Install ansible package",
    )

    if not command_exists("ansible-playbook"):
        raise RuntimeError("ansible-playbook is still missing after installing {}".format(package))

    return True


def install_text_file(report, path, content, dry_run=False, mode="0644"):
    """Install text content to a root-owned path using install."""
    path = Path(path)
    old_content = None

    if path.exists():
        try:
            old_content = path.read_text()
        except IOError:
            old_content = None

    if old_content == content:
        report.add("existing", "{} unchanged".format(path))
        return

    if dry_run:
        action = "Would update" if path.exists() else "Would create"
        report.add("dry_run", "{} {}".format(action, path))
        return

    fd, temp_path = tempfile.mkstemp(prefix="aerolit-deploy-", text=True)
    try:
        with os.fdopen(fd, "w") as handle:
            handle.write(content)

        run_logged_command(
            report,
            ["mkdir", "-p", str(path.parent)],
            dry_run=False,
            root=True,
            description="Create parent directory",
        )

        if path.exists():
            backup_path = "{}.aerolit-backup".format(path)
            run_logged_command(
                report,
                ["cp", "-a", str(path), backup_path],
                dry_run=False,
                root=True,
                description="Back up existing file",
            )

        run_logged_command(
            report,
            ["install", "-m", mode, temp_path, str(path)],
            dry_run=False,
            root=True,
            description="Install file",
        )
    finally:
        try:
            os.unlink(temp_path)
        except OSError:
            pass


def render_exports_file(nfs):
    """Render /etc/exports.d content for the AeroLIT bundle export."""
    export_path = nfs.get("export_path")
    allowed = "*" if nfs.get("allow_all_clients") else nfs.get("allowed_clients")
    return "# Managed by AeroLIT deploy server\n{} {}(rw,sync,no_subtree_check)\n".format(
        export_path,
        allowed,
    )


def deploy_nfs(plan, report, dry_run=False, skip=False):
    """Apply NFS export, service, and local permissions."""
    if skip:
        report.add("skipped", "NFS deployment skipped by option")
        return

    nfs = plan.get("nfs", {})
    if not nfs.get("enabled"):
        report.add("skipped", "NFS/controller is disabled")
        return

    export_path = Path(nfs.get("export_path"))
    create_export_path = nfs.get("create_export_path", False)

    if not export_path.exists() and not create_export_path:
        raise RuntimeError(
            "NFS export path {} does not exist. Re-run configure server and allow "
            "deploy to create it, or create it manually.".format(export_path)
        )

    ensure_directory(export_path, report, dry_run=dry_run, root=True)
    ensure_directory(export_path / "files", report, dry_run=dry_run, root=True)
    ensure_directory(export_path / "repos", report, dry_run=dry_run, root=True)

    owner = nfs.get("mount_owner") or DEFAULT_MOUNT_OWNER
    group = nfs.get("mount_group") or DEFAULT_MOUNT_GROUP
    mode = str(nfs.get("mount_mode") or DEFAULT_MOUNT_MODE)

    run_logged_command(
        report,
        ["chown", "{}:{}".format(owner, group), str(export_path), str(export_path / "files"), str(export_path / "repos")],
        dry_run=dry_run,
        root=True,
        description="Set NFS export ownership",
    )
    run_logged_command(
        report,
        ["chmod", mode, str(export_path), str(export_path / "files"), str(export_path / "repos")],
        dry_run=dry_run,
        root=True,
        description="Set NFS export directory mode",
    )

    install_text_file(
        report,
        nfs.get("exports_file") or DEFAULT_NFS_EXPORTS_FILE,
        render_exports_file(nfs),
        dry_run=dry_run,
        mode="0644",
    )

    ensure_nfs_utils(report, dry_run=dry_run)

    run_logged_command(
        report,
        ["systemctl", "enable", "--now", "rpcbind", "nfs-server"],
        dry_run=dry_run,
        root=True,
        description="Enable and start NFS services",
    )
    run_logged_command(
        report,
        ["exportfs", "-rav"],
        dry_run=dry_run,
        root=True,
        description="Refresh NFS exports",
    )


def deploy_firewall(plan, report, dry_run=False, skip=False):
    """Apply firewall intent."""
    if skip:
        report.add("skipped", "Firewall deployment skipped by option")
        return

    firewall = plan.get("firewall", {})
    if not firewall.get("manage"):
        report.add("skipped", "Firewall management intent is disabled")
        return

    if not command_exists("firewall-cmd"):
        report.add("warnings", "firewall-cmd not found; skipping firewall changes")
        return

    rc, stdout, stderr = run_command(["systemctl", "is-active", "--quiet", "firewalld"])
    if rc != 0:
        report.add("warnings", "firewalld is not active; skipping firewall changes")
        return

    services = firewall.get("services") or []
    ports = firewall.get("ports") or []

    for service in services:
        run_logged_command(
            report,
            ["firewall-cmd", "--permanent", "--add-service={}".format(service)],
            dry_run=dry_run,
            root=True,
            description="Open firewall service",
        )

    for port in ports:
        run_logged_command(
            report,
            ["firewall-cmd", "--permanent", "--add-port={}".format(port)],
            dry_run=dry_run,
            root=True,
            description="Open firewall port",
        )

    if services or ports:
        run_logged_command(
            report,
            ["firewall-cmd", "--reload"],
            dry_run=dry_run,
            root=True,
            description="Reload firewalld",
        )
    else:
        report.add("skipped", "No firewall services or ports were configured")


def ansible_environment(playbooks_dir):
    """Build ansible environment for local playbook execution."""
    env = os.environ.copy()
    cfg = Path(playbooks_dir) / "ansible.cfg"
    if cfg.exists():
        env["ANSIBLE_CONFIG"] = str(cfg)
    return env


def run_server_playbook(report, playbooks_dir, playbook_name, generated_vars_path, dry_run=False):
    """Run one existing server playbook."""
    playbooks_dir = Path(playbooks_dir)
    playbook = playbooks_dir / playbook_name

    if not playbook.exists():
        raise RuntimeError("Required playbook not found: {}".format(playbook))

    command = [
        "ansible-playbook",
        "-i",
        "localhost,",
        "-c",
        "local",
        "-e",
        "@{}".format(generated_vars_path),
        str(playbook),
    ]

    run_logged_command(
        report,
        command,
        dry_run=dry_run,
        root=False,
        cwd=str(playbooks_dir),
        env=ansible_environment(playbooks_dir),
        description="Run {}".format(playbook_name),
    )


def deploy_ansible_playbooks(
    plan,
    report,
    bundle_path,
    generated_vars_path,
    dry_run=False,
    skip_pxe=False,
    skip_controller=False,
):
    """Run PXE/controller playbooks from the bundle."""
    collections_hub = collections_hub_path(bundle_path)
    playbooks_dir = Path(collections_hub) / "ansible"

    if not plan.get("pxe_enabled"):
        skip_pxe = True
    if not plan.get("controller_enabled"):
        skip_controller = True

    if skip_pxe and skip_controller:
        report.add("skipped", "PXE/controller Ansible playbooks skipped")
        return

    ensure_ansible_playbook(report, dry_run=dry_run)

    if not Path(generated_vars_path).exists():
        raise RuntimeError(
            "Generated vars file not found: {}. Run: aerolitctl configure server".format(
                generated_vars_path
            )
        )

    if not playbooks_dir.exists():
        raise RuntimeError("Ansible playbooks directory not found: {}".format(playbooks_dir))

    if not skip_pxe:
        run_server_playbook(
            report,
            playbooks_dir,
            "pxe_server.yml",
            generated_vars_path,
            dry_run=dry_run,
        )
    else:
        report.add("skipped", "PXE playbook skipped")

    if not skip_controller:
        run_server_playbook(
            report,
            playbooks_dir,
            "ansible_controller.yml",
            generated_vars_path,
            dry_run=dry_run,
        )
    else:
        report.add("skipped", "Controller playbook skipped")


def run_deploy_server(
    dry_run=False,
    show=False,
    skip_interface=False,
    skip_nfs=False,
    skip_firewall=False,
    skip_pxe=False,
    skip_controller=False,
    verbose=False,
):
    """Deploy the saved AeroLIT server configuration."""
    report = DeployServerReport(verbose=verbose)

    config = load_config()
    bundle_path_value = get_bundle_path(config)

    if not bundle_path_value:
        raise RuntimeError("No bundle path is configured. Run: aerolitctl configure init")

    bundle_path = Path(bundle_path_value)
    generated_vars_path = aerolitctl_server_generated_vars_file(bundle_path)
    plan = load_deploy_plan(config, bundle_path)

    print_deploy_plan(plan, generated_vars_path)

    if show:
        print("Show complete. No files or services were changed.")
        return 0

    deploy_interface(plan, report, dry_run=dry_run, skip=skip_interface)
    deploy_nfs(plan, report, dry_run=dry_run, skip=skip_nfs)
    deploy_firewall(plan, report, dry_run=dry_run, skip=skip_firewall)
    deploy_ansible_playbooks(
        plan,
        report,
        bundle_path,
        generated_vars_path,
        dry_run=dry_run,
        skip_pxe=skip_pxe,
        skip_controller=skip_controller,
    )

    print("")
    if dry_run:
        print("Dry run complete. No files or services were changed.")
    else:
        print("Server deployment complete.")

    report.print_summary()

    return 1 if report.errors else 0
