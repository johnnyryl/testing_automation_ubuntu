"""Apply saved AeroLIT server configuration.

This module is the deploy side of ``aerolitctl configure server``.
It reads the saved server intent, applies host-side network/NFS/firewall
changes, and runs the existing PXE/controller Ansible playbooks.
"""

import os
import shutil
import subprocess
import tempfile
from pathlib import Path

from .config import get_bundle_path, load_config
from .paths import collections_hub_path, aerolitctl_server_generated_vars_file
from .server import (
    DEFAULT_BIND_ADDRESS,
    DEFAULT_HTTP_PORT,
    DEFAULT_MOUNT_GROUP,
    DEFAULT_MOUNT_MODE,
    DEFAULT_MOUNT_OWNER,
    DEFAULT_NFS_EXPORTS_FILE,
    DEFAULT_TARGET_MOUNT_PATH,
    current_server_config,
    interface_has_ip,
    interface_ipv4_addresses,
    parse_ipv4_address,
    parse_ipv4_network,
    parse_prefix,
    validate_absolute_path,
    normalize_mode,
)


class DeployServerReport(object):
    """Collect deploy server actions."""

    def __init__(self, verbose=False):
        self.verbose = verbose
        self.changed = []
        self.existing = []
        self.skipped = []
        self.dry_run = []
        self.warnings = []
        self.errors = []

    def add(self, category, message):
        getattr(self, category).append(message)

    def print_summary(self):
        """Print action summary."""
        print("")
        print("AeroLIT server deployment summary")
        print("")

        sections = [
            ("Changed", self.changed),
            ("Already current / skipped", self.existing),
            ("Skipped", self.skipped),
            ("Dry-run actions", self.dry_run),
            ("Warnings", self.warnings),
            ("Errors", self.errors),
        ]

        for title, values in sections:
            if not values:
                continue

            print("{}:".format(title))
            for value in values:
                print("  - {}".format(value))
            print("")


def command_exists(command):
    """Return True if command exists."""
    return shutil.which(command) is not None


def run_command(command, cwd=None, env=None):
    """Run a command and return rc, stdout, stderr."""
    try:
        process = subprocess.Popen(
            command,
            cwd=cwd,
            env=env,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            universal_newlines=True,
        )
        stdout, stderr = process.communicate()
        return process.returncode, stdout.strip(), stderr.strip()
    except OSError as exc:
        return 127, "", str(exc)


def as_root_command(command):
    """Prefix a command with sudo when not running as root."""
    if hasattr(os, "geteuid") and os.geteuid() == 0:
        return command

    if command_exists("sudo"):
        return ["sudo"] + command

    raise RuntimeError(
        "This deploy action requires root privileges. Re-run as root or install sudo."
    )


def run_logged_command(
    report,
    command,
    dry_run=False,
    check=True,
    root=False,
    cwd=None,
    env=None,
    description=None,
):
    """Run a command, record the action, and optionally fail on errors."""
    rendered = " ".join(str(item) for item in command)
    if description:
        rendered = "{}: {}".format(description, rendered)

    if dry_run:
        report.add("dry_run", "Would run {}".format(rendered))
        return 0, "", ""

    actual_command = list(command)
    if root:
        actual_command = as_root_command(actual_command)

    rc, stdout, stderr = run_command(actual_command, cwd=cwd, env=env)

    if rc == 0:
        report.add("changed", rendered)
    elif check:
        message = "Command failed rc={}: {}".format(rc, rendered)
        if stderr:
            message = "{}; stderr: {}".format(message, stderr)
        report.add("errors", message)
        raise RuntimeError(message)
    else:
        report.add("warnings", "Command returned rc={}: {}".format(rc, rendered))

    return rc, stdout, stderr


def normalize_bool(value, default=False):
    """Normalize a config boolean."""
    if value is None:
        return default

    if isinstance(value, bool):
        return value

    value = str(value).strip().lower()
    if value in ("1", "true", "yes", "y", "on"):
        return True
    if value in ("0", "false", "no", "n", "off"):
        return False

    return default


def require_value(plan, key, label):
    """Require a plan value."""
    value = plan.get(key)
    if value is None or value == "":
        raise ValueError("{} is required. Run: aerolitctl configure server --guided".format(label))
    return value


def load_deploy_plan(config, bundle_path):
    """Build a deploy plan from /etc/aerolit/aerolitctl.yml."""
    server = current_server_config(config)
    pxe_config = config.get("pxe", {})

    mode = normalize_mode(server.get("mode") or "full")
    controller_enabled = mode in ("full", "controller")
    pxe_enabled = bool(
        mode in ("full", "pxe")
        and normalize_bool(pxe_config.get("enabled"), True)
    )

    interface = server.get("interface") or pxe_config.get("interface")
    server_ip = server.get("ip_address") or pxe_config.get("server_ip")
    prefix = server.get("prefix")

    if server_ip:
        parse_ipv4_address(server_ip, "AeroLIT server IP")

    if prefix is None and pxe_config.get("dhcp_netmask"):
        network = parse_ipv4_network(
            "{}/{}".format(server_ip, pxe_config.get("dhcp_netmask")),
            "Provisioning network",
        )
        prefix = network.prefixlen

    if prefix is not None:
        prefix = parse_prefix(prefix)

    network = None
    if server_ip and prefix is not None:
        network = parse_ipv4_network(
            "{}/{}".format(server_ip, prefix),
            "Provisioning network",
        )

    pxe_http = server.get("pxe_http", {})
    nfs = dict(server.get("nfs", {}) or {})
    firewall = dict(server.get("firewall", {}) or {})

    nfs.setdefault("enabled", bool(controller_enabled))
    nfs.setdefault("server_ip", server_ip)
    nfs.setdefault("export_path", str(bundle_path))
    nfs.setdefault("allowed_clients", None)
    nfs.setdefault("allow_all_clients", False)
    nfs.setdefault("create_export_path", False)
    nfs.setdefault("exports_file", DEFAULT_NFS_EXPORTS_FILE)
    nfs.setdefault("target_mount_path", DEFAULT_TARGET_MOUNT_PATH)
    nfs.setdefault("mount_mode", DEFAULT_MOUNT_MODE)
    nfs.setdefault("mount_owner", DEFAULT_MOUNT_OWNER)
    nfs.setdefault("mount_group", DEFAULT_MOUNT_GROUP)

    nfs["enabled"] = bool(controller_enabled and normalize_bool(nfs.get("enabled"), True))
    nfs["allow_all_clients"] = normalize_bool(nfs.get("allow_all_clients"), False)
    nfs["create_export_path"] = normalize_bool(nfs.get("create_export_path"), False)

    plan = {
        "mode": mode,
        "bundle_path": str(bundle_path),
        "pxe_enabled": bool(pxe_enabled),
        "controller_enabled": bool(controller_enabled),
        "interface": interface,
        "server_ip": server_ip,
        "prefix": prefix,
        "network": str(network) if network else None,
        "gateway": server.get("gateway") or pxe_config.get("gateway"),
        "dns_servers": list(server.get("dns") or pxe_config.get("dns_servers") or []),
        "configure_interface": normalize_bool(server.get("configure_interface"), False),
        "pxe_http_port": int(pxe_http.get("port") or DEFAULT_HTTP_PORT),
        "pxe_http_bind_address": pxe_http.get("bind_address") or DEFAULT_BIND_ADDRESS,
        "dhcp_start": pxe_config.get("dhcp_start"),
        "dhcp_end": pxe_config.get("dhcp_end"),
        "dhcp_netmask": pxe_config.get("dhcp_netmask"),
        "nfs": nfs,
        "firewall": {
            "manage": normalize_bool(firewall.get("manage"), True),
            "services": list(firewall.get("services") or []),
            "ports": list(firewall.get("ports") or []),
        },
    }

    validate_deploy_plan(plan)
    return plan


def validate_no_whitespace_path(value, label):
    """Reject paths that contain whitespace because shell/system tools handle them poorly here."""
    if value and any(char.isspace() for char in str(value)):
        raise ValueError("{} must not contain whitespace: {}".format(label, value))


def validate_deploy_plan(plan):
    """Validate the saved deploy plan before applying it."""
    require_value(plan, "mode", "Server mode")
    interface = require_value(plan, "interface", "Server interface")
    server_ip = require_value(plan, "server_ip", "Server IP")
    parse_ipv4_address(server_ip, "AeroLIT server IP")

    prefix = require_value(plan, "prefix", "Server prefix")
    parse_prefix(prefix)

    if plan.get("network"):
        network = parse_ipv4_network(plan.get("network"), "Provisioning network")
        if parse_ipv4_address(server_ip, "AeroLIT server IP") not in network:
            raise ValueError("Server IP must be inside {}".format(network))

    if plan.get("pxe_enabled"):
        require_value(plan, "dhcp_start", "PXE DHCP start")
        require_value(plan, "dhcp_end", "PXE DHCP end")
        require_value(plan, "dhcp_netmask", "PXE DHCP netmask")
        parse_ipv4_address(plan.get("dhcp_start"), "PXE DHCP start")
        parse_ipv4_address(plan.get("dhcp_end"), "PXE DHCP end")
        if plan.get("pxe_http_port") < 1 or plan.get("pxe_http_port") > 65535:
            raise ValueError("PXE HTTP port must be between 1 and 65535")

    nfs = plan.get("nfs", {})
    if nfs.get("enabled"):
        validate_absolute_path(nfs.get("export_path"), "NFS export path")
        validate_absolute_path(nfs.get("exports_file"), "NFS exports file")
        validate_absolute_path(nfs.get("target_mount_path"), "Target/client mount path")
        validate_no_whitespace_path(nfs.get("export_path"), "NFS export path")
        validate_no_whitespace_path(nfs.get("exports_file"), "NFS exports file")
        validate_no_whitespace_path(nfs.get("target_mount_path"), "Target/client mount path")
        if not nfs.get("allow_all_clients") and not nfs.get("allowed_clients"):
            raise ValueError(
                "NFS allowed clients is required unless allow_all_clients is true. "
                "Run: aerolitctl configure server --guided"
            )

    return interface


def print_plan_value(label, value):
    """Print an aligned plan value."""
    if value is None or value == "":
        value = "none"
    print("  {:<31}: {}".format(label, value))


