"""AeroLIT repository discovery and generated repo configuration helpers.

`aerolitctl configure repos` is not intended to be a required happy-path step.

Default behavior should eventually be:
- deploy server uses existing system repos first
- if missing packages cannot be installed, deploy server discovers bundle repos
- deploy server can write/use an AeroLIT server bootstrap repo automatically
- provisioning repo variables are generated from bundle ISOs and repos by default

This module provides safe discovery, validation, show, managed group_vars
generation, server bootstrap repo generation, and server prerequisite package
fallback helpers.
"""

from __future__ import print_function

import datetime
import os
import re
import shutil
import subprocess
import sys
from collections import OrderedDict
from pathlib import Path
from urllib.parse import quote, unquote, urlparse

from .config import get_bundle_path, load_config


GENERATED_REPOS_MARKER = "# Generated AeroLIT repository variables"
SERVER_BOOTSTRAP_REPO_MARKER = "# Generated AeroLIT server bootstrap repository"
DEFAULT_SERVER_BOOTSTRAP_REPO_FILE = "/etc/yum.repos.d/zz-aerolit-server-bootstrap.repo"
SERVER_BOOTSTRAP_REPO_ENABLE_GLOB = "aerolit-server-bootstrap-*"

SERVER_PREREQUISITE_PACKAGES = [
    "ansible-core",
    "podman",
    "nfs-utils",
    "dnsmasq",
]

SERVER_FIREWALL_PREREQUISITE_PACKAGES = [
    "firewalld",
]

DEFAULT_PATH_FOR_ANSIBLE = "/home/unix/sysadmin"
SUPPORTED_RHEL_KEYS = ["rhel7", "rhel8", "rhel9", "rhel10"]

SKIP_SCAN_DIRS = [
    ".git",
    "__pycache__",
    ".pytest_cache",
    ".mypy_cache",
    ".tox",
    ".venv",
    "venv",
]

URL_PATTERN = re.compile(r"^[A-Za-z][A-Za-z0-9+.-]*://")


class RepoConfigError(Exception):
    """Raised when configure repos input is invalid."""


class RepoReport(object):
    """Collect configure repos validation results."""

    def __init__(self):
        self.ok = []
        self.info = []
        self.warnings = []
        self.errors = []

    def add_ok(self, message):
        self.ok.append(message)

    def add_info(self, message):
        self.info.append(message)

    def add_warning(self, message):
        self.warnings.append(message)

    def add_error(self, message):
        self.errors.append(message)

    def print_report(self):
        print("AeroLIT repository validation")
        print("")

        for message in self.ok:
            print("[OK] {}".format(message))

        for message in self.info:
            print("[INFO] {}".format(message))

        for message in self.warnings:
            print("[WARN] {}".format(message))

        for message in self.errors:
            print("[FAIL] {}".format(message))

        print("")
        print("Summary:")
        print("  OK: {}".format(len(self.ok)))
        print("  Info: {}".format(len(self.info)))
        print("  Warnings: {}".format(len(self.warnings)))
        print("  Failures: {}".format(len(self.errors)))

    def exit_code(self):
        return 1 if self.errors else 0


def timestamp():
    """Return a filesystem-safe timestamp."""
    return datetime.datetime.now().strftime("%Y%m%d-%H%M%S")


def read_text(path):
    """Read text while tolerating non-UTF8 bytes."""
    with open(str(path), "r", encoding="utf-8", errors="ignore") as handle:
        return handle.read()


def write_text(path, content):
    """Write text and create parent directories."""
    path = Path(path)

    if not path.parent.exists():
        path.parent.mkdir(parents=True)

    with open(str(path), "w", encoding="utf-8") as handle:
        handle.write(content)


def yaml_quote(value):
    """Quote a scalar as a YAML string."""
    value = str(value)
    return "'" + value.replace("'", "''") + "'"


def yaml_value(value):
    """Render a simple YAML scalar value."""
    if isinstance(value, bool):
        return "true" if value else "false"

    if value is None:
        return "null"

    if isinstance(value, int):
        return str(value)

    return yaml_quote(value)


def normalize_bool(value, default=False):
    """Normalize a config boolean."""
    if value is None:
        return default

    if isinstance(value, bool):
        return value

    value = str(value).strip().lower()

    if value in ("1", "true", "yes", "y", "on"):
        return True

    if value in ("0", "false", "no", "n", "off"):
        return False

    return default


def firewall_management_enabled_from_config(default=True):
    """Return saved server firewall intent from aerolitctl config."""
    try:
        config = load_config()
    except Exception:
        return default

    server = config.get("server", {}) or {}
    firewall = server.get("firewall", {}) or {}

    return normalize_bool(firewall.get("manage"), default=default)


def default_server_prerequisite_packages(firewall_manage=None):
    """Return default server prerequisite packages for the saved firewall intent."""
    packages = list(SERVER_PREREQUISITE_PACKAGES)

    if firewall_manage is None:
        firewall_manage = firewall_management_enabled_from_config(default=True)

    if normalize_bool(firewall_manage, default=True):
        packages.extend(SERVER_FIREWALL_PREREQUISITE_PACKAGES)

    return packages


def absolute_path(path, cwd=None):
    """Return an absolute normalized Path without requiring it to exist."""
    path = Path(path)

    if not path.is_absolute():
        path = Path(cwd or os.getcwd()) / path

    return Path(os.path.abspath(str(path)))


def normalize_client_path(path):
    """Normalize the client-visible bundle path."""
    value = str(path or "").strip()

    if not value:
        raise RepoConfigError("--path-for-ansible cannot be empty")

    if not value.startswith("/"):
        raise RepoConfigError(
            "--path-for-ansible must be an absolute client-visible path"
        )

    if value != "/":
        value = value.rstrip("/")

    return value


def is_url(value):
    """Return True when value looks like a URL."""
    return bool(URL_PATTERN.match(str(value).strip()))


def is_file_url(value):
    """Return True when value is a file:// URL."""
    return str(value).strip().lower().startswith("file://")


def trim_url(value):
    """Normalize a non-file URL without breaking scheme syntax."""
    value = str(value).strip()

    if value.endswith("/") and not re.match(
        r"^[A-Za-z][A-Za-z0-9+.-]*://[^/]+/$",
        value,
    ):
        value = value.rstrip("/")

    return value


def file_url_for_path(path):
    """Return a URL-encoded file:// baseurl for a local path."""
    path = absolute_path(path)
    return "file://{}".format(quote(str(path), safe="/:"))


def local_path_from_file_url(value):
    """Return local path from file:// URL."""
    parsed = urlparse(str(value).strip())

    if parsed.scheme.lower() != "file":
        raise RepoConfigError("Expected file:// URL, got: {}".format(value))

    if parsed.netloc not in ["", "localhost"]:
        raise RepoConfigError(
            "Only local file:// URLs are supported for validation, got: {}".format(
                value
            )
        )

    return absolute_path(unquote(parsed.path))


def local_path_from_source(source, cwd=None):
    """Return local path for local path or file:// source, else None."""
    source = str(source).strip()

    if is_file_url(source):
        return local_path_from_file_url(source)

    if is_url(source):
        return None

    return absolute_path(source, cwd=cwd)


def source_to_server_baseurl(source, cwd=None):
    """Return server-local baseurl from a path or URL source."""
    source = str(source).strip()

    if not source:
        raise RepoConfigError("Repository source cannot be empty")

    if is_file_url(source):
        return file_url_for_path(local_path_from_file_url(source))

    if is_url(source):
        return trim_url(source)

    return file_url_for_path(absolute_path(source, cwd=cwd))


def source_to_client_baseurl(bundle_path, path_for_ansible, source, cwd=None):
    """Return client-visible baseurl for a repo source."""
    source = str(source).strip()
    bundle_path = absolute_path(bundle_path)

    if is_url(source) and not is_file_url(source):
        return trim_url(source)

    local_path = local_path_from_source(source, cwd=cwd)
    if local_path is None:
        return source_to_server_baseurl(source, cwd=cwd)

    try:
        rel = local_path.relative_to(bundle_path)
    except ValueError:
        return file_url_for_path(local_path)

    client_path = Path(path_for_ansible) / rel
    return file_url_for_path(client_path)


def configured_bundle_path():
    """Return configured bundle path from aerolitctl config."""
    config = load_config()
    bundle_path = get_bundle_path(config)

    if not bundle_path:
        raise RepoConfigError(
            "No bundle path is configured. Run: aerolitctl configure init"
        )

    return absolute_path(bundle_path)


def repos_generated_vars_file(bundle_path):
    """Return managed generated repo vars path."""
    return (
        absolute_path(bundle_path)
        / "collections-hub"
        / "ansible"
        / "group_vars"
        / "all"
        / "aerolitctl_repos_generated.yml"
    )


def current_os_major():
    """Return current OS major version from /etc/os-release when available."""
    os_release = Path("/etc/os-release")

    if not os_release.exists():
        return None

    content = read_text(os_release)

    match = re.search(r'^VERSION_ID="?([0-9]+)', content, re.MULTILINE)
    if match:
        return match.group(1)

    return None


def repo_dir_is_valid(path):
    """Return True when path looks like a yum/dnf repo directory."""
    path = Path(path)
    return (path / "repodata" / "repomd.xml").exists()


def repo_source_is_valid(source, cwd=None):
    """Return True when a local repo source is valid; remote URLs are not verified."""
    local_path = local_path_from_source(source, cwd=cwd)

    if local_path is None:
        return True

    return repo_dir_is_valid(local_path)


def sanitize_repo_id(value):
    """Return a safe repo id fragment."""
    value = str(value).strip().lower()
    value = re.sub(r"[^a-z0-9_.-]+", "-", value)
    value = value.strip("-._")

    if not value:
        value = "repo"

    return value


def infer_rhel_key_from_path(path):
    """Infer rhel7/rhel8/rhel9/rhel10 from a repo path or URL."""
    text = str(path).lower()

    patterns = [
        r"rhel[-_./ ]*([0-9]+)",
        r"redhat[-_./ ]*([0-9]+)",
        r"rh[-_./ ]*([0-9]+)",
        r"el[-_./ ]*([0-9]+)",
    ]

    for pattern in patterns:
        match = re.search(pattern, text)
        if match:
            key = "rhel{}".format(match.group(1))
            if key in SUPPORTED_RHEL_KEYS:
                return key

    return None


def infer_repo_role_from_path(path):
    """Infer BaseOS/AppStream/extra role from a repo path or URL."""
    text = str(path).lower()
    parts = [part.lower() for part in re.split(r"[\\/]+", text)]
    basename = parts[-1] if parts else ""

    if "baseos" in parts or basename == "baseos":
        return "baseos"

    if "appstream" in parts or basename == "appstream":
        return "appstream"

    if basename in ["crb", "codeready-builder", "codeready_builder"]:
        return "crb"

    if basename in ["epel"]:
        return "epel"

    return "extra"


def source_kind_for_path(bundle_path, path):
    """Return a readable source kind for a repo path."""
    bundle_path = absolute_path(bundle_path)
    path = absolute_path(path)

    try:
        rel = path.relative_to(bundle_path)
    except ValueError:
        return "external-local"

    rel_text = str(rel).lower()

    if rel_text.startswith("extracted_isos/") or rel_text.startswith("isos/"):
        return "extracted-iso"

    if rel_text.startswith("repos/"):
        return "bundle-repos"

    if "iso" in rel_text:
        return "extracted-iso"

    return "bundle"


def source_kind_for_source(bundle_path, source):
    """Return source kind for local path, file URL, or remote URL."""
    if is_url(source) and not is_file_url(source):
        return "external-url"

    local_path = local_path_from_source(source)
    if local_path is None:
        return "external"

    return source_kind_for_path(bundle_path, local_path)


def bounded_repo_walk(root, max_depth=8):
    """Yield repo directories under root without unbounded traversal."""
    root = Path(root)

    if not root.exists():
        return

    root = absolute_path(root)
    root_depth = len(root.parts)

    for current, dirs, files in os.walk(str(root)):
        current_path = Path(current)
        depth = len(current_path.parts) - root_depth

        if depth > max_depth:
            dirs[:] = []
            continue

        dirs[:] = sorted(
            [
                item
                for item in dirs
                if item not in SKIP_SCAN_DIRS
            ]
        )

        if "repodata" in dirs and repo_dir_is_valid(current_path):
            dirs[:] = []
            yield current_path


def candidate_scan_roots(bundle_path):
    """Return bundle roots worth scanning for yum/dnf repositories."""
    bundle_path = absolute_path(bundle_path)

    roots = [
        bundle_path / "extracted_isos",
        bundle_path / "isos",
        bundle_path / "repos",
        bundle_path,
    ]

    result = []
    seen = set()

    for root in roots:
        key = str(root)
        if key in seen:
            continue

        seen.add(key)
        result.append(root)

    return result


def build_repo_entry(
    bundle_path,
    path_for_ansible,
    source,
    repo_id=None,
    name=None,
    os_key=None,
    role=None,
    source_kind=None,
    server_bootstrap_enabled=True,
    provisioning_enabled=True,
):
    """Build one normalized repo entry from a local path or URL."""
    bundle_path = absolute_path(bundle_path)
    path_for_ansible = normalize_client_path(path_for_ansible)
    source = str(source).strip()

    inferred_os_key = os_key or infer_rhel_key_from_path(source)
    inferred_role = role or infer_repo_role_from_path(source)
    local_path = local_path_from_source(source)
    source_kind = source_kind or source_kind_for_source(bundle_path, source)

    if repo_id:
        repo_id = sanitize_repo_id(repo_id)
    elif inferred_os_key:
        if inferred_role in ["baseos", "appstream"]:
            repo_id = "aerolit-{}-{}".format(inferred_os_key, inferred_role)
        else:
            repo_short = sanitize_repo_id(Path(str(source)).name)
            repo_id = "aerolit-{}-{}".format(inferred_os_key, repo_short)
    else:
        repo_short = sanitize_repo_id(Path(str(source)).name)
        repo_id = "aerolit-unknown-{}".format(repo_short)

    if not name:
        if inferred_os_key:
            prefix = "aerolit-{}-".format(inferred_os_key)
            name = "AeroLIT {} {}".format(
                inferred_os_key,
                repo_id.replace(prefix, ""),
            )
        else:
            name = "AeroLIT unknown {}".format(
                repo_id.replace("aerolit-unknown-", "")
            )

    return OrderedDict(
        [
            ("id", repo_id),
            ("name", name),
            ("os_key", inferred_os_key),
            ("role", inferred_role),
            ("source_kind", source_kind),
            ("source", source),
            ("path", str(local_path) if local_path is not None else None),
            ("server_baseurl", source_to_server_baseurl(source)),
            (
                "client_baseurl",
                source_to_client_baseurl(bundle_path, path_for_ansible, source),
            ),
            ("server_bootstrap_enabled", bool(server_bootstrap_enabled)),
            ("provisioning_enabled", bool(provisioning_enabled)),
        ]
    )


def dedupe_repo_entries(entries):
    """Dedupe repo ids while preserving order."""
    result = []
    used_ids = {}

    for entry in entries:
        base_id = entry["id"]
        repo_id = base_id

        if repo_id in used_ids:
            source_hint = entry.get("path") or entry.get("source") or "repo"
            parent = sanitize_repo_id(Path(str(source_hint)).parent.name)
            repo_id = "{}-{}".format(base_id, parent)

        count = used_ids.get(repo_id, 0)
        if count:
            repo_id = "{}-{}".format(repo_id, count + 1)

        used_ids[repo_id] = used_ids.get(repo_id, 0) + 1
        entry["id"] = repo_id
        result.append(entry)

    return result


def discover_bundle_repos(bundle_path, path_for_ansible=DEFAULT_PATH_FOR_ANSIBLE):
    """Discover yum/dnf repos in common AeroLIT bundle locations."""
    bundle_path = absolute_path(bundle_path)
    path_for_ansible = normalize_client_path(path_for_ansible)

    entries = []
    seen_paths = set()

    for root in candidate_scan_roots(bundle_path):
        for repo_path in bounded_repo_walk(root):
            key = str(absolute_path(repo_path))
            if key in seen_paths:
                continue

            seen_paths.add(key)
            entries.append(
                build_repo_entry(
                    bundle_path,
                    path_for_ansible,
                    str(repo_path),
                    server_bootstrap_enabled=True,
                    provisioning_enabled=True,
                )
            )

    return dedupe_repo_entries(entries)


def parse_provision_repo_spec(spec):
    """Parse OS:ID=PATH_OR_URL provisioning repo override spec."""
    spec = str(spec).strip()

    if "=" not in spec:
        raise RepoConfigError(
            "Provisioning repo override must be OS:ID=PATH_OR_URL, got: {}".format(
                spec
            )
        )

    left, source = spec.split("=", 1)

    if ":" not in left:
        raise RepoConfigError(
            "Provisioning repo override must be OS:ID=PATH_OR_URL, got: {}".format(
                spec
            )
        )

    os_key, repo_id = left.split(":", 1)
    os_key = os_key.strip().lower()
    repo_id = sanitize_repo_id(repo_id)

    if os_key not in SUPPORTED_RHEL_KEYS:
        raise RepoConfigError(
            "Unsupported provisioning repo OS '{}'. Supported values: {}".format(
                os_key,
                ", ".join(SUPPORTED_RHEL_KEYS),
            )
        )

    if not repo_id:
        raise RepoConfigError("Provisioning repo id cannot be empty: {}".format(spec))

    if not source.strip():
        raise RepoConfigError("Provisioning repo source cannot be empty: {}".format(spec))

    return os_key, repo_id, source.strip()


def explicit_entries_from_args(bundle_path, path_for_ansible, args):
    """Return explicit repo entries requested by CLI args.

    These args are optional hooks. The CLI parser can expose them later without
    changing this discovery engine.
    """
    entries = []
    current_major = current_os_major()
    current_os_key = "rhel{}".format(current_major) if current_major else None

    server_baseos = getattr(args, "server_baseos_source", None)
    server_appstream = getattr(args, "server_appstream_source", None)

    if server_baseos:
        entries.append(
            build_repo_entry(
                bundle_path,
                path_for_ansible,
                server_baseos,
                repo_id="aerolit-{}-server-baseos".format(
                    current_os_key or "server"
                ),
                name="AeroLIT server bootstrap BaseOS",
                os_key=current_os_key,
                role="baseos",
                source_kind="manual-server",
                server_bootstrap_enabled=True,
                provisioning_enabled=False,
            )
        )

    if server_appstream:
        entries.append(
            build_repo_entry(
                bundle_path,
                path_for_ansible,
                server_appstream,
                repo_id="aerolit-{}-server-appstream".format(
                    current_os_key or "server"
                ),
                name="AeroLIT server bootstrap AppStream",
                os_key=current_os_key,
                role="appstream",
                source_kind="manual-server",
                server_bootstrap_enabled=True,
                provisioning_enabled=False,
            )
        )

    provision_specs = []
    provision_specs.extend(getattr(args, "provision_repo", None) or [])
    provision_specs.extend(getattr(args, "provision_extra_repo", None) or [])

    for spec in provision_specs:
        os_key, repo_id, source = parse_provision_repo_spec(spec)
        entries.append(
            build_repo_entry(
                bundle_path,
                path_for_ansible,
                source,
                repo_id="aerolit-{}-{}".format(os_key, repo_id),
                name="AeroLIT {} {}".format(os_key, repo_id),
                os_key=os_key,
                role=infer_repo_role_from_path(source),
                source_kind="manual-provisioning",
                server_bootstrap_enabled=False,
                provisioning_enabled=True,
            )
        )

    return entries


def build_repo_plan(bundle_path, path_for_ansible, args):
    """Build the full repo plan from explicit overrides plus auto-discovery."""
    no_auto_discovery = (
        getattr(args, "no_auto_discovery", False)
        or getattr(args, "disable_auto_discovery", False)
    )

    entries = []
    entries.extend(explicit_entries_from_args(bundle_path, path_for_ansible, args))

    if not no_auto_discovery:
        entries.extend(discover_bundle_repos(bundle_path, path_for_ansible))

    return dedupe_repo_entries(entries)


def grouped_provisioning_repos(entries):
    """Return discovered provisioning repos grouped by rhel key."""
    grouped = OrderedDict()

    for key in SUPPORTED_RHEL_KEYS:
        grouped[key] = []

    for entry in entries:
        if entry.get("provisioning_enabled") is False:
            continue

        os_key = entry.get("os_key")
        if os_key in grouped:
            grouped[os_key].append(entry)

    return grouped


def server_bootstrap_pair(entries, os_major=None):
    """Return best BaseOS/AppStream pair for the current server OS."""
    os_major = os_major or current_os_major()
    os_key = "rhel{}".format(os_major) if os_major else None

    result = OrderedDict(
        [
            ("os_key", os_key),
            ("baseos", None),
            ("appstream", None),
        ]
    )

    if not os_key:
        return result

    for entry in entries:
        if entry.get("server_bootstrap_enabled") is False:
            continue

        if entry.get("os_key") != os_key:
            continue

        if entry.get("role") == "baseos" and result["baseos"] is None:
            result["baseos"] = entry

        if entry.get("role") == "appstream" and result["appstream"] is None:
            result["appstream"] = entry

    return result


def discover_provisioning_repos(entries):
    """Return discovered provisioning repos grouped by RHEL key.

    This is a small Phase 1 compatibility wrapper around the newer grouped
    repository helper.
    """
    return grouped_provisioning_repos(entries)


def discover_server_bootstrap_repos(entries, os_major=None):
    """Return discovered server bootstrap BaseOS/AppStream repo pair.

    This is a small Phase 1 compatibility wrapper around server_bootstrap_pair().
    """
    return server_bootstrap_pair(entries, os_major=os_major)


def server_bootstrap_repo_file(path=None):
    """Return the server bootstrap yum/dnf repo file path."""
    return absolute_path(path or DEFAULT_SERVER_BOOTSTRAP_REPO_FILE)


def server_bootstrap_repo_section_id(repo):
    """Return a safe server bootstrap .repo section id."""
    os_key = repo.get("os_key") or "unknown"
    role = repo.get("role") or "repo"
    return sanitize_repo_id("aerolit-server-bootstrap-{}-{}".format(os_key, role))


def render_server_bootstrap_repo_content(entries, os_major=None):
    """Render /etc/yum.repos.d repo content for server bootstrap packages."""
    server_pair = server_bootstrap_pair(entries, os_major=os_major)
    os_key = server_pair.get("os_key")

    if not os_key:
        raise RepoConfigError(
            "Cannot render server bootstrap repo because current server OS could not be detected."
        )

    missing = []
    if not server_pair.get("baseos"):
        missing.append("BaseOS")
    if not server_pair.get("appstream"):
        missing.append("AppStream")

    if missing:
        raise RepoConfigError(
            "Cannot render server bootstrap repo for {} because {} repo(s) were not discovered.".format(
                os_key,
                ", ".join(missing),
            )
        )

    lines = [
        SERVER_BOOTSTRAP_REPO_MARKER,
        "# Created by aerolitctl.",
        "# Used as a local fallback when server prerequisite packages are missing.",
        "# Safe to leave enabled for disconnected AeroLIT servers.",
        "",
    ]

    for role in ["baseos", "appstream"]:
        repo = server_pair[role]
        section_id = server_bootstrap_repo_section_id(repo)

        lines.extend(
            [
                "[{}]".format(section_id),
                "name=AeroLIT server bootstrap {} {}".format(os_key, role),
                "baseurl={}".format(repo["server_baseurl"]),
                "enabled=1",
                "gpgcheck=0",
                "",
            ]
        )

    return "\n".join(lines)


def server_bootstrap_repo_looks_managed(path):
    """Return True when an existing server bootstrap repo file is safe to update."""
    path = Path(path)

    if not path.exists():
        return True

    content = read_text(path)
    return SERVER_BOOTSTRAP_REPO_MARKER in content


def write_server_bootstrap_repo(
    entries,
    repo_file=None,
    dry_run=False,
    force=False,
    no_backup=False,
):
    """Create/update the server bootstrap yum/dnf repo file."""
    repo_file = server_bootstrap_repo_file(repo_file)
    content = render_server_bootstrap_repo_content(entries)
    exists = repo_file.exists()
    current = read_text(repo_file) if exists else None

    if current == content:
        print("Already current: server bootstrap repo")
        return "unchanged"

    if exists and not force and not server_bootstrap_repo_looks_managed(repo_file):
        raise RepoConfigError(
            "{} exists but does not look like an aerolitctl-managed server bootstrap repo. "
            "Refusing to overwrite it without --force.".format(repo_file)
        )

    if dry_run:
        if exists:
            backup_file(
                repo_file,
                dry_run=True,
                no_backup=no_backup,
                label="server bootstrap repo",
            )
            print("Would update: server bootstrap repo")
            return "would_update"

        print("Would create: server bootstrap repo")
        return "would_create"

    backup_file(
        repo_file,
        dry_run=False,
        no_backup=no_backup,
        label="server bootstrap repo",
    )
    write_text(repo_file, content)

    if exists:
        print("Updated: server bootstrap repo")
        return "updated"

    print("Created: server bootstrap repo")
    return "created"


def normalize_package_list(packages=None, firewall_manage=None):
    """Return a stable list of package names.

    Accepts None, a string, or a list. Strings may be comma or whitespace
    separated so CLI callers can pass repeated args or comma-separated values.

    When packages is None, the default package list follows the saved firewall
    intent. firewalld is included only when firewall management is enabled.
    """
    if packages is None:
        packages = default_server_prerequisite_packages(
            firewall_manage=firewall_manage,
        )

    if isinstance(packages, str):
        raw_items = re.split(r"[\s,]+", packages.strip())
    else:
        raw_items = []
        for item in packages:
            raw_items.extend(re.split(r"[\s,]+", str(item).strip()))

    result = []
    seen = set()

    for item in raw_items:
        item = str(item).strip()
        if not item:
            continue

        if item in seen:
            continue

        seen.add(item)
        result.append(item)

    return result


def normalize_repo_patterns(value=None):
    """Return repo patterns from None, string, or list input."""
    if value is None:
        return []

    if isinstance(value, str):
        raw_items = re.split(r"[\s,]+", value.strip())
    else:
        raw_items = []
        for item in value:
            raw_items.extend(re.split(r"[\s,]+", str(item).strip()))

    result = []
    seen = set()

    for item in raw_items:
        item = str(item).strip()
        if not item:
            continue

        if item in seen:
            continue

        seen.add(item)
        result.append(item)

    return result


def package_manager_command():
    """Return available package manager command."""
    if shutil.which("dnf"):
        return "dnf"

    if shutil.which("yum"):
        return "yum"

    raise RepoConfigError("Neither dnf nor yum was found on this system.")


def run_command(command, dry_run=False, check=False, capture_output=False):
    """Run a command and return rc/stdout/stderr."""
    command = [str(item) for item in command]

    if dry_run:
        print("Would run: {}".format(" ".join(command)))
        return 0, "", ""

    if capture_output:
        process = subprocess.Popen(
            command,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
            universal_newlines=True,
        )
        stdout, stderr = process.communicate()
    else:
        process = subprocess.Popen(command)
        stdout, stderr = process.communicate()

    if check and process.returncode != 0:
        message = "Command failed with exit code {}: {}".format(
            process.returncode,
            " ".join(command),
        )

        if stderr:
            message = "{}\n{}".format(message, stderr.strip())

        raise RepoConfigError(message)

    return process.returncode, stdout or "", stderr or ""


def repo_option_args(enablerepo=None, disablerepo=None):
    """Return dnf/yum repo enable/disable option args."""
    args = []

    for repo in normalize_repo_patterns(disablerepo):
        args.append("--disablerepo={}".format(repo))

    for repo in normalize_repo_patterns(enablerepo):
        args.append("--enablerepo={}".format(repo))

    return args


def installed_server_packages(packages=None):
    """Return prerequisite packages that are currently installed."""
    packages = normalize_package_list(packages)

    if not packages:
        return []

    if not shutil.which("rpm"):
        raise RepoConfigError("rpm command was not found on this system.")

    installed = []

    for package in packages:
        rc, _stdout, _stderr = run_command(
            ["rpm", "-q", package],
            capture_output=True,
        )

        if rc == 0:
            installed.append(package)

    return installed


def missing_server_packages(packages=None):
    """Return prerequisite packages that are not currently installed."""
    packages = normalize_package_list(packages)
    installed = set(installed_server_packages(packages))

    return [
        package
        for package in packages
        if package not in installed
    ]


def dnf_can_resolve_packages(packages, enablerepo=None, disablerepo=None):
    """Return True if dnf/yum can resolve all packages from selected repos."""
    packages = normalize_package_list(packages)

    if not packages:
        return True

    manager = package_manager_command()
    repo_args = repo_option_args(enablerepo=enablerepo, disablerepo=disablerepo)
    unresolved = []

    for package in packages:
        repoquery_command = [manager] + repo_args + ["-q", "repoquery", package]
        rc, stdout, _stderr = run_command(
            repoquery_command,
            capture_output=True,
        )

        if rc == 0 and stdout.strip():
            continue

        list_command = [manager] + repo_args + ["-q", "list", "available", package]
        rc, stdout, _stderr = run_command(
            list_command,
            capture_output=True,
        )

        if rc == 0 and stdout.strip():
            continue

        unresolved.append(package)

    if unresolved:
        print(
            "Unable to resolve package(s): {}".format(
                ", ".join(unresolved)
            )
        )
        return False

    return True


def clean_dnf_metadata(enablerepo=None, disablerepo=None, dry_run=False):
    """Clean and rebuild package manager metadata for selected repos."""
    manager = package_manager_command()
    repo_args = repo_option_args(enablerepo=enablerepo, disablerepo=disablerepo)

    run_command(
        [manager] + repo_args + ["clean", "metadata"],
        dry_run=dry_run,
        check=not dry_run,
    )

    run_command(
        [manager] + repo_args + ["makecache"],
        dry_run=dry_run,
        check=not dry_run,
    )


def install_server_packages(packages, enablerepo=None, disablerepo=None, dry_run=False):
    """Install missing server prerequisite packages through dnf/yum."""
    requested_packages = normalize_package_list(packages)
    missing_packages = missing_server_packages(requested_packages)

    if not missing_packages:
        print("Server prerequisite packages are already installed.")
        return 0

    manager = package_manager_command()
    repo_args = repo_option_args(enablerepo=enablerepo, disablerepo=disablerepo)

    print(
        "Installing missing server prerequisite package(s): {}".format(
            ", ".join(missing_packages)
        )
    )

    command = [manager, "-y"] + repo_args + ["install"] + missing_packages

    if dry_run:
        run_command(command, dry_run=True)
        return 0

    run_command(command, check=True)

    still_missing = missing_server_packages(requested_packages)
    if still_missing:
        raise RepoConfigError(
            "Package install finished, but these prerequisite packages are still missing: {}".format(
                ", ".join(still_missing)
            )
        )

    return 0


def ensure_server_prerequisites_with_repo_fallback(
    entries,
    repo_file=None,
    packages=None,
    dry_run=False,
    force=False,
    no_backup=False,
    bootstrap_only=False,
    firewall_manage=None,
):
    """Ensure server prerequisite packages exist, using AeroLIT repo fallback.

    Flow:
    - Determine missing prerequisite packages.
    - Try existing enabled system repos first unless bootstrap_only=True.
    - If existing repos cannot resolve the packages, write the AeroLIT server
      bootstrap repo.
    - Clean/rebuild metadata for the bootstrap repo.
    - Install missing packages from aerolit-server-bootstrap-*.
    - Leave the generated repo configured.
    """
    packages = normalize_package_list(
        packages,
        firewall_manage=firewall_manage,
    )
    missing_packages = missing_server_packages(packages)

    print("AeroLIT server prerequisite package plan")
    print("")
    print("{:<32} {}".format("Dry run:", dry_run))
    print("{:<32} {}".format("Bootstrap only:", bootstrap_only))
    print("{:<32} {}".format("Repo file:", server_bootstrap_repo_file(repo_file)))
    print("{:<32} {}".format("Requested packages:", ", ".join(packages)))
    print(
        "{:<32} {}".format(
            "Missing packages:",
            ", ".join(missing_packages) if missing_packages else "none",
        )
    )
    print("")

    if not missing_packages:
        print("All server prerequisite packages are already installed.")
        return 0

    if not bootstrap_only:
        print("Checking existing enabled system repos first...")
        if dnf_can_resolve_packages(missing_packages):
            print("Existing enabled repos can resolve missing prerequisite packages.")
            return install_server_packages(
                missing_packages,
                dry_run=dry_run,
            )

        print("")
        print("Existing enabled repos cannot resolve all missing prerequisite packages.")
        print("Falling back to the AeroLIT server bootstrap repo.")
        print("")

    write_server_bootstrap_repo(
        entries,
        repo_file=repo_file,
        dry_run=dry_run,
        force=force,
        no_backup=no_backup,
    )

    clean_dnf_metadata(
        enablerepo=SERVER_BOOTSTRAP_REPO_ENABLE_GLOB,
        disablerepo="*",
        dry_run=dry_run,
    )

    if dry_run:
        print("")
        print(
            "Would verify package resolution using repo pattern: {}".format(
                SERVER_BOOTSTRAP_REPO_ENABLE_GLOB
            )
        )
        print(
            "Would install missing packages from AeroLIT server bootstrap repo: {}".format(
                ", ".join(missing_packages)
            )
        )
        return 0

    if not dnf_can_resolve_packages(
        missing_packages,
        enablerepo=SERVER_BOOTSTRAP_REPO_ENABLE_GLOB,
        disablerepo="*",
    ):
        raise RepoConfigError(
            "AeroLIT server bootstrap repo was written, but it cannot resolve: {}".format(
                ", ".join(missing_packages)
            )
        )

    return install_server_packages(
        missing_packages,
        enablerepo=SERVER_BOOTSTRAP_REPO_ENABLE_GLOB,
        disablerepo="*",
        dry_run=False,
    )


def render_repo_item(lines, repo, indent, baseurl_key):
    """Render one repo item as a YAML list item at indent."""
    spaces = " " * indent
    lines.append("{}- id: {}".format(spaces, yaml_value(repo["id"])))
    lines.append("{}  name: {}".format(spaces, yaml_value(repo["name"])))
    lines.append("{}  role: {}".format(spaces, yaml_value(repo["role"])))
    lines.append("{}  source_kind: {}".format(spaces, yaml_value(repo["source_kind"])))
    lines.append("{}  baseurl: {}".format(spaces, yaml_value(repo[baseurl_key])))
    lines.append(
        "{}  server_baseurl: {}".format(
            spaces,
            yaml_value(repo["server_baseurl"]),
        )
    )
    lines.append("{}  enabled: true".format(spaces))
    lines.append("{}  gpgcheck: false".format(spaces))


def render_repo_dict(lines, repo, indent, baseurl_key):
    """Render one repo as a YAML dictionary at indent."""
    spaces = " " * indent
    lines.append("{}id: {}".format(spaces, yaml_value(repo["id"])))
    lines.append("{}name: {}".format(spaces, yaml_value(repo["name"])))
    lines.append("{}role: {}".format(spaces, yaml_value(repo["role"])))
    lines.append("{}source_kind: {}".format(spaces, yaml_value(repo["source_kind"])))
    lines.append("{}baseurl: {}".format(spaces, yaml_value(repo[baseurl_key])))
    lines.append(
        "{}server_baseurl: {}".format(
            spaces,
            yaml_value(repo["server_baseurl"]),
        )
    )
    lines.append("{}enabled: true".format(spaces))
    lines.append("{}gpgcheck: false".format(spaces))


def render_grouped_repo_mapping(lines, variable_name, grouped, baseurl_key):
    """Render grouped rhelX repo mapping."""
    lines.append("{}:".format(variable_name))

    for os_key, repos in grouped.items():
        if not repos:
            lines.append("  {}: []".format(os_key))
            continue

        lines.append("  {}:".format(os_key))
        for repo in repos:
            render_repo_item(lines, repo, indent=4, baseurl_key=baseurl_key)


def render_repos_generated_vars(bundle_path, path_for_ansible, entries):
    """Render managed repository group_vars YAML."""
    bundle_path = absolute_path(bundle_path)
    generated_path = repos_generated_vars_file(bundle_path)
    server_pair = server_bootstrap_pair(entries)
    grouped = grouped_provisioning_repos(entries)

    lines = [
        "---",
        GENERATED_REPOS_MARKER,
        "# Created by aerolitctl configure repos.",
        "# This file lives in group_vars/all and feeds server/provisioning repo roles.",
        "# Do not store secrets in this file.",
        "",
        "aerolitctl_repos_generated: true",
        "aerolitctl_repos_bundle_path: {}".format(yaml_value(str(bundle_path))),
        "aerolitctl_repos_client_base_path: {}".format(yaml_value(path_for_ansible)),
        "aerolitctl_repos_generated_file: {}".format(yaml_value(str(generated_path))),
        "",
        "aerolitctl_server_bootstrap_repos:",
        "  os_key: {}".format(yaml_value(server_pair["os_key"])),
    ]

    if server_pair["baseos"]:
        lines.append(
            "  baseos: {}".format(
                yaml_value(server_pair["baseos"]["server_baseurl"])
            )
        )
        lines.append("  baseos_repo:")
        render_repo_dict(
            lines,
            server_pair["baseos"],
            indent=4,
            baseurl_key="server_baseurl",
        )
    else:
        lines.append("  baseos: null")
        lines.append("  baseos_repo: null")

    if server_pair["appstream"]:
        lines.append(
            "  appstream: {}".format(
                yaml_value(server_pair["appstream"]["server_baseurl"])
            )
        )
        lines.append("  appstream_repo:")
        render_repo_dict(
            lines,
            server_pair["appstream"],
            indent=4,
            baseurl_key="server_baseurl",
        )
    else:
        lines.append("  appstream: null")
        lines.append("  appstream_repo: null")

    lines.append("")
    if entries:
        lines.append("aerolitctl_repository_inventory:")
        for repo in entries:
            render_repo_item(lines, repo, indent=2, baseurl_key="client_baseurl")
            lines.append("    os_key: {}".format(yaml_value(repo.get("os_key"))))
            lines.append(
                "    provisioning_enabled: {}".format(
                    yaml_value(repo.get("provisioning_enabled"))
                )
            )
            lines.append(
                "    server_bootstrap_enabled: {}".format(
                    yaml_value(repo.get("server_bootstrap_enabled"))
                )
            )
    else:
        lines.append("aerolitctl_repository_inventory: []")

    lines.append("")
    render_grouped_repo_mapping(
        lines,
        "aerolitctl_provisioning_repositories",
        grouped,
        baseurl_key="client_baseurl",
    )

    lines.extend(
        [
            "",
            "# Compatibility variable matching the existing bootstrap/provisioning repo shape.",
        ]
    )
    render_grouped_repo_mapping(
        lines,
        "append_bootstrap_yum_repositories",
        grouped,
        baseurl_key="client_baseurl",
    )

    lines.append("")
    return "\n".join(lines)


def file_looks_managed(path):
    """Return True when existing generated repo vars file is safe to update."""
    path = Path(path)

    if not path.exists():
        return True

    content = read_text(path)
    return (
        GENERATED_REPOS_MARKER in content
        and "aerolitctl_repos_generated: true" in content
    )


def backup_file(path, dry_run=False, no_backup=False, label=None):
    """Create a timestamped backup next to an existing file."""
    path = Path(path)
    label = label or str(path)

    if no_backup or not path.exists():
        return None

    backup_path = path.with_name(
        "{}.aerolit-backup-{}".format(path.name, timestamp())
    )

    if dry_run:
        print("Would back up {} to {}".format(label, backup_path))
        return backup_path

    shutil.copy2(str(path), str(backup_path))
    print("Backed up {} to {}".format(label, backup_path))
    return backup_path


def write_if_changed(path, content, dry_run=False, force=False, no_backup=False):
    """Create/update generated repo vars only when content differs."""
    path = Path(path)
    exists = path.exists()
    current = read_text(path) if exists else None

    if current == content:
        print("Already current: generated repository vars")
        return "unchanged"

    if exists and not force and not file_looks_managed(path):
        raise RepoConfigError(
            "{} exists but does not look like an aerolitctl-managed repo vars file. "
            "Refusing to overwrite it without --force.".format(path)
        )

    if dry_run:
        if exists:
            backup_file(
                path,
                dry_run=True,
                no_backup=no_backup,
                label="generated repository vars",
            )
            print("Would update: generated repository vars")
            return "would_update"

        print("Would create: generated repository vars")
        return "would_create"

    backup_file(
        path,
        dry_run=False,
        no_backup=no_backup,
        label="generated repository vars",
    )
    write_text(path, content)

    if exists:
        print("Updated: generated repository vars")
        return "updated"

    print("Created: generated repository vars")
    return "created"


def collect_requested_os_keys(args):
    """Return OS keys explicitly requested by configure repos arguments."""
    requested = set()

    provision_specs = []
    provision_specs.extend(getattr(args, "provision_repo", None) or [])
    provision_specs.extend(getattr(args, "provision_extra_repo", None) or [])

    for spec in provision_specs:
        left = str(spec).split("=", 1)[0].strip().lower()

        if ":" not in left:
            continue

        os_key = left.split(":", 1)[0].strip()

        if os_key in SUPPORTED_RHEL_KEYS:
            requested.add(os_key)

    return requested


def path_contains_rpms(path, max_depth=3):
    """Return True if a path contains RPM files within a bounded depth."""
    path = Path(path)

    if not path.exists() or not path.is_dir():
        return False

    root_depth = len(path.parts)

    for current, dirs, files in os.walk(str(path)):
        current_path = Path(current)
        depth = len(current_path.parts) - root_depth

        if depth > max_depth:
            dirs[:] = []
            continue

        if any(item.lower().endswith(".rpm") for item in files):
            return True

        dirs[:] = [
            item
            for item in dirs
            if item not in SKIP_SCAN_DIRS
        ]

    return False


def invalid_expected_repo_paths(bundle_path, os_key):
    """Return repo-looking paths for an OS that exist but lack repodata."""
    bundle_path = absolute_path(bundle_path)
    major = os_key.replace("rhel", "")
    invalid = []
    seen = set()

    iso_roots = [
        bundle_path / "extracted_isos" / "{}iso".format(os_key),
        bundle_path / "extracted_isos" / os_key,
        bundle_path / "extracted_isos" / "rhel{}iso".format(major),
        bundle_path / "extracted_isos" / "rhel{}".format(major),
        bundle_path / "isos" / "{}iso".format(os_key),
        bundle_path / "isos" / os_key,
        bundle_path / "isos" / "rhel{}iso".format(major),
        bundle_path / "isos" / "rhel{}".format(major),
    ]

    for root in iso_roots:
        for repo_name in ["BaseOS", "baseos", "AppStream", "appstream"]:
            candidate = root / repo_name
            key = str(candidate)

            if key in seen:
                continue

            seen.add(key)

            if candidate.exists() and not repo_dir_is_valid(candidate):
                invalid.append(candidate)

    repos_root = bundle_path / "repos"
    if repos_root.exists():
        for current, dirs, files in os.walk(str(repos_root)):
            current_path = Path(current)

            dirs[:] = [
                item
                for item in dirs
                if item not in SKIP_SCAN_DIRS
            ]

            if infer_rhel_key_from_path(current_path) != os_key:
                continue

            if repo_dir_is_valid(current_path):
                dirs[:] = []
                continue

            if path_contains_rpms(current_path, max_depth=2):
                key = str(current_path)
                if key not in seen:
                    seen.add(key)
                    invalid.append(current_path)
                dirs[:] = []

    return invalid


def validate_repos_state(bundle_path, path_for_ansible, entries, requested_os_keys=None):
    """Validate discovered repository state."""
    report = RepoReport()
    bundle_path = absolute_path(bundle_path)
    generated_path = repos_generated_vars_file(bundle_path)
    requested_os_keys = set(requested_os_keys or [])

    if bundle_path.exists():
        report.add_ok("Bundle path found: {}".format(bundle_path))
    else:
        report.add_error("Bundle path missing: {}".format(bundle_path))

    group_vars_all = generated_path.parent
    if group_vars_all.exists():
        report.add_ok("group_vars/all directory found: {}".format(group_vars_all))
    else:
        report.add_error("group_vars/all directory missing: {}".format(group_vars_all))

    if entries:
        report.add_ok("Discovered/planned {} repo(s).".format(len(entries)))
    else:
        report.add_warning(
            "No repos with repodata/repomd.xml were discovered or configured."
        )

    seen_baseurls = set()
    for entry in entries:
        baseurl = entry.get("server_baseurl")
        if baseurl in seen_baseurls:
            report.add_warning("Duplicate repo baseurl in plan: {}".format(baseurl))
        seen_baseurls.add(baseurl)

        source = entry.get("source")
        if source and is_url(source) and not is_file_url(source):
            report.add_warning(
                "Remote repo source was not validated locally: {}".format(source)
            )
            continue

        local_path = entry.get("path")
        if local_path and repo_dir_is_valid(local_path):
            report.add_ok("Repo path valid: {}".format(local_path))
        elif local_path:
            report.add_error(
                "Repo path missing repodata/repomd.xml: {}".format(local_path)
            )

    grouped = grouped_provisioning_repos(entries)
    for os_key, repos in grouped.items():
        if repos:
            report.add_ok(
                "{} provisioning repos discovered: {}".format(os_key, len(repos))
            )
            continue

        invalid_paths = invalid_expected_repo_paths(bundle_path, os_key)

        if os_key in requested_os_keys:
            report.add_warning(
                "{} provisioning repos not discovered, but that OS was explicitly requested.".format(
                    os_key
                )
            )
        elif invalid_paths:
            report.add_warning(
                "{} repo-looking path(s) exist but are missing repodata/repomd.xml.".format(
                    os_key
                )
            )
            for invalid_path in invalid_paths:
                report.add_warning(
                    "Invalid {} repo path: {}".format(os_key, invalid_path)
                )
        else:
            report.add_info(
                "{} provisioning repos not discovered; no repo-looking path was found.".format(
                    os_key
                )
            )

    unknown = [
        entry
        for entry in entries
        if not entry.get("os_key")
    ]
    if unknown:
        report.add_warning(
            "{} repo(s) discovered but OS version could not be inferred.".format(
                len(unknown)
            )
        )

    server_pair = server_bootstrap_pair(entries)
    if server_pair["os_key"]:
        if server_pair["baseos"] and server_pair["appstream"]:
            report.add_ok(
                "Server bootstrap BaseOS/AppStream pair found for {}.".format(
                    server_pair["os_key"]
                )
            )
        else:
            report.add_warning(
                "Server bootstrap BaseOS/AppStream pair incomplete for {}.".format(
                    server_pair["os_key"]
                )
            )
    else:
        report.add_warning("Could not determine current server OS major version.")

    if generated_path.exists():
        if file_looks_managed(generated_path):
            report.add_ok("Generated repo vars file found: {}".format(generated_path))
        else:
            report.add_error(
                "Generated repo vars exists but is not aerolitctl-managed: {}".format(
                    generated_path
                )
            )
    else:
        report.add_warning(
            "Generated repo vars file not created yet: {}".format(generated_path)
        )

    try:
        normalize_client_path(path_for_ansible)
    except RepoConfigError as exc:
        report.add_error(str(exc))

    return report


def print_repos_summary(bundle_path, path_for_ansible, entries):
    """Print readable repository discovery summary."""
    bundle_path = absolute_path(bundle_path)
    generated_path = repos_generated_vars_file(bundle_path)
    server_pair = server_bootstrap_pair(entries)
    grouped = grouped_provisioning_repos(entries)

    print("AeroLIT managed repository configuration")
    print("")
    print("{:<32} {}".format("Bundle path:", bundle_path))
    print("{:<32} {}".format("Client bundle path:", path_for_ansible))
    print("{:<32} {}".format("Generated vars:", generated_path))
    print("{:<32} {}".format("Current server OS:", server_pair["os_key"] or "unknown"))
    print("{:<32} {}".format("Total repos planned:", len(entries)))
    print("")

    print("Server bootstrap repos:")
    if server_pair["baseos"]:
        print("  BaseOS: {}".format(server_pair["baseos"]["server_baseurl"]))
    else:
        print("  BaseOS: not discovered")

    if server_pair["appstream"]:
        print("  AppStream: {}".format(server_pair["appstream"]["server_baseurl"]))
    else:
        print("  AppStream: not discovered")

    print("")
    print("Provisioning repos:")

    for os_key, repos in grouped.items():
        print("  {}:".format(os_key))

        if not repos:
            print("    - none discovered")
            continue

        for repo in repos:
            print(
                "    - {} [{} / {}]".format(
                    repo["id"],
                    repo["role"],
                    repo["source_kind"],
                )
            )
            print("      server: {}".format(repo["server_baseurl"]))
            print("      client: {}".format(repo["client_baseurl"]))

    unknown = [
        entry
        for entry in entries
        if not entry.get("os_key")
    ]
    if unknown:
        print("")
        print("Repos discovered with unknown OS:")
        for repo in unknown:
            print("  - {}: {}".format(repo["id"], repo["server_baseurl"]))


class GuidedRepoArgs(object):
    """Simple args container for guided configure repos choices."""


def repos_text_prompt(prompt, default=None, allow_empty=False, blank_label="skip"):
    """Prompt for text with readable default behavior."""
    if default is not None and str(default) != "":
        rendered = "{} [default: {}; Enter=default]: ".format(prompt, default)
    elif allow_empty:
        rendered = "{} [Enter={}]: ".format(prompt, blank_label)
    else:
        rendered = "{}: ".format(prompt)

    while True:
        value = input(rendered).strip()

        if value:
            return value

        if default is not None:
            return default

        if allow_empty:
            return ""

        print("This value is required. Enter a value or press Ctrl+C to cancel.")


def repos_yes_no_prompt(prompt, default=False):
    """Ask a yes/no guided question."""
    default_text = "Y" if default else "N"
    choices = "Y/n" if default else "y/N"

    while True:
        value = input(
            "{} [{}; Enter={}]: ".format(prompt, choices, default_text)
        ).strip().lower()

        if not value:
            return default

        if value in ("y", "yes"):
            return True

        if value in ("n", "no"):
            return False

        print("Please answer yes or no. Valid responses are: y, yes, n, no.")


def repos_choose_option(text, options, default_index=0):
    """Choose one guided option from a numbered list."""
    if not options:
        raise RepoConfigError("repos_choose_option requires at least one option")

    default_index = max(0, min(default_index, len(options) - 1))

    print("")
    print(text)
    print("")

    for idx, option in enumerate(options, start=1):
        marker = "*" if idx - 1 == default_index else " "
        print("{} {}) {}".format(marker, idx, option))

    while True:
        value = input(
            "Choose 1-{} [default: {}; Enter=default]: ".format(
                len(options),
                default_index + 1,
            )
        ).strip()

        if value == "":
            return default_index

        if value.isdigit():
            parsed = int(value)
            if 1 <= parsed <= len(options):
                return parsed - 1

        print(
            "Invalid selection: {}. Choose a number from 1 through {}.".format(
                value,
                len(options),
            )
        )


