def build_guided_repos_args(args):
    """Return an args object populated from guided configure repos prompts."""
    if not sys.stdin.isatty():
        raise RepoConfigError(
            "configure repos --guided requires an interactive terminal. "
            "Use --show, --validate, --refresh, or --refresh --dry-run for non-interactive use."
        )

    guided_args = GuidedRepoArgs()
    guided_args.__dict__.update(vars(args))
    guided_args.guided = False

    original_show = bool(getattr(args, "show", False))
    original_dry_run = bool(getattr(args, "dry_run", False))

    print_repos_guided_intro()

    source_mode = choose_repo_source_mode()
    guided_args.no_auto_discovery = source_mode == "custom"

    current_bundle_path = getattr(args, "bundle_path", None)
    if current_bundle_path:
        current_bundle_path = absolute_path(current_bundle_path)
    else:
        current_bundle_path = configured_bundle_path()

    bundle_path = choose_repos_bundle_path(source_mode, current_bundle_path)
    guided_args.bundle_path = str(bundle_path)

    current_client_path = (
        getattr(args, "path_for_ansible", None)
        or DEFAULT_PATH_FOR_ANSIBLE
    )
    guided_args.path_for_ansible = choose_repos_client_path(
        source_mode,
        current_client_path,
    )

    print("")
    print("#" * 80)
    print("# Step 4. Bundle discovery")
    print("#" * 80)
    print("")

    if source_mode == "custom":
        print("Custom-only mode selected. Bundle repository discovery is disabled.")
    else:
        print("AeroLIT will scan the bundle for repositories under locations like:")
        print("  - extracted_isos/")
        print("  - repos/")
        print("")
        print("A valid yum/dnf repository has:")
        print("  repodata/repomd.xml")

    guided_add_server_bootstrap_sources(guided_args)

    if source_mode in ("bundle_custom", "custom"):
        guided_add_provisioning_repos(guided_args, source_mode)
    else:
        guided_args.provision_repo = list(getattr(args, "provision_repo", None) or [])
        guided_args.provision_extra_repo = list(
            getattr(args, "provision_extra_repo", None) or []
        )

    entries = build_repo_plan(
        bundle_path,
        path_for_ansible=guided_args.path_for_ansible,
        args=guided_args,
    )

    print("")
    print("#" * 80)
    print("# Step 7. Final repository plan")
    print("#" * 80)
    print("")
    print_repos_summary(bundle_path, guided_args.path_for_ansible, entries)

    print("")
    print("#" * 80)
    print("# Step 8. Validate final repository plan")
    print("#" * 80)

    if repos_yes_no_prompt("Validate before saving?", default=True):
        print("")
        report = validate_repos_state(
            bundle_path,
            guided_args.path_for_ansible,
            entries,
            requested_os_keys=collect_requested_os_keys(guided_args),
        )
        report.print_report()

        if report.errors:
            if not repos_yes_no_prompt(
                "Validation found failures. Continue anyway?",
                default=False,
            ):
                raise RepoConfigError("Guided configure repos cancelled.")

    if original_show:
        print("")
        print("Original --show option was provided; guided mode will show the final plan only.")
        save_choice = 3
    else:
        save_choice = choose_guided_save_action(entries)

    guided_args.show = False
    guided_args.validate = False
    guided_args.refresh = False
    guided_args.write_server_bootstrap = False
    guided_args.ensure_server_prereqs = False
    guided_args.dry_run = False

    if save_choice == 0:
        guided_args.refresh = True
    elif save_choice == 1:
        guided_args.refresh = True
        guided_args.write_server_bootstrap = True
    elif save_choice == 2:
        guided_args.refresh = True
        guided_args.dry_run = True
    else:
        guided_args.show = True

    if original_dry_run and not guided_args.show:
        guided_args.dry_run = True

    return guided_args


def run_configure_repos(args):
    """Run aerolitctl configure repos."""
    try:
        if getattr(args, "guided", False):
            guided_args = build_guided_repos_args(args)
            return run_configure_repos(guided_args)

        bundle_path = getattr(args, "bundle_path", None)
        if bundle_path:
            bundle_path = absolute_path(bundle_path)
        else:
            bundle_path = configured_bundle_path()

        path_for_ansible = normalize_client_path(
            getattr(args, "path_for_ansible", None) or DEFAULT_PATH_FOR_ANSIBLE
        )

        dry_run = getattr(args, "dry_run", False)
        show_only = getattr(args, "show", False)
        validate_requested = getattr(args, "validate", False)
        refresh_requested = getattr(args, "refresh", False)
        force = getattr(args, "force", False)
        no_backup = getattr(args, "no_backup", False)
        write_server_bootstrap_requested = getattr(args, "write_server_bootstrap", False)
        server_bootstrap_repo_path = getattr(args, "server_bootstrap_repo_file", None)
        ensure_server_prereqs_requested = getattr(args, "ensure_server_prereqs", False)
        server_prereq_packages = getattr(args, "server_prereq_package", None) or None
        server_bootstrap_only = getattr(args, "server_bootstrap_only", False)

        entries = build_repo_plan(
            bundle_path,
            path_for_ansible=path_for_ansible,
            args=args,
        )

        requested_os_keys = collect_requested_os_keys(args)

        if (
            not show_only
            and not validate_requested
            and not refresh_requested
            and not write_server_bootstrap_requested
            and not ensure_server_prereqs_requested
        ):
            show_only = True

        if show_only:
            print_repos_summary(bundle_path, path_for_ansible, entries)

        if refresh_requested:
            print("")
            print("AeroLIT configure repos plan")
            print("")
            print("{:<32} {}".format("Dry run:", dry_run))
            print("{:<32} {}".format("Bundle path:", bundle_path))
            print("{:<32} {}".format("Client bundle path:", path_for_ansible))
            print(
                "{:<32} {}".format(
                    "Generated vars:",
                    repos_generated_vars_file(bundle_path),
                )
            )
            print("{:<32} {}".format("Planned repos:", len(entries)))
            print("{:<32} {}".format("Backups enabled:", not no_backup))
            print("{:<32} {}".format("Force overwrite:", force))
            print("")

            report = validate_repos_state(
                bundle_path,
                path_for_ansible,
                entries,
                requested_os_keys=requested_os_keys,
            )
            if report.errors:
                print("")
                print("Refusing to write invalid managed repository configuration.")
                print("")
                report.print_report()
                return report.exit_code()

            content = render_repos_generated_vars(
                bundle_path,
                path_for_ansible,
                entries,
            )
            write_if_changed(
                repos_generated_vars_file(bundle_path),
                content,
                dry_run=dry_run,
                force=force,
                no_backup=no_backup,
            )

            if dry_run:
                print("")
                print("Dry run complete. No files were changed.")
            else:
                print("")
                print("AeroLIT repository configuration saved.")

        if write_server_bootstrap_requested:
            print("")
            print("AeroLIT server bootstrap repo plan")
            print("")
            print("{:<32} {}".format("Dry run:", dry_run))
            print("{:<32} {}".format("Repo file:", server_bootstrap_repo_file(server_bootstrap_repo_path)))
            print("{:<32} {}".format("Backups enabled:", not no_backup))
            print("{:<32} {}".format("Force overwrite:", force))
            print("")

            report = validate_repos_state(
                bundle_path,
                path_for_ansible,
                entries,
                requested_os_keys=requested_os_keys,
            )
            if report.errors:
                print("")
                print("Refusing to write invalid server bootstrap repo.")
                print("")
                report.print_report()
                return report.exit_code()

            write_server_bootstrap_repo(
                entries,
                repo_file=server_bootstrap_repo_path,
                dry_run=dry_run,
                force=force,
                no_backup=no_backup,
            )

            if dry_run:
                print("")
                print("Dry run complete. No server bootstrap repo file was changed.")
            else:
                print("")
                print("AeroLIT server bootstrap repo saved.")

        if ensure_server_prereqs_requested:
            print("")

            report = validate_repos_state(
                bundle_path,
                path_for_ansible,
                entries,
                requested_os_keys=requested_os_keys,
            )
            if report.errors:
                print("")
                print("Refusing to ensure server prerequisites with invalid repository state.")
                print("")
                report.print_report()
                return report.exit_code()

            ensure_server_prerequisites_with_repo_fallback(
                entries,
                repo_file=server_bootstrap_repo_path,
                packages=server_prereq_packages,
                dry_run=dry_run,
                force=force,
                no_backup=no_backup,
                bootstrap_only=server_bootstrap_only,
            )

        if (
            validate_requested
            or refresh_requested
            or show_only
            or write_server_bootstrap_requested
            or ensure_server_prereqs_requested
        ):
            print("")
            report = validate_repos_state(
                bundle_path,
                path_for_ansible,
                entries,
                requested_os_keys=requested_os_keys,
            )
            report.print_report()
            return report.exit_code()

        return 0

    except RepoConfigError as exc:
        print("ERROR: {}".format(exc))
        return 1
