"""AeroLIT bundle manifest helpers.

The bundle manifest is the lightweight identity/layout file for an AeroLIT
bundle. It intentionally stores relative paths so the bundle can be copied or
moved without making the manifest stale.
"""

from __future__ import print_function

from pathlib import Path

from .paths import bundle_manifest_file


MANIFEST_SCHEMA_VERSION = 1
BUNDLE_LAYOUT_VERSION = 1


RELATIVE_PATHS = [
    ("collections_hub", "collections-hub", "directory"),
    ("ansible_dir", "collections-hub/ansible", "directory"),
    ("group_vars_dir", "collections-hub/ansible/group_vars", "directory"),
    ("group_vars_all_dir", "collections-hub/ansible/group_vars/all", "directory"),
    (
        "generated_server_vars",
        "collections-hub/ansible/group_vars/all/aerolitctl_server_generated.yml",
        "file",
    ),
    ("inventory", "collections-hub/ansible/inventory", "file"),
    ("ansible_cfg", "collections-hub/ansible/ansible.cfg", "file"),
    ("pxe_server_playbook", "collections-hub/ansible/pxe_server.yml", "file"),
    ("ansible_controller_playbook", "collections-hub/ansible/ansible_controller.yml", "file"),
    ("templates_dir", "collections-hub/templates", "directory"),
    ("repos_dir", "repos", "directory"),
    ("files_dir", "files", "directory"),
    ("extracted_isos_dir", "extracted_isos", "directory"),
    ("bootstrap", "bootstrap.sh", "file"),
    ("sync_preserve", "collections-hub/.sync-preserve", "file"),
    ("gitlab_ci", "collections-hub/.gitlab-ci.yml", "file"),
]


CAPABILITIES = [
    ("pxe_server", True),
    ("ansible_controller", True),
    ("nfs_bundle_export", True),
    ("offline_repositories", True),
    ("extracted_isos", True),
]


def manifest_path(bundle_path):
    """Return the bundle manifest path."""
    return bundle_manifest_file(bundle_path)


def _bool_text(value):
    """Return a deterministic lowercase YAML boolean string."""
    return "true" if value else "false"


def _normalize_bool(value):
    """Normalize YAML/string bool-ish values for validation."""
    if isinstance(value, bool):
        return value

    if isinstance(value, str):
        lowered = value.strip().lower()
        if lowered in ("true", "yes", "on", "1"):
            return True
        if lowered in ("false", "no", "off", "0"):
            return False

    return None


def render_bundle_manifest():
    """Render the default AeroLIT bundle manifest as deterministic YAML text."""
    lines = [
        "# AeroLIT bundle manifest",
        "# Generated by aerolitctl. Relative paths are relative to this bundle root.",
        "",
        "kind: AeroLITBundle",
        "schema_version: {}".format(MANIFEST_SCHEMA_VERSION),
        "layout_version: {}".format(BUNDLE_LAYOUT_VERSION),
        "",
        "bundle:",
        "  name: aerolit-bundle",
        "  managed_by: aerolitctl",
        "",
        "paths:",
    ]

    for name, relative_path, path_type in RELATIVE_PATHS:
        lines.append("  {}: {}".format(name, relative_path))

    lines.extend(
        [
            "",
            "path_types:",
        ]
    )

    for name, relative_path, path_type in RELATIVE_PATHS:
        lines.append("  {}: {}".format(name, path_type))

    lines.extend(
        [
            "",
            "capabilities:",
        ]
    )

    for name, enabled in CAPABILITIES:
        lines.append("  {}: {}".format(name, _bool_text(enabled)))

    lines.append("")
    return "\n".join(lines)


def write_bundle_manifest(bundle_path, force=False, dry_run=False):
    """Create or update the bundle manifest.

    Existing differing manifests are not overwritten unless force=True.

    Returns:
      path: Path to the manifest
      action: created, updated, unchanged, skipped_existing,
              would_create, would_update, or would_skip_existing
      changed: bool
      dry_run: bool
    """
    path = manifest_path(bundle_path)
    content = render_bundle_manifest()

    exists = path.exists()
    current = None

    if exists:
        try:
            current = path.read_text(encoding="utf-8")
        except UnicodeDecodeError:
            current = path.read_text(encoding="utf-8", errors="ignore")

    if exists and current == content:
        return {
            "path": path,
            "action": "unchanged",
            "changed": False,
            "dry_run": dry_run,
        }

    if exists and not force:
        return {
            "path": path,
            "action": "would_skip_existing" if dry_run else "skipped_existing",
            "changed": False,
            "dry_run": dry_run,
        }

    if exists:
        action = "would_update" if dry_run else "updated"
    else:
        action = "would_create" if dry_run else "created"

    if not dry_run:
        path.parent.mkdir(parents=True, exist_ok=True)
        path.write_text(content, encoding="utf-8")

    return {
        "path": path,
        "action": action,
        "changed": True,
        "dry_run": dry_run,
    }


def _load_yaml(path):
    """Load YAML from path."""
    try:
        import yaml
    except ImportError:
        return None, "PyYAML is not available; cannot parse bundle manifest"

    try:
        with open(str(path), "r", encoding="utf-8") as handle:
            data = yaml.safe_load(handle) or {}
    except Exception as exc:
        return None, "Could not parse bundle manifest {}: {}".format(path, exc)

    if not isinstance(data, dict):
        return None, "Bundle manifest should be a YAML mapping: {}".format(path)

    return data, None


def validate_bundle_manifest(bundle_path, required=False):
    """Validate the bundle manifest.

    Returns a list of findings:
      ("ok", message)
      ("warning", message)
      ("failure", message)
    """
    bundle_path = Path(bundle_path)
    path = manifest_path(bundle_path)
    findings = []

    if not path.exists():
        level = "failure" if required else "warning"
        findings.append((level, "Bundle manifest not found yet: {}".format(path)))
        return findings

    findings.append(("ok", "Bundle manifest found: {}".format(path)))

    data, error = _load_yaml(path)
    if error:
        findings.append(("failure", error))
        return findings

    if data.get("kind") != "AeroLITBundle":
        findings.append(
            (
                "failure",
                "Bundle manifest kind should be AeroLITBundle, got: {}".format(
                    data.get("kind")
                ),
            )
        )

    if data.get("schema_version") != MANIFEST_SCHEMA_VERSION:
        findings.append(
            (
                "failure",
                "Bundle manifest schema_version should be {}, got: {}".format(
                    MANIFEST_SCHEMA_VERSION,
                    data.get("schema_version"),
                ),
            )
        )

    if data.get("layout_version") != BUNDLE_LAYOUT_VERSION:
        findings.append(
            (
                "failure",
                "Bundle manifest layout_version should be {}, got: {}".format(
                    BUNDLE_LAYOUT_VERSION,
                    data.get("layout_version"),
                ),
            )
        )

    paths = data.get("paths") or {}
    path_types = data.get("path_types") or {}

    if not isinstance(paths, dict):
        findings.append(("failure", "Bundle manifest paths section should be a mapping"))
        paths = {}

    if not isinstance(path_types, dict):
        findings.append(("failure", "Bundle manifest path_types section should be a mapping"))
        path_types = {}

    for name, expected_relative_path, expected_type in RELATIVE_PATHS:
        actual_relative_path = paths.get(name)

        if actual_relative_path != expected_relative_path:
            findings.append(
                (
                    "failure",
                    "Bundle manifest path '{}' should be '{}', got '{}'".format(
                        name,
                        expected_relative_path,
                        actual_relative_path,
                    ),
                )
            )
            continue

        actual_type = path_types.get(name)
        if actual_type != expected_type:
            findings.append(
                (
                    "failure",
                    "Bundle manifest path type '{}' should be '{}', got '{}'".format(
                        name,
                        expected_type,
                        actual_type,
                    ),
                )
            )

        absolute_path = bundle_path / actual_relative_path

        if expected_type == "directory" and not absolute_path.is_dir():
            findings.append(
                (
                    "warning",
                    "Bundle manifest path '{}' is listed but directory is missing: {}".format(
                        name,
                        absolute_path,
                    ),
                )
            )
        elif expected_type == "file" and not absolute_path.exists():
            findings.append(
                (
                    "warning",
                    "Bundle manifest path '{}' is listed but file is missing: {}".format(
                        name,
                        absolute_path,
                    ),
                )
            )

    capabilities = data.get("capabilities") or {}
    if not isinstance(capabilities, dict):
        findings.append(("failure", "Bundle manifest capabilities section should be a mapping"))
        capabilities = {}

    for name, expected_value in CAPABILITIES:
        raw_value = capabilities.get(name)
        actual_value = _normalize_bool(raw_value)

        if actual_value is None:
            findings.append(
                (
                    "warning",
                    "Bundle manifest capability '{}' should be {}, got {}".format(
                        name,
                        expected_value,
                        raw_value,
                    ),
                )
            )
            continue

        if actual_value != expected_value:
            findings.append(
                (
                    "warning",
                    "Bundle manifest capability '{}' should be {}, got {}".format(
                        name,
                        expected_value,
                        raw_value,
                    ),
                )
            )

    return findings


def manifest_has_failures(findings):
    """Return True when validation findings include failures."""
    return any(level == "failure" for level, message in findings)