"""Safe file and directory helpers for aerolitctl."""
import shutil
from datetime import datetime
from pathlib import Path
from .paths import BACKUP_DIR
class InitReport(object):
    """Collect actions taken during initialization."""
    def __init__(self, verbose=False):
        self.verbose = verbose
        self.created = []
        self.updated = []
        self.existing = []
        self.backed_up = []
        self.warnings = []
        self.errors = []
        self.dry_run = []
        self.skipped = []
    def add(self, category, message):
        getattr(self, category).append(message)
    def print_summary(self):
        print("")
        print("AeroLIT initialization summary")
        print("")
        sections = [
            ("Created", self.created),
            ("Updated", self.updated),
            ("Already existed / skipped", self.existing),
            ("Skipped by option", self.skipped),
            ("Backed up", self.backed_up),
            ("Dry-run actions", self.dry_run),
            ("Warnings", self.warnings),
            ("Errors", self.errors),
        ]
        for title, values in sections:
            if not values:
                continue
            print("{}:".format(title))
            for value in values:
                print("  - {}".format(value))
            print("")
def timestamp():
    """Return filesystem-safe UTC timestamp."""
    return datetime.utcnow().strftime("%Y%m%d-%H%M%S")
def ensure_directory(path, report, dry_run=False):
    """Create a directory if needed."""
    path = Path(path)
    if path.exists():
        if path.is_dir():
            report.add("existing", str(path))
            return True
        report.add("errors", "{} exists but is not a directory".format(path))
        return False
    if dry_run:
        report.add("dry_run", "Would create directory {}".format(path))
        return True
    path.mkdir(parents=True, exist_ok=True)
    report.add("created", str(path))
    return True
def relative_or_safe_name(path, base_path=None):
    """Return a useful backup-relative path."""
    path = Path(path)
    if base_path is not None:
        try:
            return path.relative_to(Path(base_path))
        except ValueError:
            pass
    return Path(str(path).lstrip("/"))
def backup_existing(
    path,
    report,
    dry_run=False,
    backup_root=None,
    base_path=None,
    no_backup=False,
):
    """Back up an existing file or directory."""
    path = Path(path)
    if not path.exists():
        return None
    if no_backup:
        report.add("warnings", "Backup disabled for existing path: {}".format(path))
        return None
    if backup_root is None:
        backup_root = BACKUP_DIR / timestamp()
    backup_root = Path(backup_root)
    relative_path = relative_or_safe_name(path, base_path=base_path)
    backup_path = backup_root / relative_path
    if dry_run:
        report.add("dry_run", "Would back up {} to {}".format(path, backup_path))
        return backup_path
    backup_path.parent.mkdir(parents=True, exist_ok=True)
    if path.is_dir():
        shutil.copytree(str(path), str(backup_path))
    else:
        shutil.copy2(str(path), str(backup_path))
    report.add("backed_up", "{} -> {}".format(path, backup_path))
    return backup_path
def remove_path(path):
    """Remove a file or directory."""
    path = Path(path)
    if not path.exists():
        return
    if path.is_dir():
        shutil.rmtree(str(path))
    else:
        path.unlink()
def write_text_file(
    path,
    content,
    report,
    overwrite=False,
    backup=True,
    dry_run=False,
    backup_root=None,
    base_path=None,
    no_backup=False,
):
    """Write a text file safely."""
    path = Path(path)
    existed_before = path.exists()
    if existed_before and not overwrite:
        report.add("existing", str(path))
        return False
    if existed_before and backup:
        backup_existing(
            path,
            report,
            dry_run=dry_run,
            backup_root=backup_root,
            base_path=base_path,
            no_backup=no_backup,
        )
    if dry_run:
        action = "Would update" if existed_before else "Would create"
        report.add("dry_run", "{} file {}".format(action, path))
        return True
    path.parent.mkdir(parents=True, exist_ok=True)
    path.write_text(content)
    if existed_before:
        report.add("updated", str(path))
    else:
        report.add("created", str(path))
    return True
def copy_path(
    source,
    destination,
    report,
    overwrite=False,
    backup=True,
    dry_run=False,
    backup_root=None,
    base_path=None,
    no_backup=False,
):
    """Copy a file or directory safely."""
    source = Path(source)
    destination = Path(destination)
    existed_before = destination.exists()
    if not source.exists():
        report.add("errors", "Required source path not found: {}".format(source))
        return False
    if existed_before and not overwrite:
        report.add("existing", str(destination))
        return False
    if existed_before and backup:
        backup_existing(
            destination,
            report,
            dry_run=dry_run,
            backup_root=backup_root,
            base_path=base_path,
            no_backup=no_backup,
        )
    if dry_run:
        action = "Would replace" if existed_before else "Would copy"
        report.add("dry_run", "{} {} -> {}".format(action, source, destination))
        return True
    destination.parent.mkdir(parents=True, exist_ok=True)
    if existed_before:
        remove_path(destination)
    if source.is_dir():
        shutil.copytree(str(source), str(destination))
    else:
        shutil.copy2(str(source), str(destination))
    if existed_before:
        report.add("updated", "{} <- {}".format(destination, source))
    else:
        report.add("created", "{} <- {}".format(destination, source))
    return True
def read_lines(path):
    """Read file lines preserving line endings."""
    path = Path(path)
    with path.open("r") as handle:
        return handle.readlines()
def fragment_without_last_line(path):
    """Return file content without the last line."""
    lines = read_lines(path)
    return "".join(lines[:-1])
def fragment_without_first_and_last_line(path):
    """Return file content without the first and last lines."""
    lines = read_lines(path)
    return "".join(lines[1:-1])
def fragment_without_first_line(path):
    """Return file content without the first line."""
    lines = read_lines(path)
    return "".join(lines[1:])

