.nf
aerolitctl settings show
aerolitctl settings export --redact -o aerolitctl-settings-redacted.yml
aerolitctl settings import --dry-run aerolitctl-settings.yml
sudo aerolitctl settings import --merge aerolitctl-settings.yml
.fi
