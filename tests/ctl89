#!/usr/bin/env python3
"""Validate aerolitctl section-1 man pages without requiring groff/mandoc."""

from __future__ import print_function

import argparse
import re
import shutil
import subprocess
import sys
from pathlib import Path


REQUIRED_PAGES = (
    "aerolitctl.1",
    "aerolitctl-backup.1",
    "aerolitctl-bundle.1",
    "aerolitctl-configure.1",
    "aerolitctl-deploy.1",
    "aerolitctl-doctor.1",
    "aerolitctl-generate.1",
    "aerolitctl-logs.1",
    "aerolitctl-path.1",
    "aerolitctl-provision.1",
    "aerolitctl-settings.1",
    "aerolitctl-shell.1",
    "aerolitctl-status.1",
    "aerolitctl-sync.1",
    "aerolitctl-version.1",
)

REQUIRED_SECTIONS = ("NAME", "SYNOPSIS", "DESCRIPTION", "SEE ALSO")

IMPLEMENTED_TOP_COMMANDS = (
    "backup",
    "bundle",
    "configure",
    "deploy",
    "doctor",
    "generate",
    "logs",
    "path",
    "provision",
    "settings",
    "shell",
    "status",
    "sync",
    "version",
)

PLACEHOLDER_PATTERNS = (
    "TODO",
    "FIXME",
    "TBD",
    "placeholder text",
)


def read_text(path):
    return path.read_text(encoding="utf-8")


def section_names(text):
    return set(re.findall(r"^\.SH\s+(.+?)\s*$", text, flags=re.MULTILINE))


def validate_pages(man_dir):
    errors = []

    for name in REQUIRED_PAGES:
        path = man_dir / name
        if not path.exists():
            errors.append("missing required man page: {}".format(path))
            continue

        text = read_text(path)
        if not text.strip():
            errors.append("empty man page: {}".format(path))
            continue

        if not text.startswith(".TH "):
            errors.append("missing .TH header: {}".format(path))

        sections = section_names(text)
        for section in REQUIRED_SECTIONS:
            if section not in sections:
                errors.append("{} missing section {}".format(path, section))

        lowered = text.lower()
        for pattern in PLACEHOLDER_PATTERNS:
            if pattern.lower() in lowered:
                errors.append("{} contains placeholder or stale text: {}".format(path, pattern))

        for command in ("repo", "ui"):
            if re.search(r"\baerolitctl\s+{}\b".format(command), text):
                errors.append("{} documents unimplemented top command: {}".format(path, command))

    extra_pages = sorted(path.name for path in man_dir.glob("*.1") if path.name not in REQUIRED_PAGES)
    for name in extra_pages:
        errors.append("unexpected man page: {}".format(man_dir / name))

    return errors


def run_optional_linter(command, pages):
    binary = shutil.which(command)
    if not binary:
        print("{} not found; skipping optional roff lint.".format(command))
        return 0

    failures = 0
    for page in pages:
        if command == "mandoc":
            cmd = [binary, "-Tlint", str(page)]
        else:
            cmd = [binary, "-man", "-Tascii", str(page)]

        result = subprocess.run(cmd, stdout=subprocess.PIPE, stderr=subprocess.PIPE, text=True)
        if result.returncode != 0:
            failures += 1
            print("{} failed for {}".format(command, page))
            output = (result.stdout or "") + (result.stderr or "")
            if output.strip():
                print(output.strip())

    return 1 if failures else 0


def main(argv=None):
    parser = argparse.ArgumentParser(description="Validate aerolitctl man pages.")
    parser.add_argument("--root", default=".", help="Repository root. Default: current directory.")
    parser.add_argument("--lint", action="store_true", help="Run mandoc or groff if available.")
    args = parser.parse_args(argv)

    root = Path(args.root)
    man_dir = root / "man" / "man1"
    errors = validate_pages(man_dir)

    if errors:
        print("Man page validation failed:")
        for error in errors:
            print("  - {}".format(error))
        return 1

    print("Man page structure checks passed: {}".format(man_dir))

    if args.lint:
        pages = [man_dir / name for name in REQUIRED_PAGES]
        if shutil.which("mandoc"):
            return run_optional_linter("mandoc", pages)
        return run_optional_linter("groff", pages)

    return 0


if __name__ == "__main__":
    sys.exit(main())
















