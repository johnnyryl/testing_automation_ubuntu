"""AeroLIT configure all orchestration helper.

This command coordinates existing configure commands. It does not apply system
state directly. Real system changes still belong to deploy commands and Ansible
roles.
"""

from __future__ import print_function

import sys
from argparse import Namespace

from .ansible import run_configure_ansible
from .initialize import run_configure_init
from .pxe import run_configure_pxe
from .repos import DEFAULT_PATH_FOR_ANSIBLE, run_configure_repos
from .server import run_configure_server


SECTION_ORDER = [
    ("init", "Initialization"),
    ("server", "Server / PXE / Ansible Controller / NFS intent"),
    ("repos", "Repository discovery and generated repo vars"),
    ("ansible", "Ansible inventory and generated vars"),
    ("pxe", "PXE profile and generator inputs"),
]


def bool_arg(args, name, default=False):
    """Return a boolean argument value."""
    return bool(getattr(args, name, default))


def print_section(title):
    """Print a consistent configure all section heading."""
    print("")
    print("#" * 80)
    print("# {}".format(title))
    print("#" * 80)


def stdin_is_interactive():
    """Return True when prompts can be shown."""
    try:
        return sys.stdin.isatty()
    except AttributeError:
        return False


def prompt_yes_no(question, default=True):
    """Prompt for yes/no input."""
    default_text = "Y" if default else "N"
    choices = "Y/n" if default else "y/N"

    while True:
        value = input(
            "{} [{}; Enter={}]: ".format(question, choices, default_text)
        ).strip().lower()

        if not value:
            return default

        if value in ("y", "yes"):
            return True

        if value in ("n", "no"):
            return False

        print("Please answer yes or no.")


def section_is_skipped(args, section):
    """Return True when a configure all section is skipped by CLI option."""
    return bool_arg(args, "skip_{}".format(section), False)


def selected_sections(args):
    """Return enabled configure all sections in execution order."""
    return [
        (section, label)
        for section, label in SECTION_ORDER
        if not section_is_skipped(args, section)
    ]


def print_configure_all_plan(args, guided):
    """Show what configure all would coordinate."""
    print("")
    print("AeroLIT configure all plan")
    print("")
    print("{:<28} {}".format("Guided:", "yes" if guided else "no"))
    print("{:<28} {}".format("Dry run:", bool_arg(args, "dry_run")))
    print("{:<28} {}".format("Validate only:", bool_arg(args, "validate")))
    print("{:<28} {}".format("Non-interactive:", bool_arg(args, "non_interactive")))
    print(
        "{:<28} {}".format(
            "Bundle override:",
            getattr(args, "bundle", None) or "configured default",
        )
    )
    print(
        "{:<28} {}".format(
            "Server mode:",
            getattr(args, "mode", None) or "existing/default",
        )
    )
    print("")

    print("Sections:")
    for section, label in SECTION_ORDER:
        if section_is_skipped(args, section):
            print("  - {}: skipped".format(label))
        else:
            print("  - {}: enabled".format(label))

    print("")
    print("Configure all is an orchestration command. It coordinates existing")
    print("configure commands and does not directly run deploy actions, start")
    print("services, configure interfaces, open firewall ports, export NFS paths,")
    print("or run Ansible playbooks.")
    print("")
    print("Show complete. No files were changed.")


def validate_mode_combination(args):
    """Return an error string for conflicting configure all modes, else None."""
    show_only = bool_arg(args, "show")
    dry_run = bool_arg(args, "dry_run")
    validate_only = bool_arg(args, "validate")
    guided = bool_arg(args, "guided")
    non_interactive = bool_arg(args, "non_interactive")

    if show_only and dry_run:
        return "Use either --show or --dry-run, not both."

    if show_only and validate_only:
        return "Use either --show or --validate, not both."

    if dry_run and validate_only:
        return "Use either --dry-run or --validate, not both."

    if guided and non_interactive:
        return "Use either --guided or --non-interactive, not both."

    return None


def run_step(label, callback):
    """Run one configure all step and return its integer return code."""
    print_section(label)

    try:
        rc = callback()
    except Exception as exc:
        print("ERROR: {}".format(exc))
        rc = 1

    if rc is None:
        rc = 0

    try:
        rc = int(rc)
    except (TypeError, ValueError):
        rc = 1

    if rc != 0:
        print("")
        print("{} failed with return code {}.".format(label, rc))

    return rc


def configure_init_step(args, guided, dry_run, validate_only):
    """Run configure init step."""
    if validate_only:
        print("Initialization has no standalone validate mode. Skipping init validation.")
        return 0

    init_non_interactive = bool_arg(args, "non_interactive") or dry_run

    return run_configure_init(
        bundle_path=getattr(args, "bundle", None),
        force=bool_arg(args, "force"),
        dry_run=dry_run,
        non_interactive=init_non_interactive and not guided,
        verbose=bool_arg(args, "verbose"),
        no_backup=bool_arg(args, "no_backup"),
        skip_preserve_file=False,
        skip_ci_file=False,
        skip_ansible_files=False,
    )


