def run_configure_all(args):
    """Run aerolitctl configure all."""
    mode_error = validate_mode_combination(args)
    if mode_error:
        print("ERROR: {}".format(mode_error))
        return 1

    dry_run = bool_arg(args, "dry_run")
    show_only = bool_arg(args, "show")
    validate_only = bool_arg(args, "validate")
    non_interactive = bool_arg(args, "non_interactive")

    guided = bool_arg(args, "guided")
    if (
        not guided
        and not non_interactive
        and not dry_run
        and not show_only
        and not validate_only
    ):
        guided = True

    if show_only:
        print_configure_all_plan(args, guided=guided)
        return 0

    selected = selected_sections(args)
    if not selected:
        print("")
        print("No configure sections selected. No files were changed.")
        return 0

    if guided and not stdin_is_interactive():
        print(
            "ERROR: configure all --guided requires an interactive terminal. "
            "Use --show, --validate, --dry-run, or --non-interactive for automation."
        )
        return 1

    if (
        non_interactive
        and not dry_run
        and not validate_only
        and not section_is_skipped(args, "server")
    ):
        print("")
        print("ERROR: configure all --non-interactive cannot safely configure the server section yet.")
        print("")
        print("The server section needs site-specific network, DHCP, NFS, and firewall choices.")
        print("Use one of these instead:")
        print("  aerolitctl configure all --guided")
        print("  aerolitctl configure all --non-interactive --skip-server")
        print("  aerolitctl configure server --guided")
        return 1

    print("")
    print("AeroLIT configure all")
    print("")
    print("This command coordinates existing configure commands.")
    print("It writes configuration intent and generated inputs only.")
    print("It does not run deploy actions, start services, configure interfaces,")
    print("open firewall ports, export NFS paths, or run Ansible playbooks.")
    print("")

    completed = []
    skipped = []
    failures = []

    callbacks = {
        "init": lambda: configure_init_step(
            args,
            guided=guided,
            dry_run=dry_run,
            validate_only=validate_only,
        ),
        "server": lambda: configure_server_step(
            args,
            guided=guided,
            dry_run=dry_run,
            validate_only=validate_only,
        ),
        "repos": lambda: configure_repos_step(
            args,
            guided=guided,
            dry_run=dry_run,
            validate_only=validate_only,
        ),
        "ansible": lambda: configure_ansible_step(
            args,
            guided=guided,
            dry_run=dry_run,
            validate_only=validate_only,
        ),
        "pxe": lambda: configure_pxe_step(
            args,
            guided=guided,
            dry_run=dry_run,
            validate_only=validate_only,
        ),
    }

    for section, label in selected:
        if guided:
            print("")
            if not prompt_yes_no("Run {}?".format(label), default=True):
                print("Skipped: {}".format(label))
                skipped.append(label)
                continue

        rc = run_step(label, callbacks[section])

        if rc != 0:
            failures.append((label, rc))
            if not bool_arg(args, "continue_on_error"):
                break
            continue

        completed.append(label)

    print("")
    print("AeroLIT configure all summary")
    print("")

    if completed:
        print("Completed:")
        for label in completed:
            print("  - {}".format(label))
        print("")

    if skipped:
        print("Skipped:")
        for label in skipped:
            print("  - {}".format(label))
        print("")

    if failures:
        print("Failures:")
        for label, rc in failures:
            print("  - {} returned {}".format(label, rc))
        return 1

    if not completed and skipped:
        print("No configure sections were run. No files were changed.")
        return 0

    print("All selected configure sections completed successfully.")

    if dry_run:
        print("Dry run complete. No files were changed by configure all.")
    elif validate_only:
        print("Validation complete. No files were changed by configure all.")

    return 0
