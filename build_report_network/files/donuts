def menu_item(label: str, target: str) -> str:
    return f"item {target:<28} {label}"


class BootMenuRenderer:
    def __init__(self, config: GeneratorConfig, profiles: List[ProfileDefinition]) -> None:
        self.config = config
        self.profiles = profiles

    def visible_profiles(self) -> List[ProfileDefinition]:
        return [
            profile
            for profile in self.profiles
            if profile.show_in_main_menu
        ]

    def enabled_profiles(self) -> List[ProfileDefinition]:
        return [
            profile
            for profile in self.profiles
            if profile.show_in_main_menu and profile.implemented
        ]

    def render(self, detected: List[DetectedISO]) -> str:
        lines: List[str] = []

        lines.extend(
            [
                "#!ipxe",
                "",
                f"set server {self.config.pxe_server}",
                f"set port {self.config.pxe_port}",
                "set base http://${server}:${port}",
                "",
                f"console --picture ${{base}}{self.config.background_path} --left 360 --right 360 --top 140 --bottom 140 || goto main",
                "",
                ":main",
                "menu AeroLIT PXE Menu",
            ]
        )

        for profile in self.visible_profiles():
            lines.append(menu_item(profile.title, profile.menu_target))

        lines.extend(
            [
                menu_item("Utilities / Rescue", "rescue"),
                menu_item("Drop to iPXE shell", "shell"),
                "choose target || goto shell",
                "goto ${target}",
                "",
            ]
        )

        for profile in self.visible_profiles():
            if profile.implemented:
                lines.extend(self.render_implemented_profile_menu(profile, detected))
            else:
                lines.extend(self.render_unimplemented_profile_menu(profile, detected))

        lines.extend(self.render_boot_targets(detected))
        lines.extend(self.render_rescue_menu())
        lines.extend([":shell", "shell", ""])

        return "\n".join(lines)

    def render_implemented_profile_menu(
        self,
        profile: ProfileDefinition,
        detected: List[DetectedISO],
    ) -> List[str]:
        lines: List[str] = [
            f":{profile.menu_target}",
            f"menu {profile.title}",
        ]

        if not detected:
            lines.append(menu_item("No supported RHEL ISO trees detected", "main"))
        else:
            for item in detected:
                if profile.supports_os(item) and item.uefi and profile.uefi:
                    lines.append(
                        menu_item(
                            f"Install {item.title} {profile.install_label} (UEFI)",
                            self.profile_target(item, profile, "uefi"),
                        )
                    )

            if any(
                profile.supports_os(item) and item.bios and profile.bios
                for item in detected
            ):
                lines.append(menu_item("Legacy / BIOS Options", profile.legacy_target))

        lines.extend(
            [
                menu_item("Back to Main Menu", "main"),
                menu_item("Drop to iPXE shell", "shell"),
                "choose target || goto main",
                "goto ${target}",
                "",
            ]
        )

        if any(
            profile.supports_os(item) and item.bios and profile.bios
            for item in detected
        ):
            lines.extend(self.render_implemented_legacy_menu(profile, detected))

        return lines

    def render_implemented_legacy_menu(
        self,
        profile: ProfileDefinition,
        detected: List[DetectedISO],
    ) -> List[str]:
        lines: List[str] = [
            f":{profile.legacy_target}",
            f"menu {profile.title} - Legacy / BIOS",
        ]

        for item in detected:
            if profile.supports_os(item) and item.bios and profile.bios:
                lines.append(
                    menu_item(
                        f"Install {item.title} {profile.install_label} (BIOS / Legacy)",
                        self.profile_target(item, profile, "bios"),
                    )
                )

        lines.extend(
            [
                menu_item(f"Back to {profile.title}", profile.menu_target),
                menu_item("Back to Main Menu", "main"),
                menu_item("Drop to iPXE shell", "shell"),
                f"choose target || goto {profile.menu_target}",
                "goto ${target}",
                "",
            ]
        )

        return lines

    def render_unimplemented_profile_menu(
        self,
        profile: ProfileDefinition,
        detected: List[DetectedISO],
    ) -> List[str]:
        lines: List[str] = [
            f":{profile.menu_target}",
            f"menu {profile.title}",
            menu_item("Profile not implemented yet", "main"),
        ]

        if not detected:
            lines.append(menu_item("No supported RHEL ISO trees detected", "main"))
        else:
            for item in detected:
                if profile.supports_os(item) and item.uefi and profile.uefi:
                    lines.append(
                        menu_item(
                            f"{item.title} {profile.install_label} (UEFI) - not implemented",
                            self.not_implemented_target(item, profile, "uefi"),
                        )
                    )

            if any(
                profile.supports_os(item) and item.bios and profile.bios
                for item in detected
            ):
                lines.append(menu_item("Legacy / BIOS Options", profile.legacy_target))

        lines.extend(
            [
                menu_item("Back to Main Menu", "main"),
                menu_item("Drop to iPXE shell", "shell"),
                "choose target || goto main",
                "goto ${target}",
                "",
            ]
        )

        if any(
            profile.supports_os(item) and item.bios and profile.bios
            for item in detected
        ):
            lines.extend(self.render_unimplemented_legacy_menu(profile, detected))

        for item in detected:
            if profile.supports_os(item) and item.uefi and profile.uefi:
                lines.extend(self.render_not_implemented_target_menu(item, profile, "uefi"))

            if profile.supports_os(item) and item.bios and profile.bios:
                lines.extend(self.render_not_implemented_target_menu(item, profile, "bios"))

        return lines

    def render_unimplemented_legacy_menu(
        self,
        profile: ProfileDefinition,
        detected: List[DetectedISO],
    ) -> List[str]:
        lines: List[str] = [
            f":{profile.legacy_target}",
            f"menu {profile.title} - Legacy / BIOS",
        ]

        for item in detected:
            if profile.supports_os(item) and item.bios and profile.bios:
                lines.append(
                    menu_item(
                        f"{item.title} {profile.install_label} (BIOS / Legacy) - not implemented",
                        self.not_implemented_target(item, profile, "bios"),
                    )
                )

        lines.extend(
            [
                menu_item(f"Back to {profile.title}", profile.menu_target),
                menu_item("Back to Main Menu", "main"),
                menu_item("Drop to iPXE shell", "shell"),
                f"choose target || goto {profile.menu_target}",
                "goto ${target}",
                "",
            ]
        )

        return lines

    def render_not_implemented_target_menu(
        self,
        item: DetectedISO,
        profile: ProfileDefinition,
        firmware: str,
    ) -> List[str]:
        firmware_label = "UEFI" if firmware == "uefi" else "BIOS"
        back_target = profile.legacy_target if firmware == "bios" else profile.menu_target
        back_label = (
            f"Back to {profile.title} Legacy / BIOS"
            if firmware == "bios"
            else f"Back to {profile.title}"
        )

        return [
            f":{self.not_implemented_target(item, profile, firmware)}",
            f"menu {profile.title}",
            menu_item(
                f"{item.title} {profile.install_label} {firmware_label} is not implemented yet",
                back_target,
            ),
            menu_item(back_label, back_target),
            menu_item("Back to Main Menu", "main"),
            menu_item("Drop to iPXE shell", "shell"),
            f"choose target || goto {back_target}",
            "goto ${target}",
            "",
        ]

    def render_boot_targets(self, detected: List[DetectedISO]) -> List[str]:
        lines: List[str] = []

        for profile in self.enabled_profiles():
            for item in detected:
                if profile.supports_os(item) and item.uefi and profile.uefi:
                    lines.append(
                        self.kernel_block(
                            item,
                            profile,
                            self.profile_target(item, profile, "uefi"),
                        )
                    )

                if profile.supports_os(item) and item.bios and profile.bios:
                    lines.append(
                        self.kernel_block(
                            item,
                            profile,
                            self.profile_target(item, profile, "bios"),
                        )
                    )

        return lines

    def render_rescue_menu(self) -> List[str]:
        return [
            ":rescue",
            "menu Utilities / Rescue",
            menu_item("Back to Main Menu", "main"),
            menu_item("Drop to iPXE shell", "shell"),
            "choose target || goto main",
            "goto ${target}",
            "",
        ]

    def profile_target(
        self,
        item: DetectedISO,
        profile: ProfileDefinition,
        firmware: str,
    ) -> str:
        return f"{item.os_id}_{profile.profile_id}_{firmware}"

    def not_implemented_target(
        self,
        item: DetectedISO,
        profile: ProfileDefinition,
        firmware: str,
    ) -> str:
        return f"{self.profile_target(item, profile, firmware)}_not_implemented"

    def profile_kickstart_name(
        self,
        item: DetectedISO,
        profile: ProfileDefinition,
    ) -> str:
        return profile_kickstart_name(item, profile)

    def kernel_block(
        self,
        item: DetectedISO,
        profile: ProfileDefinition,
        target: str,
    ) -> str:
        kickstart_name = self.profile_kickstart_name(item, profile)
        extra_kernel_args = " ".join(profile.kernel_args).strip()

        kernel_line = (
            f"kernel ${{base}}/{item.http_path}/images/pxeboot/vmlinuz "
            f"initrd=initrd.img "
            f"ip=dhcp "
            f"inst.repo=${{base}}/{item.http_path} "
            f"inst.stage2=${{base}}/{item.http_path} "
            f"inst.ks=${{base}}/ks/{kickstart_name}"
        )

        if extra_kernel_args:
            kernel_line = f"{kernel_line} {extra_kernel_args}"

        return f""":{target}
{kernel_line}
initrd --name initrd.img ${{base}}/{item.http_path}/images/pxeboot/initrd.img
boot
"""


def write_boot_ipxe(
    config: GeneratorConfig,
    detected: List[DetectedISO],
    profiles: List[ProfileDefinition],
) -> None:
    renderer = BootMenuRenderer(config, profiles)
    atomic_write(config.html_root / "boot.ipxe", renderer.render(detected))


# =============================================================================
# Validation and health reporting
# =============================================================================


UNRESOLVED_JINJA_BLOCK_RE = re.compile(r"{%\s*[a-zA-Z_]")
UNRESOLVED_JINJA_VARIABLE_RE = re.compile(r"{{\s*[^}]+\s*}}")
UNRESOLVED_SHELL_PLACEHOLDER_RE = re.compile(r"\$\{[A-Za-z_][A-Za-z0-9_]*\}")


BOOT_ARTIFACT_CHECK_PREFIXES: Tuple[str, ...] = (
    "boot_ipxe_",
    "boot_target_",
    "boot_kernel_",
    "boot_initrd_",
    "boot_kickstart_",
    "unimplemented_profile_has_no_real_ks_reference:",
)


def is_boot_artifact_validation_result(result: Dict[str, object]) -> bool:
    return str(result.get("check_id", "")).startswith(BOOT_ARTIFACT_CHECK_PREFIXES)


def validation_result(
    check_id: str,
    status: str,
    message: str,
    path: str = "",
    http_path: str = "",
    details: Optional[Dict[str, object]] = None,
) -> Dict[str, object]:
    result: Dict[str, object] = {
        "check_id": check_id,
        "status": status,
        "message": message,
    }

    if path:
        result["path"] = path

    if http_path:
        result["http_path"] = http_path

    if details:
        result["details"] = details

    return result


def validation_summary(results: List[Dict[str, object]]) -> Dict[str, object]:
    counts = {
        "ok": 0,
        "warning": 0,
        "error": 0,
    }

    for result in results:
        status = str(result.get("status", "error"))

        if status not in counts:
            status = "error"

        counts[status] += 1

    if counts["error"] > 0:
        health = "error"
    elif counts["warning"] > 0:
        health = "warning"
    else:
        health = "ok"

    return {
        "health": health,
        "total": len(results),
        "ok": counts["ok"],
        "warning": counts["warning"],
        "error": counts["error"],
    }


def validate_file_exists(
    results: List[Dict[str, object]],
    check_id: str,
    path: Path,
    message: str,
    http_path: str = "",
) -> None:
    if path.is_file():
        results.append(
            validation_result(
                check_id=check_id,
                status="ok",
                message=message,
                path=str(path),
                http_path=http_path,
                details={"size_bytes": path.stat().st_size},
            )
        )
        return

    results.append(
        validation_result(
            check_id=check_id,
            status="error",
            message=f"{message} is missing.",
            path=str(path),
            http_path=http_path,
        )
    )


def validate_directory_exists(
    results: List[Dict[str, object]],
    check_id: str,
    path: Path,
    message: str,
) -> None:
    if path.is_dir():
        results.append(
            validation_result(
                check_id=check_id,
                status="ok",
                message=message,
                path=str(path),
            )
        )
        return

    results.append(
        validation_result(
            check_id=check_id,
            status="error",
            message=f"{message} is missing.",
            path=str(path),
        )
    )


def iso_repository_validation_status(item: DetectedISO) -> Dict[str, object]:
    required_repos: List[Dict[str, object]] = []

    def add_repo(name: str, metadata_path: Path, http_path: str) -> None:
        exists = metadata_path.is_file()

        required_repos.append(
            {
                "name": name,
                "path": str(metadata_path),
                "http_path": http_path,
                "exists": exists,
                "status": "ok" if exists else "warning",
            }
        )

    if item.major >= 8:
        layout = "baseos-appstream"

        add_repo(
            "BaseOS",
            item.iso_path / "BaseOS" / "repodata" / "repomd.xml",
            f"/{item.http_path}/BaseOS/repodata/repomd.xml",
        )
        add_repo(
            "AppStream",
            item.iso_path / "AppStream" / "repodata" / "repomd.xml",
            f"/{item.http_path}/AppStream/repodata/repomd.xml",
        )
    else:
        layout = "single-repo"

        add_repo(
            "RHEL 7 repository",
            item.iso_path / "repodata" / "repomd.xml",
            f"/{item.http_path}/repodata/repomd.xml",
        )

    missing = [
        repo
        for repo in required_repos
        if repo["exists"] is not True
    ]

    return {
        "layout": layout,
        "health": "warning" if missing else "ok",
        "required_repos": required_repos,
        "missing_repos": missing,
    }


def validate_iso_repository_content(
    results: List[Dict[str, object]],
    item: DetectedISO,
) -> None:
    repo_status = iso_repository_validation_status(item)
    required_repos = repo_status["required_repos"]

    if not isinstance(required_repos, list):
        return

    for repo in required_repos:
        name = str(repo["name"])
        path = Path(str(repo["path"]))
        http_path = str(repo["http_path"])
        exists = repo["exists"] is True

        check_name = name.lower().replace(" ", "_")

        if exists:
            results.append(
                validation_result(
                    check_id=f"repo_metadata_exists:{item.os_id}:{check_name}",
                    status="ok",
                    message=f"Repository metadata found for {item.os_id} {name}.",
                    path=str(path),
                    http_path=http_path,
                    details={"size_bytes": path.stat().st_size},
                )
            )
        else:
            results.append(
                validation_result(
                    check_id=f"repo_metadata_exists:{item.os_id}:{check_name}",
                    status="warning",
                    message=(
                        f"Repository metadata is missing for {item.os_id} {name}. "
                        "The ISO tree has PXE boot files, but installs may fail if repo content is incomplete."
                    ),
                    path=str(path),
                    http_path=http_path,
                    details={
                        "expected_layout": repo_status["layout"],
                    },
                )
            )


def validate_kickstart_content(
    results: List[Dict[str, object]],
    kickstart_name: str,
    path: Path,
) -> None:
    if not path.is_file():
        return

    content = path.read_text(encoding="utf-8")

    if not content.strip():
        results.append(
            validation_result(
                check_id=f"kickstart_nonempty:{kickstart_name}",
                status="error",
                message=f"Generated Kickstart {kickstart_name} is empty.",
                path=str(path),
                http_path=f"/ks/{kickstart_name}",
            )
        )
        return

    results.append(
        validation_result(
            check_id=f"kickstart_nonempty:{kickstart_name}",
            status="ok",
            message=f"Generated Kickstart {kickstart_name} is not empty.",
            path=str(path),
            http_path=f"/ks/{kickstart_name}",
            details={"size_bytes": path.stat().st_size},
        )
    )

    unresolved_checks = [
        (
            "unresolved_jinja_block",
            UNRESOLVED_JINJA_BLOCK_RE,
            "contains an unresolved Jinja block such as {% ... %}",
            "error",
        ),
        (
            "unresolved_jinja_variable",
            UNRESOLVED_JINJA_VARIABLE_RE,
            "contains an unresolved Jinja variable such as {{ ... }}",
            "error",
        ),
        (
            "unresolved_shell_placeholder",
            UNRESOLVED_SHELL_PLACEHOLDER_RE,
            "contains a possible unresolved shell-style placeholder such as ${VAR}",
            "warning",
        ),
    ]

    for check_name, pattern, message, status in unresolved_checks:
        if pattern.search(content):
            results.append(
                validation_result(
                    check_id=f"{check_name}:{kickstart_name}",
                    status=status,
                    message=f"Generated Kickstart {kickstart_name} {message}.",
                    path=str(path),
                    http_path=f"/ks/{kickstart_name}",
                )
            )
        else:
            results.append(
                validation_result(
                    check_id=f"{check_name}:{kickstart_name}",
                    status="ok",
                    message=f"Generated Kickstart {kickstart_name} passed check {check_name}.",
                    path=str(path),
                    http_path=f"/ks/{kickstart_name}",
                )
            )


def validate_boot_ipxe_content(
    results: List[Dict[str, object]],
    config: GeneratorConfig,
    detected: List[DetectedISO],
    profiles: List[ProfileDefinition],
) -> None:
    boot_path = config.html_root / "boot.ipxe"
    http_path = "/boot.ipxe"

    if not boot_path.is_file():
        return

    content = boot_path.read_text(encoding="utf-8")
    padded_content = f"\n{content}\n"

    def add_check(
        check_id: str,
        condition: bool,
        ok_message: str,
        fail_message: str,
        fail_status: str = "error",
        details: Optional[Dict[str, object]] = None,
    ) -> None:
        results.append(
            validation_result(
                check_id=check_id,
                status="ok" if condition else fail_status,
                message=ok_message if condition else fail_message,
                path=str(boot_path),
                http_path=http_path,
                details=details,
            )
        )

    add_check(
        "boot_ipxe_nonempty",
        bool(content.strip()),
        "boot.ipxe is not empty.",
        "boot.ipxe is empty.",
        details={"size_bytes": boot_path.stat().st_size},
    )

    if not content.strip():
        return

    add_check(
        "boot_ipxe_has_shebang",
        content.startswith("#!ipxe"),
        "boot.ipxe starts with #!ipxe.",
        "boot.ipxe does not start with #!ipxe.",
    )

    add_check(
        "boot_ipxe_has_main_menu",
        "\n:main\n" in padded_content,
        "boot.ipxe contains the main menu target.",
        "boot.ipxe is missing the :main target.",
    )

    add_check(
        "boot_ipxe_has_choose_target",
        "choose target" in content,
        "boot.ipxe contains a choose target statement.",
        "boot.ipxe is missing a choose target statement.",
    )

    add_check(
        "boot_ipxe_has_shell_target",
        "\n:shell\n" in padded_content,
        "boot.ipxe contains the shell target.",
        "boot.ipxe is missing the :shell target.",
    )

    add_check(
        "boot_ipxe_no_unresolved_jinja_block",
        UNRESOLVED_JINJA_BLOCK_RE.search(content) is None,
        "boot.ipxe has no unresolved Jinja blocks.",
        "boot.ipxe contains an unresolved Jinja block such as {% ... %}.",
    )

    add_check(
        "boot_ipxe_no_unresolved_jinja_variable",
        UNRESOLVED_JINJA_VARIABLE_RE.search(content) is None,
        "boot.ipxe has no unresolved Jinja variables.",
        "boot.ipxe contains an unresolved Jinja variable such as {{ ... }}.",
    )

    def validate_real_boot_target(
        item: DetectedISO,
        profile: ProfileDefinition,
        firmware: str,
    ) -> None:
        target = f"{item.os_id}_{profile.profile_id}_{firmware}"
        kickstart_name = profile_kickstart_name(item, profile)

        details = {
            "os_id": item.os_id,
            "profile_id": profile.profile_id,
            "firmware": firmware,
            "target": target,
            "kickstart_name": kickstart_name,
        }

        add_check(
            f"boot_target_exists:{item.os_id}:{profile.profile_id}:{firmware}",
            f"\n:{target}\n" in padded_content,
            f"boot.ipxe contains target {target}.",
            f"boot.ipxe is missing target {target}.",
            details=details,
        )

        add_check(
            f"boot_kernel_reference_exists:{item.os_id}:{profile.profile_id}:{firmware}",
            f"/{item.http_path}/images/pxeboot/vmlinuz" in content,
            (
                f"boot.ipxe references the PXE kernel for "
                f"{item.os_id} {profile.profile_id} {firmware}."
            ),
            (
                f"boot.ipxe does not reference the PXE kernel for "
                f"{item.os_id} {profile.profile_id} {firmware}."
            ),
            details=details,
        )

        add_check(
            f"boot_initrd_reference_exists:{item.os_id}:{profile.profile_id}:{firmware}",
            f"/{item.http_path}/images/pxeboot/initrd.img" in content,
            (
                f"boot.ipxe references the PXE initrd for "
                f"{item.os_id} {profile.profile_id} {firmware}."
            ),
            (
                f"boot.ipxe does not reference the PXE initrd for "
                f"{item.os_id} {profile.profile_id} {firmware}."
            ),
            details=details,
        )

        add_check(
            f"boot_kickstart_reference_exists:{item.os_id}:{profile.profile_id}:{firmware}",
            f"/ks/{kickstart_name}" in content,
            (
                f"boot.ipxe references Kickstart {kickstart_name} for "
                f"{item.os_id} {profile.profile_id} {firmware}."
            ),
            (
                f"boot.ipxe does not reference Kickstart {kickstart_name} for "
                f"{item.os_id} {profile.profile_id} {firmware}."
            ),
            details=details,
        )

    for profile in profiles:
        for item in detected:
            if not profile_has_install_option(item, profile):
                continue

            if profile.implemented:
                if item.uefi and profile.uefi:
                    validate_real_boot_target(item, profile, "uefi")

                if item.bios and profile.bios:
                    validate_real_boot_target(item, profile, "bios")

                continue

            kickstart_name = profile_kickstart_name(item, profile)
            real_ks_reference = f"/ks/{kickstart_name}"

            add_check(
                f"unimplemented_profile_has_no_real_ks_reference:{item.os_id}:{profile.profile_id}",
                real_ks_reference not in content,
                (
                    f"Unimplemented profile {profile.profile_id} for {item.os_id} "
                    "does not reference a real Kickstart."
                ),
                (
                    f"Unimplemented profile {profile.profile_id} for {item.os_id} "
                    f"references real Kickstart {kickstart_name}."
                ),
                details={
                    "os_id": item.os_id,
                    "profile_id": profile.profile_id,
                    "kickstart_name": kickstart_name,
                },
            )


def validate_generated_content(
    config: GeneratorConfig,
    detected: List[DetectedISO],
    profiles: List[ProfileDefinition],
) -> List[Dict[str, object]]:
    results: List[Dict[str, object]] = []

    validate_directory_exists(
        results,
        "html_root_exists",
        config.html_root,
        "HTML root exists",
    )

    validate_directory_exists(
        results,
        "generated_dir_exists",
        config.html_root / "generated",
        "Generated metadata directory exists",
    )

    validate_directory_exists(
        results,
        "kickstart_output_dir_exists",
        config.html_root / "ks",
        "Kickstart output directory exists",
    )

    validate_file_exists(
        results,
        "boot_ipxe_exists",
        config.html_root / "boot.ipxe",
        "boot.ipxe exists",
        "/boot.ipxe",
    )

    validate_boot_ipxe_content(
        results,
        config,
        detected,
        profiles,
    )

    for item in detected:
        validate_directory_exists(
            results,
            f"iso_tree_exists:{item.os_id}",
            item.iso_path,
            f"ISO tree exists for {item.os_id}",
        )

        validate_file_exists(
            results,
            f"pxeboot_vmlinuz_exists:{item.os_id}",
            item.iso_path / "images" / "pxeboot" / "vmlinuz",
            f"PXE kernel exists for {item.os_id}",
            f"/{item.http_path}/images/pxeboot/vmlinuz",
        )

        validate_file_exists(
            results,
            f"pxeboot_initrd_exists:{item.os_id}",
            item.iso_path / "images" / "pxeboot" / "initrd.img",
            f"PXE initrd exists for {item.os_id}",
            f"/{item.http_path}/images/pxeboot/initrd.img",
        )

        validate_iso_repository_content(results, item)

    for profile in profiles:
        if not profile.implemented:
            continue

        for item in detected:
            if not profile_has_install_option(item, profile):
                continue

            kickstart_name = profile_kickstart_name(item, profile)
            kickstart_path = config.html_root / "ks" / kickstart_name

            validate_file_exists(
                results,
                f"kickstart_exists:{kickstart_name}",
                kickstart_path,
                f"Generated Kickstart exists for {item.os_id} {profile.profile_id}",
                f"/ks/{kickstart_name}",
            )

            validate_kickstart_content(results, kickstart_name, kickstart_path)

    return results


def render_status_text(status: Dict[str, object]) -> str:
    summary = status["validation_summary"]
    results = status["validation_results"]

    lines = [
        "AeroLIT PXE Content Status",
        "==========================",
        "",
        f"PXE server: {status['pxe_server']}",
        f"PXE port: {status['pxe_port']}",
        f"HTML root: {status['html_root']}",
        f"ISO root: {status['container_iso_root']}",
        "",
        "Validation Summary",
        "------------------",
        f"Health: {summary['health']}",
        f"Total checks: {summary['total']}",
        f"OK: {summary['ok']}",
        f"Warnings: {summary['warning']}",
        f"Errors: {summary['error']}",
        "",
        "Detected ISOs",
        "-------------",
    ]

    detected_isos = status["detected_isos"]

    if detected_isos:
        for item in detected_isos:
            lines.append(
                f"- {item['os_id']}: {item['title']} from {item['iso_path']}"
            )
    else:
        lines.append("- none")

    boot_artifact_validation = status.get("boot_artifact_validation", [])

    lines.extend(
        [
            "",
            "Boot Artifact Validation",
            "------------------------",
        ]
    )

    if isinstance(boot_artifact_validation, list) and boot_artifact_validation:
        boot_summary = validation_summary(
            [
                result
                for result in boot_artifact_validation
                if isinstance(result, dict)
            ]
        )

        lines.extend(
            [
                f"Health: {boot_summary['health']}",
                f"Total checks: {boot_summary['total']}",
                f"OK: {boot_summary['ok']}",
                f"Warnings: {boot_summary['warning']}",
                f"Errors: {boot_summary['error']}",
                "",
            ]
        )

        for result in boot_artifact_validation:
            if not isinstance(result, dict):
                continue

            location = result.get("http_path") or result.get("path") or ""
            suffix = f" [{location}]" if location else ""

            lines.append(
                f"- [{str(result.get('status', 'error')).upper()}] "
                f"{result.get('check_id', 'unknown')}: "
                f"{result.get('message', '')}{suffix}"
            )
    else:
        lines.append("- none")

    lines.extend(
        [
            "",
            "Repository Content",
            "------------------",
        ]
    )

    if detected_isos:
        for item in detected_isos:
            repo_validation = item.get("repo_validation", {})

            if not isinstance(repo_validation, dict):
                continue

            required_repos = repo_validation.get("required_repos", [])

            if not isinstance(required_repos, list):
                continue

            for repo in required_repos:
                if not isinstance(repo, dict):
                    continue

                repo_status = str(repo.get("status", "warning")).upper()
                repo_name = repo.get("name", "unknown")
                repo_path = repo.get("path", "")

                lines.append(
                    f"- [{repo_status}] {item['os_id']} {repo_name}: {repo_path}"
                )
    else:
        lines.append("- none")

    lines.extend(
        [
            "",
            "Generated Kickstarts",
            "--------------------",
        ]
    )

    generated_kickstarts = status["generated_kickstarts"]

    if generated_kickstarts:
        for item in generated_kickstarts:
            state = item.get("emergency_edit_state", {})
            source = item.get(
                "template_source_detail",
                item.get("template_source", "unknown"),
            )

            if isinstance(state, dict) and state.get("preserved_manual_edit") is True:
                source = "preserved-manual-edit"

            lines.append(
                f"- {item['kickstart']} "
                f"profile={item['profile_id']} "
                f"os={item['os_id']} "
                f"source={source}"
            )
    else:
        lines.append("- none")

    stale_kickstarts = status.get("stale_kickstarts", [])

    lines.extend(
        [
            "",
            "Stale Kickstarts",
            "----------------",
        ]
    )

    if stale_kickstarts:
        for item in stale_kickstarts:
            lines.append(
                f"- {item.get('kickstart', item.get('kickstart_name', 'unknown'))} "
                f"action={item.get('action', 'unknown')} "
                f"reason={item.get('reason', 'unknown')}"
            )
    else:
        lines.append("- none")

    lines.extend(
        [
            "",
            "Validation Results",
            "------------------",
        ]
    )

    for result in results:
        location = result.get("http_path") or result.get("path") or ""
        suffix = f" [{location}]" if location else ""

        lines.append(
            f"- [{str(result['status']).upper()}] "
            f"{result['check_id']}: {result['message']}{suffix}"
        )

    lines.append("")

    return "\n".join(lines)


def enforce_validation_failure_policy(
    config: GeneratorConfig,
    detected: List[DetectedISO],
    profiles: List[ProfileDefinition],
) -> None:
    validation_results = validate_generated_content(config, detected, profiles)
    summary = validation_summary(validation_results)

    if config.validation_failure_policy == "warn":
        return

    if summary["error"] == 0:
        return

    error_lines = []

    for result in validation_results:
        if result.get("status") != "error":
            continue

        location = result.get("http_path") or result.get("path") or ""
        suffix = f" [{location}]" if location else ""

        error_lines.append(
            f"- {result.get('check_id', 'unknown')}: "
            f"{result.get('message', '')}{suffix}"
        )

    joined_errors = "\n".join(error_lines)

    fail(
        "Validation failed and PXE_VALIDATION_FAILURE_POLICY=fail.\n"
        f"Validation errors: {summary['error']}\n"
        f"{joined_errors}"
    )


