def atomic_write(path: Path, content: str, mode: int = 0o644) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)

    tmp_path = path.with_name(f".{path.name}.tmp")
    tmp_path.write_text(content, encoding="utf-8")
    tmp_path.chmod(mode)
    tmp_path.replace(path)


def sha256_text(content: str) -> str:
    return hashlib.sha256(content.encode("utf-8")).hexdigest()


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()

    with path.open("rb") as file_obj:
        for chunk in iter(lambda: file_obj.read(1024 * 1024), b""):
            digest.update(chunk)

    return digest.hexdigest()


def read_json_mapping(path: Path) -> Dict[str, Any]:
    if not path.is_file():
        return {}

    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        fail(f"JSON state file {path} is invalid: {exc}")

    if not isinstance(data, dict):
        fail(f"JSON state file {path} must contain a JSON object.")

    return data


def utc_timestamp() -> str:
    return datetime.now(timezone.utc).isoformat()


def relative_to_root(path: Optional[Path], root: Path) -> Optional[str]:
    if path is None:
        return None

    try:
        return str(path.relative_to(root))
    except ValueError:
        return str(path)


def active_override_files(config: GeneratorConfig) -> Dict[str, List[str]]:
    profile_overrides = [
        str(path)
        for path in override_profile_definition_files(config)
    ]

    template_overrides: List[str] = []

    if config.override_template_root.is_dir():
        for pattern in ("**/*.ks.tmpl", "**/*.ks.j2"):
            template_overrides.extend(
                str(path)
                for path in sorted(config.override_template_root.glob(pattern))
                if path.is_file()
            )

    return {
        "profiles": profile_overrides,
        "templates": sorted(set(template_overrides)),
    }


def template_source_label(config: GeneratorConfig, template_path: Optional[Path]) -> str:
    if template_path is None:
        return "built-in-default"

    try:
        template_path.relative_to(config.override_template_root)
        return "override"
    except ValueError:
        return "base"


def managed_kickstart_header(
    config: GeneratorConfig,
    item: DetectedISO,
    profile: ProfileDefinition,
    resolution: KickstartTemplateResolution,
    destination: Path,
) -> str:
    template_path = (
        str(resolution.template_path)
        if resolution.template_path is not None
        else "built-in-default"
    )

    return f"""# ---------------------------------------------------------------------------
# Managed by AeroLIT PXE Content Generator
# Profile: {profile.profile_id}
# Profile title: {profile.title}
# OS: {item.os_id}
# OS title: {item.title}
# Template: {resolution.template_name}
# Template path: {template_path}
# Template source: {template_source_label(config, resolution.template_path)}
# Generated output: /ks/{destination.name}
# Direct edit policy: {config.generated_ks_edit_policy}
#
# Manual edits to this generated file may be preserved depending on policy.
# Preferred customization path:
#   {config.override_profile_root}
#   {config.override_template_root}
# ---------------------------------------------------------------------------

"""


def kickstart_state_path(config: GeneratorConfig, destination: Path) -> Path:
    return config.html_root / "generated" / "kickstart-state" / f"{destination.name}.json"


def kickstart_candidate_path(config: GeneratorConfig, destination: Path) -> Path:
    return (
        config.html_root
        / "generated"
        / "preserved-kickstarts"
        / f"{destination.name}.candidate"
    )


def write_generated_kickstart(
    config: GeneratorConfig,
    destination: Path,
    content: str,
) -> None:
    desired_sha = sha256_text(content)
    state_path = kickstart_state_path(config, destination)
    candidate_path = kickstart_candidate_path(config, destination)

    destination_exists = destination.is_file()
    current_sha = sha256_file(destination) if destination_exists else ""
    state = read_json_mapping(state_path)
    previous_generated_sha = str(state.get("last_generated_sha256", ""))

    manual_edit_detected = (
        destination_exists
        and bool(previous_generated_sha)
        and current_sha != previous_generated_sha
    )

    if manual_edit_detected and config.generated_ks_edit_policy == "preserve":
        atomic_write(candidate_path, content)

        state_data = {
            "output_path": str(destination),
            "state_path": str(state_path),
            "candidate_path": str(candidate_path),
            "edit_policy": config.generated_ks_edit_policy,
            "manual_edit_detected": True,
            "preserved_manual_edit": True,
            "current_output_sha256": current_sha,
            "last_generated_sha256": desired_sha,
            "previous_generated_sha256": previous_generated_sha,
            "updated_at_epoch": int(time.time()),
        }

        atomic_write(
            state_path,
            json.dumps(state_data, indent=2, sort_keys=True) + "\n",
        )

        print(
            f"Preserved manually edited Kickstart: {destination}. "
            f"Regenerated candidate written to: {candidate_path}",
            flush=True,
        )
        return

    atomic_write(destination, content)

    if candidate_path.exists():
        candidate_path.unlink()

    state_data = {
        "output_path": str(destination),
        "state_path": str(state_path),
        "candidate_path": None,
        "edit_policy": config.generated_ks_edit_policy,
        "manual_edit_detected": manual_edit_detected,
        "preserved_manual_edit": False,
        "current_output_sha256": desired_sha,
        "last_generated_sha256": desired_sha,
        "previous_generated_sha256": previous_generated_sha or None,
        "updated_at_epoch": int(time.time()),
    }

    atomic_write(
        state_path,
        json.dumps(state_data, indent=2, sort_keys=True) + "\n",
    )


def generated_kickstart_state_status(
    config: GeneratorConfig,
    kickstart_name: str,
) -> Dict[str, object]:
    destination = config.html_root / "ks" / kickstart_name
    state_path = kickstart_state_path(config, destination)

    if not state_path.is_file():
        return {
            "state_exists": False,
            "state_path": str(state_path),
        }

    state = read_json_mapping(state_path)
    state["state_exists"] = True
    state["state_path"] = str(state_path)

    return state


def cleanup_stale_kickstarts(
    config: GeneratorConfig,
    expected_kickstarts: Iterable[str],
) -> List[Dict[str, object]]:
    ks_dir = config.html_root / "ks"
    expected = set(expected_kickstarts)
    stale_actions: List[Dict[str, object]] = []

    if not ks_dir.is_dir():
        return stale_actions

    for destination in sorted(ks_dir.glob("*.ks")):
        kickstart_name = destination.name

        if kickstart_name in expected:
            continue

        state_path = kickstart_state_path(config, destination)
        candidate_path = kickstart_candidate_path(config, destination)

        action: Dict[str, object] = {
            "kickstart_name": kickstart_name,
            "kickstart": f"/ks/{kickstart_name}",
            "output_path": str(destination),
            "state_path": str(state_path),
        }

        if not state_path.is_file():
            action.update(
                {
                    "action": "preserved",
                    "reason": "unmanaged Kickstart; no generator state file exists",
                    "manual_edit_detected": None,
                }
            )
            stale_actions.append(action)
            continue

        state = read_json_mapping(state_path)
        last_generated_sha = str(state.get("last_generated_sha256", ""))
        current_sha = sha256_file(destination)

        if last_generated_sha and current_sha == last_generated_sha:
            destination.unlink()

            if candidate_path.exists():
                candidate_path.unlink()

            state_path.unlink()

            action.update(
                {
                    "action": "deleted",
                    "reason": "stale generated Kickstart matched last generated hash",
                    "manual_edit_detected": False,
                    "last_generated_sha256": last_generated_sha,
                    "current_output_sha256": current_sha,
                }
            )
            stale_actions.append(action)
            continue

        reason = (
            "manual edit detected; stale Kickstart preserved"
            if last_generated_sha
            else "generator state exists but last_generated_sha256 is missing; stale Kickstart preserved"
        )

        state["stale"] = True
        state["stale_action"] = "preserved"
        state["stale_reason"] = reason
        state["updated_at_epoch"] = int(time.time())

        atomic_write(
            state_path,
            json.dumps(state, indent=2, sort_keys=True) + "\n",
        )

        action.update(
            {
                "action": "preserved",
                "reason": reason,
                "manual_edit_detected": bool(last_generated_sha),
                "last_generated_sha256": last_generated_sha or None,
                "current_output_sha256": current_sha,
            }
        )
        stale_actions.append(action)

    return stale_actions


def ensure_output_directories(config: GeneratorConfig) -> None:
    config.html_root.mkdir(parents=True, exist_ok=True)
    (config.html_root / "ks").mkdir(parents=True, exist_ok=True)
    (config.html_root / "generated").mkdir(parents=True, exist_ok=True)


