    }


def generated_kickstart_status(
    config: GeneratorConfig,
    detected: List[DetectedISO],
    profiles: List[ProfileDefinition],
) -> List[Dict[str, object]]:
    generated: List[Dict[str, object]] = []
    safe_rootpw_placeholder = "__hidden__"

    for profile in profiles:
        if not profile.implemented:
            continue

        for item in detected:
            if not profile_has_install_option(item, profile):
                continue

            resolution = resolve_kickstart_template(config, item, profile)
            values = profile_template_values(config, item, profile, safe_rootpw_placeholder)
            kickstart_name = profile_kickstart_name(item, profile)

            generated.append(
                {
                    "profile_id": profile.profile_id,
                    "os_id": item.os_id,
                    "kickstart_name": kickstart_name,
                    "kickstart": f"/ks/{kickstart_name}",
                    "kickstart_url": values["kickstart_url"],
                    "repo_url": values["repo_url"],
                    "base_url": values["base_url"],
                    "kickstart_template": resolution.template_name,
                    "template_path": (
                        str(resolution.template_path)
                        if resolution.template_path is not None
                        else None
                    ),
                    "template_source": resolution.template_source,
                    "template_source_detail": template_source_label(config, resolution.template_path),
                    "template_engine": resolution.template_engine,
                    "template_search_paths": [
                        str(candidate) for candidate in resolution.candidates
                    ],
                    "template_context_keys": sorted(values.keys()),
                    "kernel_args": list(profile.kernel_args),
                    "emergency_edit_state": generated_kickstart_state_status(
                        config,
                        kickstart_name,
                    ),
                }
            )

    return generated


def render_status(
    config: GeneratorConfig,
    detected: List[DetectedISO],
    profiles: List[ProfileDefinition],
    stale_kickstarts: List[Dict[str, object]],
) -> None:
    generated_dir = config.html_root / "generated"
    generated_dir.mkdir(parents=True, exist_ok=True)

    detected_list = [detected_iso_status(item) for item in detected]

    visible_profiles = [
        profile.profile_id
        for profile in profiles
        if profile.show_in_main_menu
    ]

    enabled_profiles = [
        profile.profile_id
        for profile in profiles
        if profile.show_in_main_menu and profile.implemented
    ]

    unimplemented_profiles = [
        profile.profile_id
        for profile in profiles
        if profile.show_in_main_menu and not profile.implemented
    ]

    generated_kickstarts = generated_kickstart_status(config, detected, profiles)
    validation_results = validate_generated_content(config, detected, profiles)
    summary = validation_summary(validation_results)

    boot_artifact_validation = [
        result
        for result in validation_results
        if is_boot_artifact_validation_result(result)
    ]

    status = {
        "generator": {
            "generated_at": utc_timestamp(),
            "generated_ks_edit_policy": config.generated_ks_edit_policy,
            "validation_failure_policy": config.validation_failure_policy,
            "template_root": str(config.template_root),
            "profile_root": str(config.profile_root),
            "override_root": str(config.override_root),
            "override_template_root": str(config.override_template_root),
            "override_profile_root": str(config.override_profile_root),
            "kickstart_output_root": str(config.html_root / "ks"),
            "preferred_customization_paths": [
                str(config.override_profile_root),
                str(config.override_template_root),
            ],
        },
        "active_overrides": active_override_files(config),
        "pxe_server": config.pxe_server,
        "pxe_port": config.pxe_port,
        "container_iso_root": str(config.iso_root),
        "html_root": str(config.html_root),
        "template_root": str(config.template_root),
        "profile_root": str(config.profile_root),
        "override_root": str(config.override_root),
        "override_template_root": str(config.override_template_root),
        "override_profile_root": str(config.override_profile_root),
        "generated_ks_edit_policy": config.generated_ks_edit_policy,
        "validation_failure_policy": config.validation_failure_policy,
        "detected_isos": detected_list,
        "profiles": [
