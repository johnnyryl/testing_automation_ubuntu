def getenv(name: str, default: str = "") -> str:
    return os.environ.get(name, default).strip()


def getenv_bool(name: str, default: bool = False) -> bool:
    raw = getenv(name, str(default)).lower()
    return raw in ("1", "true", "yes", "y", "on")


def getenv_int(name: str, default: int) -> int:
    raw = getenv(name, str(default))

    try:
        return int(raw)
    except ValueError:
        fail(f"{name} must be an integer. Got: {raw}")


def fail(message: str) -> None:
    raise SystemExit(f"ERROR: {message}")


@dataclass(frozen=True)
class GeneratorConfig:
    pxe_server: str
    pxe_port: str
    iso_root: Path
    html_root: Path
    template_root: Path
    profile_root: Path
    override_root: Path
    override_template_root: Path
    override_profile_root: Path
    generated_ks_edit_policy: str
    validation_failure_policy: str
    background_path: str
    watch_interval: int
    rootpw_hash: str
    allow_default_rootpw: bool

    @classmethod
    def from_env(cls) -> "GeneratorConfig":
        override_root = Path(getenv("PXE_OVERRIDE_ROOT", "/overrides"))

        return cls(
            pxe_server=getenv("PXE_SERVER"),
            pxe_port=getenv("PXE_PORT", "18080"),
            iso_root=Path(getenv("PXE_ISO_ROOT", "/iso")),
            html_root=Path(getenv("PXE_HTML_ROOT", "/etc/nginx/html")),
            template_root=Path(getenv("PXE_TEMPLATE_ROOT", "/templates")),
            profile_root=Path(getenv("PXE_PROFILE_ROOT", "/profiles")),
            override_root=override_root,
            override_template_root=Path(
                getenv("PXE_OVERRIDE_TEMPLATE_ROOT", str(override_root / "templates"))
            ),
            override_profile_root=Path(
                getenv("PXE_OVERRIDE_PROFILE_ROOT", str(override_root / "profiles"))
            ),
            generated_ks_edit_policy=getenv("PXE_GENERATED_KS_EDIT_POLICY", "preserve").lower(),
            validation_failure_policy=getenv("PXE_VALIDATION_FAILURE_POLICY", "warn").lower(),
            background_path=getenv("PXE_BACKGROUND_PATH", "/ui/background.png"),
            watch_interval=getenv_int("PXE_WATCH_INTERVAL", 15),
            rootpw_hash=getenv("ROOTPW_HASH"),
            allow_default_rootpw=getenv_bool("ALLOW_DEFAULT_ROOTPW", True),
        )

    def resolved_rootpw_hash(self) -> str:
        if self.rootpw_hash:
            return self.rootpw_hash

        if self.allow_default_rootpw:
            return DEFAULT_ROOTPW_HASH

        fail("ROOTPW_HASH is required unless ALLOW_DEFAULT_ROOTPW=true.")
        return ""

    def validate(self) -> None:
        if not self.pxe_server:
            fail("PXE_SERVER is required.")

        if self.watch_interval < 1:
            fail("PXE_WATCH_INTERVAL must be 1 or greater.")

        if self.generated_ks_edit_policy not in ("preserve", "overwrite"):
            fail(
                "PXE_GENERATED_KS_EDIT_POLICY must be one of: "
                "preserve, overwrite."
            )


        if self.validation_failure_policy not in ("warn", "fail"):
            fail(
                "PXE_VALIDATION_FAILURE_POLICY must be one of: "
                "warn, fail."
            )


