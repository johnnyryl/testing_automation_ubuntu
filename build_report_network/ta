2. Add these helper functions before ProfileDefinition

Put these right above the @dataclass(frozen=True) line for ProfileDefinition:

def parse_yaml_bool(value: Any, field_name: str, source: str) -> bool:
    if isinstance(value, bool):
        return value
    fail(
        f"Profile file {source} field {field_name} must be literal true or false. "
        f"Got: {value!r}. Do not quote booleans and do not use yes/no/on/off."
    )
def parse_optional_string_list(
    value: Any,
    field_name: str,
    source: str,
) -> Tuple[str, ...]:
    if value is None:
        return ()
    if not isinstance(value, list):
        fail(f"Profile file {source} field {field_name} must be a YAML list.")
    parsed: List[str] = []
    for index, item in enumerate(value):
        if not isinstance(item, str):
            fail(
                f"Profile file {source} field {field_name}[{index}] must be a string. "
                f"Got: {item!r}."
            )
        stripped = item.strip()
        if stripped:
            parsed.append(stripped)
    return tuple(parsed)

