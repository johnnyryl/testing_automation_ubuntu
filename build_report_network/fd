class KickstartRenderer:
    def __init__(self, config: GeneratorConfig, rootpw_hash: str) -> None:
        self.config = config
        self.rootpw_hash = rootpw_hash

    def render_all(
        self,
        detected: Iterable[DetectedISO],
        profiles: Iterable[ProfileDefinition],
    ) -> None:
        for profile in profiles:
            if not profile.implemented:
                continue

            for item in detected:
                if profile_has_install_option(item, profile):
                    self.render_one(item, profile)

    def render_one(self, item: DetectedISO, profile: ProfileDefinition) -> None:
        destination = self.config.html_root / "ks" / profile_kickstart_name(item, profile)
        resolution = resolve_kickstart_template(self.config, item, profile)

        if resolution.template_path is not None:
            rendered = self.render_template(resolution, item, profile)
        elif resolution.template_source == "built-in-default" and profile.profile_id == "minimal":
            rendered = self.default_kickstart(item)
        else:
            fail(
                f"Profile {profile.profile_id} has unresolved Kickstart template "
                f"{resolution.template_name!r}."
            )

        atomic_write(destination, rendered)

    def render_template(
        self,
        resolution: KickstartTemplateResolution,
        item: DetectedISO,
        profile: ProfileDefinition,
    ) -> str:
        if resolution.template_path is None:
            fail(
                f"Profile {profile.profile_id} has no template path for "
                f"{resolution.template_name!r}."
            )

        values = profile_template_values(
            self.config,
            item,
            profile,
            self.rootpw_hash,
        )

        raw = resolution.template_path.read_text(encoding="utf-8")
        return render_kickstart_template_text(
            raw,
            values,
            str(resolution.template_path),
            resolution.template_engine,
        )

    def default_kickstart(self, item: DetectedISO) -> str:
        return f"""#version=RHEL{item.major}
text
reboot

lang en_US.UTF-8
keyboard us
timezone America/Chicago --utc

network --bootproto=dhcp --device=link --activate

rootpw --iscrypted {self.rootpw_hash}
firstboot --disable
selinux --enforcing
firewall --enabled --service=ssh
services --enabled=sshd

url --url="http://{self.config.pxe_server}:{self.config.pxe_port}/{item.os_id}"

zerombr
clearpart --all --initlabel
autopart --type=lvm

%packages
@^minimal-environment
%end

%addon com_redhat_kdump --enable
%end
"""


