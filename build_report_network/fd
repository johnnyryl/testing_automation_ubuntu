            lines.append(f"<li>{item.title}: /{item.http_path}/ from {item.iso_path}</li>")
    else:
        lines.append("<li>No supported RHEL ISO trees detected.</li>")

    lines.extend(
        [
            "</ul>",
            "<h2>Profile Sets</h2>",
            "<ul>",
        ]
    )

    for profile in profiles:
        if not profile.show_in_main_menu:
            continue

        state = "implemented" if profile.implemented else "placeholder / not implemented"
        lines.append(f"<li>{profile.title}: {state}</li>")

    lines.extend(
        [
            "</ul>",
            "<h2>Generated Files</h2>",
            "<ul>",
            '<li><a href="/boot.ipxe">boot.ipxe</a></li>',
            '<li><a href="/generated/status.json">generated/status.json</a></li>',
            '<li><a href="/generated/isos.txt">generated/isos.txt</a></li>',
            "</ul>",
            "</body>",
            "</html>",
            "",
        ]
    )

    atomic_write(config.html_root / "index.html", "\n".join(lines))


# =============================================================================
# Watch-state hashing
# =============================================================================


def watched_template_files(template_root: Path) -> List[Path]:
    paths: List[Path] = []

    paths.append(template_root)
    paths.append(template_root / "ks")

    for pattern in ("**/*.ks.tmpl", "**/*.ks.j2"):
        paths.extend(sorted(template_root.glob(pattern)))

    return paths


def watched_paths(config: GeneratorConfig) -> List[Path]:
    paths: List[Path] = []

    for definition in OS_DEFINITIONS:
        iso_path = config.iso_root / definition.iso_dir
        paths.extend(
            [
                iso_path,
                iso_path / "images" / "pxeboot" / "vmlinuz",
                iso_path / "images" / "pxeboot" / "initrd.img",
                config.template_root / "ks" / definition.ks_template,
                config.template_root / definition.ks_template,
            ]
        )

    paths.extend(watched_template_files(config.template_root))

    paths.append(config.profile_root)

    for path in profile_definition_files(config.profile_root):
        paths.append(path)

    paths.append(config.html_root / config.background_path.lstrip("/"))

    return paths


def watched_env_values(config: GeneratorConfig) -> List[str]:
    return [
        config.pxe_server,
        config.pxe_port,
        str(config.iso_root),
        str(config.html_root),
        str(config.template_root),
        str(config.profile_root),
        config.background_path,
        config.rootpw_hash,
        str(config.allow_default_rootpw),
    ]


def watched_state_hash(config: GeneratorConfig) -> str:
    digest = hashlib.sha256()

    for value in watched_env_values(config):
        digest.update(value.encode("utf-8"))

    for path in watched_paths(config):
        digest.update(str(path).encode("utf-8"))

        if path.exists():
            stat = path.stat()
            digest.update(str(stat.st_mtime_ns).encode("utf-8"))
            digest.update(str(stat.st_size).encode("utf-8"))
            digest.update(b"exists")
        else:
            digest.update(b"missing")

    return digest.hexdigest()


# =============================================================================
# Generation workflows
# =============================================================================


def generate_once(config: GeneratorConfig) -> None:
    config.validate()
    rootpw_hash = config.resolved_rootpw_hash()
    profiles = load_profile_definitions(config)
    detected = discover_isos(config)

    ensure_output_directories(config)

    KickstartRenderer(config, rootpw_hash).render_all(detected, profiles)
    write_boot_ipxe(config, detected, profiles)
    render_status(config, detected, profiles)
    render_index(config, detected, profiles)

    detected_names = ", ".join(item.os_id for item in detected) if detected else "none"
    profile_names = ", ".join(profile.profile_id for profile in profiles)

    print(
        f"Generated PXE content. Detected ISOs: {detected_names}. Profiles: {profile_names}",
        flush=True,
    )


def watch_loop(config: GeneratorConfig) -> None:
    last_hash = ""

    while True:
        current_hash = watched_state_hash(config)

        if current_hash != last_hash:
            generate_once(config)
            last_hash = current_hash

        time.sleep(config.watch_interval)


# =============================================================================
# CLI entrypoint
# =============================================================================


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Generate dynamic AeroLIT PXE content.")
    parser.add_argument("--once", action="store_true", help="Generate once and exit.")
    parser.add_argument("--watch", action="store_true", help="Watch for changes and regenerate.")
    return parser.parse_args()


def main() -> None:
    args = parse_args()
    config = GeneratorConfig.from_env()

    if args.once:
        generate_once(config)
        return

    # Default to watch mode so older entrypoints that run this script with no args still work.
    watch_loop(config)


if __name__ == "__main__":
    main()