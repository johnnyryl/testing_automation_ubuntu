def profile_definition_files(profile_root: Path) -> List[Path]:
    if not profile_root.is_dir():
        return []

    files: List[Path] = []
    files.extend(sorted(profile_root.glob("*.yml")))
    files.extend(sorted(profile_root.glob("*.yaml")))

    return files


def load_profile_file(path: Path) -> ProfileDefinition:
    source = str(path)
    raw = path.read_text(encoding="utf-8")

    validate_yaml_boolean_literals(raw, source)
    data = load_yaml_mapping(raw, source)

    return ProfileDefinition.from_dict(data, source=source)


def validate_relative_template_path(value: str, profile_id: str, field: str) -> None:
    template_path = Path(value)

    if not value:
        fail(f"Profile {profile_id} {field} cannot be empty.")

    if template_path.is_absolute():
        fail(
            f"Profile {profile_id} {field} must be relative. "
            f"Got: {value}"
        )

    if ".." in template_path.parts:
        fail(
            f"Profile {profile_id} {field} must not contain '..'. "
            f"Got: {value}"
        )

    if "\n" in value or "\r" in value:
        fail(f"Profile {profile_id} {field} must not contain newlines.")


def validate_kernel_arg(profile_id: str, index: int, arg: str) -> None:
    if not isinstance(arg, str):
        fail(f"Profile {profile_id} kernel_args[{index}] must be a string.")

    if not arg.strip():
        fail(f"Profile {profile_id} kernel_args[{index}] cannot be empty.")

    if "\n" in arg or "\r" in arg:
        fail(f"Profile {profile_id} kernel_args[{index}] must not contain newlines.")

    if any(character.isspace() for character in arg):
        fail(
            f"Profile {profile_id} kernel_args[{index}] must be one kernel argument "
            f"with no whitespace. Got: {arg!r}"
        )

    for prefix in RESERVED_KERNEL_ARG_PREFIXES:
        if arg.startswith(prefix):
            fail(
                f"Profile {profile_id} kernel_args[{index}] must not set generated "
                f"kernel argument {prefix!r}. Got: {arg!r}"
            )


def validate_profile_definitions(profiles: List[ProfileDefinition]) -> None:
    if not profiles:
        fail("At least one PXE profile must be defined.")

    profile_ids = set()
    known_os_ids = {definition.os_id for definition in OS_DEFINITIONS}
    visible_profile_count = 0

    target_sources: Dict[str, str] = {
        target: "reserved iPXE menu target"
        for target in RESERVED_MENU_TARGETS
    }

    for profile in profiles:
        source = profile.source

        if not profile.profile_id:
            fail(f"Profile from {source} has an empty profile_id.")

        if not profile.title:
            fail(f"Profile {profile.profile_id} has an empty title.")

        if not profile.install_label:
            fail(f"Profile {profile.profile_id} has an empty install_label.")

        if not profile.menu_target:
            fail(f"Profile {profile.profile_id} has an empty menu_target.")

        validate_safe_identifier(profile.profile_id, "profile_id", source)
        validate_safe_identifier(profile.menu_target, "menu_target", source)

        if not isinstance(profile.implemented, bool):
            fail(f"Profile {profile.profile_id} field implemented must be a boolean.")

        if not isinstance(profile.show_in_main_menu, bool):
            fail(f"Profile {profile.profile_id} field show_in_main_menu must be a boolean.")

        if not isinstance(profile.uefi, bool):
            fail(f"Profile {profile.profile_id} field uefi must be a boolean.")

        if not isinstance(profile.bios, bool):
            fail(f"Profile {profile.profile_id} field bios must be a boolean.")

        if not profile.uefi and not profile.bios:
            fail(
                f"Profile {profile.profile_id} must enable at least one firmware type: "
                "uefi=true and/or bios=true."
            )

        if profile.show_in_main_menu:
            visible_profile_count += 1

        if profile.profile_id in profile_ids:
            fail(f"Duplicate profile_id found: {profile.profile_id}")

        profile_ids.add(profile.profile_id)

        profile_targets = {
            "menu_target": profile.menu_target,
            "legacy_target": profile.legacy_target,
        }

        for field, target in profile_targets.items():
            if target in target_sources:
                fail(
                    f"Profile {profile.profile_id} {field} value {target!r} conflicts with "
                    f"{target_sources[target]}."
                )

            target_sources[target] = f"profile {profile.profile_id} {field}"

        if not isinstance(profile.supported_os, tuple):
            fail(f"Profile {profile.profile_id} field supported_os must be stored as a tuple.")

        seen_supported_os = set()

        for os_id in profile.supported_os:
            if not isinstance(os_id, str):
                fail(f"Profile {profile.profile_id} has a non-string supported_os value.")

            if os_id in seen_supported_os:
                fail(
                    f"Profile {profile.profile_id} has duplicate supported_os value: {os_id}"
                )

            seen_supported_os.add(os_id)

            if os_id not in known_os_ids:
                fail(
                    f"Profile {profile.profile_id} references unknown supported_os value: {os_id}"
                )

        if profile.kickstart_template:
            validate_relative_template_path(
                profile.kickstart_template,
                profile.profile_id,
                "kickstart_template",
            )

        if profile.implemented and profile.profile_id != "minimal" and not profile.kickstart_template:
            fail(
                f"Profile {profile.profile_id} is implemented, so it must define "
                "kickstart_template. Only the minimal profile may use the built-in "
                "default Kickstart fallback."
            )

        if not isinstance(profile.kernel_args, tuple):
            fail(f"Profile {profile.profile_id} field kernel_args must be stored as a tuple.")

        for index, arg in enumerate(profile.kernel_args):
            validate_kernel_arg(profile.profile_id, index, arg)

    if visible_profile_count == 0:
        fail("At least one PXE profile must have show_in_main_menu=true.")

    if "minimal" not in profile_ids:
        fail("The minimal profile must be defined.")


def load_profile_definitions(config: GeneratorConfig) -> List[ProfileDefinition]:
    files = profile_definition_files(config.profile_root)

    if not files:
        profiles = list(BUILTIN_PROFILE_DEFINITIONS)
        validate_profile_definitions(profiles)
        return profiles

    profiles = [load_profile_file(path) for path in files]
    validate_profile_definitions(profiles)

    return profiles


