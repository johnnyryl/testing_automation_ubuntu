def profile_kickstart_name(item: DetectedISO, profile: ProfileDefinition) -> str:
    if profile.profile_id == "minimal":
        return item.ks_name

    return f"{item.os_id}-{profile.profile_slug}.ks"


def profile_has_install_option(item: DetectedISO, profile: ProfileDefinition) -> bool:
    return (
        profile.supports_os(item)
        and (
            (item.uefi and profile.uefi)
            or (item.bios and profile.bios)
        )
    )


def template_engine_for_path(template_path: Path) -> str:
    if template_path.name.endswith(".j2"):
        return "jinja2"

    return "simple"


def profile_template_values(
    config: GeneratorConfig,
    item: DetectedISO,
    profile: ProfileDefinition,
    rootpw_hash: str,
) -> Dict[str, Any]:
    base_url = f"http://{config.pxe_server}:{config.pxe_port}"
    repo_url = f"{base_url}/{item.http_path}"
    kickstart_name = profile_kickstart_name(item, profile)
    kickstart_path = f"/ks/{kickstart_name}"
    kickstart_url = f"{base_url}{kickstart_path}"
    kernel_args = list(profile.kernel_args)
    kernel_args_string = " ".join(profile.kernel_args).strip()

    return {
        "PXE_SERVER": config.pxe_server,
        "PXE_PORT": config.pxe_port,
        "ROOTPW_HASH": rootpw_hash,
        "BASE_URL": base_url,
        "REPO_URL": repo_url,
        "KICKSTART_NAME": kickstart_name,
        "KICKSTART_PATH": kickstart_path,
