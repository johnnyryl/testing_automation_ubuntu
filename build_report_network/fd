SAFE_PROFILE_IDENTIFIER_RE = re.compile(r"^[a-z0-9][a-z0-9_]*$")
YAML_BOOL_FIELD_RE = re.compile(
    r"^\s*(implemented|show_in_main_menu|uefi|bios)\s*:\s*([^#\n]*?)(?:\s+#.*)?$"
)
SIMPLE_JINJA_VARIABLE_RE = re.compile(r"{{\s*([a-zA-Z_][a-zA-Z0-9_]*)\s*}}")

RESERVED_MENU_TARGETS = {
    "main",
    "rescue",
    "shell",
}

DEFAULT_KERNEL_ARGS: Tuple[str, ...] = ("inst.text", "nomodeset")

RESERVED_KERNEL_ARG_PREFIXES: Tuple[str, ...] = (
    "initrd=",
    "ip=",
    "inst.repo=",
    "inst.stage2=",
    "inst.ks=",
)


def validate_safe_identifier(value: str, field: str, source: str) -> None:
    if not SAFE_PROFILE_IDENTIFIER_RE.match(value):
        fail(
            f"Profile file {source} field {field} has invalid value: {value!r}. "
            "Use lowercase letters, numbers, and underscores only. "
            "It must start with a lowercase letter or number."
        )


def require_string_field(data: Dict[str, Any], field: str, source: str) -> str:
    if field not in data:
        fail(f"Profile file {source} is missing required field: {field}")

    value = data[field]

    if not isinstance(value, str):
        fail(
            f"Profile file {source} field {field} must be a string. "
            f"Got: {type(value).__name__}"
        )

    value = value.strip()

    if not value:
        fail(f"Profile file {source} field {field} cannot be empty.")

    if "\n" in value or "\r" in value:
        fail(f"Profile file {source} field {field} must be a single-line string.")

    return value


def optional_string_field(
    data: Dict[str, Any],
    field: str,
    source: str,
    default: str = "",
) -> str:
    if field not in data or data[field] is None:
        return default

    value = data[field]

    if not isinstance(value, str):
        fail(
            f"Profile file {source} field {field} must be a string. "
            f"Got: {type(value).__name__}"
        )

    value = value.strip()

    if "\n" in value or "\r" in value:
        fail(f"Profile file {source} field {field} must be a single-line string.")

    return value


def require_bool_field(data: Dict[str, Any], field: str, source: str) -> bool:
    if field not in data:
        fail(f"Profile file {source} is missing required field: {field}")

    value = data[field]

    if not isinstance(value, bool):
        fail(
            f"Profile file {source} field {field} must be a YAML boolean true/false. "
            f"Do not quote booleans. Got: {value!r}"
        )

    return value


def optional_bool_field(
    data: Dict[str, Any],
    field: str,
    source: str,
    default: bool,
) -> bool:
    if field not in data:
        return default

    value = data[field]

    if not isinstance(value, bool):
        fail(
            f"Profile file {source} field {field} must be a YAML boolean true/false. "
            f"Do not quote booleans. Got: {value!r}"
        )

    return value


def optional_string_list_field(
    data: Dict[str, Any],
    field: str,
    source: str,
    default: Tuple[str, ...] = (),
) -> Tuple[str, ...]:
    if field not in data or data[field] is None:
        return default

    value = data[field]

    if not isinstance(value, list):
        fail(f"Profile file {source} field {field} must be a YAML list.")

    parsed: List[str] = []

    for index, item in enumerate(value):
        if not isinstance(item, str):
            fail(
                f"Profile file {source} field {field}[{index}] must be a string. "
                f"Got: {type(item).__name__}"
            )

        item = item.strip()

        if not item:
            fail(f"Profile file {source} field {field}[{index}] cannot be empty.")

        parsed.append(item)

    return tuple(parsed)


def validate_yaml_boolean_literals(raw: str, source: str) -> None:
    for line_number, line in enumerate(raw.splitlines(), start=1):
        match = YAML_BOOL_FIELD_RE.match(line)

        if not match:
            continue

        field = match.group(1)
        value = match.group(2).strip()

        if not value:
            fail(
                f"Profile file {source} field {field} on line {line_number} "
                "must be literal true or false."
            )

        if value not in ("true", "false"):
            fail(
                f"Profile file {source} field {field} on line {line_number} "
                f"must be literal true or false. Got: {value!r}. "
                "Do not quote booleans and do not use yes/no/on/off."
            )


def load_yaml_mapping(raw: str, source: str) -> Dict[str, Any]:
    if yaml is None:
        fail(
            "PyYAML is required when profile YAML files are present. "
            "Install py3-yaml on Alpine or python3-pyyaml on RHEL."
        )

    class UniqueKeySafeLoader(yaml.SafeLoader):
        pass

    def construct_mapping(loader: Any, node: Any, deep: bool = False) -> Dict[Any, Any]:
        mapping: Dict[Any, Any] = {}

        for key_node, value_node in node.value:
            key = loader.construct_object(key_node, deep=deep)

            if key in mapping:
                line_number = key_node.start_mark.line + 1
                fail(
                    f"Profile file {source} contains duplicate YAML key {key!r} "
                    f"on line {line_number}."
                )

            mapping[key] = loader.construct_object(value_node, deep=deep)

        return mapping

    UniqueKeySafeLoader.add_constructor(
        yaml.resolver.BaseResolver.DEFAULT_MAPPING_TAG,
        construct_mapping,
    )

    data = yaml.load(raw, Loader=UniqueKeySafeLoader)

    if data is None:
        fail(f"Profile file {source} is empty.")

    if not isinstance(data, dict):
        fail(f"Profile file {source} must contain a YAML mapping/object.")

    for key in data:
        if not isinstance(key, str):
            fail(
                f"Profile file {source} contains a non-string YAML key: {key!r}. "
                "All profile fields must use string keys."
            )

    return data


@dataclass(frozen=True)
class ProfileDefinition:
    profile_id: str
    title: str
    install_label: str
    menu_target: str
    implemented: bool
    show_in_main_menu: bool = True
    uefi: bool = True
    bios: bool = True
    supported_os: Tuple[str, ...] = ()
    kickstart_template: str = ""
    kernel_args: Tuple[str, ...] = DEFAULT_KERNEL_ARGS
    source: str = "built-in"

    @property
    def legacy_target(self) -> str:
        return f"{self.menu_target}_legacy"

    @property
    def profile_slug(self) -> str:
        return self.profile_id.replace("_", "-")

    def supports_os(self, item: DetectedISO) -> bool:
        return not self.supported_os or item.os_id in self.supported_os

    @classmethod
    def from_dict(cls, data: Dict[str, Any], source: str) -> "ProfileDefinition":
        profile_id = require_string_field(data, "profile_id", source)
        title = require_string_field(data, "title", source)
        install_label = require_string_field(data, "install_label", source)
        menu_target = require_string_field(data, "menu_target", source)

        validate_safe_identifier(profile_id, "profile_id", source)
        validate_safe_identifier(menu_target, "menu_target", source)

        implemented = require_bool_field(data, "implemented", source)
        show_in_main_menu = optional_bool_field(data, "show_in_main_menu", source, True)
        uefi = optional_bool_field(data, "uefi", source, True)
        bios = optional_bool_field(data, "bios", source, True)

        supported_os = optional_string_list_field(data, "supported_os", source)
        kickstart_template = optional_string_field(data, "kickstart_template", source)
        kernel_args = optional_string_list_field(
            data,
            "kernel_args",
            source,
            default=DEFAULT_KERNEL_ARGS,
        )

        return cls(
            profile_id=profile_id,
            title=title,
            install_label=install_label,
            menu_target=menu_target,
            implemented=implemented,
            show_in_main_menu=show_in_main_menu,
            uefi=uefi,
            bios=bios,
            supported_os=supported_os,
            kickstart_template=kickstart_template,
            kernel_args=kernel_args,
            source=source,
        )


