def render_simple_template_text(raw: str, values: Dict[str, Any], source: str) -> str:
    string_values = {key: str(value) for key, value in values.items()}

    try:
        rendered = Template(raw).safe_substitute(string_values)
    except ValueError as exc:
        fail(f"Template {source} contains an invalid $ placeholder: {exc}")

    def replace_jinja_variable(match: re.Match[str]) -> str:
        key = match.group(1)

        if key not in string_values:
            fail(f"Template {source} references unknown variable: {key}")

        return string_values[key]

    return SIMPLE_JINJA_VARIABLE_RE.sub(replace_jinja_variable, rendered)


def render_jinja2_template_text(raw: str, values: Dict[str, Any], source: str) -> str:
    if jinja2 is None:
        fail(
            f"Template {source} requires Jinja2, but the jinja2 Python package is not installed. "
            "Install py3-jinja2 on Alpine or python3-jinja2 on RHEL/UBI."
        )

    environment = jinja2.Environment(
        undefined=jinja2.StrictUndefined,
        autoescape=False,
        keep_trailing_newline=True,
    )

    try:
        return environment.from_string(raw).render(**values)
    except jinja2.TemplateError as exc:
        fail(f"Template {source} failed Jinja2 rendering: {exc}")


def render_kickstart_template_text(
    raw: str,
    values: Dict[str, Any],
    source: str,
    template_engine: str,
) -> str:
    if template_engine == "jinja2":
        return render_jinja2_template_text(raw, values, source)

    if template_engine == "simple":
        return render_simple_template_text(raw, values, source)

    fail(f"Template {source} has unsupported template engine: {template_engine}")
    return ""


def render_name_template(
    raw: str,
    item: DetectedISO,
    profile: ProfileDefinition,
    field: str,
) -> str:
    values = profile_template_values(
        GeneratorConfig(
            pxe_server="",
            pxe_port="",
            iso_root=Path("/"),
            html_root=Path("/"),
            template_root=Path("/"),
            profile_root=Path("/"),
            background_path="",
            watch_interval=1,
            rootpw_hash="",
            allow_default_rootpw=True,
        ),
        item,
        profile,
        "",
    )

    rendered = render_simple_template_text(raw, values, f"profile {profile.profile_id} {field}")
    rendered = rendered.strip()

    validate_relative_template_path(rendered, profile.profile_id, field)

    return rendered


def profile_kickstart_template_name(item: DetectedISO, profile: ProfileDefinition) -> str:
    raw_template = profile.kickstart_template

    if not raw_template:
        if profile.profile_id == "minimal":
            raw_template = item.ks_template
        else:
            fail(
                f"Profile {profile.profile_id} must define kickstart_template. "
                "Only the minimal profile may use the built-in default Kickstart fallback."
            )

    return render_name_template(raw_template, item, profile, "kickstart_template")


def kickstart_template_candidates(
    config: GeneratorConfig,
    template_name: str,
) -> Tuple[Path, ...]:
    return (
        config.template_root / "ks" / template_name,
        config.template_root / template_name,
    )


def resolve_kickstart_template(
    config: GeneratorConfig,
    item: DetectedISO,
    profile: ProfileDefinition,
) -> KickstartTemplateResolution:
    template_name = profile_kickstart_template_name(item, profile)
    candidates = kickstart_template_candidates(config, template_name)

    for candidate in candidates:
        if candidate.is_file():
            return KickstartTemplateResolution(
                template_name=template_name,
                candidates=candidates,
                template_path=candidate,
                template_source="file",
                template_engine=template_engine_for_path(candidate),
            )

    if profile.profile_id == "minimal":
        return KickstartTemplateResolution(
            template_name=template_name,
            candidates=candidates,
            template_path=None,
            template_source="built-in-default",
            template_engine="built-in-default",
        )

    searched_paths = "\n".join(f"- {candidate}" for candidate in candidates)

    fail(
        f"Profile {profile.profile_id} is implemented, but kickstart template "
        f"{template_name!r} was not found.\n"
        "Searched:\n"
        f"{searched_paths}"
    )


