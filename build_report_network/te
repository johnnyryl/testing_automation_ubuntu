def kickstart_template_candidates(
    config: GeneratorConfig,
    template_name: str,
) -> Tuple[Path, ...]:
    template_path = Path(template_name)
    candidates: List[Path] = []
    # Explicit subdirectory path, such as:
    #   ks/rhel8-minimal.ks.j2
    #   profiles/rhel8-developer-workstation.ks.j2
    candidates.append(config.template_root / template_path)
    # Backward-compatible convenience for bare filenames, such as:
    #   rhel8-minimal.ks.j2
    # This keeps the old lookup behavior:
    #   /templates/ks/<filename>
    #   /templates/<filename>
    if len(template_path.parts) == 1:
        candidates.insert(0, config.template_root / "ks" / template_path)
    deduped: List[Path] = []
    for candidate in candidates:
        if candidate not in deduped:
            deduped.append(candidate)
    return tuple(deduped)

