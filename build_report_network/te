Fix 1 — Replace render_jinja2_template_text

Replace your current function with this:

def render_jinja2_template_text(
    raw: str,
    values: Dict[str, Any],
    source: str,
    template_root: Path,
) -> str:
    if jinja2 is None:
        fail(
            f"Template {source} requires Jinja2, but the jinja2 Python package is not installed. "
            "Install py3-jinja2 on Alpine or python3-jinja2 on RHEL/UBI."
        )
    environment = jinja2.Environment(
        loader=jinja2.FileSystemLoader(str(template_root)),
        undefined=jinja2.StrictUndefined,
        autoescape=False,
        keep_trailing_newline=True,
    )
    try:
        return environment.from_string(raw).render(**values)
    except jinja2.TemplateError as exc:
        fail(f"Template {source} failed Jinja2 rendering: {exc}")

