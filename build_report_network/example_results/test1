# Change 4 — Add helper functions after `atomic_write`

Find this section:

```python
def atomic_write(path: Path, content: str, mode: int = 0o644) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)

    tmp_path = path.with_name(f".{path.name}.tmp")
    tmp_path.write_text(content, encoding="utf-8")
    tmp_path.chmod(mode)
    tmp_path.replace(path)
```

Immediately **after it**, add this whole block:

```python
def sha256_text(content: str) -> str:
    return hashlib.sha256(content.encode("utf-8")).hexdigest()


def sha256_file(path: Path) -> str:
    digest = hashlib.sha256()

    with path.open("rb") as file_obj:
        for chunk in iter(lambda: file_obj.read(1024 * 1024), b""):
            digest.update(chunk)

    return digest.hexdigest()


def read_json_mapping(path: Path) -> Dict[str, Any]:
    if not path.is_file():
        return {}

    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except json.JSONDecodeError as exc:
        fail(f"JSON state file {path} is invalid: {exc}")

    if not isinstance(data, dict):
        fail(f"JSON state file {path} must contain a JSON object.")

    return data


def kickstart_state_path(config: GeneratorConfig, destination: Path) -> Path:
    return config.html_root / "generated" / "kickstart-state" / f"{destination.name}.json"


def kickstart_candidate_path(config: GeneratorConfig, destination: Path) -> Path:
    return (
        config.html_root
        / "generated"
        / "preserved-kickstarts"
        / f"{destination.name}.candidate"
    )


def write_generated_kickstart(
    config: GeneratorConfig,
    destination: Path,
    content: str,
) -> None:
    desired_sha = sha256_text(content)
    state_path = kickstart_state_path(config, destination)
    candidate_path = kickstart_candidate_path(config, destination)

    destination_exists = destination.is_file()
    current_sha = sha256_file(destination) if destination_exists else ""
    state = read_json_mapping(state_path)
    previous_generated_sha = str(state.get("last_generated_sha256", ""))

    manual_edit_detected = (
        destination_exists
        and bool(previous_generated_sha)
        and current_sha != previous_generated_sha
    )

    if manual_edit_detected and config.generated_ks_edit_policy == "preserve":
        atomic_write(candidate_path, content)

        state_data = {
            "output_path": str(destination),
            "state_path": str(state_path),
            "candidate_path": str(candidate_path),
            "edit_policy": config.generated_ks_edit_policy,
            "manual_edit_detected": True,
            "preserved_manual_edit": True,
            "current_output_sha256": current_sha,
            "last_generated_sha256": desired_sha,
            "previous_generated_sha256": previous_generated_sha,
            "updated_at_epoch": int(time.time()),
        }

        atomic_write(
            state_path,
            json.dumps(state_data, indent=2, sort_keys=True) + "\n",
        )

        print(
            f"Preserved manually edited Kickstart: {destination}. "
            f"Regenerated candidate written to: {candidate_path}",
            flush=True,
        )
        return

    atomic_write(destination, content)

    if candidate_path.exists():
        candidate_path.unlink()

    state_data = {
        "output_path": str(destination),
        "state_path": str(state_path),
        "candidate_path": None,
        "edit_policy": config.generated_ks_edit_policy,
        "manual_edit_detected": manual_edit_detected,
        "preserved_manual_edit": False,
        "current_output_sha256": desired_sha,
        "last_generated_sha256": desired_sha,
        "previous_generated_sha256": previous_generated_sha or None,
        "updated_at_epoch": int(time.time()),
    }

    atomic_write(
        state_path,
        json.dumps(state_data, indent=2, sort_keys=True) + "\n",
    )


def generated_kickstart_state_status(
    config: GeneratorConfig,
    kickstart_name: str,
) -> Dict[str, object]:
    destination = config.html_root / "ks" / kickstart_name
    state_path = kickstart_state_path(config, destination)

    if not state_path.is_file():
        return {
            "state_exists": False,
            "state_path": str(state_path),
        }

    state = read_json_mapping(state_path)
    state["state_exists"] = True
    state["state_path"] = str(state_path)

    return state
```

