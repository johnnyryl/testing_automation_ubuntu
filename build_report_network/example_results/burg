CID=pxe-content
SCRIPT=/usr/local/bin/generate-pxe-content.py

podman exec "$CID" /bin/sh -lc '
  set -e
  rm -rf /overrides/templates/ks
  mkdir -p /overrides/templates/ks

  python3 /usr/local/bin/generate-pxe-content.py --watch &
  WATCH_PID=$!

  sleep 2

  cat > /overrides/templates/ks/rhel8-minimal.ks.j2 <<EOF
# PHASE6E WATCH OVERRIDE WORKED
#version=RHEL{{ os_major }}
{% include "partials/install-mode-text.ks.j2" %}
{% include "partials/language-keyboard.ks.j2" %}
{% include "partials/timezone.ks.j2" %}
{% include "partials/network-dhcp.ks.j2" %}
{% include "partials/root-password.ks.j2" %}
{% include "partials/repo-url.ks.j2" %}
{% include "partials/storage-default-lvm.ks.j2" %}
{% include "partials/packages-minimal.ks.j2" %}
{% include "partials/services-basic.ks.j2" %}
{% include "partials/kdump-enabled.ks.j2" %}
{% include "partials/post-empty.ks.j2" %}
EOF

  sleep 20

  grep -q "PHASE6E WATCH OVERRIDE WORKED" /etc/nginx/html/ks/rhel8-minimal.ks

  kill "$WATCH_PID"

  echo "OK: watch mode noticed override template change"
'







set -e

CID=pxe-content
SCRIPT=/usr/local/bin/generate-pxe-content.py

podman exec "$CID" python3 -m py_compile "$SCRIPT"
podman exec "$CID" python3 "$SCRIPT" --once

curl -fss http://127.0.0.1:18080/index.html -o /tmp/index-6d.html
curl -fss http://127.0.0.1:18080/generated/status.json -o /tmp/status-6d.json

grep -q "Generation Policy" /tmp/index-6d.html
grep -q "Kickstart State" /tmp/index-6d.html
grep -q "Warnings" /tmp/index-6d.html
grep -q "Generated Files" /tmp/index-6d.html

python3 -m json.tool /tmp/status-6d.json >/dev/null
grep -q '"generator"' /tmp/status-6d.json
grep -q '"active_overrides"' /tmp/status-6d.json
grep -q '"stale_kickstarts"' /tmp/status-6d.json

echo "6D test passed"









curl -fss http://127.0.0.1:18080/generated/status.json -o /tmp/status-6d.json
curl -fss http://127.0.0.1:18080/index.html -o /tmp/index-6d.html

if grep -E '\$6\$|REKKqe02' /tmp/status-6d.json /tmp/index-6d.html; then
  echo "ERROR: root password hash leaked into status/index"
  exit 1
else
  echo "OK: no root password hash leaked into status/index"
fi




