Then test that **stale generated Kickstarts get deleted**:

```bash
podman exec "$CID" /bin/sh -lc '
set -e
mkdir -p /etc/nginx/html/ks /etc/nginx/html/generated/kickstart-state

echo "# fake stale generated kickstart" > /etc/nginx/html/ks/rhel8-stale-generated.ks

sha="$(python3 - <<PY
from pathlib import Path
import hashlib
p = Path("/etc/nginx/html/ks/rhel8-stale-generated.ks")
print(hashlib.sha256(p.read_bytes()).hexdigest())
PY
)"

cat > /etc/nginx/html/generated/kickstart-state/rhel8-stale-generated.ks.json <<EOF
{
  "last_generated_sha256": "$sha"
}
EOF

python3 /usr/local/bin/generate-pxe-content.py --once

test ! -f /etc/nginx/html/ks/rhel8-stale-generated.ks
test ! -f /etc/nginx/html/generated/kickstart-state/rhel8-stale-generated.ks.json
'

curl -fss http://127.0.0.1:18080/generated/status.json -o /tmp/status-6c-delete.json
grep -q '"kickstart_name": "rhel8-stale-generated.ks"' /tmp/status-6c-delete.json
grep -q '"action": "deleted"' /tmp/status-6c-delete.json
```

