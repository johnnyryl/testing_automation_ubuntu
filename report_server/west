    def render_unimplemented_profile_targets(
        self,
        profile: ProfileDefinition,
        detected: List[DetectedISO],
    ) -> List[str]:
        lines: List[str] = []
        for item in detected:
            if item.uefi and profile.uefi:
                lines.extend(
                    [
                        f":{self.placeholder_target(item, profile, 'uefi')}",
                        f"menu {profile.title}",
                        menu_item(
                            f"{item.title} {profile.install_label} UEFI is not implemented yet",
                            profile.menu_target,
                        ),
                        menu_item(f"Back to {profile.title}", profile.menu_target),
                        menu_item("Back to Main Menu", "main"),
                        menu_item("Drop to iPXE shell", "shell"),
                        f"choose target || goto {profile.menu_target}",
                        "goto ${target}",
                        "",
                    ]
                )
            if item.bios and profile.bios:
                lines.extend(
                    [
                        f":{self.placeholder_target(item, profile, 'bios')}",
                        f"menu {profile.title}",
                        menu_item(
                            f"{item.title} {profile.install_label} BIOS is not implemented yet",
                            profile.legacy_target,
                        ),
                        menu_item(f"Back to {profile.title} Legacy / BIOS", profile.legacy_target),
                        menu_item(f"Back to {profile.title}", profile.menu_target),
                        menu_item("Back to Main Menu", "main"),
                        menu_item("Drop to iPXE shell", "shell"),
                        f"choose target || goto {profile.legacy_target}",
                        "goto ${target}",
                        "",
                    ]
                )
        return lines
    def placeholder_target(
        self,
        item: DetectedISO,
        profile: ProfileDefinition,
        firmware: str,
    ) -> str:
        return f"{item.os_id}_{profile.profile_id}_{firmware}_not_implemented"

