---
# UNCLASSIFIED
# pxe-content
# Bundle / host path behavior
#
# If aerolit_bundle_root is provided by bootstrap/group_vars, this role uses:
#   <bundle root>/extracted_isos
#   <bundle root>/files/pxe/pxe-content.tar
#
# If no bundle root is provided, it falls back to /srv/ipxe and /srv/pxe-content.
pxe_content_bundle_root: "{{ aerolit_bundle_root | default('') }}"
pxe_content_extracted_isos_root: "{{ ((pxe_content_bundle_root | string | length) > 0) | ternary(pxe_content_bundle_root ~ '/extracted_isos', '/srv/ipxe') }}"
# Container identity
pxe_content_container_name: "pxe-content"
pxe_content_service_name: "pxe-content"
# Image source
# Supported values:
#   - registry
#   - tar
pxe_content_image_source: "registry"
# Registry image source
pxe_content_image: "registry.gitlab.us.lmco.com/lit/containers/pxe-content:latest"
# Image name used at runtime by Quadlet.
# In registry mode this usually matches pxe_content_image.
# In tar mode this must match the tag embedded in the loaded tar.
pxe_content_runtime_image: "{{ pxe_content_image }}"
# Supported values when image_source=registry:
#   - missing
#   - always
pxe_content_image_pull_policy: "missing"
# Tar image options
# Optional controller-side source file to copy to the target first.
pxe_content_image_tar_src: ""
# Target-side tar path used by podman load.
# In bundle mode, this defaults to <bundle root>/files/pxe/pxe-content.tar.
pxe_content_image_tar_path: "{{ ((pxe_content_bundle_root | string | length) > 0) | ternary(pxe_content_bundle_root ~ '/files/pxe/pxe-content.tar', '/srv/pxe-content/pxe-content.tar') }}"
# Stamp file used so podman load only reruns when the tar changes,
# unless the runtime image is missing.
pxe_content_image_tar_checksum_file: "/etc/pxe-content/.loaded-image.sha256"
# Runtime / service settings
pxe_content_host_port: 18080
pxe_content_container_port: 8080
pxe_content_server_ip: "192.168.109.139"
pxe_content_stop_timeout: 10
pxe_content_restart_policy: "always"
pxe_content_restart_sec: 5
# Host-side ISO/content root.
# This should point to extracted_isos on the host.
pxe_content_iso_root: "{{ pxe_content_extracted_isos_root }}"
# Container-side ISO path.
# Keep this as /iso because the container/Nginx/generator should use a stable internal path.
pxe_content_container_iso_root: "/iso"
# Environment / state
pxe_content_state_dir: "/etc/pxe-content"
pxe_content_env_file: "/etc/pxe-content/pxe-content.env"
# Quadlet
pxe_content_quadlet_dir: "/etc/containers/systemd"
pxe_content_quadlet_file: "{{ pxe_content_quadlet_dir }}/{{ pxe_content_service_name }}.container"
# Cleanup from the earlier hand-written systemd service design
pxe_content_remove_legacy_service_file: true
pxe_content_legacy_service_file: "/etc/systemd/system/{{ pxe_content_service_name }}.service"
# Podman / SELinux behavior
pxe_content_security_opt_label_disable: true
# Main content mount plus any extras.
# Host extracted_isos gets mounted into the container as /iso.
pxe_content_volume_mounts:
  - "{{ pxe_content_iso_root }}:{{ pxe_content_container_iso_root }}:ro,Z"
# Extra ports in standard Quadlet PublishPort format, for example:
#   - "8443:8443/tcp"
pxe_content_extra_ports: []
# Extra env vars written into /etc/pxe-content/pxe-content.env.
# Example:
# pxe_content_extra_env:
#   PXE_SCAN_INTERVAL: 15
pxe_content_extra_env: {}
# Podman args that should always be present for the Quadlet container.
# This prevents boot-time startup from depending on live registry access.
pxe_content_quadlet_podman_args:
  - "--pull=never"
# Extra raw podman args for Quadlet, for example:
#   - "--log-driver=journald"
#   - "--cpus=2"
pxe_content_extra_run_args: []
# Package / firewall management
pxe_content_packages:
  - podman
pxe_content_manage_firewall: true
pxe_content_firewall_zone: "public"
pxe_content_firewall_packages:
  - firewalld
pxe_content_firewall_ports:
  - "{{ pxe_content_host_port }}/tcp"
# Validation after deployment
pxe_content_validate_deployment: true
pxe_content_validate_scheme: "http"
pxe_content_validate_host: "127.0.0.1"
pxe_content_validate_path: "/boot.ipxe"
pxe_content_validate_status_code: 200
pxe_content_validate_timeout: 30
pxe_content_validate_retries: 10
pxe_content_validate_delay: 3
