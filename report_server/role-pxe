---
# UNCLASSIFIED
- name: Assert valid pxe_content_image_source
  ansible.builtin.assert:
    that:
      - pxe_content_image_source in ['registry', 'tar']
    fail_msg: "pxe_content_image_source must be 'registry' or 'tar'."
- name: Assert valid pxe_content_image_pull_policy
  ansible.builtin.assert:
    that:
      - pxe_content_image_pull_policy in ['missing', 'always']
    fail_msg: "pxe_content_image_pull_policy must be 'missing' or 'always'."
- name: Assert runtime image is set
  ansible.builtin.assert:
    that:
      - pxe_content_runtime_image | length > 0
    fail_msg: "pxe_content_runtime_image must be set."
- name: Assert registry image is set when using registry source
  ansible.builtin.assert:
    that:
      - pxe_content_image | length > 0
    fail_msg: "pxe_content_image must be set when pxe_content_image_source=registry."
  when: pxe_content_image_source == 'registry'
- name: Assert tar image path is set when using tar source
  ansible.builtin.assert:
    that:
      - pxe_content_image_tar_path | length > 0
    fail_msg: "pxe_content_image_tar_path must be set when pxe_content_image_source=tar."
  when: pxe_content_image_source == 'tar'
- name: Assert valid pxe_content_host_port
  ansible.builtin.assert:
    that:
      - (pxe_content_host_port | int) >= 1
      - (pxe_content_host_port | int) <= 65535
    fail_msg: "pxe_content_host_port must be between 1 and 65535."
- name: Assert valid pxe_content_container_port
  ansible.builtin.assert:
    that:
      - (pxe_content_container_port | int) >= 1
      - (pxe_content_container_port | int) <= 65535
    fail_msg: "pxe_content_container_port must be between 1 and 65535."
- name: Assert PXE content ISO root is safe
  ansible.builtin.assert:
    that:
      - pxe_content_iso_root | length > 1
      - pxe_content_iso_root != '/'
    fail_msg: "pxe_content_iso_root must be a safe directory path and cannot be '/'."
- name: Install Podman package(s)
  ansible.builtin.package:
    name: "{{ pxe_content_packages }}"
    state: present
- name: Install firewall package(s) when firewall management is enabled
  ansible.builtin.package:
    name: "{{ pxe_content_firewall_packages }}"
    state: present
  when: pxe_content_manage_firewall | bool
- name: Ensure pxe-content state directory exists
  ansible.builtin.file:
    path: "{{ pxe_content_state_dir }}"
    state: directory
    owner: root
    group: root
    mode: "0755"
- name: Ensure PXE extracted ISO root exists
  ansible.builtin.file:
    path: "{{ pxe_content_iso_root }}"
    state: directory
    owner: root
    group: root
    mode: "0755"
- name: Ensure Quadlet directory exists
  ansible.builtin.file:
    path: "{{ pxe_content_quadlet_dir }}"
    state: directory
    owner: root
    group: root
    mode: "0755"
- name: Ensure pxe-content env file parent directory exists
  ansible.builtin.file:
    path: "{{ pxe_content_env_file | dirname }}"
    state: directory
    owner: root
    group: root
    mode: "0755"
- name: Ensure pxe-content checksum file parent directory exists
  ansible.builtin.file:
    path: "{{ pxe_content_image_tar_checksum_file | dirname }}"
    state: directory
    owner: root
    group: root
    mode: "0755"
- name: Ensure tar image parent directory exists when using tar source
  ansible.builtin.file:
    path: "{{ pxe_content_image_tar_path | dirname }}"
    state: directory
    owner: root
    group: root
    mode: "0755"
  when: pxe_content_image_source == 'tar'
- name: Copy pxe-content image tar from controller when provided
  ansible.builtin.copy:
    src: "{{ pxe_content_image_tar_src }}"
    dest: "{{ pxe_content_image_tar_path }}"
    owner: root
    group: root
    mode: "0644"
  when:
    - pxe_content_image_source == 'tar'
    - pxe_content_image_tar_src | length > 0
- name: Stat target-side pxe-content image tar
  ansible.builtin.stat:
    path: "{{ pxe_content_image_tar_path }}"
    checksum_algorithm: sha256
  register: pxe_content_tar_stat
  when: pxe_content_image_source == 'tar'
- name: Assert pxe-content image tar exists
  ansible.builtin.assert:
    that:
      - pxe_content_tar_stat.stat.exists
      - not pxe_content_tar_stat.stat.isdir
    fail_msg: "pxe_content_image_tar_path does not exist or is not a file."
  when:
    - pxe_content_image_source == 'tar'
    - not ansible_check_mode
- name: Stat loaded image checksum stamp
  ansible.builtin.stat:
    path: "{{ pxe_content_image_tar_checksum_file }}"
  register: pxe_content_tar_checksum_stamp
  when: pxe_content_image_source == 'tar'
- name: Read loaded image checksum stamp
  ansible.builtin.slurp:
    src: "{{ pxe_content_image_tar_checksum_file }}"
  register: pxe_content_tar_checksum_slurp
  when:
    - pxe_content_image_source == 'tar'
    - pxe_content_tar_checksum_stamp.stat.exists
- name: Set loaded image checksum fact
  ansible.builtin.set_fact:
    pxe_content_loaded_tar_checksum: >-
      {{
        (pxe_content_tar_checksum_slurp.content | b64decode | trim)
        if pxe_content_tar_checksum_stamp.stat.exists
        else ''
      }}
  when: pxe_content_image_source == 'tar'
- name: Check whether runtime image exists locally before tar load
  ansible.builtin.command:
    cmd: "podman image exists {{ pxe_content_runtime_image }}"
  register: pxe_content_runtime_image_exists_pre
  changed_when: false
  failed_when: false
  when:
    - pxe_content_image_source == 'tar'
    - not ansible_check_mode
- name: Load pxe-content image tar into Podman
  ansible.builtin.command:
    cmd: "podman load -i {{ pxe_content_image_tar_path }}"
  register: pxe_content_load_result
  changed_when: true
  when:
    - pxe_content_image_source == 'tar'
    - not ansible_check_mode
    - >
      ((pxe_content_loaded_tar_checksum | default('')) != (pxe_content_tar_stat.stat.checksum | default('')))
      or ((pxe_content_runtime_image_exists_pre.rc | default(1)) != 0)
- name: Write loaded image checksum stamp
  ansible.builtin.copy:
    dest: "{{ pxe_content_image_tar_checksum_file }}"
    content: "{{ pxe_content_tar_stat.stat.checksum }}\n"
    owner: root
    group: root
    mode: "0644"
  when:
    - pxe_content_image_source == 'tar'
    - not ansible_check_mode
    - pxe_content_tar_stat.stat.checksum is defined
    - >
      ((pxe_content_loaded_tar_checksum | default('')) != (pxe_content_tar_stat.stat.checksum | default('')))
      or ((pxe_content_runtime_image_exists_pre.rc | default(1)) != 0)
- name: Assert runtime image exists locally after tar load
  ansible.builtin.command:
    cmd: "podman image exists {{ pxe_content_runtime_image }}"
  register: pxe_content_runtime_image_exists_post
  changed_when: false
  failed_when: pxe_content_runtime_image_exists_post.rc != 0
  when:
    - pxe_content_image_source == 'tar'
    - not ansible_check_mode
- name: Check whether registry image already exists locally
  ansible.builtin.command:
    cmd: "podman image exists {{ pxe_content_image }}"
  register: pxe_content_image_exists
  changed_when: false
  failed_when: false
  when:
    - pxe_content_image_source == 'registry'
    - pxe_content_image_pull_policy == 'missing'
    - not ansible_check_mode
- name: Pull pxe-content image from registry
  ansible.builtin.command:
    cmd: "podman pull {{ pxe_content_image }}"
  register: pxe_content_pull_result
  changed_when: true
  when:
    - pxe_content_image_source == 'registry'
    - not ansible_check_mode
    - >
      pxe_content_image_pull_policy == 'always'
      or
      (pxe_content_image_pull_policy == 'missing' and (pxe_content_image_exists.rc | default(1)) != 0)
- name: Assert runtime image exists locally after registry handling
  ansible.builtin.command:
    cmd: "podman image exists {{ pxe_content_runtime_image }}"
  register: pxe_content_runtime_image_exists_registry
  changed_when: false
  failed_when: pxe_content_runtime_image_exists_registry.rc != 0
  when:
    - pxe_content_image_source == 'registry'
    - not ansible_check_mode
