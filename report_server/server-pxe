# Bundle / ISO source
# If pxe_content_bundle_root is set, the role uses:
#   {{ pxe_content_bundle_root }}/extracted_isos
#
# If pxe_content_bundle_root is blank, it falls back to pxe_content_iso_root.
pxe_content_bundle_root: ""
