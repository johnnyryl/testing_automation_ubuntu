#!/usr/bin/env python3
import os
import time
import hashlib
from pathlib import Path
from string import Template
PXE_SERVER = os.environ.get("PXE_SERVER", "").strip()
PXE_PORT = os.environ.get("PXE_PORT", "18080").strip()
# This is the path inside the container.
# The host/bundle extracted_isos directory should be bind-mounted here.
ISO_ROOT = Path(os.environ.get("PXE_ISO_ROOT", "/iso"))
HTML_ROOT = Path(os.environ.get("PXE_HTML_ROOT", "/etc/nginx/html"))
TEMPLATE_ROOT = Path(os.environ.get("PXE_TEMPLATE_ROOT", "/templates"))
BACKGROUND_PATH = os.environ.get("PXE_BACKGROUND_PATH", "/ui/background.png")
WATCH_INTERVAL = int(os.environ.get("PXE_WATCH_INTERVAL", "15"))
ROOTPW_HASH = os.environ.get("ROOTPW_HASH", "").strip()
ALLOW_DEFAULT_ROOTPW = os.environ.get("ALLOW_DEFAULT_ROOTPW", "true").lower() == "true"
DEFAULT_ROOTPW_HASH = "$6$RREkK0eQ2R3z8Y64USCA2sEUK/HJ4dPEAZ/CqSK2Rauff3tbR00t2apKmPTbXaXUALwgHWXdUggyaKOQQJ6Pwucavq4I35SXAZj5P/"
OS_DEFINITIONS = {
    "rhel7": {
        "title": "RHEL 7",
        "iso_dir": "rhel7iso",
        "ks_template": "rhel7-minimal.ks.tmpl",
        "uefi": False,
        "bios": True,
    },
    "rhel8": {
        "title": "RHEL 8",
        "iso_dir": "rhel8iso",
        "ks_template": "rhel8-minimal.ks.tmpl",
        "uefi": True,
        "bios": True,
    },
    "rhel9": {
        "title": "RHEL 9",
        "iso_dir": "rhel9iso",
        "ks_template": "rhel9-minimal.ks.tmpl",
        "uefi": True,
        "bios": False,
    },
    "rhel10": {
        "title": "RHEL 10",
        "iso_dir": "rhel10iso",
        "ks_template": "rhel10-minimal.ks.tmpl",
        "uefi": True,
        "bios": False,
    },
}
def fail(message: str) -> None:
    raise SystemExit(f"ERROR: {message}")
def validate_env() -> str:
    if not PXE_SERVER:
        fail("PXE_SERVER is required.")
    if ROOTPW_HASH:
        return ROOTPW_HASH
    if ALLOW_DEFAULT_ROOTPW:
        return DEFAULT_ROOTPW_HASH
    fail("ROOTPW_HASH is required unless ALLOW_DEFAULT_ROOTPW=true.")
    return ""
def detect_isos() -> dict:
    detected = {}
    for os_id, data in OS_DEFINITIONS.items():
        iso_path = ISO_ROOT / data["iso_dir"]
        pxeboot_path = iso_path / "images" / "pxeboot"
        has_kernel = (pxeboot_path / "vmlinuz").is_file()
        has_initrd = (pxeboot_path / "initrd.img").is_file()
        if iso_path.is_dir() and has_kernel and has_initrd:
            detected[os_id] = {
                **data,
                "iso_path": str(iso_path),
            }
    return detected
def render_template(src: Path, dest: Path, values: dict) -> None:
    if not src.is_file():
        print(f"WARN: missing template: {src}")
        return
    raw = src.read_text()
    rendered = Template(raw).safe_substitute(values)
    dest.parent.mkdir(parents=True, exist_ok=True)
    dest.write_text(rendered)
def render_kickstarts(detected: dict, rootpw_hash: str) -> None:
    ks_out_dir = HTML_ROOT / "ks"
    ks_out_dir.mkdir(parents=True, exist_ok=True)
    for os_id, data in detected.items():
        src = TEMPLATE_ROOT / data["ks_template"]
        dest = ks_out_dir / f"{os_id}-minimal.ks"
        values = {
            "PXE_SERVER": PXE_SERVER,
            "PXE_PORT": PXE_PORT,
            "ROOTPW_HASH": rootpw_hash,
        }
        render_template(src, dest, values)
def menu_item(label: str, target: str) -> str:
    return f"item {target:<24} {label}"
def render_boot_ipxe(detected: dict) -> None:
    lines = []
    lines.extend([
        "#!ipxe",
        "",
        f"set server {PXE_SERVER}",
        f"set port {PXE_PORT}",
        "set base http://${server}:${port}",
        "",
        f"console --picture ${{base}}{BACKGROUND_PATH} --left 80 --right 80 --top 60 --bottom 80 || goto main",
        "",
        ":main",
        "menu AeroLIT PXE Menu",
        "item minimal                 Minimal Installs",
        "item rescue                  Utilities / Rescue",
        "item shell                   Drop to iPXE shell",
        "choose target || goto shell",
        "goto ${target}",
        "",
        ":minimal",
        "menu Minimal Installs",
    ])
    for os_id, data in detected.items():
        if data["uefi"]:
            lines.append(menu_item(f"Install {data['title']} Minimal (UEFI)", f"{os_id}_minimal_uefi"))
    if any(data["bios"] for data in detected.values()):
        lines.append("item minimal_legacy          Legacy / BIOS Options")
    lines.extend([
        "item main                    Back to Main Menu",
        "item shell                   Drop to iPXE shell",
        "choose target || goto main",
        "goto ${target}",
        "",
        ":minimal_legacy",
        "menu Minimal Installs - Legacy / BIOS",
    ])
    for os_id, data in detected.items():
        if data["bios"]:
            lines.append(menu_item(f"Install {data['title']} Minimal (BIOS / Legacy)", f"{os_id}_minimal_bios"))
    lines.extend([
        "item minimal                 Back to Minimal Installs",
        "item main                    Back to Main Menu",
        "item shell                   Drop to iPXE shell",
        "choose target || goto minimal",
        "goto ${target}",
        "",
    ])
    for os_id, data in detected.items():
        if data["uefi"]:
            lines.extend([
                f":{os_id}_minimal_uefi",
                f"kernel ${{base}}/{os_id}/images/pxeboot/vmlinuz initrd=initrd.img ip=dhcp inst.repo=${{base}}/{os_id} inst.stage2=${{base}}/{os_id} inst.ks=${{base}}/ks/{os_id}-minimal.ks inst.text nomodeset",
                f"initrd --name initrd.img ${{base}}/{os_id}/images/pxeboot/initrd.img",
                "boot",
                "",
            ])
        if data["bios"]:
            lines.extend([
                f":{os_id}_minimal_bios",
                f"kernel ${{base}}/{os_id}/images/pxeboot/vmlinuz ip=dhcp inst.repo=${{base}}/{os_id} inst.stage2=${{base}}/{os_id} inst.ks=${{base}}/ks/{os_id}-minimal.ks inst.text nomodeset",
                f"initrd ${{base}}/{os_id}/images/pxeboot/initrd.img",
                "boot",
                "",
            ])
    lines.extend([
        ":rescue",
        "menu Utilities / Rescue",
        "item main                    Back to Main Menu",
        "item shell                   Drop to iPXE shell",
        "choose target || goto main",
        "goto ${target}",
        "",
        ":shell",
        "shell",
        "",
    ])
    boot_file = HTML_ROOT / "boot.ipxe"
    boot_file.write_text("\n".join(lines))
def render_status(detected: dict) -> None:
    generated_dir = HTML_ROOT / "generated"
    generated_dir.mkdir(parents=True, exist_ok=True)
    detected_list = sorted(detected.keys())
    status = [
        "{",
        f'  "pxe_server": "{PXE_SERVER}",',
        f'  "pxe_port": "{PXE_PORT}",',
        f'  "container_iso_root": "{ISO_ROOT}",',
        f'  "detected_isos": {detected_list},',
        '  "enabled_profiles": ["minimal"],',
        '  "boot_menu": "/boot.ipxe"',
        "}",
        "",
    ]
    (generated_dir / "status.json").write_text("\n".join(status))
def watched_state_hash() -> str:
    """
    Do not hash the whole extracted ISO tree.
    That could be huge. Only watch the marker files that matter for PXE boot.
    """
    h = hashlib.sha256()
    watched_paths = []
    for os_id, data in OS_DEFINITIONS.items():
        iso_path = ISO_ROOT / data["iso_dir"]
        watched_paths.extend([
            iso_path,
            iso_path / "images" / "pxeboot" / "vmlinuz",
            iso_path / "images" / "pxeboot" / "initrd.img",
            TEMPLATE_ROOT / data["ks_template"],
        ])
    watched_paths.append(HTML_ROOT / BACKGROUND_PATH.lstrip("/"))
    for path in watched_paths:
        h.update(str(path).encode())
        if path.exists():
            stat = path.stat()
            h.update(str(stat.st_mtime_ns).encode())
            h.update(str(stat.st_size).encode())
            h.update(b"exists")
        else:
            h.update(b"missing")
    return h.hexdigest()
def generate_once() -> None:
    rootpw_hash = validate_env()
    detected = detect_isos()
    HTML_ROOT.mkdir(parents=True, exist_ok=True)
    render_kickstarts(detected, rootpw_hash)
    render_boot_ipxe(detected)
    render_status(detected)
    print(f"Generated PXE content. Detected ISOs: {', '.join(sorted(detected.keys())) or 'none'}", flush=True)
def watch_loop() -> None:
    last_hash = ""
    while True:
        current_hash = watched_state_hash()
        if current_hash != last_hash:
            generate_once()
            last_hash = current_hash
        time.sleep(WATCH_INTERVAL)
if __name__ == "__main__":
    watch_loop()

