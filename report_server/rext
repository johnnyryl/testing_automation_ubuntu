def detected_iso_status(item: DetectedISO) -> Dict[str, object]:
    return {
        "os_id": item.os_id,
        "title": item.title,
        "iso_dir": item.iso_dir,
        "iso_path": str(item.iso_path),
        "http_path": f"/{item.http_path}",
        "kickstart": f"/ks/{item.ks_name}",
        "uefi_enabled": item.uefi,
        "bios_enabled": item.bios,
    }


def profile_status(profile: ProfileDefinition) -> Dict[str, object]:
    return {
        "profile_id": profile.profile_id,
        "title": profile.title,
        "install_label": profile.install_label,
        "menu_target": profile.menu_target,
        "implemented": profile.implemented,
        "show_in_main_menu": profile.show_in_main_menu,
        "uefi_enabled": profile.uefi,
        "bios_enabled": profile.bios,
    }


def render_status(config: GeneratorConfig, detected: List[DetectedISO]) -> None:
    generated_dir = config.html_root / "generated"
    generated_dir.mkdir(parents=True, exist_ok=True)

    detected_list = [detected_iso_status(item) for item in detected]

    visible_profiles = [
        profile.profile_id
        for profile in PROFILE_DEFINITIONS
        if profile.show_in_main_menu
    ]

    enabled_profiles = [
        profile.profile_id
        for profile in PROFILE_DEFINITIONS
        if profile.show_in_main_menu and profile.implemented
    ]

    unimplemented_profiles = [
        profile.profile_id
        for profile in PROFILE_DEFINITIONS
        if profile.show_in_main_menu and not profile.implemented
    ]

    status = {
        "pxe_server": config.pxe_server,
        "pxe_port": config.pxe_port,
        "container_iso_root": str(config.iso_root),
        "html_root": str(config.html_root),
        "detected_isos": detected_list,
        "profiles": [
            profile_status(profile)
            for profile in PROFILE_DEFINITIONS
            if profile.show_in_main_menu
        ],
        "visible_profiles": visible_profiles,
        "enabled_profiles": enabled_profiles,
        "unimplemented_profiles": unimplemented_profiles,
        "boot_menu": "/boot.ipxe",
    }

    atomic_write(
        generated_dir / "status.json",
        json.dumps(status, indent=2, sort_keys=True) + "\n",
    )

    inventory_lines = [
        f"{item.os_id} {item.iso_dir} {item.iso_path}" for item in detected
    ]

    if not inventory_lines:
        inventory_lines.append("No supported RHEL ISO trees detected.")

    atomic_write(generated_dir / "isos.txt", "\n".join(inventory_lines) + "\n")


def render_index(config: GeneratorConfig, detected: List[DetectedISO]) -> None:
    lines = [
        "<html>",
        "<head><title>AeroLIT PXE Content</title></head>",
        "<body>",
        "<h1>AeroLIT PXE Content</h1>",
        "<h2>Detected ISO Trees</h2>",
        "<ul>",
    ]

    if detected:
        for item in detected:
            lines.append(f"<li>{item.title}: /{item.http_path}/ from {item.iso_path}</li>")
    else:
        lines.append("<li>No supported RHEL ISO trees detected.</li>")

    lines.extend(
        [
            "</ul>",
            "<h2>Profile Sets</h2>",
            "<ul>",
        ]
    )

    for profile in PROFILE_DEFINITIONS:
        if not profile.show_in_main_menu:
            continue

        state = "implemented" if profile.implemented else "placeholder / not implemented"
        lines.append(f"<li>{profile.title}: {state}</li>")

    lines.extend(
        [
            "</ul>",
            "<h2>Generated Files</h2>",
            "<ul>",
            '<li><a href="/boot.ipxe">boot.ipxe</a></li>',
            '<li><a href="/generated/status.json">generated/status.json</a></li>',
            '<li><a href="/generated/isos.txt">generated/isos.txt</a></li>',
            "</ul>",
            "</body>",
            "</html>",
            "",
        ]
    )

    atomic_write(config.html_root / "index.html", "\n".join(lines))


