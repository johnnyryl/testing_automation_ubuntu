class KickstartRenderer:
    def __init__(self, config: GeneratorConfig, rootpw_hash: str) -> None:
        self.config = config
        self.rootpw_hash = rootpw_hash

    def find_template(self, template_name: str) -> Optional[Path]:
        candidates = [
            self.config.template_root / "ks" / template_name,
            self.config.template_root / template_name,
        ]

        for candidate in candidates:
            if candidate.is_file():
                return candidate

        return None

    def render_all(self, detected: Iterable[DetectedISO]) -> None:
        for item in detected:
            self.render_one(item)

    def render_one(self, item: DetectedISO) -> None:
        destination = self.config.html_root / "ks" / item.ks_name
        template_path = self.find_template(item.ks_template)

        if template_path:
            rendered = self.render_template(template_path)
        else:
            rendered = self.default_kickstart(item)

        atomic_write(destination, rendered)

    def render_template(self, template_path: Path) -> str:
        values = {
            "PXE_SERVER": self.config.pxe_server,
            "PXE_PORT": self.config.pxe_port,
            "ROOTPW_HASH": self.rootpw_hash,
        }

        raw = template_path.read_text(encoding="utf-8")
        return Template(raw).safe_substitute(values)

    def default_kickstart(self, item: DetectedISO) -> str:
        return f"""#version=RHEL{item.major}
text
reboot

lang en_US.UTF-8
keyboard us
timezone America/Chicago --utc

network --bootproto=dhcp --device=link --activate

rootpw --iscrypted {self.rootpw_hash}
firstboot --disable
selinux --enforcing
firewall --enabled --service=ssh
services --enabled=sshd

url --url="http://{self.config.pxe_server}:{self.config.pxe_port}/{item.os_id}"

zerombr
clearpart --all --initlabel
autopart --type=lvm

%packages
@^minimal-environment
%end

%addon com_redhat_kdump --enable
%end
"""


