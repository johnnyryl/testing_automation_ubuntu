def menu_item(label: str, target: str) -> str:
    return f"item {target:<28} {label}"


class BootMenuRenderer:
    def __init__(self, config: GeneratorConfig) -> None:
        self.config = config

    def visible_profiles(self) -> List[ProfileDefinition]:
        return [
            profile
            for profile in PROFILE_DEFINITIONS
            if profile.show_in_main_menu
        ]

    def enabled_profiles(self) -> List[ProfileDefinition]:
        return [
            profile
            for profile in PROFILE_DEFINITIONS
            if profile.show_in_main_menu and profile.implemented
        ]

    def render(self, detected: List[DetectedISO]) -> str:
        lines: List[str] = []

        lines.extend(
            [
                "#!ipxe",
                "",
                f"set server {self.config.pxe_server}",
                f"set port {self.config.pxe_port}",
                "set base http://${server}:${port}",
                "",
                f"console --picture ${{base}}{self.config.background_path} --left 360 --right 360 --top 140 --bottom 140 || goto main",
                "",
                ":main",
                "menu AeroLIT PXE Menu",
            ]
        )

        for profile in self.visible_profiles():
            lines.append(menu_item(profile.title, profile.menu_target))

        lines.extend(
            [
                menu_item("Utilities / Rescue", "rescue"),
                menu_item("Drop to iPXE shell", "shell"),
                "choose target || goto shell",
                "goto ${target}",
                "",
            ]
        )

        for profile in self.visible_profiles():
            if profile.implemented:
                lines.extend(self.render_implemented_profile_menu(profile, detected))
            else:
                lines.extend(self.render_unimplemented_profile_menu(profile, detected))

        lines.extend(self.render_boot_targets(detected))
        lines.extend(self.render_rescue_menu())
        lines.extend([":shell", "shell", ""])

        return "\n".join(lines)

    def render_implemented_profile_menu(
        self,
        profile: ProfileDefinition,
        detected: List[DetectedISO],
    ) -> List[str]:
        lines: List[str] = [
            f":{profile.menu_target}",
            f"menu {profile.title}",
        ]

        if not detected:
            lines.append(menu_item("No supported RHEL ISO trees detected", "main"))
        else:
            for item in detected:
                if item.uefi and profile.uefi:
                    lines.append(
                        menu_item(
                            f"Install {item.title} {profile.install_label} (UEFI)",
                            self.profile_target(item, profile, "uefi"),
                        )
                    )

            if any(item.bios and profile.bios for item in detected):
                lines.append(menu_item("Legacy / BIOS Options", profile.legacy_target))

        lines.extend(
            [
                menu_item("Back to Main Menu", "main"),
                menu_item("Drop to iPXE shell", "shell"),
                "choose target || goto main",
                "goto ${target}",
                "",
            ]
        )

        if any(item.bios and profile.bios for item in detected):
            lines.extend(self.render_implemented_legacy_menu(profile, detected))

        return lines

    def render_implemented_legacy_menu(
        self,
        profile: ProfileDefinition,
        detected: List[DetectedISO],
    ) -> List[str]:
        lines: List[str] = [
            f":{profile.legacy_target}",
            f"menu {profile.title} - Legacy / BIOS",
        ]

        for item in detected:
            if item.bios and profile.bios:
                lines.append(
                    menu_item(
                        f"Install {item.title} {profile.install_label} (BIOS / Legacy)",
                        self.profile_target(item, profile, "bios"),
                    )
                )

        lines.extend(
            [
                menu_item(f"Back to {profile.title}", profile.menu_target),
                menu_item("Back to Main Menu", "main"),
                menu_item("Drop to iPXE shell", "shell"),
                f"choose target || goto {profile.menu_target}",
                "goto ${target}",
                "",
            ]
        )

        return lines

    def render_unimplemented_profile_menu(
        self,
        profile: ProfileDefinition,
        detected: List[DetectedISO],
    ) -> List[str]:
        lines: List[str] = [
            f":{profile.menu_target}",
            f"menu {profile.title}",
            menu_item("Profile not implemented yet", "main"),
        ]

        if not detected:
            lines.append(menu_item("No supported RHEL ISO trees detected", "main"))
        else:
            for item in detected:
                if item.uefi and profile.uefi:
                    lines.append(
                        menu_item(
                            f"{item.title} {profile.install_label} (UEFI) - not implemented",
                            self.not_implemented_target(item, profile, "uefi"),
                        )
                    )

            if any(item.bios and profile.bios for item in detected):
                lines.append(menu_item("Legacy / BIOS Options", profile.legacy_target))

        lines.extend(
            [
                menu_item("Back to Main Menu", "main"),
                menu_item("Drop to iPXE shell", "shell"),
                "choose target || goto main",
                "goto ${target}",
                "",
            ]
        )

        if any(item.bios and profile.bios for item in detected):
            lines.extend(self.render_unimplemented_legacy_menu(profile, detected))

        for item in detected:
            if item.uefi and profile.uefi:
                lines.extend(self.render_not_implemented_target_menu(item, profile, "uefi"))

            if item.bios and profile.bios:
                lines.extend(self.render_not_implemented_target_menu(item, profile, "bios"))

        return lines

    def render_unimplemented_legacy_menu(
        self,
        profile: ProfileDefinition,
        detected: List[DetectedISO],
    ) -> List[str]:
        lines: List[str] = [
            f":{profile.legacy_target}",
            f"menu {profile.title} - Legacy / BIOS",
        ]

        for item in detected:
            if item.bios and profile.bios:
                lines.append(
                    menu_item(
                        f"{item.title} {profile.install_label} (BIOS / Legacy) - not implemented",
                        self.not_implemented_target(item, profile, "bios"),
                    )
                )

        lines.extend(
            [
                menu_item(f"Back to {profile.title}", profile.menu_target),
                menu_item("Back to Main Menu", "main"),
                menu_item("Drop to iPXE shell", "shell"),
                f"choose target || goto {profile.menu_target}",
                "goto ${target}",
                "",
            ]
        )

        return lines

    def render_not_implemented_target_menu(
        self,
        item: DetectedISO,
        profile: ProfileDefinition,
        firmware: str,
    ) -> List[str]:
        firmware_label = "UEFI" if firmware == "uefi" else "BIOS"
        back_target = profile.legacy_target if firmware == "bios" else profile.menu_target
        back_label = (
            f"Back to {profile.title} Legacy / BIOS"
            if firmware == "bios"
            else f"Back to {profile.title}"
        )

        return [
            f":{self.not_implemented_target(item, profile, firmware)}",
            f"menu {profile.title}",
            menu_item(
                f"{item.title} {profile.install_label} {firmware_label} is not implemented yet",
                back_target,
            ),
            menu_item(back_label, back_target),
            menu_item("Back to Main Menu", "main"),
            menu_item("Drop to iPXE shell", "shell"),
            f"choose target || goto {back_target}",
            "goto ${target}",
            "",
        ]

    def render_boot_targets(self, detected: List[DetectedISO]) -> List[str]:
        lines: List[str] = []

        for profile in self.enabled_profiles():
            for item in detected:
                if item.uefi and profile.uefi:
                    lines.append(
                        self.kernel_block(
                            item,
                            profile,
                            self.profile_target(item, profile, "uefi"),
                        )
                    )

                if item.bios and profile.bios:
                    lines.append(
                        self.kernel_block(
                            item,
                            profile,
                            self.profile_target(item, profile, "bios"),
                        )
                    )

        return lines

    def render_rescue_menu(self) -> List[str]:
        return [
            ":rescue",
            "menu Utilities / Rescue",
            menu_item("Back to Main Menu", "main"),
            menu_item("Drop to iPXE shell", "shell"),
            "choose target || goto main",
            "goto ${target}",
            "",
        ]

    def profile_target(
        self,
        item: DetectedISO,
        profile: ProfileDefinition,
        firmware: str,
    ) -> str:
        return f"{item.os_id}_{profile.profile_id}_{firmware}"

    def not_implemented_target(
        self,
        item: DetectedISO,
        profile: ProfileDefinition,
        firmware: str,
    ) -> str:
        return f"{self.profile_target(item, profile, firmware)}_not_implemented"

    def profile_kickstart_name(
        self,
        item: DetectedISO,
        profile: ProfileDefinition,
    ) -> str:
        if profile.profile_id == "minimal":
            return item.ks_name

        return f"{item.os_id}-{profile.profile_id.replace('_', '-')}.ks"

    def kernel_block(
        self,
        item: DetectedISO,
        profile: ProfileDefinition,
        target: str,
    ) -> str:
        kickstart_name = self.profile_kickstart_name(item, profile)

        return f""":{target}
kernel ${{base}}/{item.http_path}/images/pxeboot/vmlinuz initrd=initrd.img ip=dhcp inst.repo=${{base}}/{item.http_path} inst.stage2=${{base}}/{item.http_path} inst.ks=${{base}}/ks/{kickstart_name} inst.text nomodeset
initrd --name initrd.img ${{base}}/{item.http_path}/images/pxeboot/initrd.img
boot
"""


def write_boot_ipxe(config: GeneratorConfig, detected: List[DetectedISO]) -> None:
    renderer = BootMenuRenderer(config)
    atomic_write(config.html_root / "boot.ipxe", renderer.render(detected))


