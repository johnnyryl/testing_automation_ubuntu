def atomic_write(path: Path, content: str, mode: int = 0o644) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)

    tmp_path = path.with_name(f".{path.name}.tmp")
    tmp_path.write_text(content, encoding="utf-8")
    tmp_path.chmod(mode)
    tmp_path.replace(path)


def ensure_output_directories(config: GeneratorConfig) -> None:
    config.html_root.mkdir(parents=True, exist_ok=True)
    (config.html_root / "ks").mkdir(parents=True, exist_ok=True)
    (config.html_root / "generated").mkdir(parents=True, exist_ok=True)


# =============================================================================
# ISO discovery
# =============================================================================


def pxeboot_dir(iso_path: Path) -> Path:
    return iso_path / "images" / "pxeboot"


def is_bootable_iso_tree(iso_path: Path) -> bool:
    boot_dir = pxeboot_dir(iso_path)

    return (
        iso_path.is_dir()
        and (boot_dir / "vmlinuz").is_file()
        and (boot_dir / "initrd.img").is_file()
    )


def discover_isos(config: GeneratorConfig) -> List[DetectedISO]:
    detected: List[DetectedISO] = []

    for definition in OS_DEFINITIONS:
        iso_path = config.iso_root / definition.iso_dir

        if is_bootable_iso_tree(iso_path):
            detected.append(DetectedISO(definition=definition, iso_path=iso_path))

    return detected


