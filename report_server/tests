#!/usr/bin/env python3
import os
import re
from pathlib import Path
from string import Template
SUPPORTED_RHEL_MAJORS = [7, 8, 9, 10]
def getenv(name: str, default: str = "") -> str:
    return os.environ.get(name, default).strip()
PXE_SERVER = getenv("PXE_SERVER")
PXE_PORT = getenv("PXE_PORT", "18080")
PXE_ISO_ROOT = Path(getenv("PXE_ISO_ROOT", "/iso"))
PXE_HTML_ROOT = Path(getenv("PXE_HTML_ROOT", "/etc/nginx/html"))
PXE_TEMPLATE_ROOT = Path(getenv("PXE_TEMPLATE_ROOT", "/templates"))
PXE_BACKGROUND_PATH = getenv("PXE_BACKGROUND_PATH", "/ui/background.png")
ROOTPW_HASH = getenv("ROOTPW_HASH")
ISO_NAME_RE = re.compile(r"^rhel(?P<major>7|8|9|10)(?:iso)?$", re.IGNORECASE)
def atomic_write(path: Path, content: str, mode: int = 0o644) -> None:
    path.parent.mkdir(parents=True, exist_ok=True)
    tmp_path = path.with_name(f".{path.name}.tmp")
    tmp_path.write_text(content, encoding="utf-8")
    tmp_path.chmod(mode)
    tmp_path.replace(path)
def is_bootable_rhel_iso_tree(path: Path) -> bool:
    return (
        (path / "images" / "pxeboot" / "vmlinuz").is_file()
        and (path / "images" / "pxeboot" / "initrd.img").is_file()
    )
def discover_rhel_isos() -> list[dict]:
    discovered = {}
    if not PXE_ISO_ROOT.exists():
        return []
    for child in PXE_ISO_ROOT.iterdir():
        if not child.is_dir():
            continue
        match = ISO_NAME_RE.match(child.name)
        if not match:
            continue
        major = int(match.group("major"))
        if major not in SUPPORTED_RHEL_MAJORS:
            continue
        if not is_bootable_rhel_iso_tree(child):
            continue
        discovered[major] = {
            "major": major,
            "name": child.name,
            "path": str(child),
            "http_path": f"rhel{major}",
            "ks_name": f"rhel{major}-minimal.ks",
            "label": f"rhel{major}",
            "bios_label": f"rhel{major}_bios",
        }
    return [discovered[major] for major in sorted(discovered.keys(), reverse=True)]
def render_kernel_block(item: dict, label: str) -> str:
    major = item["major"]
    http_path = item["http_path"]
    ks_name = item["ks_name"]
    return f""":{label}
kernel ${{base}}/{http_path}/images/pxeboot/vmlinuz initrd=initrd.img ip=dhcp inst.repo=${{base}}/{http_path} inst.stage2=${{base}}/{http_path} inst.ks=${{base}}/ks/{ks_name} inst.text nomodeset
initrd ${{base}}/{http_path}/images/pxeboot/initrd.img
boot
"""
def render_boot_ipxe(discovered: list[dict]) -> str:
    lines = [
        "#!ipxe",
        "",
        f"set server {PXE_SERVER}",
        f"set port {PXE_PORT}",
        "set base http://${server}:${port}",
        "",
        f"console --picture ${{base}}{PXE_BACKGROUND_PATH} --left 80 --right 80 --top 60 --bottom 60 || goto main",
        "",
        ":main",
        "menu AeroLIT PXE Menu",
    ]
    if discovered:
        for item in discovered:
            lines.append(f"item {item['label']} Install RHEL {item['major']} Minimal (UEFI)")
        lines.extend(
            [
                "item legacy Legacy / BIOS Compatibility Options",
                "item shell Drop to iPXE shell",
                "choose target || goto shell",
                "goto ${target}",
                "",
                ":legacy",
                "menu AeroLIT PXE Legacy / BIOS Compatibility Options",
            ]
        )
        for item in discovered:
            lines.append(f"item {item['bios_label']} Install RHEL {item['major']} Minimal (BIOS / Legacy)")
        lines.extend(
            [
                "item main Return to Main Menu",
                "item shell Drop to iPXE shell",
                "choose target || goto shell",
                "goto ${target}",
                "",
            ]
        )
        for item in discovered:
            lines.append(render_kernel_block(item, item["label"]))
            lines.append(render_kernel_block(item, item["bios_label"]))
    else:
        lines.extend(
            [
                "item shell No supported RHEL ISO trees found - drop to iPXE shell",
                "choose target || goto shell",
                "goto ${target}",
                "",
            ]
        )
    lines.extend(
        [
            ":shell",
            "shell",
            "",
        ]
    )
    return "\n".join(lines)
def default_kickstart(major: int) -> str:
    return f"""#version=RHEL{major}
text
reboot
lang en_US.UTF-8
keyboard us
timezone America/Chicago --utc
network --bootproto=dhcp --device=link --activate
rootpw --iscrypted {ROOTPW_HASH}
firstboot --disable
selinux --enforcing
firewall --enabled --service=ssh
services --enabled=sshd
url --url="http://{PXE_SERVER}:{PXE_PORT}/rhel{major}"
zerombr
clearpart --all --initlabel
autopart --type=lvm
%packages
@^minimal-environment
%end
%addon com_redhat_kdump --enable
%end
"""
def find_kickstart_template(major: int) -> Path | None:
    candidates = [
        PXE_TEMPLATE_ROOT / "ks" / f"rhel{major}-minimal.ks.tmpl",
        PXE_TEMPLATE_ROOT / f"rhel{major}-minimal.ks.tmpl",
    ]
    for candidate in candidates:
        if candidate.is_file():
            return candidate
    return None
def render_kickstarts(discovered: list[dict]) -> None:
    ks_dir = PXE_HTML_ROOT / "ks"
    ks_dir.mkdir(parents=True, exist_ok=True)
    template_vars = {
        "PXE_SERVER": PXE_SERVER,
        "PXE_PORT": PXE_PORT,
        "ROOTPW_HASH": ROOTPW_HASH,
    }
    for item in discovered:
        major = item["major"]
        output_path = ks_dir / item["ks_name"]
        template_path = find_kickstart_template(major)
        if template_path:
            template_text = template_path.read_text(encoding="utf-8")
            rendered = Template(template_text).safe_substitute(template_vars)
        else:
            rendered = default_kickstart(major)
        atomic_write(output_path, rendered)
def render_index(discovered: list[dict]) -> None:
    lines = [
        "<html>",
        "<head><title>AeroLIT PXE Content</title></head>",
        "<body>",
        "<h1>AeroLIT PXE Content</h1>",
        "<h2>Detected ISO Trees</h2>",
        "<ul>",
    ]
    if discovered:
        for item in discovered:
            lines.append(
                f"<li>RHEL {item['major']}: /{item['http_path']}/ "
                f"from {item['path']}</li>"
            )
    else:
        lines.append("<li>No supported RHEL ISO trees detected.</li>")
    lines.extend(
        [
            "</ul>",
            "<h2>Generated Files</h2>",
            "<ul>",
            '<li><a href="/boot.ipxe">boot.ipxe</a></li>',
            '<li><a href="/generated/isos.txt">generated/isos.txt</a></li>',
            "</ul>",
            "</body>",
            "</html>",
            "",
        ]
    )
    atomic_write(PXE_HTML_ROOT / "index.html", "\n".join(lines))
def render_iso_inventory(discovered: list[dict]) -> None:
    lines = []
    if discovered:
        for item in discovered:
            lines.append(f"rhel{item['major']} {item['name']} {item['path']}")
    else:
        lines.append("No supported RHEL ISO trees detected.")
    atomic_write(PXE_HTML_ROOT / "generated" / "isos.txt", "\n".join(lines) + "\n")
def main() -> None:
    if not PXE_SERVER:
        raise SystemExit("PXE_SERVER is required.")
    if not ROOTPW_HASH:
        raise SystemExit("ROOTPW_HASH is required.")
    PXE_HTML_ROOT.mkdir(parents=True, exist_ok=True)
    (PXE_HTML_ROOT / "ks").mkdir(parents=True, exist_ok=True)
    (PXE_HTML_ROOT / "generated").mkdir(parents=True, exist_ok=True)
    discovered = discover_rhel_isos()
    boot_ipxe = render_boot_ipxe(discovered)
    atomic_write(PXE_HTML_ROOT / "boot.ipxe", boot_ipxe)
    render_kickstarts(discovered)
    render_index(discovered)
    render_iso_inventory(discovered)
    print("PXE content generated successfully.")
    print(f"Detected {len(discovered)} supported ISO tree(s).")
    for item in discovered:
        print(f"  RHEL {item['major']}: {item['path']} -> /{item['http_path']}/")
if __name__ == "__main__":
    main()

